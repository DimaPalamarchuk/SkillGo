@page "/Account/Login"

@using System.ComponentModel.DataAnnotations
@using Microsoft.AspNetCore.Authentication
@using Microsoft.AspNetCore.Identity
@using SkillGo.Data

@inject SignInManager<ApplicationUser> SignInManager
@inject ILogger<Login> Logger
@inject NavigationManager NavigationManager
@inject IdentityRedirectManager RedirectManager

<PageTitle>Log in</PageTitle>

<div class="sg-auth-page">
    <div class="sg-auth-bg"></div>

    <div class="sg-auth-shell">
        <div class="sg-auth-side">
            <div class="sg-auth-side-badge">SkillGo</div>
            <div class="sg-auth-side-title">Welcome back</div>
            <div class="sg-auth-side-sub">
                Log in to manage orders, messages, wallet and your freelancer profile.
            </div>

            <div class="sg-auth-side-points">
                <div class="sg-auth-side-point">
                    <span class="sg-auth-side-dot"></span>
                    <span>Fast access to chats and orders</span>
                </div>

                <div class="sg-auth-side-point">
                    <span class="sg-auth-side-dot"></span>
                    <span>Secure account and balance management</span>
                </div>

                <div class="sg-auth-side-point">
                    <span class="sg-auth-side-dot"></span>
                    <span>Freelance marketplace in one workspace</span>
                </div>
            </div>
        </div>

        <div class="sg-auth-card">
            <div class="sg-auth-card-head">
                <div class="sg-auth-kicker">Account</div>
                <h1 class="sg-auth-title">Log in</h1>
                <div class="sg-auth-subtitle">Enter your username and password to continue.</div>
            </div>

            <StatusMessage Message="@errorMessage" />

            <EditForm Model="@Input" OnValidSubmit="LoginUser" FormName="login-form">
                <DataAnnotationsValidator />
                <ValidationSummary class="sg-validation-summary" />

                <div class="sg-field">
                    <label class="sg-label">Username</label>
                    <InputText @bind-Value="Input.UserName"
                               class="sg-input"
                               autocomplete="username"
                               placeholder="Enter your username" />
                    <ValidationMessage For="@(() => Input.UserName)" class="sg-validation" />
                </div>

                <div class="sg-field">
                    <label class="sg-label">Password</label>
                    <InputText @bind-Value="Input.Password"
                               type="password"
                               class="sg-input"
                               autocomplete="current-password"
                               placeholder="Enter your password" />
                    <ValidationMessage For="@(() => Input.Password)" class="sg-validation" />
                </div>

                <div class="sg-auth-row">
                    <label class="sg-check">
                        <InputCheckbox @bind-Value="Input.RememberMe" />
                        <span>Remember me</span>
                    </label>

                    <a class="sg-auth-link" href="/Account/ForgotPassword">Forgot password?</a>
                </div>

                <button type="submit" class="sg-primary-btn">
                    Log in
                </button>
            </EditForm>

            <div class="sg-auth-divider">
                <span>or</span>
            </div>

            <div class="sg-auth-external">
                <ExternalLoginPicker />
            </div>

            <div class="sg-auth-footer">
                Don’t have an account?
                <a class="sg-auth-link"
                   href="@NavigationManager.GetUriWithQueryParameters("/Account/Register", new Dictionary<string, object?> { ["ReturnUrl"] = ReturnUrl })">
                    Create account
                </a>
            </div>
        </div>
    </div>
</div>

<style>
    .sg-auth-page {
        min-height: calc(100vh - 78px);
        position: relative;
        overflow: hidden;
        padding: 34px 20px;
        display: flex;
        align-items: center;
        justify-content: center;
        background:
            radial-gradient(circle at top left, rgba(124,58,237,.12), transparent 24%),
            radial-gradient(circle at top right, rgba(99,102,241,.09), transparent 24%),
            linear-gradient(180deg, #fbfaff 0%, #f7f4ff 46%, #ffffff 100%);
    }

    .sg-auth-bg {
        position: absolute;
        inset: 0;
        pointer-events: none;
        background:
            radial-gradient(700px 260px at 12% 10%, rgba(124,58,237,.10), transparent 60%),
            radial-gradient(620px 240px at 88% 16%, rgba(99,102,241,.08), transparent 58%);
    }

    .sg-auth-shell {
        position: relative;
        z-index: 1;
        width: 100%;
        max-width: 1120px;
        display: grid;
        grid-template-columns: 1.02fr .98fr;
        gap: 22px;
        align-items: stretch;
    }

    .sg-auth-side {
        border-radius: 32px;
        padding: 34px;
        background: linear-gradient(135deg, #2e1065 0%, #4c1d95 46%, #5b21b6 100%);
        color: #ffffff;
        border: 1px solid rgba(255,255,255,.10);
        box-shadow: 0 26px 60px rgba(76,29,149,.20);
        display: flex;
        flex-direction: column;
        justify-content: center;
        min-height: 640px;
    }

    .sg-auth-side-badge {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        width: fit-content;
        min-height: 34px;
        padding: 0 14px;
        border-radius: 999px;
        background: rgba(255,255,255,.10);
        border: 1px solid rgba(255,255,255,.14);
        font-size: .8rem;
        font-weight: 900;
        letter-spacing: .08em;
        text-transform: uppercase;
    }

    .sg-auth-side-title {
        margin-top: 18px;
        font-size: 2.6rem;
        line-height: 1.02;
        font-weight: 950;
        letter-spacing: -.03em;
        max-width: 520px;
    }

    .sg-auth-side-sub {
        margin-top: 14px;
        color: rgba(255,255,255,.78);
        font-size: 1rem;
        line-height: 1.7;
        max-width: 520px;
    }

    .sg-auth-side-points {
        margin-top: 28px;
        display: flex;
        flex-direction: column;
        gap: 14px;
    }

    .sg-auth-side-point {
        display: flex;
        align-items: center;
        gap: 12px;
        color: rgba(255,255,255,.88);
        font-weight: 700;
    }

    .sg-auth-side-dot {
        width: 10px;
        height: 10px;
        border-radius: 999px;
        background: #c4b5fd;
        flex: 0 0 auto;
    }

    .sg-auth-card {
        border-radius: 32px;
        padding: 30px;
        background: rgba(255,255,255,.94);
        border: 1px solid rgba(109,40,217,.10);
        box-shadow: 0 26px 60px rgba(31,17,71,.10);
        backdrop-filter: blur(12px);
        display: flex;
        flex-direction: column;
        justify-content: center;
        min-height: 640px;
    }

    .sg-auth-card-head {
        margin-bottom: 18px;
    }

    .sg-auth-kicker {
        color: rgba(31,17,71,.46);
        font-size: .76rem;
        font-weight: 900;
        letter-spacing: .14em;
        text-transform: uppercase;
    }

    .sg-auth-title {
        margin: 10px 0 0 0;
        color: #1f1147;
        font-size: 2rem;
        line-height: 1.05;
        font-weight: 950;
    }

    .sg-auth-subtitle {
        margin-top: 8px;
        color: #6b5f8d;
        line-height: 1.45;
        font-weight: 700;
    }

    .sg-field {
        margin-top: 14px;
    }

    .sg-label {
        display: block;
        margin-bottom: 8px;
        color: #1f1147;
        font-size: .92rem;
        font-weight: 850;
    }

    .sg-input {
        width: 100%;
        min-height: 54px;
        padding: 0 16px;
        border-radius: 16px;
        border: 1px solid rgba(109,40,217,.14);
        background: #ffffff;
        color: #1f1147;
        outline: none;
        font-size: .98rem;
        transition: border-color .18s ease, box-shadow .18s ease, transform .18s ease;
    }

    .sg-input::placeholder {
        color: rgba(31,17,71,.40);
    }

    .sg-input:focus {
        border-color: #7c3aed;
        box-shadow: 0 0 0 4px rgba(124,58,237,.12);
    }

    .sg-auth-row {
        margin-top: 16px;
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 12px;
        flex-wrap: wrap;
    }

    .sg-check {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        color: #6b5f8d;
        font-weight: 700;
    }

    .sg-primary-btn {
        width: 100%;
        margin-top: 18px;
        min-height: 54px;
        border: none;
        border-radius: 18px;
        background: linear-gradient(135deg, #6d28d9 0%, #8b5cf6 100%);
        color: #ffffff;
        font-weight: 900;
        font-size: 1rem;
        letter-spacing: .02em;
        box-shadow: 0 18px 34px rgba(109,40,217,.20);
        cursor: pointer;
        transition: transform .18s ease, box-shadow .18s ease;
    }

    .sg-primary-btn:hover {
        transform: translateY(-1px);
        box-shadow: 0 22px 42px rgba(109,40,217,.24);
    }

    .sg-auth-divider {
        margin: 22px 0 16px 0;
        position: relative;
        text-align: center;
        color: rgba(31,17,71,.42);
        font-size: .84rem;
        font-weight: 800;
    }

    .sg-auth-divider::before {
        content: "";
        position: absolute;
        top: 50%;
        left: 0;
        right: 0;
        height: 1px;
        background: rgba(109,40,217,.10);
        transform: translateY(-50%);
    }

    .sg-auth-divider span {
        position: relative;
        z-index: 1;
        padding: 0 12px;
        background: rgba(255,255,255,.94);
    }

    .sg-auth-external {
        border-radius: 18px;
        padding: 12px;
        background: #faf7ff;
        border: 1px solid rgba(109,40,217,.10);
    }

    .sg-auth-footer {
        margin-top: 18px;
        text-align: center;
        color: #6b5f8d;
        font-weight: 700;
    }

    .sg-auth-link {
        color: #6d28d9;
        text-decoration: none;
        font-weight: 900;
    }

    .sg-auth-link:hover {
        text-decoration: underline;
    }

    .sg-validation,
    .sg-validation-summary {
        color: #dc2626;
        font-size: .84rem;
        margin-top: 6px;
    }

    @@media (max-width: 980px) {
        .sg-auth-shell {
            grid-template-columns: 1fr;
            max-width: 640px;
        }

        .sg-auth-side {
            min-height: auto;
            padding: 28px;
        }

        .sg-auth-card {
            min-height: auto;
        }
    }

    @@media (max-width: 640px) {
        .sg-auth-page {
            padding: 18px 10px;
        }

        .sg-auth-side,
        .sg-auth-card {
            border-radius: 24px;
            padding: 20px;
        }

        .sg-auth-side-title {
            font-size: 2rem;
        }

        .sg-auth-title {
            font-size: 1.7rem;
        }
    }
</style>

@code {
    private string? errorMessage;

    [CascadingParameter]
    private HttpContext HttpContext { get; set; } = default!;

    [SupplyParameterFromForm]
    private InputModel Input { get; set; } = new();

    [SupplyParameterFromQuery]
    private string? ReturnUrl { get; set; }

    protected override async Task OnInitializedAsync()
    {
        Input ??= new InputModel();

        if (HttpMethods.IsGet(HttpContext.Request.Method))
            await HttpContext.SignOutAsync(IdentityConstants.ExternalScheme);
    }

    private async Task LoginUser()
    {
        errorMessage = null;

        var result = await SignInManager.PasswordSignInAsync(
            Input.UserName,
            Input.Password,
            Input.RememberMe,
            false);

        if (result.Succeeded)
        {
            Logger.LogInformation("User logged in.");
            NavigationManager.NavigateTo(ReturnUrl ?? "/", true);
            return;
        }

        if (result.IsLockedOut)
        {
            errorMessage = "This account is locked.";
            return;
        }

        errorMessage = "Invalid login attempt.";
    }

    private sealed class InputModel
    {
        [Required]
        public string UserName { get; set; } = "";

        [Required]
        [DataType(DataType.Password)]
        public string Password { get; set; } = "";

        public bool RememberMe { get; set; }
    }
}