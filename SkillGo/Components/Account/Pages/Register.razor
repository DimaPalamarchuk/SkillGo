@page "/Account/Register"
@rendermode InteractiveServer

@using System.ComponentModel.DataAnnotations
@using System.Text
@using System.Text.Encodings.Web
@using Microsoft.AspNetCore.Identity
@using Microsoft.AspNetCore.WebUtilities
@using SkillGo.Data
@using SkillGo.Components.Account

@inject UserManager<ApplicationUser> UserManager
@inject IUserStore<ApplicationUser> UserStore
@inject SignInManager<ApplicationUser> SignInManager
@inject IEmailSender<ApplicationUser> EmailSender
@inject ILogger<Register> Logger
@inject NavigationManager NavigationManager
@inject IdentityRedirectManager RedirectManager

<PageTitle>Register</PageTitle>

<div class="sg-auth-page">
    <div class="sg-auth-bg"></div>

    <div class="sg-auth-shell">
        <div class="sg-auth-side">
            <div class="sg-auth-side-badge">SkillGo</div>
            <div class="sg-auth-side-title">Create account</div>
            <div class="sg-auth-side-sub">
                Join SkillGo to manage orders, messages, wallet and your freelancer profile in one place.
            </div>

            <div class="sg-auth-side-points">
                <div class="sg-auth-side-point">
                    <span class="sg-auth-side-dot"></span>
                    <span>Quick access to chats and orders</span>
                </div>

                <div class="sg-auth-side-point">
                    <span class="sg-auth-side-dot"></span>
                    <span>Secure account and balance management</span>
                </div>

                <div class="sg-auth-side-point">
                    <span class="sg-auth-side-dot"></span>
                    <span>Freelance marketplace in one workspace</span>
                </div>
            </div>
        </div>

        <div class="sg-auth-card">
            <div class="sg-auth-card-head">
                <div class="sg-auth-kicker">Account</div>
                <h1 class="sg-auth-title">Register</h1>
                <div class="sg-auth-subtitle">Create your account to continue.</div>
            </div>

            @if (!string.IsNullOrWhiteSpace(_errorMessage))
            {
                <div class="sg-validation-summary">@_errorMessage</div>
            }

            <EditForm Model="@Input"
                      OnValidSubmit="RegisterUser"
                      FormName="register-form">
                <DataAnnotationsValidator />
                <ValidationSummary class="sg-validation-summary" />

                <div class="sg-field">
                    <label class="sg-label">Username</label>
                    <InputText @bind-Value="Input.UserName"
                               class="sg-input"
                               autocomplete="username"
                               placeholder="Enter your username" />
                    <ValidationMessage For="@(() => Input.UserName)" class="sg-validation" />
                </div>

                <div class="sg-field">
                    <label class="sg-label">Email</label>
                    <InputText @bind-Value="Input.Email"
                               class="sg-input"
                               autocomplete="email"
                               placeholder="Enter your email" />
                    <ValidationMessage For="@(() => Input.Email)" class="sg-validation" />
                </div>

                <div class="sg-field">
                    <label class="sg-label">Password</label>
                    <InputText @bind-Value="Input.Password"
                               type="password"
                               class="sg-input"
                               autocomplete="new-password"
                               placeholder="Create your password" />
                    <ValidationMessage For="@(() => Input.Password)" class="sg-validation" />
                </div>

                <div class="sg-field">
                    <label class="sg-label">Confirm password</label>
                    <InputText @bind-Value="Input.ConfirmPassword"
                               type="password"
                               class="sg-input"
                               autocomplete="new-password"
                               placeholder="Repeat your password" />
                    <ValidationMessage For="@(() => Input.ConfirmPassword)" class="sg-validation" />
                </div>

                <button type="submit" class="sg-primary-btn">
                    Create account
                </button>
            </EditForm>

            <div class="sg-auth-divider">
                <span>or</span>
            </div>

            <div class="sg-auth-external">
                <ExternalLoginPicker />
            </div>

            <div class="sg-auth-footer">
                Already have an account?
                <a class="sg-auth-link"
                   href="@NavigationManager.GetUriWithQueryParameters("/Account/Login", new Dictionary<string, object?> { ["ReturnUrl"] = ReturnUrl })">
                    Log in
                </a>
            </div>
        </div>
    </div>
</div>

