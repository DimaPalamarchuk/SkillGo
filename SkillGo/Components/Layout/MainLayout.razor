@inherits LayoutComponentBase
@implements IDisposable
@using MudBlazor
@using Microsoft.AspNetCore.Components.Authorization
@using SkillGo.Components.Shared
@inject SkillGo.Repository.WalletState WalletState

<MudThemeProvider Theme="_theme" />
<MudPopoverProvider />
<MudDialogProvider />
<MudSnackbarProvider />

<MudLayout Class="sg-layout">
    <UserPresencePinger />

    <MudAppBar Elevation="0" Dense="true" Fixed="true" Class="sg-appbar">
        <div class="sg-appbar-inner">
            <div class="sg-appbar-left">
                <MudIconButton Icon="@Icons.Material.Filled.Menu"
                               Color="Color.Inherit"
                               Edge="Edge.Start"
                               OnClick="ToggleDrawer"
                               Class="sg-menu-btn" />

                <a href="/" class="sg-brand-link">
                    <div class="sg-brand-mark">S</div>

                    <div class="sg-brand-copy">
                        <div class="sg-brand-title">SkillGo</div>
                        <div class="sg-brand-sub">Freelance marketplace</div>
                    </div>
                </a>
            </div>

            <div class="sg-appbar-center">
                <AuthorizeView>
                    <Authorized>
                        <a href="/services/category" class="sg-top-link">Browse</a>
                        <a href="/chats" class="sg-top-link">Chats</a>
                        <a href="/orders" class="sg-top-link">Orders</a>
                    </Authorized>
                </AuthorizeView>

                <AuthorizeView Roles="Admin">
                    <Authorized Context="adminContext">
                        <a href="/admin" class="sg-top-link sg-top-link-admin">Admin</a>
                    </Authorized>
                </AuthorizeView>
            </div>

            <div class="sg-appbar-right">
                <AuthorizeView>
                    <Authorized Context="authContext">
                        <a href="/wallet" class="sg-balance-pill">
                            <span class="sg-balance-label">Balance</span>
                            <span class="sg-balance-value">@BalanceText</span>
                        </a>

                        <details class="sg-user-dropdown">
                            <summary class="sg-user-summary">
                                <div class="sg-user-summary-left">
                                    <div class="sg-user-avatar">@UserInitial(authContext.User.Identity?.Name)</div>

                                    <div class="sg-user-copy">
                                        <div class="sg-user-name">@authContext.User.Identity?.Name</div>
                                        <div class="sg-user-sub">Account</div>
                                    </div>
                                </div>

                                <span class="sg-user-caret">▾</span>
                            </summary>

                            <div class="sg-user-menu">
                                <div class="sg-user-menu-head">
                                    <div class="sg-user-menu-avatar">@UserInitial(authContext.User.Identity?.Name)</div>

                                    <div class="sg-user-menu-copy">
                                        <div class="sg-user-menu-name">@authContext.User.Identity?.Name</div>
                                        <div class="sg-user-menu-sub">Manage your workspace</div>
                                    </div>
                                </div>

                                <div class="sg-user-menu-divider"></div>

                                <a href="/Account/Manage" class="sg-user-menu-item">Account settings</a>
                                <a href="/wallet" class="sg-user-menu-item">Wallet</a>
                                <a href="/orders" class="sg-user-menu-item">Orders</a>
                                <a href="/chats" class="sg-user-menu-item">Chats</a>

                                <AuthorizeView Roles="Admin">
                                    <Authorized Context="adminContext">
                                        <a href="/admin" class="sg-user-menu-item sg-user-menu-item-admin">Admin dashboard</a>
                                        <a href="/admin/users" class="sg-user-menu-item sg-user-menu-item-admin">Manage users</a>
                                    </Authorized>
                                </AuthorizeView>

                                <div class="sg-user-menu-divider"></div>

                                <a href="/Account/Logout" class="sg-user-menu-item sg-user-menu-item-danger">Logout</a>
                            </div>
                        </details>
                    </Authorized>

                    <NotAuthorized>
                        <a href="/Account/Login" class="sg-auth-link">Login</a>
                        <a href="/Account/Register" class="sg-signup-btn">Sign up</a>
                    </NotAuthorized>
                </AuthorizeView>
            </div>
        </div>
    </MudAppBar>

    <MudDrawer @bind-Open="_drawerOpen"
               Variant="DrawerVariant.Responsive"
               Elevation="0"
               ClipMode="DrawerClipMode.Always"
               Class="sg-drawer">
        <NavMenu @rendermode="InteractiveServer" />
    </MudDrawer>

    <MudMainContent Class="sg-main">
        <div class="sg-page-shell">
            <div class="sg-page-inner">
                @Body
            </div>
        </div>
    </MudMainContent>
</MudLayout>

<style>
    .sg-layout {
        min-height: 100vh;
        background: radial-gradient(900px 360px at 0% 0%, rgba(79,70,229,.10), transparent 46%), radial-gradient(700px 280px at 100% 0%, rgba(124,58,237,.06), transparent 40%), linear-gradient(180deg, #f8f9fd 0%, #f5f7fb 100%);
    }

    .sg-appbar {
        height: 78px;
        padding: 0 18px;
        background: linear-gradient(90deg, #312e81 0%, #4338ca 50%, #4f46e5 100%);
        color: #f8fafc;
        border-bottom: 1px solid rgba(255,255,255,.10);
        box-shadow: 0 18px 40px rgba(49,46,129,.20);
        z-index: 1200;
    }

    .sg-appbar-inner {
        width: 100%;
        height: 78px;
        display: grid;
        grid-template-columns: auto 1fr auto;
        align-items: center;
        gap: 18px;
    }

    .sg-appbar-left {
        display: flex;
        align-items: center;
        gap: 12px;
        min-width: 0;
    }

    .sg-appbar-center {
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 6px;
        min-width: 0;
    }

    .sg-appbar-right {
        display: flex;
        align-items: center;
        justify-content: flex-end;
        gap: 12px;
        min-width: 0;
    }

    .sg-menu-btn {
        width: 42px;
        height: 42px;
        border-radius: 14px;
        background: rgba(255,255,255,.12);
        color: #ffffff;
        border: 1px solid rgba(255,255,255,.14);
    }

    .sg-brand-link {
        display: flex;
        align-items: center;
        gap: 12px;
        text-decoration: none;
        color: inherit;
        min-width: 0;
    }

    .sg-brand-mark {
        width: 42px;
        height: 42px;
        border-radius: 15px;
        display: flex;
        align-items: center;
        justify-content: center;
        background: linear-gradient(135deg, rgba(255,255,255,.24) 0%, rgba(255,255,255,.12) 100%);
        color: #ffffff;
        font-weight: 950;
        font-size: 1rem;
        box-shadow: inset 0 0 0 1px rgba(255,255,255,.10);
        flex: 0 0 auto;
    }

    .sg-brand-copy {
        min-width: 0;
    }

    .sg-brand-title {
        color: #ffffff;
        font-size: 1.04rem;
        font-weight: 950;
        line-height: 1;
        letter-spacing: .2px;
    }

    .sg-brand-sub {
        margin-top: 4px;
        color: rgba(255,255,255,.72);
        font-size: .78rem;
        line-height: 1;
        font-weight: 700;
    }

    .sg-top-link {
        padding: 10px 14px;
        border-radius: 999px;
        text-decoration: none;
        color: rgba(255,255,255,.82);
        font-weight: 800;
        transition: background .16s ease, color .16s ease, transform .16s ease;
    }

        .sg-top-link:hover {
            background: rgba(255,255,255,.10);
            color: #ffffff;
            transform: translateY(-1px);
        }

    .sg-top-link-admin {
        background: rgba(255,255,255,.10);
        border: 1px solid rgba(255,255,255,.14);
    }

    .sg-balance-pill {
        min-height: 44px;
        padding: 0 16px;
        border-radius: 999px;
        display: inline-flex;
        align-items: center;
        gap: 10px;
        text-decoration: none;
        color: #eef2ff;
        background: rgba(255,255,255,.12);
        border: 1px solid rgba(255,255,255,.14);
        box-shadow: 0 10px 24px rgba(30,27,75,.18);
        white-space: nowrap;
    }

    .sg-balance-label {
        color: rgba(255,255,255,.62);
        font-size: .76rem;
        font-weight: 800;
        text-transform: uppercase;
        letter-spacing: .08em;
    }

    .sg-balance-value {
        color: #ffffff;
        font-weight: 950;
    }

    .sg-auth-link {
        padding: 10px 14px;
        border-radius: 999px;
        text-decoration: none;
        color: rgba(255,255,255,.84);
        font-weight: 800;
        transition: background .16s ease, color .16s ease;
    }

        .sg-auth-link:hover {
            background: rgba(255,255,255,.10);
            color: #ffffff;
        }

    .sg-signup-btn {
        min-height: 44px;
        padding: 0 18px;
        border-radius: 999px;
        display: inline-flex;
        align-items: center;
        text-decoration: none;
        background: #ffffff;
        color: #3730a3;
        font-weight: 900;
        box-shadow: 0 14px 26px rgba(30,27,75,.18);
    }

    .sg-user-dropdown {
        position: relative;
    }

        .sg-user-dropdown summary {
            list-style: none;
        }

            .sg-user-dropdown summary::-webkit-details-marker {
                display: none;
            }

    .sg-user-summary {
        min-height: 46px;
        padding: 0 10px 0 8px;
        border-radius: 999px;
        display: flex;
        align-items: center;
        gap: 10px;
        cursor: pointer;
        user-select: none;
        background: rgba(255,255,255,.12);
        border: 1px solid rgba(255,255,255,.14);
        box-shadow: 0 10px 24px rgba(30,27,75,.18);
        color: #ffffff;
    }

    .sg-user-summary-left {
        display: flex;
        align-items: center;
        gap: 10px;
        min-width: 0;
    }

    .sg-user-avatar {
        width: 30px;
        height: 30px;
        border-radius: 999px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        background: rgba(255,255,255,.18);
        color: #ffffff;
        font-size: .83rem;
        font-weight: 950;
        flex: 0 0 auto;
    }

    .sg-user-copy {
        display: flex;
        flex-direction: column;
        gap: 2px;
        min-width: 0;
    }

    .sg-user-name {
        max-width: 120px;
        overflow: hidden;
        text-overflow: ellipsis;
        white-space: nowrap;
        color: #ffffff;
        line-height: 1.02;
        font-weight: 850;
    }

    .sg-user-sub {
        color: rgba(255,255,255,.68);
        font-size: .7rem;
        line-height: 1;
        font-weight: 700;
    }

    .sg-user-caret {
        color: rgba(255,255,255,.76);
        font-size: .86rem;
        flex: 0 0 auto;
    }

    .sg-user-menu {
        position: absolute;
        top: calc(100% + 12px);
        right: 0;
        min-width: 250px;
        padding: 10px;
        border-radius: 22px;
        background: rgba(255,255,255,.98);
        border: 1px solid rgba(15,23,42,.08);
        box-shadow: 0 26px 54px rgba(15,23,42,.16);
        z-index: 1400;
    }

    .sg-user-menu-head {
        display: flex;
        align-items: center;
        gap: 12px;
        padding: 8px;
    }

    .sg-user-menu-avatar {
        width: 40px;
        height: 40px;
        border-radius: 15px;
        display: flex;
        align-items: center;
        justify-content: center;
        background: linear-gradient(135deg, #e0e7ff 0%, #c7d2fe 100%);
        color: #4338ca;
        font-weight: 950;
        flex: 0 0 auto;
    }

    .sg-user-menu-copy {
        min-width: 0;
    }

    .sg-user-menu-name {
        color: #111827;
        font-weight: 900;
        line-height: 1.08;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
    }

    .sg-user-menu-sub {
        margin-top: 3px;
        color: rgba(17,24,39,.56);
        font-size: .78rem;
        font-weight: 700;
    }

    .sg-user-menu-divider {
        height: 1px;
        background: rgba(15,23,42,.08);
        margin: 8px 4px;
    }

    .sg-user-menu-item {
        display: block;
        padding: 11px 12px;
        border-radius: 14px;
        text-decoration: none;
        color: #111827;
        font-weight: 750;
        transition: background .16s ease, transform .16s ease, color .16s ease;
    }

        .sg-user-menu-item:hover {
            background: rgba(79,70,229,.08);
            color: #3730a3;
            transform: translateX(1px);
        }

    .sg-user-menu-item-admin {
        color: #312e81;
        font-weight: 850;
    }

    .sg-user-menu-item-danger {
        color: #b91c1c;
    }

    .sg-drawer {
        top: 78px !important;
        height: calc(100vh - 78px) !important;
        background: rgba(255,255,255,.90);
        backdrop-filter: blur(14px);
        border-right: 1px solid rgba(15,23,42,.06);
        box-shadow: 8px 0 26px rgba(15,23,42,.04);
        z-index: 1100 !important;
    }

    .sg-main {
        padding-top: 78px !important;
    }

    .sg-page-shell {
        width: 100%;
        padding: 34px 32px 32px 32px;
    }

    .sg-page-inner {
        width: 100%;
        min-height: calc(100vh - 78px - 66px);
    }

    @@media (max-width: 1180px) {
        .sg-appbar-center {
            justify-content: flex-start;
        }

        .sg-top-link {
            display: none;
        }
    }

    @@media (max-width: 760px) {
        .sg-appbar {
            padding: 0 10px;
        }

        .sg-appbar-inner {
            grid-template-columns: auto 1fr auto;
            gap: 10px;
        }

        .sg-brand-sub,
        .sg-user-sub {
            display: none;
        }

        .sg-user-name {
            max-width: 76px;
        }

        .sg-balance-pill {
            padding-left: 12px;
            padding-right: 12px;
        }

        .sg-balance-label {
            display: none;
        }

        .sg-page-shell {
            padding: 22px 14px 20px 14px;
        }
    }

    @@media (max-width: 560px) {
        .sg-brand-copy {
            display: none;
        }

        .sg-user-name {
            display: none;
        }

        .sg-user-summary {
            padding-right: 10px;
        }
    }
</style>

@code {
    private bool _drawerOpen = true;

    private readonly MudTheme _theme = new MudTheme()
        {
            PaletteLight = new PaletteLight()
            {
                Primary = "#4f46e5",
                Secondary = "#7c3aed",
                Tertiary = "#0f172a",
                Background = "#f8f9fd",
                Surface = "#ffffff",
                AppbarBackground = "rgba(255,255,255,.82)",
                DrawerBackground = "rgba(255,255,255,.90)",
                DrawerText = "#111827",
                AppbarText = "#f8fafc",
                TextPrimary = "#111827",
                TextSecondary = "rgba(17,24,39,.64)"
            },
            LayoutProperties = new LayoutProperties()
            {
                DrawerWidthLeft = "304px"
            }
        };

    private string BalanceText =>
        WalletState.IsLoaded ? $"{WalletState.Balance:0.##} zł" : "—";

    protected override async Task OnInitializedAsync()
    {
        WalletState.Changed += OnWalletChanged;
        await WalletState.RefreshAsync();
    }

    private void OnWalletChanged()
    {
        InvokeAsync(StateHasChanged);
    }

    private void ToggleDrawer()
    {
        _drawerOpen = !_drawerOpen;
    }

    private static string UserInitial(string? name)
    {
        return string.IsNullOrWhiteSpace(name) ? "U" : name.Substring(0, 1).ToUpperInvariant();
    }

    public void Dispose()
    {
        WalletState.Changed -= OnWalletChanged;
    }
}