@page "/admin/bans"
@attribute [Authorize(Roles = "Admin")]
@using Microsoft.AspNetCore.Authorization
@using Microsoft.EntityFrameworkCore
@using MudBlazor
@using SkillGo.Data
@using SkillGo.Data.Models
@inject IDbContextFactory<ApplicationDbContext> DbFactory
@inject NavigationManager Nav
@inject ISnackbar Snackbar

<PageTitle>Banned Users</PageTitle>

<MudContainer MaxWidth="MaxWidth.False" Class="mt-6">
    <div class="bans-hero">
        <div>
            <div class="bans-kicker">Administration</div>
            <div class="bans-title">Banned users</div>
            <div class="bans-subtitle">View active restrictions and remove them when needed.</div>
        </div>
    </div>

    <MudPaper Class="bans-shell mt-4" Elevation="0">
        <div class="bans-toolbar">
            <MudTextField T="string"
                          Value="@_search"
                          ValueChanged="OnSearchChanged"
                          Placeholder="Search by user, reason, admin..."
                          Variant="Variant.Outlined"
                          Adornment="Adornment.Start"
                          AdornmentIcon="@Icons.Material.Filled.Search"
                          Immediate="true"
                          Class="bans-search" />
        </div>

        @if (_loading)
        {
            <div class="bans-loading">
                <MudProgressCircular Indeterminate="true" />
            </div>
        }
        else if (_items.Count == 0)
        {
            <div class="bans-empty">
                <MudIcon Icon="@Icons.Material.Filled.GppMaybe" Size="Size.Large" />
                <div class="bans-empty-title">No active bans</div>
                <div class="bans-empty-subtitle">There are currently no restricted users.</div>
            </div>
        }
        else
        {
            <div class="bans-list">
                @foreach (var item in _items)
                {
                    <div class="ban-card">
                        <div class="ban-card-top">
                            <div class="ban-user-block">
                                <img class="ban-avatar" src="@Avatar(item.User)" />
                                <div class="ban-user-copy">
                                    <div class="ban-user-name">@DisplayUser(item.User)</div>
                                    <div class="ban-user-username">@UserNameText(item.User)</div>
                                </div>
                            </div>

                            <MudStack Spacing="1" AlignItems="AlignItems.End">
                                <MudChip T="string" Size="Size.Small" Variant="Variant.Filled" Color="Color.Error">
                                    @(item.EndsAtUtc.HasValue ? "Temporary" : "Permanent")
                                </MudChip>

                                <MudChip T="string" Size="Size.Small" Variant="Variant.Outlined" Color="Color.Warning">
                                    @RemainingText(item)
                                </MudChip>
                            </MudStack>
                        </div>

                        <div class="ban-grid">
                            <div class="ban-box">
                                <div class="ban-label">Created by</div>
                                <div class="ban-value">@DisplayUser(item.CreatedByUser)</div>
                            </div>

                            <div class="ban-box">
                                <div class="ban-label">Started</div>
                                <div class="ban-value">@item.StartsAtUtc.ToLocalTime().ToString("yyyy-MM-dd HH:mm")</div>
                            </div>

                            <div class="ban-box">
                                <div class="ban-label">Ends</div>
                                <div class="ban-value">@EndText(item)</div>
                            </div>

                            <div class="ban-box">
                                <div class="ban-label">Type</div>
                                <div class="ban-value">@(item.EndsAtUtc.HasValue ? "Temporary restriction" : "Permanent restriction")</div>
                            </div>
                        </div>

                        <div class="ban-reason-label">Reason</div>
                        <div class="ban-reason">@item.Reason</div>

                        <div class="ban-actions">
                            @if (!string.IsNullOrWhiteSpace(item.User?.UserName))
                            {
                                <MudButton Variant="Variant.Outlined"
                                           Color="Color.Primary"
                                           OnClick="@(() => Nav.NavigateTo($"/profile/{item.User!.UserName}"))">
                                    Open profile
                                </MudButton>
                            }

                            <MudButton Variant="Variant.Filled"
                                       Color="Color.Success"
                                       Disabled="_unbanningId == item.Id"
                                       OnClick="@(() => UnbanAsync(item.Id))">
                                @(_unbanningId == item.Id ? "Removing..." : "Unban")
                            </MudButton>
                        </div>
                    </div>
                }
            </div>

            <div class="bans-pagination">
                <MudPagination Count="@_totalPages"
                               Selected="@_page"
                               SelectedChanged="OnPageChanged"
                               Color="Color.Primary"
                               Variant="Variant.Outlined" />
            </div>
        }
    </MudPaper>
</MudContainer>

<style>
    .bans-hero {
        border-radius: 26px;
        padding: 28px;
        background: linear-gradient(135deg, #111827 0%, #1f2937 45%, #312e81 100%);
        color: #fff;
        box-shadow: 0 24px 56px rgba(15,23,42,.18);
    }

    .bans-kicker {
        color: rgba(255,255,255,.68);
        font-size: .78rem;
        font-weight: 900;
        text-transform: uppercase;
        letter-spacing: .16em;
    }

    .bans-title {
        margin-top: 8px;
        font-size: 2rem;
        font-weight: 950;
        line-height: 1.04;
    }

    .bans-subtitle {
        margin-top: 8px;
        color: rgba(255,255,255,.78);
        font-weight: 700;
    }

    .bans-shell {
        padding: 22px;
        border-radius: 24px;
        background: rgba(255,255,255,.96);
        border: 1px solid rgba(15,23,42,.06);
        box-shadow: 0 18px 40px rgba(15,23,42,.05);
    }

    .bans-toolbar {
        display: flex;
        gap: 12px;
        flex-wrap: wrap;
        margin-bottom: 18px;
    }

    .bans-search {
        flex: 1 1 360px;
    }

    .bans-loading,
    .bans-empty {
        min-height: 280px;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        gap: 12px;
        text-align: center;
    }

    .bans-empty-title {
        font-size: 1.08rem;
        font-weight: 900;
        color: #111827;
    }

    .bans-empty-subtitle {
        color: rgba(17,24,39,.62);
        font-weight: 700;
    }

    .bans-list {
        display: flex;
        flex-direction: column;
        gap: 16px;
    }

    .ban-card {
        border-radius: 22px;
        border: 1px solid rgba(15,23,42,.08);
        background: #fff;
        box-shadow: 0 14px 34px rgba(15,23,42,.05);
        padding: 18px;
        display: flex;
        flex-direction: column;
        gap: 14px;
    }

    .ban-card-top {
        display: flex;
        align-items: flex-start;
        justify-content: space-between;
        gap: 12px;
        flex-wrap: wrap;
    }

    .ban-user-block {
        display: flex;
        align-items: center;
        gap: 12px;
        min-width: 0;
    }

    .ban-avatar {
        width: 52px;
        height: 52px;
        border-radius: 16px;
        object-fit: cover;
        background: #fff;
        border: 1px solid rgba(0,0,0,.08);
        flex: 0 0 auto;
    }

    .ban-user-copy {
        min-width: 0;
    }

    .ban-user-name {
        color: #111827;
        font-size: 1.02rem;
        font-weight: 950;
        line-height: 1.1;
    }

    .ban-user-username {
        margin-top: 4px;
        color: rgba(17,24,39,.56);
        font-weight: 800;
    }

    .ban-grid {
        display: grid;
        grid-template-columns: repeat(4, minmax(0, 1fr));
        gap: 10px;
    }

    .ban-box {
        border-radius: 16px;
        border: 1px solid rgba(15,23,42,.06);
        background: #f8fafc;
        padding: 12px;
        min-width: 0;
    }

    .ban-label {
        color: rgba(17,24,39,.56);
        font-size: .72rem;
        font-weight: 900;
        text-transform: uppercase;
        letter-spacing: .08em;
    }

    .ban-value {
        margin-top: 6px;
        color: #111827;
        font-weight: 900;
        line-height: 1.35;
        word-break: break-word;
    }

    .ban-reason-label {
        color: rgba(17,24,39,.56);
        font-size: .72rem;
        font-weight: 900;
        text-transform: uppercase;
        letter-spacing: .08em;
    }

    .ban-reason {
        color: #111827;
        line-height: 1.45;
        white-space: pre-wrap;
        word-break: break-word;
    }

    .ban-actions {
        display: flex;
        justify-content: flex-end;
        gap: 10px;
        flex-wrap: wrap;
    }

    .bans-pagination {
        margin-top: 22px;
        display: flex;
        justify-content: center;
    }

    @@media (max-width: 980px) {
        .ban-grid {
            grid-template-columns: 1fr 1fr;
        }
    }

    @@media (max-width: 760px) {
        .bans-title {
            font-size: 1.6rem;
        }

        .ban-grid {
            grid-template-columns: 1fr;
        }
    }
</style>

@code {
    private bool _loading = true;
    private string _search = string.Empty;
    private List<UserBan> _items = new();

    private int _page = 1;
    private int _pageSize = 10;
    private int _totalItems;
    private int _totalPages = 1;
    private int? _unbanningId;

    protected override async Task OnInitializedAsync()
    {
        await LoadAsync();
    }

    private async Task LoadAsync()
    {
        _loading = true;

        await using var db = await DbFactory.CreateDbContextAsync();
        var now = DateTime.UtcNow;

        var query = db.UserBans
            .AsNoTracking()
            .Include(x => x.User)
            .Include(x => x.CreatedByUser)
            .Where(x => x.StartsAtUtc <= now && (!x.EndsAtUtc.HasValue || x.EndsAtUtc > now))
            .AsQueryable();

        var term = _search.Trim();

        if (!string.IsNullOrWhiteSpace(term))
        {
            query = query.Where(x =>
                x.Reason.Contains(term) ||
                (x.User.DisplayName != null && x.User.DisplayName.Contains(term)) ||
                (x.User.UserName != null && x.User.UserName.Contains(term)) ||
                (x.User.Email != null && x.User.Email.Contains(term)) ||
                (x.CreatedByUser.DisplayName != null && x.CreatedByUser.DisplayName.Contains(term)) ||
                (x.CreatedByUser.UserName != null && x.CreatedByUser.UserName.Contains(term)) ||
                (x.CreatedByUser.Email != null && x.CreatedByUser.Email.Contains(term)));
        }

        _totalItems = await query.CountAsync();
        _totalPages = Math.Max(1, (int)Math.Ceiling(_totalItems / (double)_pageSize));

        if (_page > _totalPages)
            _page = _totalPages;

        _items = await query
            .OrderByDescending(x => x.StartsAtUtc)
            .Skip((_page - 1) * _pageSize)
            .Take(_pageSize)
            .ToListAsync();

        _loading = false;
        StateHasChanged();
    }

    private async Task OnSearchChanged(string value)
    {
        _search = value ?? string.Empty;
        _page = 1;
        await LoadAsync();
    }

    private async Task OnPageChanged(int page)
    {
        _page = page;
        await LoadAsync();
    }

    private async Task UnbanAsync(int banId)
    {
        if (_unbanningId.HasValue)
            return;

        _unbanningId = banId;

        try
        {
            await using var db = await DbFactory.CreateDbContextAsync();

            var ban = await db.UserBans.FirstOrDefaultAsync(x => x.Id == banId);

            if (ban is null)
            {
                Snackbar.Add("Ban not found", Severity.Error);
                return;
            }

            ban.EndsAtUtc = DateTime.UtcNow;
            await db.SaveChangesAsync();

            Snackbar.Add("User unbanned", Severity.Success);
            await LoadAsync();
        }
        catch (Exception ex)
        {
            Snackbar.Add(ex.Message, Severity.Error);
        }
        finally
        {
            _unbanningId = null;
            StateHasChanged();
        }
    }

    private static string DisplayUser(ApplicationUser? user)
    {
        if (user is null)
            return "-";

        if (!string.IsNullOrWhiteSpace(user.DisplayName))
            return user.DisplayName;

        return user.UserName ?? user.Email ?? user.Id;
    }

    private static string UserNameText(ApplicationUser? user)
    {
        return !string.IsNullOrWhiteSpace(user?.UserName) ? "@" + user!.UserName : "-";
    }

    private static string Avatar(ApplicationUser? user)
    {
        return user?.AvatarUrl ?? "/images/default-avatar.png";
    }

    private static string EndText(UserBan ban)
    {
        return ban.EndsAtUtc.HasValue
            ? ban.EndsAtUtc.Value.ToLocalTime().ToString("yyyy-MM-dd HH:mm")
            : "Permanent";
    }

    private static string RemainingText(UserBan ban)
    {
        if (!ban.EndsAtUtc.HasValue)
            return "No end date";

        var left = ban.EndsAtUtc.Value - DateTime.UtcNow;

        if (left.TotalMinutes <= 0)
            return "Ending now";

        if (left.TotalDays >= 1)
            return $"{Math.Floor(left.TotalDays)} day(s) left";

        if (left.TotalHours >= 1)
            return $"{Math.Floor(left.TotalHours)} hour(s) left";

        return $"{Math.Floor(left.TotalMinutes)} minute(s) left";
    }
}