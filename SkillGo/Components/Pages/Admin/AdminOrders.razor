@page "/admin/orders"
@attribute [Authorize(Roles = "Admin")]
@layout SkillGo.Components.Layout.AdminLayout
@using Microsoft.AspNetCore.Authorization
@using Microsoft.EntityFrameworkCore
@using MudBlazor
@using SkillGo.Data
@using SkillGo.Data.Models
@using SkillGo.Data.Models.Orders
@inject IDbContextFactory<ApplicationDbContext> DbFactory
@inject ISnackbar Snackbar
@inject NavigationManager Nav

<PageTitle>Admin Orders</PageTitle>

<MudStack Spacing="3">
    <MudPaper Class="admin-orders-hero" Elevation="0">
        <div class="admin-orders-hero-content">
            <div>
                <div class="admin-orders-kicker">Administration</div>
                <div class="admin-orders-title">Orders moderation</div>
                <div class="admin-orders-subtitle">Review active orders, disputes and resolve cases with refund if needed.</div>
            </div>
        </div>
    </MudPaper>

    <MudPaper Class="admin-orders-panel" Elevation="0">
        <MudStack Spacing="2">
            <MudStack Row="true" Spacing="2" Class="admin-orders-toolbar">
                <MudTextField T="string"
                              Value="@_search"
                              ValueChanged="OnSearchChanged"
                              Placeholder="Search by order id, service, buyer, seller..."
                              Variant="Variant.Outlined"
                              Adornment="Adornment.Start"
                              AdornmentIcon="@Icons.Material.Filled.Search"
                              Immediate="true"
                              Class="admin-orders-search" />

                <MudSelect T="string"
                           Value="@_status"
                           ValueChanged="OnStatusChanged"
                           Variant="Variant.Outlined"
                           Class="admin-orders-filter">
                    <MudSelectItem T="string" Value="@("All")">All statuses</MudSelectItem>
                    <MudSelectItem T="string" Value="@("InProgress")">In progress</MudSelectItem>
                    <MudSelectItem T="string" Value="@("Completed")">Completed</MudSelectItem>
                    <MudSelectItem T="string" Value="@("Cancelled")">Cancelled</MudSelectItem>
                </MudSelect>

                <MudSelect T="string"
                           Value="@_disputeFilter"
                           ValueChanged="OnDisputeFilterChanged"
                           Variant="Variant.Outlined"
                           Class="admin-orders-filter">
                    <MudSelectItem T="string" Value="@("All")">All orders</MudSelectItem>
                    <MudSelectItem T="string" Value="@("WithDisputes")">With disputes</MudSelectItem>
                    <MudSelectItem T="string" Value="@("OpenDisputes")">Open disputes</MudSelectItem>
                </MudSelect>
            </MudStack>

            @if (_loading)
            {
                <div class="admin-orders-loading">
                    <MudProgressCircular Indeterminate="true" />
                </div>
            }
            else if (_rows.Count == 0)
            {
                <div class="admin-orders-empty">
                    <MudIcon Icon="@Icons.Material.Filled.ReceiptLong" Size="Size.Large" />
                    <div class="admin-orders-empty-title">No orders found</div>
                    <div class="admin-orders-empty-subtitle">Try changing the filters.</div>
                </div>
            }
            else
            {
                <div class="admin-orders-list">
                    @foreach (var row in _rows)
                    {
                        <div class="admin-order-card">
                            <div class="admin-order-top">
                                <div>
                                    <div class="admin-order-id">Order #@row.Order.Id</div>
                                    <div class="admin-order-service">@((row.Order.ServiceOffer?.Title) ?? "Service")</div>
                                </div>

                                <MudStack Spacing="1" AlignItems="AlignItems.End">
                                    <MudChip T="string" Size="Size.Small" Variant="Variant.Filled" Color="@StatusColor(row.Order.Status)">
                                        @row.Order.Status
                                    </MudChip>

                                    @if (row.OpenDisputesCount > 0)
                                    {
                                        <MudChip T="string" Size="Size.Small" Variant="Variant.Outlined" Color="Color.Error">
                                            @row.OpenDisputesCount open dispute(s)
                                        </MudChip>
                                    }
                                </MudStack>
                            </div>

                            <div class="admin-order-grid">
                                <div class="admin-order-box">
                                    <div class="admin-order-label">Buyer</div>
                                    <div class="admin-order-value">@DisplayUser(row.Buyer)</div>
                                </div>

                                <div class="admin-order-box">
                                    <div class="admin-order-label">Seller</div>
                                    <div class="admin-order-value">@DisplayUser(row.Seller)</div>
                                </div>

                                <div class="admin-order-box">
                                    <div class="admin-order-label">Amount</div>
                                    <div class="admin-order-value">@row.Order.Amount.ToString("0.00") zł</div>
                                </div>

                                <div class="admin-order-box">
                                    <div class="admin-order-label">Escrow</div>
                                    <div class="admin-order-value">@row.Order.EscrowAmount.ToString("0.00") zł</div>
                                </div>
                            </div>

                            @if (row.Disputes.Any())
                            {
                                <div class="admin-order-disputes-title">Disputes</div>

                                <div class="admin-order-disputes">
                                    @foreach (var dispute in row.Disputes)
                                    {
                                        <div class="admin-dispute-card">
                                            <div class="admin-dispute-top">
                                                <div>
                                                    <div class="admin-dispute-subject">@dispute.Subject</div>
                                                    <div class="admin-dispute-meta">
                                                        @DisplayUser(row.Reporters.TryGetValue(dispute.ReporterId, out var reporter) ? reporter : null)
                                                        · @dispute.CreatedAtUtc.ToLocalTime().ToString("yyyy-MM-dd HH:mm")
                                                    </div>
                                                </div>

                                                <MudChip T="string" Size="Size.Small" Variant="Variant.Filled" Color="@(dispute.Status == OrderDisputeStatus.Open ? Color.Error : Color.Success)">
                                                    @dispute.Status
                                                </MudChip>
                                            </div>

                                            <div class="admin-dispute-description">@dispute.Description</div>

                                            @if (dispute.Status == OrderDisputeStatus.Open)
                                            {
                                                <div class="admin-dispute-actions">
                                                    <MudButton Variant="Variant.Outlined"
                                                               Color="Color.Primary"
                                                               Disabled="_busy"
                                                               OnClick="@(() => OpenOrder(row.Order.Id))">
                                                        Open order
                                                    </MudButton>

                                                    <MudButton Variant="Variant.Filled"
                                                               Color="Color.Warning"
                                                               Disabled="_busy"
                                                               OnClick="@(() => RefundAndResolveAsync(row.Order.Id, dispute.Id))">
                                                        Refund client
                                                    </MudButton>

                                                    <MudButton Variant="Variant.Filled"
                                                               Color="Color.Success"
                                                               Disabled="_busy"
                                                               OnClick="@(() => ResolveDisputeOnlyAsync(row.Order.Id, dispute.Id))">
                                                        Resolve only
                                                    </MudButton>
                                                </div>
                                            }
                                        </div>
                                    }
                                </div>
                            }

                            <div class="admin-order-actions">
                                <MudButton Variant="Variant.Filled"
                                           Color="Color.Primary"
                                           OnClick="@(() => OpenOrder(row.Order.Id))">
                                    Details
                                </MudButton>

                                <MudButton Variant="Variant.Outlined"
                                           Color="Color.Primary"
                                           OnClick="@(() => Nav.NavigateTo($"/chat/{row.Order.ConversationId}"))">
                                    Chat
                                </MudButton>

                                @if (row.Order.ServiceOfferId > 0)
                                {
                                    <MudButton Variant="Variant.Outlined"
                                               Color="Color.Primary"
                                               OnClick="@(() => Nav.NavigateTo($"/services/{row.Order.ServiceOfferId}"))">
                                        Service
                                    </MudButton>
                                }
                            </div>
                        </div>
                    }
                </div>

                <div class="admin-orders-pagination">
                    <MudPagination Count="@_totalPages"
                                   Selected="@_page"
                                   SelectedChanged="OnPageChanged"
                                   Color="Color.Primary"
                                   Variant="Variant.Outlined" />
                </div>
            }
        </MudStack>
    </MudPaper>
</MudStack>

<style>
