        }

        .admin-orders-filter {
            width: 100%;
        }

        .admin-order-grid {
            grid-template-columns: 1fr;
        }
    }
</style>

@code {
    private bool _loading = true;
    private bool _busy;
    private string _search = string.Empty;
    private string _status = "All";
    private string _disputeFilter = "All";

    private List<OrderRow> _allRows = new();
    private List<OrderRow> _rows = new();

    private int _page = 1;
    private int _pageSize = 8;
    private int _totalItems;
    private int _totalPages = 1;

    protected override async Task OnInitializedAsync()
    {
        await LoadAsync();
    }

    private async Task LoadAsync()
    {
        _loading = true;
        StateHasChanged();

        await using var db = await DbFactory.CreateDbContextAsync();

        var orders = await db.Orders
            .AsNoTracking()
            .Include(x => x.ServiceOffer)
            .OrderByDescending(x => x.CreatedAtUtc)
            .ToListAsync();

        var disputes = await db.OrderDisputes
            .AsNoTracking()
            .OrderByDescending(x => x.CreatedAtUtc)
            .ToListAsync();

        var userIds = orders
            .SelectMany(x => new[] { x.BuyerId, x.SellerId })
            .Concat(disputes.Select(x => x.ReporterId))
            .Distinct()
            .ToList();

        var users = await db.Users
            .AsNoTracking()
            .Where(x => userIds.Contains(x.Id))
            .ToListAsync();

        var userMap = users.ToDictionary(x => x.Id, x => x);

        _allRows = orders.Select(order =>
        {
            var orderDisputes = disputes
                .Where(x => x.OrderId == order.Id)
                .OrderByDescending(x => x.CreatedAtUtc)
                .ToList();

            var reporters = orderDisputes
                .Select(x => x.ReporterId)
                .Distinct()
                .Where(x => userMap.ContainsKey(x))
                .ToDictionary(x => x, x => userMap[x]);

            userMap.TryGetValue(order.BuyerId, out var buyer);
            userMap.TryGetValue(order.SellerId, out var seller);

            return new OrderRow
            {
                Order = order,
                Buyer = buyer,
                Seller = seller,
                Disputes = orderDisputes,
                Reporters = reporters,
                OpenDisputesCount = orderDisputes.Count(x => x.Status == OrderDisputeStatus.Open)
            };
        }).ToList();

        ApplyFiltersAndPaging();

        _loading = false;
        StateHasChanged();
    }

    private void ApplyFiltersAndPaging()
    {
        IEnumerable<OrderRow> query = _allRows;

        if (_status != "All" && Enum.TryParse<OrderStatus>(_status, out var parsedStatus))
            query = query.Where(x => x.Order.Status == parsedStatus);

        query = _disputeFilter switch
        {
            "WithDisputes" => query.Where(x => x.Disputes.Any()),
            "OpenDisputes" => query.Where(x => x.Disputes.Any(d => d.Status == OrderDisputeStatus.Open)),
            _ => query
        };

        if (!string.IsNullOrWhiteSpace(_search))
        {
            var term = _search.Trim().ToLowerInvariant();

            query = query.Where(x =>
                x.Order.Id.ToString().Contains(term) ||
                (x.Order.ServiceOffer?.Title?.ToLowerInvariant().Contains(term) ?? false) ||
                DisplayUser(x.Buyer).ToLowerInvariant().Contains(term) ||
                DisplayUser(x.Seller).ToLowerInvariant().Contains(term));
        }

        var filtered = query.ToList();

        _totalItems = filtered.Count;
        _totalPages = Math.Max(1, (int)Math.Ceiling(_totalItems / (double)_pageSize));

        if (_page > _totalPages)
            _page = _totalPages;

        _rows = filtered
            .Skip((_page - 1) * _pageSize)
            .Take(_pageSize)
            .ToList();
    }

    private async Task OnSearchChanged(string value)
    {
        _search = value ?? string.Empty;
        _page = 1;
        ApplyFiltersAndPaging();
        await InvokeAsync(StateHasChanged);
    }

    private async Task OnStatusChanged(string value)
    {
        _status = value ?? "All";
        _page = 1;
        ApplyFiltersAndPaging();
        await InvokeAsync(StateHasChanged);
    }

    private async Task OnDisputeFilterChanged(string value)
    {
        _disputeFilter = value ?? "All";
        _page = 1;
        ApplyFiltersAndPaging();
        await InvokeAsync(StateHasChanged);
    }

    private async Task OnPageChanged(int page)
    {
        _page = page;
        ApplyFiltersAndPaging();
        await InvokeAsync(StateHasChanged);
    }

    private void OpenOrder(int orderId)
    {
        Nav.NavigateTo($"/orders/{orderId}");
    }

    private async Task ResolveDisputeOnlyAsync(int orderId, int disputeId)
    {
        if (_busy) return;

        _busy = true;

        try
        {
            await using var db = await DbFactory.CreateDbContextAsync();

            var dispute = await db.OrderDisputes.FirstOrDefaultAsync(x => x.Id == disputeId && x.OrderId == orderId);
            if (dispute == null)
            {
                Snackbar.Add("Dispute not found", Severity.Error);
                return;
            }

            dispute.Status = OrderDisputeStatus.Resolved;

            var reports = await db.Reports
                .Where(x => x.TargetType == SkillGo.Data.Models.Reports.ReportTargetType.Order && x.OrderId == orderId && x.Status == SkillGo.Data.Models.Reports.ReportStatus.Open)
                .ToListAsync();

            foreach (var report in reports)
            {
                report.Status = SkillGo.Data.Models.Reports.ReportStatus.Resolved;
                report.ResolvedAtUtc = DateTime.UtcNow;
                report.ResolutionResult = "Resolved by admin without refund";
            }

            await db.SaveChangesAsync();

            Snackbar.Add("Dispute resolved", Severity.Success);
            await LoadAsync();
        }
        finally
        {
            _busy = false;
        }
    }

    private async Task RefundAndResolveAsync(int orderId, int disputeId)
    {
        if (_busy) return;

        _busy = true;

        try
        {
            await using var db = await DbFactory.CreateDbContextAsync();

            var order = await db.Orders.FirstOrDefaultAsync(x => x.Id == orderId);
            if (order == null)
            {
                Snackbar.Add("Order not found", Severity.Error);
                return;
            }

            if (order.Status == OrderStatus.Cancelled)
            {
                Snackbar.Add("Order already cancelled", Severity.Warning);
                return;
            }

            var dispute = await db.OrderDisputes.FirstOrDefaultAsync(x => x.Id == disputeId && x.OrderId == orderId);
            if (dispute == null)
            {
                Snackbar.Add("Dispute not found", Severity.Error);
                return;
            }

            var buyer = await db.Users.FirstOrDefaultAsync(x => x.Id == order.BuyerId);
            if (buyer == null)
            {
                Snackbar.Add("Buyer not found", Severity.Error);
                return;
            }

            var refundAmount = order.EscrowAmount > 0 ? order.EscrowAmount : order.Amount;

            buyer.Balance += refundAmount;

            db.WalletTransactions.Add(new WalletTransaction
            {
                UserId = buyer.Id,
                Amount = refundAmount,
                Type = WalletTransactionType.Refund,
                Note = $"Admin refund for order #{order.Id}",
                CreatedAt = DateTime.UtcNow
            });

            order.Status = OrderStatus.Cancelled;
            order.CompletedAtUtc = DateTime.UtcNow;

            dispute.Status = OrderDisputeStatus.Resolved;

            var reports = await db.Reports
                .Where(x => x.TargetType == SkillGo.Data.Models.Reports.ReportTargetType.Order && x.OrderId == orderId && x.Status == SkillGo.Data.Models.Reports.ReportStatus.Open)
                .ToListAsync();

            foreach (var report in reports)
            {
                report.Status = SkillGo.Data.Models.Reports.ReportStatus.Resolved;
                report.ResolvedAtUtc = DateTime.UtcNow;
                report.ResolutionResult = "Refund issued to client";
                report.ResolutionNote = $"Refund amount: {refundAmount:0.##} zł";
            }

            await db.SaveChangesAsync();

            Snackbar.Add($"Refunded {refundAmount:0.##} zł to client", Severity.Success);
            await LoadAsync();
        }
        finally
        {
            _busy = false;
        }
    }

    private static string DisplayUser(ApplicationUser? user)
    {
        if (user == null)
            return "-";

        if (!string.IsNullOrWhiteSpace(user.DisplayName))
            return user.DisplayName;

        return user.UserName ?? user.Email ?? user.Id;
    }

    private static Color StatusColor(OrderStatus status)
        => status switch
        {
            OrderStatus.InProgress => Color.Warning,
            OrderStatus.Completed => Color.Success,
            OrderStatus.Cancelled => Color.Error,
            _ => Color.Default
        };

    private sealed class OrderRow
    {
        public Order Order { get; set; } = default!;
        public ApplicationUser? Buyer { get; set; }
        public ApplicationUser? Seller { get; set; }
        public List<OrderDispute> Disputes { get; set; } = new();
        public Dictionary<string, ApplicationUser> Reporters { get; set; } = new();
        public int OpenDisputesCount { get; set; }
    }
}