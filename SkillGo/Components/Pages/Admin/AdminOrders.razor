        padding: 28px;
        background: linear-gradient(135deg, #111827 0%, #1f2937 40%, #312e81 100%);
        color: #fff;
        box-shadow: 0 24px 48px rgba(15,23,42,.16);
    }

    .admin-orders-kicker {
        color: rgba(255,255,255,.66);
        font-size: .78rem;
        font-weight: 900;
        text-transform: uppercase;
        letter-spacing: .16em;
    }

    .admin-orders-title {
        margin-top: 8px;
        font-size: 2rem;
        line-height: 1.05;
        font-weight: 950;
    }

    .admin-orders-subtitle {
        margin-top: 8px;
        color: rgba(255,255,255,.76);
        font-weight: 700;
    }

    .admin-orders-panel {
        padding: 22px;
        border-radius: 24px;
        background: rgba(255,255,255,.94);
        border: 1px solid rgba(15,23,42,.06);
        box-shadow: 0 18px 36px rgba(15,23,42,.05);
    }

    .admin-orders-toolbar {
        flex-wrap: wrap;
    }

    .admin-orders-search {
        flex: 1 1 360px;
    }

    .admin-orders-filter {
        width: 220px;
    }

    .admin-orders-loading,
    .admin-orders-empty {
        min-height: 280px;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        gap: 12px;
        text-align: center;
    }

    .admin-orders-empty-title {
        font-size: 1.08rem;
        font-weight: 900;
        color: #111827;
    }

    .admin-orders-empty-subtitle {
        color: rgba(17,24,39,.62);
        font-weight: 700;
    }

    .admin-orders-list {
        display: flex;
        flex-direction: column;
        gap: 16px;
    }

    .admin-order-card {
        border-radius: 22px;
        border: 1px solid rgba(15,23,42,.08);
        background: #fff;
        box-shadow: 0 14px 34px rgba(15,23,42,.05);
        padding: 18px;
        display: flex;
        flex-direction: column;
        gap: 14px;
    }

    .admin-order-top {
        display: flex;
        justify-content: space-between;
        gap: 12px;
        align-items: flex-start;
        flex-wrap: wrap;
    }

    .admin-order-id {
        color: #111827;
        font-size: 1.04rem;
        font-weight: 950;
        line-height: 1.1;
    }

    .admin-order-service {
        margin-top: 4px;
        color: rgba(17,24,39,.56);
        font-weight: 800;
        line-height: 1.35;
    }

    .admin-order-grid {
        display: grid;
        grid-template-columns: repeat(4, minmax(0, 1fr));
        gap: 10px;
    }

    .admin-order-box {
        border-radius: 16px;
        border: 1px solid rgba(15,23,42,.06);
        background: #f8fafc;
        padding: 12px;
    }

    .admin-order-label {
        color: rgba(17,24,39,.56);
        font-size: .72rem;
        font-weight: 900;
        text-transform: uppercase;
        letter-spacing: .08em;
    }

    .admin-order-value {
        margin-top: 6px;
        color: #111827;
        font-weight: 900;
        line-height: 1.35;
        word-break: break-word;
    }

    .admin-order-disputes-title {
        color: #111827;
        font-size: .96rem;
        font-weight: 950;
    }

    .admin-order-disputes {
        display: flex;
        flex-direction: column;
        gap: 10px;
    }

    .admin-dispute-card {
        border-radius: 18px;
        border: 1px solid rgba(239,68,68,.16);
