        flex-direction: column;
        align-items: center;
        justify-content: center;
        gap: 14px;
        border-radius: 24px;
        background: rgba(255,255,255,.96);
        border: 1px solid rgba(15,23,42,.06);
        text-align: center;
    }

    .details-empty-title {
        font-size: 1.08rem;
        font-weight: 900;
        color: #111827;
    }

