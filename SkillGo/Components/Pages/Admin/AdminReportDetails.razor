    private async Task BanUserAsync()
    {
        if (_moderating || _report is null || string.IsNullOrWhiteSpace(_banReason))
            return;

        var auth = await AuthenticationStateTask;
        var adminId = auth.User.FindFirstValue(ClaimTypes.NameIdentifier);

        if (string.IsNullOrWhiteSpace(adminId))
            return;

        _moderating = true;
        StateHasChanged();

        try
        {
            await using var db = await DbFactory.CreateDbContextAsync();

            var now = DateTime.UtcNow;
            var endsAt = _banDuration switch
            {
                "1d" => now.AddDays(1),
                "7d" => now.AddDays(7),
                "30d" => now.AddDays(30),
                "perm" => (DateTime?)null,
                _ => now.AddDays(7)
            };

            var active = await db.UserBans
                .Where(x => x.UserId == _report.TargetUserId && x.StartsAtUtc <= now && (!x.EndsAtUtc.HasValue || x.EndsAtUtc > now))
                .OrderByDescending(x => x.StartsAtUtc)
                .FirstOrDefaultAsync();

            if (active is not null)
            {
                active.Reason = _banReason.Trim();
                active.EndsAtUtc = endsAt;
                active.CreatedByUserId = adminId;
            }
            else
            {
                db.UserBans.Add(new UserBan
                    {
                        UserId = _report.TargetUserId,
                        CreatedByUserId = adminId,
                        Reason = _banReason.Trim(),
                        StartsAtUtc = now,
                        EndsAtUtc = endsAt
                    });
            }

            await db.SaveChangesAsync();
            Snackbar.Add("User restriction saved", Severity.Success);
            await LoadAsync();
        }
        catch (Exception ex)
        {
            Snackbar.Add(ex.Message, Severity.Error);
        }
        finally
        {
            _moderating = false;
            StateHasChanged();
        }
    }

    private async Task UnbanUserAsync()
    {
        if (_moderating || _report is null)
            return;

        _moderating = true;
        StateHasChanged();

        try
        {
            await using var db = await DbFactory.CreateDbContextAsync();
            var now = DateTime.UtcNow;

            var activeBans = await db.UserBans
                .Where(x => x.UserId == _report.TargetUserId && x.StartsAtUtc <= now && (!x.EndsAtUtc.HasValue || x.EndsAtUtc > now))
                .ToListAsync();

            if (activeBans.Count == 0)
            {
                Snackbar.Add("Active ban not found", Severity.Error);
                return;
            }

            foreach (var ban in activeBans)
                ban.EndsAtUtc = now;

            await db.SaveChangesAsync();

            Snackbar.Add("User unbanned", Severity.Success);
            await LoadAsync();
        }
        catch (Exception ex)
        {
            Snackbar.Add(ex.Message, Severity.Error);
        }
        finally
        {
            _moderating = false;
            StateHasChanged();
        }
    }

    private async Task DeleteMessageAsync()
    {
        if (_moderating || _report is null || !_report.MessageId.HasValue)
            return;

        _moderating = true;
        StateHasChanged();

        try
        {
            await using var db = await DbFactory.CreateDbContextAsync();

            var msg = await db.Messages
                .Include(x => x.Attachments)
                .FirstOrDefaultAsync(x => x.Id == _report.MessageId.Value);

            if (msg is null)
            {
                Snackbar.Add("Message not found", Severity.Error);
                return;
            }

            if (msg.Attachments.Any())
                db.MessageAttachments.RemoveRange(msg.Attachments);

            msg.Body = null;
            msg.IsDeleted = true;
            msg.DeletedAtUtc = DateTime.UtcNow;

            await db.SaveChangesAsync();

            Snackbar.Add("Message deleted", Severity.Success);
            await LoadAsync();
        }
        catch (Exception ex)
        {
            Snackbar.Add(ex.Message, Severity.Error);
        }
        finally
        {
            _moderating = false;
            StateHasChanged();
        }
    }

    private async Task DeleteServiceAsync()
    {
        if (_moderating || _service is null)
            return;

        _moderating = true;
        StateHasChanged();

        try
        {
            await using var db = await DbFactory.CreateDbContextAsync();

            var service = await db.ServiceOffers.FirstOrDefaultAsync(x => x.Id == _service.Id);

            if (service is null)
            {
                Snackbar.Add("Service not found", Severity.Error);
                return;
            }

            var hasOrders = await db.Orders.AnyAsync(x => x.ServiceOfferId == service.Id);

            if (hasOrders)
            {
                Snackbar.Add("Service cannot be deleted because it is used in orders", Severity.Error);
                return;
            }

            db.ServiceOffers.Remove(service);
            await db.SaveChangesAsync();

            Snackbar.Add("Service deleted", Severity.Success);
            await LoadAsync();
        }
        catch (Exception ex)
        {
            Snackbar.Add(ex.Message, Severity.Error);
        }
        finally
        {
            _moderating = false;
            StateHasChanged();
        }
    }

    private async Task RefundOrderAsync()
    {
        if (_moderating || _report is null || _order is null)
            return;

        var auth = await AuthenticationStateTask;
        var adminId = auth.User.FindFirstValue(ClaimTypes.NameIdentifier);

        _moderating = true;
        StateHasChanged();

        try
        {
            await using var db = await DbFactory.CreateDbContextAsync();

            var order = await db.Orders.FirstOrDefaultAsync(x => x.Id == _order.Id);
            if (order is null)
            {
                Snackbar.Add("Order not found", Severity.Error);
                return;
            }

            if (order.Status == OrderStatus.Cancelled)
            {
                Snackbar.Add("Order already cancelled", Severity.Warning);
                return;
            }

            var buyer = await db.Users.FirstOrDefaultAsync(x => x.Id == order.BuyerId);
            if (buyer is null)
            {
                Snackbar.Add("Buyer not found", Severity.Error);
                return;
            }

            var refundAmount = order.EscrowAmount > 0 ? order.EscrowAmount : order.Amount;

            buyer.Balance += refundAmount;

            db.WalletTransactions.Add(new WalletTransaction
                {
                    UserId = buyer.Id,
                    Amount = refundAmount,
                    Type = WalletTransactionType.Refund,
                    Note = $"Admin refund for order #{order.Id}",
                    CreatedAt = DateTime.UtcNow
                });

            order.Status = OrderStatus.Cancelled;
            order.CompletedAtUtc = DateTime.UtcNow;

            var disputes = await db.OrderDisputes
                .Where(x => x.OrderId == order.Id && x.Status == OrderDisputeStatus.Open)
                .ToListAsync();

            foreach (var dispute in disputes)
                dispute.Status = OrderDisputeStatus.Resolved;

            var report = await db.Reports.FirstOrDefaultAsync(x => x.Id == _report.Id);
            if (report is not null && report.Status == ReportStatus.Open)
            {
                report.Status = ReportStatus.Resolved;
                report.ResolvedByUserId = string.IsNullOrWhiteSpace(adminId) ? null : adminId;
                report.ResolvedAtUtc = DateTime.UtcNow;
                report.ResolutionResult = "Refund issued to client";
                report.ResolutionNote = $"Refund amount: {refundAmount:0.##} zł";
            }

            await db.SaveChangesAsync();

            Snackbar.Add($"Refunded {refundAmount:0.##} zł to client", Severity.Success);
            await LoadAsync();
        }
        catch (Exception ex)
        {
            Snackbar.Add(ex.Message, Severity.Error);
        }
        finally
        {
            _moderating = false;
            StateHasChanged();
        }
    }

