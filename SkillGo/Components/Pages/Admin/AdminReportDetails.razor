@page "/admin/reports/{Id:int}"
@attribute [Authorize(Roles = "Admin")]
@layout SkillGo.Components.Layout.AdminLayout
@using System.Security.Claims
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Components.Authorization
@using Microsoft.EntityFrameworkCore
@using MudBlazor
@using SkillGo.Data
@using SkillGo.Data.Models
@using SkillGo.Data.Models.Chat
@using SkillGo.Data.Models.Orders
@using SkillGo.Data.Models.Reports
@inject IDbContextFactory<ApplicationDbContext> DbFactory
@inject NavigationManager Nav
@inject ISnackbar Snackbar

<PageTitle>Report Details</PageTitle>

<MudStack Spacing="3">
    @if (_loading)
    {
        <MudPaper Class="ard-loading" Elevation="0">
            <MudProgressCircular Indeterminate="true" Size="Size.Large" Color="Color.Primary" />
            <MudText Typo="Typo.h6">Loading report...</MudText>
        </MudPaper>
    }
    else if (_report is null)
    {
        <MudPaper Class="ard-empty" Elevation="0">
            <MudIcon Icon="@Icons.Material.Filled.ErrorOutline" Size="Size.Large" />
            <div class="ard-empty-title">Report not found</div>
            <div class="ard-empty-sub">The report may have been removed or does not exist.</div>

            <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="GoBack">
                Back to reports
            </MudButton>
        </MudPaper>
    }
    else
    {
        <MudPaper Class="ard-hero" Elevation="0">
            <div class="ard-hero-top">
                <div>
                    <div class="ard-kicker">Administration</div>
                    <div class="ard-title">Report #@_report.Id</div>
                    <div class="ard-subtitle">Review the violation, inspect the related entity and take moderation action.</div>
                </div>

                <div class="ard-hero-badges">
                    <MudChip T="string" Variant="Variant.Filled" Color="@TargetTypeColor(_report.TargetType)">
                        @_report.TargetType
                    </MudChip>

                    <MudChip T="string" Variant="Variant.Outlined" Color="@StatusColor(_report.Status)">
                        @_report.Status
                    </MudChip>
                </div>
            </div>

            <div class="ard-hero-grid">
                <div class="ard-stat">
                    <div class="ard-stat-label">Reporter</div>
                    <div class="ard-stat-value">@DisplayUser(_report.ReporterUser)</div>
                </div>

                <div class="ard-stat">
                    <div class="ard-stat-label">Target user</div>
                    <div class="ard-stat-value">@DisplayUser(_report.TargetUser)</div>
                </div>

                <div class="ard-stat">
                    <div class="ard-stat-label">Created</div>
                    <div class="ard-stat-value">@_report.CreatedAt.ToLocalTime().ToString("yyyy-MM-dd HH:mm")</div>
                </div>

                <div class="ard-stat">
                    <div class="ard-stat-label">Object</div>
                    <div class="ard-stat-value">@ObjectText()</div>
                </div>
            </div>
        </MudPaper>

        <div class="ard-grid">
            <MudPaper Class="ard-main" Elevation="0">
                <div class="ard-section">
                    <div class="ard-section-title">Reason</div>
                    <div class="ard-reason-box">@_report.Reason</div>
                </div>

                @if (_report.Status != ReportStatus.Open)
                {
                    <div class="ard-section">
                        <div class="ard-section-title">Resolution</div>

                        <div class="ard-info-grid">
                            <div class="ard-info-card">
                                <div class="ard-info-label">Closed by</div>
                                <div class="ard-info-value">@DisplayUser(_report.ResolvedByUser)</div>
                            </div>

                            <div class="ard-info-card">
                                <div class="ard-info-label">Closed at</div>
                                <div class="ard-info-value">@(_report.ResolvedAtUtc.HasValue ? _report.ResolvedAtUtc.Value.ToLocalTime().ToString("yyyy-MM-dd HH:mm") : "-")</div>
                            </div>

                            <div class="ard-info-card">
                                <div class="ard-info-label">Result</div>
                                <div class="ard-info-value">@(_report.ResolutionResult ?? "-")</div>
                            </div>

                            <div class="ard-info-card">
                                <div class="ard-info-label">Status</div>
                                <div class="ard-info-value">@_report.Status</div>
                            </div>
                        </div>

                        @if (!string.IsNullOrWhiteSpace(_report.ResolutionNote))
                        {
                            <div class="ard-resolution-note">@_report.ResolutionNote</div>
                        }
                    </div>
                }

                @if (_report.TargetType == ReportTargetType.Message)
                {
                    <div class="ard-section">
                        <div class="ard-section-title">Reported message</div>

                        @if (_message is null)
                        {
                            <div class="ard-note-box">Message not found.</div>
                        }
                        else
                        {
                            <div class="ard-object-card">
                                <div class="ard-object-head">
                                    <div>
                                        <div class="ard-object-title">@DisplayUser(_messageSender)</div>
                                        <div class="ard-object-sub">@_message.CreatedAtUtc.ToLocalTime().ToString("yyyy-MM-dd HH:mm")</div>
                                    </div>

                                    @if (_report.Status == ReportStatus.Open && _message.ConversationId > 0)
                                    {
                                        <MudButton Variant="Variant.Outlined"
                                                   Color="Color.Primary"
                                                   OnClick="OpenReportedMessageChat">
                                            Open chat
                                        </MudButton>
                                    }
                                </div>

                                @if (_message.IsDeleted)
                                {
                                    <div class="ard-note-box mt-3">Message deleted.</div>
                                }
                                else
                                {
                                    @if (!string.IsNullOrWhiteSpace(_message.Body))
                                    {
                                        <div class="ard-message-body">@_message.Body</div>
                                    }

                                    @if (_message.Attachments.Any())
                                    {
                                        <div class="ard-attachments">
                                            @foreach (var att in _message.Attachments)
                                            {
                                                <a class="ard-attachment" href="@att.Url" target="_blank">
                                                    <MudIcon Icon="@(att.IsImage ? Icons.Material.Filled.Image : Icons.Material.Filled.AttachFile)" />
                                                    <span>@att.FileName</span>
                                                </a>
                                            }
                                        </div>
                                    }
                                }
                            </div>
                        }
                    </div>
                }

                @if (_report.TargetType == ReportTargetType.Order)
                {
                    <div class="ard-section">
                        <div class="ard-section-title">Reported order</div>

                        @if (_order is null)
                        {
                            <div class="ard-note-box">Order not found.</div>
                        }
                        else
                        {
                            <div class="ard-object-card">
                                <div class="ard-object-title">Order #@_order.Id</div>
                                <div class="ard-object-sub">@(_order.ServiceOffer?.Title ?? "Service")</div>

                                <div class="ard-info-grid mt-4">
                                    <div class="ard-info-card">
                                        <div class="ard-info-label">Buyer</div>
                                        <div class="ard-info-value">@DisplayUser(_buyer)</div>
                                    </div>

                                    <div class="ard-info-card">
                                        <div class="ard-info-label">Seller</div>
                                        <div class="ard-info-value">@DisplayUser(_seller)</div>
                                    </div>

                                    <div class="ard-info-card">
                                        <div class="ard-info-label">Amount</div>
                                        <div class="ard-info-value">@_order.Amount.ToString("0.00") zł</div>
                                    </div>

                                    <div class="ard-info-card">
                                        <div class="ard-info-label">Status</div>
                                        <div class="ard-info-value">@_order.Status</div>
                                    </div>
                                </div>

                                <div class="ard-object-actions">
                                    @if (_report.Status == ReportStatus.Open)
                                    {
                                        <MudButton Variant="Variant.Outlined"
                                                   Color="Color.Primary"
                                                   OnClick="OpenReportedOrder">
                                            Open order
                                        </MudButton>

                                        @if (_order.ConversationId > 0)
                                        {
                                            <MudButton Variant="Variant.Outlined"
                                                       Color="Color.Primary"
                                                       OnClick="OpenReportedOrderChat">
                                                Open chat
                                            </MudButton>
                                        }
                                    }
                                </div>
                            </div>
                        }
                    </div>
                }

                @if (_report.TargetType == ReportTargetType.Service)
                {
                    <div class="ard-section">
                        <div class="ard-section-title">Reported service</div>

                        @if (_service is null)
                        {
                            <div class="ard-note-box">Service not found.</div>
                        }
                        else
                        {
                            <div class="ard-object-card">
                                <div class="ard-object-title">@_service.Title</div>
                                <div class="ard-object-sub">@TrimText(_service.Description, 280)</div>

                                <div class="ard-info-grid mt-4">
                                    <div class="ard-info-card">
                                        <div class="ard-info-label">Owner</div>
                                        <div class="ard-info-value">@DisplayUser(_serviceOwner)</div>
                                    </div>

                                    <div class="ard-info-card">
                                        <div class="ard-info-label">Price</div>
                                        <div class="ard-info-value">@_service.Price.ToString("0.00") zł</div>
                                    </div>
                                </div>

                                <div class="ard-object-actions">
                                    <MudButton Variant="Variant.Outlined"
                                               Color="Color.Primary"
                                               OnClick="@(() => Nav.NavigateTo($"/services/{_service.Id}"))">
                                        Open service
                                    </MudButton>
                                </div>
                            </div>
                        }
                    </div>
                }

                @if (_report.TargetType == ReportTargetType.Profile)
                {
                    <div class="ard-section">
                        <div class="ard-section-title">Reported profile</div>

                        <div class="ard-object-card">
                            <div class="ard-object-title">@DisplayUser(_report.TargetUser)</div>
                            <div class="ard-object-sub">@(_report.TargetUser?.UserName is null ? "-" : "@" + _report.TargetUser.UserName)</div>

                            <div class="ard-object-actions">
                                @if (!string.IsNullOrWhiteSpace(_report.TargetUser?.UserName))
                                {
                                    <MudButton Variant="Variant.Outlined"
                                               Color="Color.Primary"
                                               OnClick="@(() => Nav.NavigateTo($"/profile/{_report.TargetUser!.UserName}"))">
                                        Open profile
                                    </MudButton>
                                }
                            </div>
                        </div>
                    </div>
                }
            </MudPaper>

            <MudPaper Class="ard-side" Elevation="0">
                <div class="ard-side-title">Quick actions</div>

                <MudStack Spacing="2" Class="mt-4">
                    <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="GoBack">
                        Back to reports
                    </MudButton>

                    @if (!string.IsNullOrWhiteSpace(_report.ReporterUser?.UserName))
                    {
                        <MudButton Variant="Variant.Outlined"
                                   Color="Color.Primary"
                                   OnClick="@(() => Nav.NavigateTo($"/profile/{_report.ReporterUser!.UserName}"))">
                            Open reporter
                        </MudButton>
                    }

                    @if (!string.IsNullOrWhiteSpace(_report.TargetUser?.UserName))
                    {
                        <MudButton Variant="Variant.Outlined"
                                   Color="Color.Error"
                                   OnClick="@(() => Nav.NavigateTo($"/profile/{_report.TargetUser!.UserName}"))">
                            Open target
                        </MudButton>
                    }

                    @if (_report.TargetType == ReportTargetType.Message && _message is not null && _report.Status == ReportStatus.Open && _message.ConversationId > 0)
                    {
                        <MudButton Variant="Variant.Outlined"
                                   Color="Color.Primary"
                                   OnClick="OpenReportedMessageChat">
                            Open reported chat
                        </MudButton>
                    }

                    @if (_report.TargetType == ReportTargetType.Order && _order is not null && _report.Status == ReportStatus.Open)
                    {
                        <MudButton Variant="Variant.Outlined"
                                   Color="Color.Primary"
                                   OnClick="OpenReportedOrder">
                            Open reported order
                        </MudButton>

                        @if (_order.ConversationId > 0)
                        {
                            <MudButton Variant="Variant.Outlined"
                                       Color="Color.Primary"
                                       OnClick="OpenReportedOrderChat">
                                Open order chat
                            </MudButton>
                        }
                    }
                </MudStack>

                @if (_report.Status == ReportStatus.Open)
                {
                    <div class="ard-side-title mt-6">Close report</div>

                    <MudStack Spacing="2" Class="mt-4">
                        <MudSelect T="string" @bind-Value="_resolutionResult" Variant="Variant.Outlined">
                            <MudSelectItem T="string" Value="@("Violation confirmed")">Violation confirmed</MudSelectItem>
                            <MudSelectItem T="string" Value="@("False report")">False report</MudSelectItem>
                            <MudSelectItem T="string" Value="@("No action required")">No action required</MudSelectItem>
                            <MudSelectItem T="string" Value="@("User warned")">User warned</MudSelectItem>
                            <MudSelectItem T="string" Value="@("Content removed")">Content removed</MudSelectItem>
                            <MudSelectItem T="string" Value="@("User banned")">User banned</MudSelectItem>
                            <MudSelectItem T="string" Value="@("Refund issued to client")">Refund issued to client</MudSelectItem>
                        </MudSelect>

                        <MudTextField @bind-Value="_resolutionNote"
                                      Label="Admin note"
                                      Variant="Variant.Outlined"
                                      Lines="4"
                                      Immediate="true"
                                      Counter="1000"
                                      MaxLength="1000" />

                        <MudButton Variant="Variant.Filled"
                                   Color="Color.Success"
                                   Disabled="_moderating || string.IsNullOrWhiteSpace(_resolutionResult)"
                                   OnClick="CloseAsResolvedAsync">
                            @(_moderating ? "Saving..." : "Close report")
                        </MudButton>

                        <MudButton Variant="Variant.Outlined"
                                   Color="Color.Secondary"
                                   Disabled="_moderating"
                                   OnClick="CloseAsRejectedAsync">
                            @(_moderating ? "Saving..." : "Skip as false report")
                        </MudButton>
                    </MudStack>
                }

                <div class="ard-side-title mt-6">User restriction</div>

                @if (_activeBan is not null)
                {
                    <MudAlert Severity="Severity.Warning" Dense="true" Variant="Variant.Outlined" Class="mt-3">
                        Active ban until @(_activeBan.EndsAtUtc.HasValue ? _activeBan.EndsAtUtc.Value.ToLocalTime().ToString("yyyy-MM-dd HH:mm") : "Permanent")
                    </MudAlert>

                    <MudButton Variant="Variant.Filled"
                               Color="Color.Success"
                               Class="mt-4"
                               Disabled="_moderating"
                               OnClick="UnbanUserAsync">
                        @(_moderating ? "Saving..." : "Unban user")
                    </MudButton>
                }
                else
                {
                    <MudStack Spacing="2" Class="mt-4">
                        <MudSelect T="string" @bind-Value="_banDuration" Variant="Variant.Outlined">
                            <MudSelectItem T="string" Value="@("1d")">1 day</MudSelectItem>
                            <MudSelectItem T="string" Value="@("7d")">7 days</MudSelectItem>
                            <MudSelectItem T="string" Value="@("30d")">30 days</MudSelectItem>
                            <MudSelectItem T="string" Value="@("perm")">Permanent</MudSelectItem>
                        </MudSelect>

                        <MudTextField @bind-Value="_banReason"
                                      Label="Ban reason"
                                      Variant="Variant.Outlined"
                                      Lines="4"
                                      Immediate="true"
                                      Counter="500"
                                      MaxLength="500" />

                        <MudButton Variant="Variant.Filled"
                                   Color="Color.Error"
                                   Disabled="_moderating || string.IsNullOrWhiteSpace(_banReason)"
                                   OnClick="BanUserAsync">
                            @(_moderating ? "Saving..." : "Ban user")
                        </MudButton>
                    </MudStack>
                }

                @if (_report.TargetType == ReportTargetType.Message && _message is not null && !_message.IsDeleted)
                {
                    <div class="ard-side-title mt-6">Message moderation</div>

                    <MudButton Variant="Variant.Outlined"
                               Color="Color.Error"
                               Class="mt-4"
                               Disabled="_moderating"
                               OnClick="DeleteMessageAsync">
                        Delete message
                    </MudButton>
                }

                @if (_report.TargetType == ReportTargetType.Service && _service is not null)
                {
                    <div class="ard-side-title mt-6">Service moderation</div>

                    <MudButton Variant="Variant.Outlined"
                               Color="Color.Error"
                               Class="mt-4"
                               Disabled="_moderating"
                               OnClick="DeleteServiceAsync">
                        Delete service
                    </MudButton>
                }

                @if (_report.TargetType == ReportTargetType.Order && _order is not null)
                {
                    <div class="ard-side-title mt-6">Order refund</div>

                    <MudButton Variant="Variant.Filled"
                               Color="Color.Warning"
                               Class="mt-4"
                               Disabled="_moderating"
                               OnClick="RefundOrderAsync">
                        @(_moderating ? "Saving..." : "Refund client")
                    </MudButton>
                }
            </MudPaper>
        </div>
    }
</MudStack>

<style>
    .ard-loading,
    .ard-empty {
        min-height: 360px;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        gap: 14px;
        border-radius: 28px;
        background: rgba(255,255,255,.94);
        border: 1px solid rgba(15,23,42,.06);
        box-shadow: 0 18px 36px rgba(15,23,42,.05);
        text-align: center;
    }

    .ard-empty-title {
        color: #111827;
        font-size: 1.08rem;
        font-weight: 950;
    }

    .ard-empty-sub {
        color: rgba(17,24,39,.62);
        font-weight: 700;
    }

    .ard-hero {
        border-radius: 30px;
        padding: 28px;
        background: linear-gradient(135deg, #1f1147 0%, #4c1d95 42%, #6d28d9 100%);
        color: #fff;
        box-shadow: 0 24px 48px rgba(31,17,71,.16);
    }

    .ard-hero-top {
        display: flex;
        align-items: flex-start;
        justify-content: space-between;
        gap: 18px;
        flex-wrap: wrap;
    }

    .ard-kicker {
        color: rgba(255,255,255,.68);
        font-size: .78rem;
        font-weight: 900;
        text-transform: uppercase;
        letter-spacing: .16em;
    }

    .ard-title {
        margin-top: 8px;
        font-size: 2rem;
        line-height: 1.04;
        font-weight: 950;
    }

    .ard-subtitle {
        margin-top: 8px;
        color: rgba(255,255,255,.78);
        font-weight: 700;
        max-width: 760px;
    }

    .ard-hero-badges {
        display: flex;
        gap: 8px;
        flex-wrap: wrap;
    }

    .ard-hero-grid {
        margin-top: 20px;
        display: grid;
        grid-template-columns: repeat(4, minmax(0, 1fr));
        gap: 12px;
    }

    .ard-stat {
        padding: 14px;
        border-radius: 18px;
        background: rgba(255,255,255,.12);
        border: 1px solid rgba(255,255,255,.14);
        backdrop-filter: blur(8px);
    }

    .ard-stat-label {
        color: rgba(255,255,255,.64);
        font-size: .74rem;
        font-weight: 900;
        text-transform: uppercase;
        letter-spacing: .08em;
    }

    .ard-stat-value {
        margin-top: 6px;
        color: #fff;
        font-weight: 900;
        line-height: 1.35;
        word-break: break-word;
    }

    .ard-grid {
        display: grid;
        grid-template-columns: minmax(0, 1fr) 340px;
        gap: 18px;
        align-items: start;
    }

    .ard-main,
    .ard-side {
        border-radius: 26px;
        background: rgba(255,255,255,.95);
        border: 1px solid rgba(109,40,217,.10);
        box-shadow: 0 18px 38px rgba(88,28,135,.06);
    }

    .ard-main {
        padding: 24px;
    }

    .ard-side {
        padding: 22px;
        position: sticky;
        top: 92px;
    }

    .ard-section + .ard-section {
        margin-top: 24px;
        padding-top: 24px;
        border-top: 1px solid rgba(109,40,217,.08);
    }

    .ard-section-title,
    .ard-side-title {
        color: #1f1147;
        font-size: 1.04rem;
        font-weight: 900;
        line-height: 1.1;
    }

    .ard-reason-box,
    .ard-resolution-note,
    .ard-note-box,
    .ard-message-body {
        margin-top: 14px;
        padding: 16px;
        border-radius: 18px;
        background: linear-gradient(180deg, #faf7ff 0%, #ffffff 100%);
        border: 1px solid rgba(109,40,217,.10);
        color: #1f1147;
        white-space: pre-wrap;
        line-height: 1.55;
        word-break: break-word;
    }

    .ard-info-grid {
        margin-top: 14px;
        display: grid;
        grid-template-columns: repeat(2, minmax(0, 1fr));
        gap: 12px;
    }

    .ard-info-card {
        padding: 14px;
        border-radius: 18px;
        background: #f8fafc;
        border: 1px solid rgba(15,23,42,.06);
        min-width: 0;
    }

    .ard-info-label {
        color: rgba(17,24,39,.56);
        font-size: .72rem;
        font-weight: 900;
        text-transform: uppercase;
        letter-spacing: .08em;
    }

    .ard-info-value {
        margin-top: 6px;
        color: #111827;
        font-weight: 900;
        line-height: 1.35;
        word-break: break-word;
    }

    .ard-object-card {
        margin-top: 14px;
        padding: 18px;
        border-radius: 22px;
        background: linear-gradient(180deg, #ffffff 0%, #fbfaff 100%);
        border: 1px solid rgba(109,40,217,.10);
        box-shadow: 0 14px 28px rgba(88,28,135,.05);
    }

    .ard-object-head {
        display: flex;
        align-items: flex-start;
        justify-content: space-between;
        gap: 12px;
        flex-wrap: wrap;
    }

    .ard-object-title {
        color: #1f1147;
        font-size: 1.05rem;
        font-weight: 950;
        line-height: 1.1;
    }

    .ard-object-sub {
        margin-top: 6px;
        color: #6b5f8d;
        font-weight: 700;
        line-height: 1.45;
        white-space: pre-wrap;
        word-break: break-word;
    }

    .ard-attachments {
        margin-top: 14px;
        display: flex;
        flex-direction: column;
        gap: 10px;
    }

    .ard-attachment {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        width: fit-content;
        max-width: 100%;
        padding: 10px 12px;
        border-radius: 14px;
        text-decoration: none;
        color: #1f1147;
        background: #f8fafc;
        border: 1px solid rgba(15,23,42,.06);
        font-weight: 800;
        word-break: break-word;
    }

    .ard-object-actions {
        margin-top: 16px;
        display: flex;
        gap: 10px;
        flex-wrap: wrap;
    }

    @@media (max-width: 1100px) {
        .ard-grid {
            grid-template-columns: 1fr;
        }

        .ard-side {
            position: static;
        }

        .ard-hero-grid {
            grid-template-columns: 1fr 1fr;
        }
    }

    @@media (max-width: 760px) {
        .ard-title {
            font-size: 1.6rem;
        }

        .ard-hero-grid,
        .ard-info-grid {
            grid-template-columns: 1fr;
        }

        .ard-main,
        .ard-side {
            border-radius: 22px;
        }
    }
</style>

@code {
    [Parameter] public int Id { get; set; }
    [CascadingParameter] public Task<AuthenticationState> AuthenticationStateTask { get; set; } = default!;

    private bool _loading = true;
    private bool _moderating;
    private Report? _report;
    private Message? _message;
    private ApplicationUser? _messageSender;
    private Order? _order;
    private ApplicationUser? _buyer;
    private ApplicationUser? _seller;
    private ServiceOffer? _service;
    private ApplicationUser? _serviceOwner;
    private UserBan? _activeBan;

    private string _banDuration = "7d";
    private string? _banReason;
    private string _resolutionResult = "Violation confirmed";
    private string? _resolutionNote;

    protected override async Task OnParametersSetAsync()
    {
        await LoadAsync();
    }

    private async Task LoadAsync()
    {
        _loading = true;

        await using var db = await DbFactory.CreateDbContextAsync();

        _report = await db.Reports
            .Include(x => x.ReporterUser)
            .Include(x => x.TargetUser)
            .Include(x => x.ServiceOffer)
            .Include(x => x.ResolvedByUser)
            .FirstOrDefaultAsync(x => x.Id == Id);

        _message = null;
        _messageSender = null;
        _order = null;
        _buyer = null;
        _seller = null;
        _service = null;
        _serviceOwner = null;
        _activeBan = null;

        if (_report is not null)
        {
            if (_report.MessageId.HasValue)
            {
                _message = await db.Messages
                    .Include(x => x.Attachments)
                    .FirstOrDefaultAsync(x => x.Id == _report.MessageId.Value);

                if (_message is not null)
                    _messageSender = await db.Users.FirstOrDefaultAsync(x => x.Id == _message.SenderId);
            }

            if (_report.OrderId.HasValue)
            {
                _order = await db.Orders
                    .Include(x => x.ServiceOffer)
                    .FirstOrDefaultAsync(x => x.Id == _report.OrderId.Value);

                if (_order is not null)
                {
                    _buyer = await db.Users.FirstOrDefaultAsync(x => x.Id == _order.BuyerId);
                    _seller = await db.Users.FirstOrDefaultAsync(x => x.Id == _order.SellerId);
                }
            }

            if (_report.ServiceOfferId.HasValue)
            {
                _service = await db.ServiceOffers
                    .FirstOrDefaultAsync(x => x.Id == _report.ServiceOfferId.Value);

                if (_service is not null)
                    _serviceOwner = await db.Users.FirstOrDefaultAsync(x => x.Id == _service.OwnerUserId);
            }

            var now = DateTime.UtcNow;

            _activeBan = await db.UserBans
                .Include(x => x.CreatedByUser)
                .Where(x => x.UserId == _report.TargetUserId && x.StartsAtUtc <= now && (!x.EndsAtUtc.HasValue || x.EndsAtUtc > now))
                .OrderByDescending(x => x.StartsAtUtc)
                .FirstOrDefaultAsync();
        }

        _loading = false;
        StateHasChanged();
    }

