    private static string DisplayUser(ApplicationUser? user)
    {
        if (user is null)
            return "-";

        if (!string.IsNullOrWhiteSpace(user.DisplayName))
            return user.DisplayName;

        return user.UserName ?? user.Email ?? user.Id;
    }

    private static string TrimText(string? text, int max)
    {
        if (string.IsNullOrWhiteSpace(text))
            return "-";

        return text.Length <= max ? text : text.Substring(0, max) + "...";
    }

    private static Color TargetTypeColor(ReportTargetType type)
    {
        return type switch
        {
            ReportTargetType.Profile => Color.Info,
            ReportTargetType.Service => Color.Primary,
            ReportTargetType.Order => Color.Warning,
            ReportTargetType.Message => Color.Error,
            _ => Color.Default
        };
    }

    private static Color StatusColor(ReportStatus status)
    {
        return status switch
        {
            ReportStatus.Open => Color.Warning,
            ReportStatus.Resolved => Color.Success,
            ReportStatus.Rejected => Color.Secondary,
            _ => Color.Default
        };
    }
