        color: rgba(255,255,255,.68);
        font-size: .78rem;
        font-weight: 900;
        text-transform: uppercase;
        letter-spacing: .16em;
    }

    .details-title {
        margin-top: 8px;
        font-size: 2rem;
        font-weight: 950;
        line-height: 1.04;
    }

    .details-subtitle {
        margin-top: 8px;
        color: rgba(255,255,255,.78);
        font-weight: 700;
    }

    .details-grid {
        display: grid;
        grid-template-columns: minmax(0, 1fr) 320px;
        gap: 16px;
        align-items: start;
    }

    .details-main,
    .details-side {
        border-radius: 24px;
        background: rgba(255,255,255,.96);
        border: 1px solid rgba(15,23,42,.06);
        box-shadow: 0 18px 40px rgba(15,23,42,.05);
    }

    .details-main {
        padding: 22px;
    }

    .details-side {
        padding: 20px;
        position: sticky;
        top: 92px;
    }

    .details-side-title,
    .details-section-title {
        color: #111827;
        font-size: 1.02rem;
        font-weight: 950;
