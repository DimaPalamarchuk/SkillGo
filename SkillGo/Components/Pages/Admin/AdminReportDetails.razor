@page "/admin/reports/{Id:int}"
@attribute [Authorize(Roles = "Admin")]
@using System.Security.Claims
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Components.Authorization
@using Microsoft.EntityFrameworkCore
@using MudBlazor
@using SkillGo.Data
@using SkillGo.Data.Models
@using SkillGo.Data.Models.Chat
@using SkillGo.Data.Models.Orders
@using SkillGo.Data.Models.Reports
@inject IDbContextFactory<ApplicationDbContext> DbFactory
@inject NavigationManager Nav
@inject ISnackbar Snackbar

<PageTitle>Report Details</PageTitle>

<MudContainer MaxWidth="MaxWidth.False" Class="mt-6">
    @if (_loading)
    {
        <MudPaper Class="details-loading" Elevation="0">
            <MudProgressCircular Indeterminate="true" />
        </MudPaper>
    }
    else if (_report is null)
    {
        <MudPaper Class="details-empty" Elevation="0">
            <MudIcon Icon="@Icons.Material.Filled.ErrorOutline" Size="Size.Large" />
            <div class="details-empty-title">Report not found</div>
            <MudButton Variant="Variant.Filled" Color="Color.Primary" Class="mt-3" OnClick="GoBack">
                Back to reports
            </MudButton>
        </MudPaper>
    }
    else
    {
        <div class="details-hero">
            <div class="details-hero-left">
                <div class="details-kicker">Administration</div>
                <div class="details-title">Report #@_report.Id</div>
                <div class="details-subtitle">Inspect the reported violation and related object.</div>
            </div>

            <div class="details-hero-right">
                <MudStack Row="true" Spacing="1">
                    <MudChip T="string" Variant="Variant.Filled" Color="@TargetTypeColor(_report.TargetType)">
                        @_report.TargetType
                    </MudChip>

                    <MudChip T="string" Variant="Variant.Outlined" Color="@StatusColor(_report.Status)">
                        @_report.Status
                    </MudChip>
                </MudStack>
            </div>
        </div>

        <div class="details-grid mt-4">
            <MudPaper Class="details-main" Elevation="0">
                <div class="details-section">
                    <div class="details-section-title">Report information</div>

                    <div class="details-info-grid">
                        <div class="details-info-card">
                            <div class="details-info-label">Reporter</div>
                            <div class="details-info-value">@DisplayUser(_report.ReporterUser)</div>
                        </div>

                        <div class="details-info-card">
                            <div class="details-info-label">Target user</div>
                            <div class="details-info-value">@DisplayUser(_report.TargetUser)</div>
                        </div>

                        <div class="details-info-card">
                            <div class="details-info-label">Created</div>
                            <div class="details-info-value">@_report.CreatedAt.ToLocalTime().ToString("yyyy-MM-dd HH:mm")</div>
                        </div>

                        <div class="details-info-card">
                            <div class="details-info-label">Type</div>
                            <div class="details-info-value">@_report.TargetType</div>
                        </div>
                    </div>
                </div>

                <div class="details-section">
                    <div class="details-section-title">Reason</div>
                    <div class="details-reason">@_report.Reason</div>
                </div>

                @if (_report.Status != ReportStatus.Open)
                {
                    <div class="details-section">
                        <div class="details-section-title">Resolution</div>

                        <div class="details-info-grid">
                            <div class="details-info-card">
                                <div class="details-info-label">Closed by</div>
                                <div class="details-info-value">@DisplayUser(_report.ResolvedByUser)</div>
                            </div>

                            <div class="details-info-card">
                                <div class="details-info-label">Closed at</div>
                                <div class="details-info-value">@(_report.ResolvedAtUtc.HasValue ? _report.ResolvedAtUtc.Value.ToLocalTime().ToString("yyyy-MM-dd HH:mm") : "-")</div>
                            </div>

                            <div class="details-info-card">
                                <div class="details-info-label">Result</div>
                                <div class="details-info-value">@(_report.ResolutionResult ?? "-")</div>
                            </div>

                            <div class="details-info-card">
                                <div class="details-info-label">Status</div>
                                <div class="details-info-value">@_report.Status</div>
                            </div>
                        </div>

                        @if (!string.IsNullOrWhiteSpace(_report.ResolutionNote))
                        {
                            <div class="details-reason">@_report.ResolutionNote</div>
                        }
                    </div>
                }

                @if (_report.TargetType == ReportTargetType.Message)
                {
                    <div class="details-section">
                        <div class="details-section-title">Reported message</div>

                        @if (_message is null)
                        {
                            <div class="details-note">Message was not found.</div>
                        }
                        else
                        {
                            <div class="message-card">
                                <div class="message-top">
                                    <div class="message-top-left">
                                        <div class="message-user">@DisplayUser(_messageSender)</div>
                                        <div class="message-time">@_message.CreatedAtUtc.ToLocalTime().ToString("yyyy-MM-dd HH:mm")</div>
                                    </div>

                                    @if (_message.ConversationId > 0)
                                    {
                                        <MudButton Variant="Variant.Outlined"
                                                   Color="Color.Primary"
                                                   OnClick="@(() => Nav.NavigateTo($"/chat/{_message.ConversationId}"))">
                                            Open chat
                                        </MudButton>
                                    }
                                </div>

                                @if (_message.IsDeleted)
                                {
                                    <div class="details-note">Message deleted</div>
                                }
                                else
                                {
                                    @if (!string.IsNullOrWhiteSpace(_message.Body))
                                    {
                                        <div class="message-body">@_message.Body</div>
                                    }

                                    @if (_message.Attachments.Any())
                                    {
                                        <div class="attachments-list">
                                            @foreach (var att in _message.Attachments)
                                            {
                                                <a class="attachment-item" href="@att.Url" target="_blank">
                                                    <MudIcon Icon="@(att.IsImage ? Icons.Material.Filled.Image : Icons.Material.Filled.AttachFile)" />
                                                    <span>@att.FileName</span>
                                                </a>
                                            }
                                        </div>
                                    }
                                }
                            </div>
                        }
                    </div>
                }

                @if (_report.TargetType == ReportTargetType.Order)
                {
                    <div class="details-section">
                        <div class="details-section-title">Reported order</div>

                        @if (_order is null)
                        {
                            <div class="details-note">Order was not found.</div>
                        }
                        else
                        {
                            <div class="object-card">
                                <div class="object-title">Order #@_order.Id</div>
                                <div class="object-subtitle">@(_order.ServiceOffer?.Title ?? "Service")</div>

                                <div class="details-info-grid mt-4">
                                    <div class="details-info-card">
                                        <div class="details-info-label">Buyer</div>
                                        <div class="details-info-value">@DisplayUser(_buyer)</div>
                                    </div>

                                    <div class="details-info-card">
                                        <div class="details-info-label">Seller</div>
                                        <div class="details-info-value">@DisplayUser(_seller)</div>
                                    </div>

                                    <div class="details-info-card">
                                        <div class="details-info-label">Amount</div>
                                        <div class="details-info-value">@_order.Amount.ToString("0.00") zł</div>
                                    </div>

                                    <div class="details-info-card">
                                        <div class="details-info-label">Status</div>
                                        <div class="details-info-value">@_order.Status</div>
                                    </div>
                                </div>

                                <div class="object-actions">
                                    <MudButton Variant="Variant.Outlined"
                                               Color="Color.Primary"
                                               OnClick="@(() => Nav.NavigateTo($"/orders/{_order.Id}"))">
                                        Open order
                                    </MudButton>
                                </div>
                            </div>
                        }
                    </div>
                }

                @if (_report.TargetType == ReportTargetType.Service)
                {
                    <div class="details-section">
                        <div class="details-section-title">Reported service</div>

                        @if (_service is null)
                        {
                            <div class="details-note">Service was not found or removed.</div>
                        }
                        else
                        {
                            <div class="object-card">
                                <div class="object-title">@_service.Title</div>
                                <div class="object-subtitle">@TrimText(_service.Description, 280)</div>

                                <div class="details-info-grid mt-4">
                                    <div class="details-info-card">
                                        <div class="details-info-label">Owner</div>
                                        <div class="details-info-value">@DisplayUser(_serviceOwner)</div>
                                    </div>

                                    <div class="details-info-card">
                                        <div class="details-info-label">Price</div>
                                        <div class="details-info-value">@_service.Price.ToString("0.00") zł</div>
                                    </div>
                                </div>

                                <div class="object-actions">
                                    <MudButton Variant="Variant.Outlined"
                                               Color="Color.Primary"
                                               OnClick="@(() => Nav.NavigateTo($"/services/{_service.Id}"))">
                                        Open service
                                    </MudButton>
                                </div>
                            </div>
                        }
                    </div>
                }

                @if (_report.TargetType == ReportTargetType.Profile)
                {
                    <div class="details-section">
                        <div class="details-section-title">Reported profile</div>

                        <div class="object-card">
                            <div class="object-title">@DisplayUser(_report.TargetUser)</div>
                            <div class="object-subtitle">@(_report.TargetUser?.UserName is null ? "-" : "@" + _report.TargetUser.UserName)</div>

                            <div class="object-actions">
                                @if (!string.IsNullOrWhiteSpace(_report.TargetUser?.UserName))
                                {
                                    <MudButton Variant="Variant.Outlined"
                                               Color="Color.Primary"
                                               OnClick="@(() => Nav.NavigateTo($"/profile/{_report.TargetUser!.UserName}"))">
                                        Open profile
                                    </MudButton>
                                }
                            </div>
                        </div>
                    </div>
                }
            </MudPaper>

            <MudPaper Class="details-side" Elevation="0">
                <div class="details-side-title">Quick actions</div>

                <MudStack Spacing="2" Class="mt-4">
                    <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="GoBack">
                        Back to reports
                    </MudButton>

                    @if (!string.IsNullOrWhiteSpace(_report.ReporterUser?.UserName))
                    {
                        <MudButton Variant="Variant.Outlined"
                                   Color="Color.Primary"
                                   OnClick="@(() => Nav.NavigateTo($"/profile/{_report.ReporterUser!.UserName}"))">
                            Open reporter
                        </MudButton>
                    }

                    @if (!string.IsNullOrWhiteSpace(_report.TargetUser?.UserName))
                    {
                        <MudButton Variant="Variant.Outlined"
                                   Color="Color.Error"
                                   OnClick="@(() => Nav.NavigateTo($"/profile/{_report.TargetUser!.UserName}"))">
                            Open target
                        </MudButton>
                    }
                </MudStack>

                @if (_report.Status == ReportStatus.Open)
                {
                    <div class="details-side-title mt-6">Close report</div>

                    <MudStack Spacing="2" Class="mt-4">
                        <MudSelect T="string" @bind-Value="_resolutionResult">
                            <MudSelectItem T="string" Value="@("Violation confirmed")">Violation confirmed</MudSelectItem>
                            <MudSelectItem T="string" Value="@("False report")">False report</MudSelectItem>
                            <MudSelectItem T="string" Value="@("No action required")">No action required</MudSelectItem>
                            <MudSelectItem T="string" Value="@("User warned")">User warned</MudSelectItem>
                            <MudSelectItem T="string" Value="@("Content removed")">Content removed</MudSelectItem>
                            <MudSelectItem T="string" Value="@("User banned")">User banned</MudSelectItem>
                        </MudSelect>

                        <MudTextField @bind-Value="_resolutionNote"
                                      Label="Admin note"
                                      Variant="Variant.Outlined"
                                      Lines="4"
                                      Immediate="true"
                                      Counter="1000"
                                      MaxLength="1000" />

                        <MudButton Variant="Variant.Filled"
                                   Color="Color.Success"
                                   Disabled="_moderating || string.IsNullOrWhiteSpace(_resolutionResult)"
                                   OnClick="CloseAsResolvedAsync">
                            @(_moderating ? "Saving..." : "Close report")
                        </MudButton>

                        <MudButton Variant="Variant.Outlined"
                                   Color="Color.Secondary"
                                   Disabled="_moderating"
                                   OnClick="CloseAsRejectedAsync">
                            @(_moderating ? "Saving..." : "Skip as false report")
                        </MudButton>
                    </MudStack>
                }

                <div class="details-side-title mt-6">User restriction</div>

                @if (_activeBan is not null)
                {
                    <MudAlert Severity="Severity.Warning" Dense="true" Variant="Variant.Outlined" Class="mt-3">
                        Active ban until @(_activeBan.EndsAtUtc.HasValue ? _activeBan.EndsAtUtc.Value.ToLocalTime().ToString("yyyy-MM-dd HH:mm") : "Permanent")
                    </MudAlert>

                    <MudButton Variant="Variant.Filled"
                               Color="Color.Success"
                               Class="mt-4"
                               Disabled="_moderating"
                               OnClick="UnbanUserAsync">
                        @(_moderating ? "Saving..." : "Unban user")
                    </MudButton>
                }
                else
                {
                    <MudStack Spacing="2" Class="mt-4">
                        <MudSelect T="string" @bind-Value="_banDuration">
                            <MudSelectItem T="string" Value="@("1d")">1 day</MudSelectItem>
                            <MudSelectItem T="string" Value="@("7d")">7 days</MudSelectItem>
                            <MudSelectItem T="string" Value="@("30d")">30 days</MudSelectItem>
                            <MudSelectItem T="string" Value="@("perm")">Permanent</MudSelectItem>
                        </MudSelect>

                        <MudTextField @bind-Value="_banReason"
                                      Label="Ban reason"
                                      Variant="Variant.Outlined"
                                      Lines="4"
                                      Immediate="true"
                                      Counter="500"
                                      MaxLength="500" />

                        <MudButton Variant="Variant.Filled"
                                   Color="Color.Error"
                                   Disabled="_moderating || string.IsNullOrWhiteSpace(_banReason)"
                                   OnClick="BanUserAsync">
                            @(_moderating ? "Saving..." : "Ban user")
                        </MudButton>
                    </MudStack>
                }

                @if (_report.TargetType == ReportTargetType.Message && _message is not null && !_message.IsDeleted)
                {
                    <div class="details-side-title mt-6">Message moderation</div>

                    <MudButton Variant="Variant.Outlined"
                               Color="Color.Error"
                               Class="mt-4"
                               Disabled="_moderating"
                               OnClick="DeleteMessageAsync">
                        Delete message
                    </MudButton>
                }

                @if (_report.TargetType == ReportTargetType.Service && _service is not null)
                {
                    <div class="details-side-title mt-6">Service moderation</div>

                    <MudButton Variant="Variant.Outlined"
                               Color="Color.Error"
                               Class="mt-4"
                               Disabled="_moderating"
                               OnClick="DeleteServiceAsync">
                        Delete service
                    </MudButton>
                }
            </MudPaper>
        </div>
    }
</MudContainer>

