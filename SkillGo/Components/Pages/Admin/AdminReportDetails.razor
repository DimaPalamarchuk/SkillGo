    @@media (max-width: 760px) {
        .details-title {
            font-size: 1.6rem;
        }

        .details-info-grid {
            grid-template-columns: 1fr;
        }
    }
</style>

@code {
    [Parameter] public int Id { get; set; }
    [CascadingParameter] public Task<AuthenticationState> AuthenticationStateTask { get; set; } = default!;

    private bool _loading = true;
    private bool _moderating;
    private Report? _report;
    private Message? _message;
    private ApplicationUser? _messageSender;
    private Order? _order;
    private ApplicationUser? _buyer;
    private ApplicationUser? _seller;
    private ServiceOffer? _service;
    private ApplicationUser? _serviceOwner;
    private UserBan? _activeBan;

    private string _banDuration = "7d";
    private string? _banReason;
    private string _resolutionResult = "Violation confirmed";
    private string? _resolutionNote;

    protected override async Task OnParametersSetAsync()
    {
        await LoadAsync();
    }

    private async Task LoadAsync()
    {
        _loading = true;

        await using var db = await DbFactory.CreateDbContextAsync();

        _report = await db.Reports
            .Include(x => x.ReporterUser)
            .Include(x => x.TargetUser)
            .Include(x => x.ServiceOffer)
            .Include(x => x.ResolvedByUser)
            .FirstOrDefaultAsync(x => x.Id == Id);

        _message = null;
        _messageSender = null;
        _order = null;
        _buyer = null;
        _seller = null;
        _service = null;
        _serviceOwner = null;
        _activeBan = null;

        if (_report is not null)
        {
            if (_report.MessageId.HasValue)
            {
                _message = await db.Messages
                    .Include(x => x.Attachments)
                    .FirstOrDefaultAsync(x => x.Id == _report.MessageId.Value);

                if (_message is not null)
                    _messageSender = await db.Users.FirstOrDefaultAsync(x => x.Id == _message.SenderId);
            }

            if (_report.OrderId.HasValue)
            {
                _order = await db.Orders
                    .Include(x => x.ServiceOffer)
                    .FirstOrDefaultAsync(x => x.Id == _report.OrderId.Value);

                if (_order is not null)
                {
                    _buyer = await db.Users.FirstOrDefaultAsync(x => x.Id == _order.BuyerId);
                    _seller = await db.Users.FirstOrDefaultAsync(x => x.Id == _order.SellerId);
                }
            }

            if (_report.ServiceOfferId.HasValue)
            {
                _service = await db.ServiceOffers
                    .FirstOrDefaultAsync(x => x.Id == _report.ServiceOfferId.Value);

                if (_service is not null)
                    _serviceOwner = await db.Users.FirstOrDefaultAsync(x => x.Id == _service.OwnerUserId);
            }

            var now = DateTime.UtcNow;

            _activeBan = await db.UserBans
                .Include(x => x.CreatedByUser)
                .Where(x => x.UserId == _report.TargetUserId && x.StartsAtUtc <= now && (!x.EndsAtUtc.HasValue || x.EndsAtUtc > now))
                .OrderByDescending(x => x.StartsAtUtc)
                .FirstOrDefaultAsync();
        }

        _loading = false;
        StateHasChanged();
    }

    private async Task CloseAsResolvedAsync()
    {
        if (_moderating || _report is null || _report.Status != ReportStatus.Open)
            return;

        var auth = await AuthenticationStateTask;
        var adminId = auth.User.FindFirstValue(ClaimTypes.NameIdentifier);

        if (string.IsNullOrWhiteSpace(adminId))
            return;

        _moderating = true;
        StateHasChanged();

        try
        {
            await using var db = await DbFactory.CreateDbContextAsync();

            var report = await db.Reports.FirstOrDefaultAsync(x => x.Id == _report.Id);

            if (report is null)
            {
                Snackbar.Add("Report not found", Severity.Error);
                return;
            }

            if (report.Status != ReportStatus.Open)
            {
                Snackbar.Add("Report already closed", Severity.Warning);
                return;
            }

            report.Status = ReportStatus.Resolved;
            report.ResolvedByUserId = adminId;
            report.ResolvedAtUtc = DateTime.UtcNow;
            report.ResolutionResult = string.IsNullOrWhiteSpace(_resolutionResult) ? "Resolved" : _resolutionResult.Trim();
            report.ResolutionNote = string.IsNullOrWhiteSpace(_resolutionNote) ? null : _resolutionNote.Trim();

            await db.SaveChangesAsync();

            Snackbar.Add("Report closed", Severity.Success);
            await LoadAsync();
        }
        catch (Exception ex)
        {
            Snackbar.Add(ex.Message, Severity.Error);
        }
        finally
        {
            _moderating = false;
            StateHasChanged();
        }
    }

    private async Task CloseAsRejectedAsync()
    {
        if (_moderating || _report is null || _report.Status != ReportStatus.Open)
            return;

        var auth = await AuthenticationStateTask;
        var adminId = auth.User.FindFirstValue(ClaimTypes.NameIdentifier);

        if (string.IsNullOrWhiteSpace(adminId))
            return;

        _moderating = true;
        StateHasChanged();

        try
        {
            await using var db = await DbFactory.CreateDbContextAsync();

            var report = await db.Reports.FirstOrDefaultAsync(x => x.Id == _report.Id);

            if (report is null)
            {
                Snackbar.Add("Report not found", Severity.Error);
                return;
            }

            if (report.Status != ReportStatus.Open)
            {
                Snackbar.Add("Report already closed", Severity.Warning);
                return;
            }

            report.Status = ReportStatus.Rejected;
            report.ResolvedByUserId = adminId;
            report.ResolvedAtUtc = DateTime.UtcNow;
            report.ResolutionResult = "False report";
            report.ResolutionNote = string.IsNullOrWhiteSpace(_resolutionNote) ? "Closed without action" : _resolutionNote.Trim();

            await db.SaveChangesAsync();

            Snackbar.Add("Report skipped", Severity.Success);
            await LoadAsync();
        }
        catch (Exception ex)
        {
            Snackbar.Add(ex.Message, Severity.Error);
        }
        finally
        {
            _moderating = false;
            StateHasChanged();
        }
    }

    private async Task BanUserAsync()
    {
        if (_moderating || _report is null || string.IsNullOrWhiteSpace(_banReason))
            return;

        var auth = await AuthenticationStateTask;
        var adminId = auth.User.FindFirstValue(ClaimTypes.NameIdentifier);

        if (string.IsNullOrWhiteSpace(adminId))
            return;

        _moderating = true;
        StateHasChanged();

        try
        {
            await using var db = await DbFactory.CreateDbContextAsync();

            var now = DateTime.UtcNow;
            var endsAt = _banDuration switch
            {
                "1d" => now.AddDays(1),
                "7d" => now.AddDays(7),
                "30d" => now.AddDays(30),
                "perm" => (DateTime?)null,
                _ => now.AddDays(7)
            };

            var active = await db.UserBans
                .Where(x => x.UserId == _report.TargetUserId && x.StartsAtUtc <= now && (!x.EndsAtUtc.HasValue || x.EndsAtUtc > now))
                .OrderByDescending(x => x.StartsAtUtc)
                .FirstOrDefaultAsync();

            if (active is not null)
            {
                active.Reason = _banReason.Trim();
                active.EndsAtUtc = endsAt;
                active.CreatedByUserId = adminId;
            }
            else
            {
                db.UserBans.Add(new UserBan
                    {
                        UserId = _report.TargetUserId,
                        CreatedByUserId = adminId,
                        Reason = _banReason.Trim(),
                        StartsAtUtc = now,
                        EndsAtUtc = endsAt
                    });
            }

            await db.SaveChangesAsync();
            Snackbar.Add("User restriction saved", Severity.Success);
            await LoadAsync();
        }
        catch (Exception ex)
        {
            Snackbar.Add(ex.Message, Severity.Error);
        }
        finally
        {
            _moderating = false;
            StateHasChanged();
        }
    }

    private async Task UnbanUserAsync()
    {
        if (_moderating || _report is null)
            return;

        _moderating = true;
        StateHasChanged();

        try
        {
            await using var db = await DbFactory.CreateDbContextAsync();
            var now = DateTime.UtcNow;

            var activeBans = await db.UserBans
                .Where(x => x.UserId == _report.TargetUserId && x.StartsAtUtc <= now && (!x.EndsAtUtc.HasValue || x.EndsAtUtc > now))
                .ToListAsync();

            if (activeBans.Count == 0)
            {
                Snackbar.Add("Active ban not found", Severity.Error);
                return;
            }

            foreach (var ban in activeBans)
                ban.EndsAtUtc = now;

            await db.SaveChangesAsync();

            Snackbar.Add("User unbanned", Severity.Success);
            await LoadAsync();
        }
        catch (Exception ex)
        {
            Snackbar.Add(ex.Message, Severity.Error);
        }
        finally
        {
            _moderating = false;
            StateHasChanged();
        }
    }

    private async Task DeleteMessageAsync()
    {
        if (_moderating || _report is null || !_report.MessageId.HasValue)
            return;

        _moderating = true;
        StateHasChanged();

        try
        {
            await using var db = await DbFactory.CreateDbContextAsync();

            var msg = await db.Messages
                .Include(x => x.Attachments)
                .FirstOrDefaultAsync(x => x.Id == _report.MessageId.Value);

            if (msg is null)
            {
                Snackbar.Add("Message not found", Severity.Error);
                return;
            }

            if (msg.Attachments.Any())
                db.MessageAttachments.RemoveRange(msg.Attachments);

            msg.Body = null;
            msg.IsDeleted = true;
            msg.DeletedAtUtc = DateTime.UtcNow;

            await db.SaveChangesAsync();

            Snackbar.Add("Message deleted", Severity.Success);
            await LoadAsync();
        }
        catch (Exception ex)
        {
            Snackbar.Add(ex.Message, Severity.Error);
        }
        finally
        {
            _moderating = false;
            StateHasChanged();
        }
    }

    private async Task DeleteServiceAsync()
    {
        if (_moderating || _service is null)
            return;

        _moderating = true;
        StateHasChanged();

        try
        {
            await using var db = await DbFactory.CreateDbContextAsync();

            var service = await db.ServiceOffers.FirstOrDefaultAsync(x => x.Id == _service.Id);

            if (service is null)
            {
                Snackbar.Add("Service not found", Severity.Error);
                return;
            }

            var hasOrders = await db.Orders.AnyAsync(x => x.ServiceOfferId == service.Id);

            if (hasOrders)
            {
                Snackbar.Add("Service cannot be deleted because it is used in orders", Severity.Error);
                return;
            }

            db.ServiceOffers.Remove(service);
            await db.SaveChangesAsync();

            Snackbar.Add("Service deleted", Severity.Success);
            await LoadAsync();
        }
        catch (Exception ex)
        {
            Snackbar.Add(ex.Message, Severity.Error);
        }
        finally
        {
            _moderating = false;
            StateHasChanged();
        }
    }

    private void GoBack()
