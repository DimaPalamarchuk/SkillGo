@page "/admin/reports"
@attribute [Authorize(Roles = "Admin")]
@layout SkillGo.Components.Layout.AdminLayout
@using Microsoft.AspNetCore.Authorization
@using Microsoft.EntityFrameworkCore
@using MudBlazor
@using SkillGo.Data
@using SkillGo.Data.Models
@using SkillGo.Data.Models.Reports
@inject IDbContextFactory<ApplicationDbContext> DbFactory
@inject NavigationManager Nav

<PageTitle>Admin Reports</PageTitle>

<MudStack Spacing="3">
    <MudPaper Class="ar-hero" Elevation="0">
        <div class="ar-hero-top">
            <div>
                <div class="ar-kicker">Administration</div>
                <div class="ar-title">Reports center</div>
                <div class="ar-subtitle">Review profile, service, order and message violations in one moderation queue.</div>
            </div>
        </div>

        <div class="ar-stats">
            <div class="ar-stat">
                <div class="ar-stat-label">Total</div>
                <div class="ar-stat-value">@_items.Count</div>
            </div>

            <div class="ar-stat">
                <div class="ar-stat-label">Open</div>
                <div class="ar-stat-value">@_items.Count(x => x.Status == ReportStatus.Open)</div>
            </div>

            <div class="ar-stat">
                <div class="ar-stat-label">Resolved</div>
                <div class="ar-stat-value">@_items.Count(x => x.Status == ReportStatus.Resolved)</div>
            </div>

            <div class="ar-stat">
                <div class="ar-stat-label">Rejected</div>
                <div class="ar-stat-value">@_items.Count(x => x.Status == ReportStatus.Rejected)</div>
            </div>
        </div>
    </MudPaper>

    <MudPaper Class="ar-panel" Elevation="0">
        <div class="ar-toolbar">
            <MudTextField T="string"
                          Value="@_search"
                          ValueChanged="OnSearchChanged"
                          Placeholder="Search by reason, reporter, target..."
                          Variant="Variant.Outlined"
                          Adornment="Adornment.Start"
                          AdornmentIcon="@Icons.Material.Filled.Search"
                          Immediate="true"
                          Class="ar-search" />

            <MudSelect T="string"
                       Value="@_typeFilter"
                       ValueChanged="OnTypeChanged"
                       Variant="Variant.Outlined"
                       Class="ar-filter">
                <MudSelectItem T="string" Value="@("All")">All types</MudSelectItem>
                <MudSelectItem T="string" Value="@("Profile")">Profile</MudSelectItem>
                <MudSelectItem T="string" Value="@("Service")">Service</MudSelectItem>
                <MudSelectItem T="string" Value="@("Order")">Order</MudSelectItem>
                <MudSelectItem T="string" Value="@("Message")">Message</MudSelectItem>
            </MudSelect>

            <MudSelect T="string"
                       Value="@_statusFilter"
                       ValueChanged="OnStatusChanged"
                       Variant="Variant.Outlined"
                       Class="ar-filter">
                <MudSelectItem T="string" Value="@("All")">All statuses</MudSelectItem>
                <MudSelectItem T="string" Value="@("Open")">Open</MudSelectItem>
                <MudSelectItem T="string" Value="@("Resolved")">Resolved</MudSelectItem>
                <MudSelectItem T="string" Value="@("Rejected")">Rejected</MudSelectItem>
            </MudSelect>
        </div>

        @if (_loading)
        {
            <div class="ar-loading">
                <MudProgressCircular Indeterminate="true" />
            </div>
        }
        else if (_items.Count == 0)
        {
            <div class="ar-empty">
                <MudIcon Icon="@Icons.Material.Filled.ReportGmailerrorred" Size="Size.Large" />
                <div class="ar-empty-title">No reports found</div>
                <div class="ar-empty-subtitle">Try changing the filters or wait for new reports.</div>
            </div>
        }
        else
        {
            <div class="ar-grid">
                @foreach (var item in _items)
                {
                    <div class="ar-card">
                        <div class="ar-card-top">
                            <div>
                                <div class="ar-card-id">Report #@item.Id</div>
                                <div class="ar-card-sub">@TargetObjectText(item)</div>
                            </div>

                            <div class="ar-card-badges">
                                <MudChip T="string" Size="Size.Small" Variant="Variant.Filled" Color="@TargetTypeColor(item.TargetType)">
                                    @item.TargetType
                                </MudChip>

                                <MudChip T="string" Size="Size.Small" Variant="Variant.Outlined" Color="@StatusColor(item.Status)">
                                    @item.Status
                                </MudChip>
                            </div>
                        </div>

                        <div class="ar-meta-grid">
                            <div class="ar-meta-box">
                                <div class="ar-meta-label">Reporter</div>
                                <div class="ar-meta-value">@DisplayUser(item.ReporterUser)</div>
                            </div>

                            <div class="ar-meta-box">
                                <div class="ar-meta-label">Target</div>
                                <div class="ar-meta-value">@DisplayUser(item.TargetUser)</div>
                            </div>

                            <div class="ar-meta-box">
                                <div class="ar-meta-label">Created</div>
                                <div class="ar-meta-value">@item.CreatedAt.ToLocalTime().ToString("yyyy-MM-dd HH:mm")</div>
                            </div>

                            <div class="ar-meta-box">
                                <div class="ar-meta-label">Status</div>
                                <div class="ar-meta-value">@item.Status</div>
                            </div>
                        </div>

                        <div class="ar-reason-label">Reason</div>
                        <div class="ar-reason">@TrimText(item.Reason, 180)</div>

                        @if (item.Status != ReportStatus.Open)
                        {
                            <div class="ar-resolution">
                                <div class="ar-resolution-label">Resolution</div>
                                <div class="ar-resolution-value">@ResolutionResultText(item)</div>

                                @if (!string.IsNullOrWhiteSpace(item.ResolutionNote))
                                {
                                    <div class="ar-resolution-note">@TrimText(item.ResolutionNote, 160)</div>
                                }
                            </div>
                        }

                        <div class="ar-actions">
                            <MudButton Variant="Variant.Filled"
                                       Color="Color.Primary"
                                       OnClick="@(() => Nav.NavigateTo($"/admin/reports/{item.Id}"))">
                                Open report
                            </MudButton>
                        </div>
                    </div>
                }
            </div>
        }
    </MudPaper>
</MudStack>

<style>
    .ar-hero {
        border-radius: 30px;
        padding: 28px;
        background: linear-gradient(135deg, #1f1147 0%, #4c1d95 42%, #6d28d9 100%);
        color: #fff;
        box-shadow: 0 24px 48px rgba(31,17,71,.16);
    }

    .ar-hero-top {
        display: flex;
        align-items: flex-start;
        justify-content: space-between;
        gap: 18px;
        flex-wrap: wrap;
    }

    .ar-kicker {
        color: rgba(255,255,255,.68);
        font-size: .78rem;
        font-weight: 900;
        text-transform: uppercase;
        letter-spacing: .16em;
    }

    .ar-title {
        margin-top: 8px;
        font-size: 2rem;
        line-height: 1.04;
        font-weight: 950;
    }

    .ar-subtitle {
        margin-top: 8px;
        color: rgba(255,255,255,.78);
        font-weight: 700;
        max-width: 760px;
    }

    .ar-stats {
        margin-top: 20px;
        display: grid;
        grid-template-columns: repeat(4, minmax(0, 1fr));
        gap: 12px;
    }

    .ar-stat {
        padding: 14px;
        border-radius: 18px;
        background: rgba(255,255,255,.12);
        border: 1px solid rgba(255,255,255,.14);
        backdrop-filter: blur(8px);
    }

    .ar-stat-label {
        color: rgba(255,255,255,.64);
        font-size: .74rem;
        font-weight: 900;
        text-transform: uppercase;
        letter-spacing: .08em;
    }

    .ar-stat-value {
        margin-top: 6px;
        color: #fff;
        font-weight: 950;
        font-size: 1.3rem;
        line-height: 1;
    }

    .ar-panel {
        padding: 22px;
        border-radius: 26px;
        background: rgba(255,255,255,.95);
        border: 1px solid rgba(109,40,217,.10);
        box-shadow: 0 18px 38px rgba(88,28,135,.06);
    }

    .ar-toolbar {
        display: flex;
        gap: 12px;
        flex-wrap: wrap;
        margin-bottom: 18px;
    }

    .ar-search {
        flex: 1 1 360px;
    }

    .ar-filter {
        width: 220px;
    }

    .ar-loading,
    .ar-empty {
        min-height: 280px;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        gap: 12px;
        text-align: center;
    }

    .ar-empty-title {
        font-size: 1.08rem;
        font-weight: 900;
        color: #111827;
    }

    .ar-empty-subtitle {
        color: rgba(17,24,39,.62);
        font-weight: 700;
    }

    .ar-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(340px, 1fr));
        gap: 16px;
    }

    .ar-card {
        border-radius: 24px;
        border: 1px solid rgba(109,40,217,.10);
        background: linear-gradient(180deg, #ffffff 0%, #fbfaff 100%);
        box-shadow: 0 14px 34px rgba(88,28,135,.05);
        padding: 18px;
        display: flex;
        flex-direction: column;
        gap: 14px;
    }

    .ar-card-top {
        display: flex;
        align-items: flex-start;
        justify-content: space-between;
        gap: 10px;
    }

    .ar-card-id {
        color: #1f1147;
        font-size: 1.04rem;
        font-weight: 950;
        line-height: 1.1;
    }

    .ar-card-sub {
        margin-top: 4px;
        color: #6b5f8d;
        font-weight: 800;
        line-height: 1.4;
    }

    .ar-card-badges {
        display: flex;
        flex-direction: column;
        gap: 8px;
        align-items: flex-end;
    }

    .ar-meta-grid {
        display: grid;
        grid-template-columns: repeat(2, minmax(0, 1fr));
        gap: 10px;
    }

    .ar-meta-box {
        border-radius: 16px;
        border: 1px solid rgba(15,23,42,.06);
        background: #f8fafc;
        padding: 12px;
