        word-break: break-word;
    }

    .ar-resolution {
        border-radius: 16px;
        border: 1px solid rgba(109,40,217,.10);
        background: #faf7ff;
        padding: 12px;
    }

    .ar-resolution-value {
        margin-top: 6px;
        color: #1f1147;
        font-weight: 900;
        line-height: 1.35;
    }

    .ar-resolution-note {
        margin-top: 8px;
        color: #6b5f8d;
