        }

        .ar-filter {
            width: 100%;
        }

        .ar-card-badges {
            align-items: flex-start;
        }
    }
</style>

@code {
    private bool _loading = true;
    private string _search = string.Empty;
    private string _typeFilter = "All";
    private string _statusFilter = "All";
    private List<Report> _items = new();

    protected override async Task OnInitializedAsync()
    {
        await LoadAsync();
    }

    private async Task LoadAsync()
    {
        _loading = true;

        await using var db = await DbFactory.CreateDbContextAsync();

        var query = db.Reports
            .AsNoTracking()
            .Include(x => x.ReporterUser)
            .Include(x => x.TargetUser)
            .Include(x => x.ServiceOffer)
            .Include(x => x.ResolvedByUser)
            .AsQueryable();

        if (_typeFilter != "All" && Enum.TryParse<ReportTargetType>(_typeFilter, true, out var parsedType))
            query = query.Where(x => x.TargetType == parsedType);

        if (_statusFilter != "All" && Enum.TryParse<ReportStatus>(_statusFilter, true, out var parsedStatus))
            query = query.Where(x => x.Status == parsedStatus);

        var term = _search.Trim();

        if (!string.IsNullOrWhiteSpace(term))
        {
            query = query.Where(x =>
                x.Reason.Contains(term) ||
                (x.ResolutionNote != null && x.ResolutionNote.Contains(term)) ||
                (x.ResolutionResult != null && x.ResolutionResult.Contains(term)) ||
                (x.ReporterUser.DisplayName != null && x.ReporterUser.DisplayName.Contains(term)) ||
                (x.ReporterUser.UserName != null && x.ReporterUser.UserName.Contains(term)) ||
                (x.ReporterUser.Email != null && x.ReporterUser.Email.Contains(term)) ||
                (x.TargetUser.DisplayName != null && x.TargetUser.DisplayName.Contains(term)) ||
                (x.TargetUser.UserName != null && x.TargetUser.UserName.Contains(term)) ||
                (x.TargetUser.Email != null && x.TargetUser.Email.Contains(term)) ||
                (x.ResolvedByUser != null && x.ResolvedByUser.UserName != null && x.ResolvedByUser.UserName.Contains(term)));
        }

        _items = await query
            .OrderByDescending(x => x.CreatedAt)
            .ToListAsync();

        _loading = false;
        StateHasChanged();
    }

    private async Task OnSearchChanged(string value)
    {
        _search = value ?? string.Empty;
        await LoadAsync();
    }

    private async Task OnTypeChanged(string value)
    {
        _typeFilter = value ?? "All";
        await LoadAsync();
    }

    private async Task OnStatusChanged(string value)
    {
        _statusFilter = value ?? "All";
        await LoadAsync();
    }

    private static string DisplayUser(ApplicationUser? user)
    {
        if (user is null)
            return "-";

        if (!string.IsNullOrWhiteSpace(user.DisplayName))
            return user.DisplayName;

        return user.UserName ?? user.Email ?? user.Id;
    }

    private static string TargetObjectText(Report report)
    {
        return report.TargetType switch
        {
            ReportTargetType.Profile => $"Profile of {DisplayUser(report.TargetUser)}",
            ReportTargetType.Service => report.ServiceOffer is null ? "Service" : $"Service #{report.ServiceOffer.Id}",
            ReportTargetType.Order => report.OrderId.HasValue ? $"Order #{report.OrderId.Value}" : "Order",
            ReportTargetType.Message => report.MessageId.HasValue ? $"Message #{report.MessageId.Value}" : "Message",
            _ => "-"
        };
    }

    private static string TrimText(string? text, int max)
    {
        if (string.IsNullOrWhiteSpace(text))
            return "-";

        return text.Length <= max ? text : text.Substring(0, max) + "...";
    }

    private static string ResolutionResultText(Report report)
    {
        if (!string.IsNullOrWhiteSpace(report.ResolutionResult))
            return report.ResolutionResult!;

        return report.Status.ToString();
    }

    private static Color TargetTypeColor(ReportTargetType type)
    {
        return type switch
        {
            ReportTargetType.Profile => Color.Info,
            ReportTargetType.Service => Color.Primary,
            ReportTargetType.Order => Color.Warning,
            ReportTargetType.Message => Color.Error,
            _ => Color.Default
        };
    }

    private static Color StatusColor(ReportStatus status)
    {
        return status switch
        {
            ReportStatus.Open => Color.Warning,
            ReportStatus.Resolved => Color.Success,
            ReportStatus.Rejected => Color.Secondary,
            _ => Color.Default
        };
    }
}