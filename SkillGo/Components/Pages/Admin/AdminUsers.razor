@page "/admin/users"
@attribute [Authorize(Roles = "Admin")]
@layout SkillGo.Components.Layout.AdminLayout
@using System.Security.Claims
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Components.Authorization
@using Microsoft.AspNetCore.Identity
@using Microsoft.EntityFrameworkCore
@using MudBlazor
@using SkillGo.Data
@using SkillGo.Data.Models
@inject IDbContextFactory<ApplicationDbContext> DbFactory
@inject UserManager<ApplicationUser> UserManager
@inject RoleManager<IdentityRole> RoleManager
@inject ISnackbar Snackbar

<PageTitle>Admin Users</PageTitle>

<MudPaper Class="admin-users-panel" Elevation="0">
    <MudStack Spacing="2">
        <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center" Class="admin-users-head">
            <MudText Typo="Typo.h6" Class="fw-bold">Users management</MudText>

            <MudButton Variant="Variant.Outlined"
                       Color="Color.Primary"
                       StartIcon="@Icons.Material.Filled.Refresh"
                       OnClick="LoadUsers">
                Refresh
            </MudButton>
        </MudStack>

        <MudTextField T="string"
                      Variant="Variant.Outlined"
                      Placeholder="Search by username or email"
                      Adornment="Adornment.Start"
                      AdornmentIcon="@Icons.Material.Filled.Search"
                      Immediate="true"
                      Value="@_search"
                      ValueChanged="OnSearchChanged" />

        @if (_loading)
        {
            <MudProgressCircular Indeterminate="true" />
        }
        else if (_pagedUsers.Count == 0)
        {
            <MudText Color="Color.Secondary">No users found</MudText>
        }
        else
        {
            <MudTable Items="@_pagedUsers"
                      Hover="true"
                      Dense="true"
                      Bordered="false"
                      Striped="false"
                      Class="admin-users-table">
                <HeaderContent>
                    <MudTh>User</MudTh>
                    <MudTh>Email</MudTh>
                    <MudTh>Balance</MudTh>
                    <MudTh>Roles</MudTh>
                    <MudTh>Status</MudTh>
                    <MudTh Align="Align.Right">Actions</MudTh>
                </HeaderContent>

                <RowTemplate>
                    <MudTd DataLabel="User">
                        <div class="admin-user-cell">
                            <a class="admin-user-avatar-link" href="@ProfileUrl(context)">
                                <img class="admin-user-avatar" src="@Avatar(context)" />
                            </a>

                            <div class="admin-user-copy">
                                <a class="admin-user-name-link" href="@ProfileUrl(context)">
                                    <div class="admin-user-name">@context.UserName</div>
                                </a>

                                <div class="admin-user-id">@context.Id</div>
                            </div>
                        </div>
                    </MudTd>

                    <MudTd DataLabel="Email">
                        @context.Email
                    </MudTd>

                    <MudTd DataLabel="Balance">
                        @($"{context.Balance:0.##} zł")
                    </MudTd>

                    <MudTd DataLabel="Roles">
                        <div class="admin-role-list">
                            @foreach (var role in context.Roles)
                            {
                                <span class="admin-role-badge">@role</span>
                            }
                        </div>
                    </MudTd>

                    <MudTd DataLabel="Status">
                        @if (context.IsBlocked)
                        {
                            <MudTooltip Text="@BlockedTooltip(context)">
                                <span class="admin-status-badge admin-status-badge-blocked">Blocked</span>
                            </MudTooltip>
                        }
                        else
                        {
                            <span class="admin-status-badge admin-status-badge-active">Active</span>
                        }
                    </MudTd>

                    <MudTd DataLabel="Actions" Align="Align.Right">
                        <MudMenu Icon="@Icons.Material.Filled.MoreVert" Dense="true">
                            @if (context.HasAdminRole)
                            {
                                <MudMenuItem OnClick="() => RemoveAdmin(context)">Remove admin</MudMenuItem>
                            }
                            else
                            {
                                <MudMenuItem OnClick="() => MakeAdmin(context)">Make admin</MudMenuItem>
                            }

                            @if (context.HasFreelancerRole)
                            {
                                <MudMenuItem OnClick="() => RemoveFreelancer(context)">Remove freelancer</MudMenuItem>
                            }
                            else
                            {
                                <MudMenuItem OnClick="() => MakeFreelancer(context)">Make freelancer</MudMenuItem>
                            }

                            @if (context.IsBlocked)
                            {
                                <MudMenuItem OnClick="() => UnblockUser(context)">Unblock</MudMenuItem>
                            }
                            else
                            {
                                <MudMenuItem OnClick="() => OpenBlockModal(context)">Block</MudMenuItem>
                            }
                        </MudMenu>
                    </MudTd>
                </RowTemplate>
            </MudTable>

            <div class="admin-users-pagination">
                <MudPagination Count="@_totalPages"
                               Selected="@_page"
                               SelectedChanged="OnPageChanged"
                               Color="Color.Primary"
                               Variant="Variant.Outlined" />
            </div>
        }
    </MudStack>
</MudPaper>

@if (_blockModalOpen && _blockTarget is not null)
{
    <div class="sg-block-overlay" @onclick="CloseBlockModal">
        <div class="sg-block-modal" @onclick:stopPropagation="true">
            <div class="sg-block-head">
                <div>
                    <div class="sg-block-kicker">Moderation</div>
                    <div class="sg-block-title">Block @(_blockTarget.UserName)</div>
                </div>

                <MudIconButton Icon="@Icons.Material.Filled.Close"
                               Color="Color.Default"
                               OnClick="CloseBlockModal" />
            </div>

            <div class="sg-block-user">
                <img class="sg-block-user-avatar" src="@Avatar(_blockTarget)" />
                <div class="sg-block-user-copy">
                    <div class="sg-block-user-name">@_blockTarget.UserName</div>
                    <div class="sg-block-user-email">@_blockTarget.Email</div>
                </div>
            </div>

            <MudSelect T="string"
                       Label="Block duration"
                       Variant="Variant.Outlined"
                       Value="@_blockDuration"
                       ValueChanged="OnBlockDurationChanged"
                       Class="mt-4">
                <MudSelectItem T="string" Value="@("1d")">1 day</MudSelectItem>
                <MudSelectItem T="string" Value="@("7d")">7 days</MudSelectItem>
                <MudSelectItem T="string" Value="@("30d")">30 days</MudSelectItem>
                <MudSelectItem T="string" Value="@("perm")">Permanent</MudSelectItem>
            </MudSelect>

            <MudTextField @bind-Value="_blockReason"
                          Label="Reason"
                          Variant="Variant.Outlined"
                          Lines="5"
                          Immediate="true"
                          Counter="500"
                          MaxLength="500"
                          Class="mt-4" />

            <div class="sg-block-actions">
                <MudButton Variant="Variant.Text"
                           Color="Color.Default"
                           Disabled="_blockSaving"
                           OnClick="CloseBlockModal">
                    Cancel
                </MudButton>

                <MudButton Variant="Variant.Filled"
                           Color="Color.Error"
                           Disabled="_blockSaving || string.IsNullOrWhiteSpace(_blockReason)"
                           OnClick="ConfirmBlockAsync">
                    @(_blockSaving ? "Saving..." : "Block user")
                </MudButton>
            </div>
        </div>
    </div>
}

