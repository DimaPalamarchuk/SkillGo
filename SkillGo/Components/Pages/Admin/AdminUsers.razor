    private async Task UnblockUser(AdminUserRow row)
    {
        await using var db = await DbFactory.CreateDbContextAsync();
        var now = DateTime.UtcNow;

        var activeBans = await db.UserBans
            .Where(x => x.UserId == row.Id && x.StartsAtUtc <= now && (!x.EndsAtUtc.HasValue || x.EndsAtUtc > now))
            .ToListAsync();

        if (activeBans.Count == 0)
        {
            Snackbar.Add("Active ban not found", Severity.Error);
            return;
        }

        foreach (var ban in activeBans)
            ban.EndsAtUtc = now;

        await db.SaveChangesAsync();

        Snackbar.Add("User unblocked", Severity.Success);
        await LoadUsers();
    }

    private static string ProfileUrl(AdminUserRow row)
    {
        return !string.IsNullOrWhiteSpace(row.UserName) && row.UserName != "-"
            ? $"/profile/{row.UserName}"
            : "#";
    }

    private static string Avatar(AdminUserRow row)
    {
        return row.AvatarUrl ?? "/images/default-avatar.png";
    }

    private static string BlockedTooltip(AdminUserRow row)
    {
        var endText = row.ActiveBanEndsAtUtc.HasValue
            ? row.ActiveBanEndsAtUtc.Value.ToLocalTime().ToString("yyyy-MM-dd HH:mm")
            : "Permanent";

        var reason = string.IsNullOrWhiteSpace(row.ActiveBanReason) ? "No reason" : row.ActiveBanReason;
        var by = string.IsNullOrWhiteSpace(row.ActiveBanCreatedBy) ? "Unknown admin" : row.ActiveBanCreatedBy;

        return $"By: {by}\nEnds: {endText}\nReason: {reason}";
    }

    private sealed class AdminUserRow
    {
        public string Id { get; set; } = string.Empty;
        public string UserName { get; set; } = string.Empty;
        public string Email { get; set; } = string.Empty;
        public string? AvatarUrl { get; set; }
        public decimal Balance { get; set; }
        public List<string> Roles { get; set; } = new();
        public bool HasAdminRole { get; set; }
        public bool HasFreelancerRole { get; set; }
        public bool IsBlocked { get; set; }
        public string? ActiveBanReason { get; set; }
        public DateTime? ActiveBanEndsAtUtc { get; set; }
        public string? ActiveBanCreatedBy { get; set; }
    }
}