@page "/admin/users"
@attribute [Authorize(Roles = "Admin")]
@layout SkillGo.Components.Layout.AdminLayout
@using System.Security.Claims
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Components.Authorization
@using Microsoft.AspNetCore.Identity
@using Microsoft.EntityFrameworkCore
@using MudBlazor
@using SkillGo.Data
@using SkillGo.Data.Models
@inject IDbContextFactory<ApplicationDbContext> DbFactory
@inject UserManager<ApplicationUser> UserManager
@inject RoleManager<IdentityRole> RoleManager
@inject ISnackbar Snackbar

<PageTitle>Admin Users</PageTitle>

<MudStack Spacing="3">
    <MudPaper Class="au-hero" Elevation="0">
        <div class="au-hero-top">
            <div>
                <div class="au-kicker">Administration</div>
                <div class="au-title">Users management</div>
                <div class="au-subtitle">Manage roles, moderation status and access for all platform users.</div>
            </div>

            <MudButton Variant="Variant.Outlined"
                       Color="Color.Inherit"
                       StartIcon="@Icons.Material.Filled.Refresh"
                       OnClick="LoadUsers">
                Refresh
            </MudButton>
        </div>

        <div class="au-stats">
            <div class="au-stat">
                <div class="au-stat-label">Total users</div>
                <div class="au-stat-value">@_users.Count</div>
            </div>

            <div class="au-stat">
                <div class="au-stat-label">Admins</div>
                <div class="au-stat-value">@_users.Count(x => x.HasAdminRole)</div>
            </div>

            <div class="au-stat">
                <div class="au-stat-label">Freelancers</div>
                <div class="au-stat-value">@_users.Count(x => x.HasFreelancerRole)</div>
            </div>

            <div class="au-stat">
                <div class="au-stat-label">Blocked</div>
                <div class="au-stat-value">@_users.Count(x => x.IsBlocked)</div>
            </div>
        </div>
    </MudPaper>

    <MudPaper Class="au-panel" Elevation="0">
        <MudStack Spacing="2">
            <MudTextField T="string"
                          Variant="Variant.Outlined"
                          Placeholder="Search by username or email"
                          Adornment="Adornment.Start"
                          AdornmentIcon="@Icons.Material.Filled.Search"
                          Immediate="true"
                          Value="@_search"
                          ValueChanged="OnSearchChanged" />

            @if (_loading)
            {
                <div class="au-loading">
                    <MudProgressCircular Indeterminate="true" />
                </div>
            }
            else if (_pagedUsers.Count == 0)
            {
                <div class="au-empty">
                    <MudIcon Icon="@Icons.Material.Filled.PeopleAlt" Size="Size.Large" />
                    <div class="au-empty-title">No users found</div>
                    <div class="au-empty-sub">Try another search query.</div>
                </div>
            }
            else
            {
                <div class="au-list">
                    @foreach (var context in _pagedUsers)
                    {
                        <div class="au-card">
                            <div class="au-card-top">
                                <div class="au-user-cell">
                                    <a class="au-user-avatar-link" href="@ProfileUrl(context)">
                                        <img class="au-user-avatar" src="@Avatar(context)" />
                                    </a>

                                    <div class="au-user-copy">
                                        <a class="au-user-name-link" href="@ProfileUrl(context)">
                                            <div class="au-user-name">@context.UserName</div>
                                        </a>

                                        <div class="au-user-email">@context.Email</div>
                                        <div class="au-user-id">@context.Id</div>
                                    </div>
                                </div>

                                <div class="au-status-wrap">
                                    @if (context.IsBlocked)
                                    {
                                        <MudTooltip Text="@BlockedTooltip(context)">
                                            <span class="au-status-badge au-status-badge-blocked">Blocked</span>
                                        </MudTooltip>
                                    }
                                    else
                                    {
                                        <span class="au-status-badge au-status-badge-active">Active</span>
                                    }
                                </div>
                            </div>

                            <div class="au-grid">
                                <div class="au-box">
                                    <div class="au-label">Balance</div>
                                    <div class="au-value">@($"{context.Balance:0.##} zł")</div>
                                </div>

                                <div class="au-box">
                                    <div class="au-label">Roles</div>
                                    <div class="au-role-list">
                                        @foreach (var role in context.Roles)
                                        {
                                            <span class="au-role-badge">@role</span>
                                        }
                                    </div>
                                </div>
                            </div>

                            <div class="au-actions">
                                @if (context.HasAdminRole)
                                {
                                    <MudButton Variant="Variant.Outlined"
                                               Color="Color.Warning"
                                               OnClick="() => RemoveAdmin(context)">
                                        Remove admin
                                    </MudButton>
                                }
                                else
                                {
                                    <MudButton Variant="Variant.Outlined"
                                               Color="Color.Primary"
                                               OnClick="() => MakeAdmin(context)">
                                        Make admin
                                    </MudButton>
                                }

                                @if (context.HasFreelancerRole)
                                {
                                    <MudButton Variant="Variant.Outlined"
                                               Color="Color.Warning"
                                               OnClick="() => RemoveFreelancer(context)">
                                        Remove freelancer
                                    </MudButton>
                                }
                                else
                                {
                                    <MudButton Variant="Variant.Outlined"
                                               Color="Color.Primary"
                                               OnClick="() => MakeFreelancer(context)">
                                        Make freelancer
                                    </MudButton>
                                }

                                @if (context.IsBlocked)
                                {
                                    <MudButton Variant="Variant.Filled"
                                               Color="Color.Success"
                                               OnClick="() => UnblockUser(context)">
                                        Unblock
                                    </MudButton>
                                }
                                else
                                {
                                    <MudButton Variant="Variant.Filled"
                                               Color="Color.Error"
                                               OnClick="() => OpenBlockModal(context)">
                                        Block
                                    </MudButton>
                                }
                            </div>
                        </div>
                    }
                </div>

                <div class="au-pagination">
                    <MudPagination Count="@_totalPages"
                                   Selected="@_page"
                                   SelectedChanged="OnPageChanged"
                                   Color="Color.Primary"
                                   Variant="Variant.Outlined" />
                </div>
            }
        </MudStack>
    </MudPaper>
</MudStack>

@if (_blockModalOpen && _blockTarget is not null)
{
    <div class="au-block-overlay" @onclick="CloseBlockModal">
        <div class="au-block-modal" @onclick:stopPropagation="true">
            <div class="au-block-head">
                <div>
                    <div class="au-block-kicker">Moderation</div>
                    <div class="au-block-title">Block @(_blockTarget.UserName)</div>
                </div>

                <MudIconButton Icon="@Icons.Material.Filled.Close"
                               Color="Color.Default"
                               OnClick="CloseBlockModal" />
            </div>

            <div class="au-block-user">
                <img class="au-block-user-avatar" src="@Avatar(_blockTarget)" />
                <div class="au-block-user-copy">
                    <div class="au-block-user-name">@_blockTarget.UserName</div>
                    <div class="au-block-user-email">@_blockTarget.Email</div>
                </div>
            </div>

            <MudSelect T="string"
                       Label="Block duration"
                       Variant="Variant.Outlined"
                       Value="@_blockDuration"
                       ValueChanged="OnBlockDurationChanged"
                       Class="mt-4">
                <MudSelectItem T="string" Value="@("1d")">1 day</MudSelectItem>
                <MudSelectItem T="string" Value="@("7d")">7 days</MudSelectItem>
                <MudSelectItem T="string" Value="@("30d")">30 days</MudSelectItem>
                <MudSelectItem T="string" Value="@("perm")">Permanent</MudSelectItem>
            </MudSelect>

            <MudTextField @bind-Value="_blockReason"
                          Label="Reason"
                          Variant="Variant.Outlined"
                          Lines="5"
                          Immediate="true"
                          Counter="500"
                          MaxLength="500"
                          Class="mt-4" />

            <div class="au-block-actions">
                <MudButton Variant="Variant.Text"
                           Color="Color.Default"
                           Disabled="_blockSaving"
                           OnClick="CloseBlockModal">
                    Cancel
                </MudButton>

                <MudButton Variant="Variant.Filled"
                           Color="Color.Error"
                           Disabled="_blockSaving || string.IsNullOrWhiteSpace(_blockReason)"
                           OnClick="ConfirmBlockAsync">
                    @(_blockSaving ? "Saving..." : "Block user")
                </MudButton>
            </div>
        </div>
    </div>
}

