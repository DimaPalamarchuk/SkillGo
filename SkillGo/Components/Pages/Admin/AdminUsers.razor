@code {
    [CascadingParameter] public Task<AuthenticationState> AuthenticationStateTask { get; set; } = default!;

    private bool _loading = true;
    private string? _search;
    private List<AdminUserRow> _users = new();
    private List<AdminUserRow> _pagedUsers = new();

    private int _page = 1;
    private int _pageSize = 10;
    private int _totalItems;
    private int _totalPages = 1;

    private bool _blockModalOpen;
    private bool _blockSaving;
    private AdminUserRow? _blockTarget;
    private string _blockDuration = "7d";
    private string? _blockReason;

    private IEnumerable<AdminUserRow> FilteredUsers =>
        string.IsNullOrWhiteSpace(_search)
            ? _users
            : _users.Where(x =>
                (!string.IsNullOrWhiteSpace(x.UserName) && x.UserName.Contains(_search, StringComparison.OrdinalIgnoreCase)) ||
                (!string.IsNullOrWhiteSpace(x.Email) && x.Email.Contains(_search, StringComparison.OrdinalIgnoreCase)));

    protected override async Task OnInitializedAsync()
    {
        await EnsureRolesAsync();
        await LoadUsers();
    }

    private async Task EnsureRolesAsync()
    {
        if (!await RoleManager.RoleExistsAsync("Admin"))
            await RoleManager.CreateAsync(new IdentityRole("Admin"));

        if (!await RoleManager.RoleExistsAsync("Freelancer"))
            await RoleManager.CreateAsync(new IdentityRole("Freelancer"));
    }

    private async Task LoadUsers()
    {
        _loading = true;
        StateHasChanged();

        await using var db = await DbFactory.CreateDbContextAsync();
        var now = DateTime.UtcNow;

        var users = await db.Users
            .AsNoTracking()
            .OrderBy(x => x.UserName)
            .ToListAsync();

        var activeBans = await db.UserBans
            .AsNoTracking()
            .Include(x => x.CreatedByUser)
            .Where(x => x.StartsAtUtc <= now && (!x.EndsAtUtc.HasValue || x.EndsAtUtc > now))
            .ToListAsync();

        var activeBanMap = activeBans
            .GroupBy(x => x.UserId)
            .ToDictionary(x => x.Key, x => x.OrderByDescending(v => v.StartsAtUtc).First());

        var list = new List<AdminUserRow>();

        foreach (var user in users)
        {
            var roles = await UserManager.GetRolesAsync(user);
            activeBanMap.TryGetValue(user.Id, out var ban);

            list.Add(new AdminUserRow
                {
                    Id = user.Id,
                    UserName = user.UserName ?? "-",
                    Email = user.Email ?? "-",
                    AvatarUrl = user.AvatarUrl,
                    Balance = user.Balance,
                    Roles = roles.ToList(),
                    HasAdminRole = roles.Contains("Admin"),
                    HasFreelancerRole = roles.Contains("Freelancer"),
                    IsBlocked = ban is not null,
                    ActiveBanReason = ban?.Reason,
                    ActiveBanEndsAtUtc = ban?.EndsAtUtc,
                    ActiveBanCreatedBy = ban?.CreatedByUser is null
                        ? null
                        : (!string.IsNullOrWhiteSpace(ban.CreatedByUser.DisplayName)
                            ? ban.CreatedByUser.DisplayName
                            : ban.CreatedByUser.UserName ?? ban.CreatedByUser.Email ?? ban.CreatedByUser.Id)
                });
        }

        _users = list;
        _page = 1;
        ApplyPaging();

        _loading = false;
        StateHasChanged();
    }

    private Task OnSearchChanged(string value)
    {
        _search = value;
        _page = 1;
        ApplyPaging();
        return Task.CompletedTask;
    }

    private Task OnPageChanged(int page)
    {
        _page = page;
        ApplyPaging();
        return Task.CompletedTask;
    }

    private void ApplyPaging()
    {
        var filtered = FilteredUsers.ToList();

        _totalItems = filtered.Count;
        _totalPages = Math.Max(1, (int)Math.Ceiling(_totalItems / (double)_pageSize));

        if (_page > _totalPages)
            _page = _totalPages;

        _pagedUsers = filtered
            .Skip((_page - 1) * _pageSize)
            .Take(_pageSize)
            .ToList();

        StateHasChanged();
    }

    private void OpenBlockModal(AdminUserRow row)
    {
        _blockTarget = row;
        _blockDuration = "7d";
        _blockReason = null;
        _blockSaving = false;
        _blockModalOpen = true;
        StateHasChanged();
    }

    private void CloseBlockModal()
    {
        _blockModalOpen = false;
        _blockSaving = false;
        _blockTarget = null;
        _blockDuration = "7d";
        _blockReason = null;
        StateHasChanged();
    }

    private Task OnBlockDurationChanged(string value)
    {
        _blockDuration = value ?? "7d";
        return Task.CompletedTask;
    }

    private async Task ConfirmBlockAsync()
    {
        if (_blockSaving || _blockTarget is null || string.IsNullOrWhiteSpace(_blockReason))
            return;

        var auth = await AuthenticationStateTask;
        var adminId = auth.User.FindFirstValue(ClaimTypes.NameIdentifier);

        if (string.IsNullOrWhiteSpace(adminId))
            return;

        _blockSaving = true;
        StateHasChanged();

        try
        {
            await using var db = await DbFactory.CreateDbContextAsync();
            var now = DateTime.UtcNow;

            var endsAt = _blockDuration switch
            {
                "1d" => now.AddDays(1),
                "7d" => now.AddDays(7),
                "30d" => now.AddDays(30),
                "perm" => (DateTime?)null,
                _ => now.AddDays(7)
            };

            var active = await db.UserBans
                .Where(x => x.UserId == _blockTarget.Id && x.StartsAtUtc <= now && (!x.EndsAtUtc.HasValue || x.EndsAtUtc > now))
                .OrderByDescending(x => x.StartsAtUtc)
                .FirstOrDefaultAsync();

            if (active is not null)
            {
                active.Reason = _blockReason.Trim();
                active.EndsAtUtc = endsAt;
                active.CreatedByUserId = adminId;
            }
            else
            {
                db.UserBans.Add(new UserBan
                    {
                        UserId = _blockTarget.Id,
                        CreatedByUserId = adminId,
                        Reason = _blockReason.Trim(),
                        StartsAtUtc = now,
                        EndsAtUtc = endsAt
                    });
            }

            await db.SaveChangesAsync();

            Snackbar.Add("User blocked", Severity.Warning);
            CloseBlockModal();
            await LoadUsers();
        }
        catch (Exception ex)
        {
            Snackbar.Add(ex.Message, Severity.Error);
            _blockSaving = false;
            StateHasChanged();
        }
    }

    private async Task MakeAdmin(AdminUserRow row)
    {
        var user = await UserManager.FindByIdAsync(row.Id);
        if (user == null)
            return;

        var result = await UserManager.AddToRoleAsync(user, "Admin");
        if (result.Succeeded)
        {
            Snackbar.Add("Admin role added", Severity.Success);
            await LoadUsers();
        }
        else
        {
            Snackbar.Add(string.Join(" | ", result.Errors.Select(x => x.Description)), Severity.Error);
        }
    }

    private async Task RemoveAdmin(AdminUserRow row)
    {
        var user = await UserManager.FindByIdAsync(row.Id);
        if (user == null)
            return;

        var result = await UserManager.RemoveFromRoleAsync(user, "Admin");
        if (result.Succeeded)
        {
            Snackbar.Add("Admin role removed", Severity.Success);
            await LoadUsers();
        }
        else
        {
            Snackbar.Add(string.Join(" | ", result.Errors.Select(x => x.Description)), Severity.Error);
        }
    }

    private async Task MakeFreelancer(AdminUserRow row)
    {
        var user = await UserManager.FindByIdAsync(row.Id);
        if (user == null)
            return;

        var result = await UserManager.AddToRoleAsync(user, "Freelancer");
        if (result.Succeeded)
        {
            Snackbar.Add("Freelancer role added", Severity.Success);
            await LoadUsers();
        }
        else
        {
            Snackbar.Add(string.Join(" | ", result.Errors.Select(x => x.Description)), Severity.Error);
        }
    }

    private async Task RemoveFreelancer(AdminUserRow row)
    {
        var user = await UserManager.FindByIdAsync(row.Id);
        if (user == null)
            return;

        var result = await UserManager.RemoveFromRoleAsync(user, "Freelancer");
        if (result.Succeeded)
        {
            Snackbar.Add("Freelancer role removed", Severity.Success);
            await LoadUsers();
        }
        else
        {
            Snackbar.Add(string.Join(" | ", result.Errors.Select(x => x.Description)), Severity.Error);
        }
    }

    private async Task UnblockUser(AdminUserRow row)
    {
        await using var db = await DbFactory.CreateDbContextAsync();
        var now = DateTime.UtcNow;

        var activeBans = await db.UserBans
            .Where(x => x.UserId == row.Id && x.StartsAtUtc <= now && (!x.EndsAtUtc.HasValue || x.EndsAtUtc > now))
            .ToListAsync();

        if (activeBans.Count == 0)
        {
            Snackbar.Add("Active ban not found", Severity.Error);
            return;
        }

        foreach (var ban in activeBans)
            ban.EndsAtUtc = now;

        await db.SaveChangesAsync();

        Snackbar.Add("User unblocked", Severity.Success);
        await LoadUsers();
    }

    private static string ProfileUrl(AdminUserRow row)
    {
        return !string.IsNullOrWhiteSpace(row.UserName) && row.UserName != "-"
            ? $"/profile/{row.UserName}"
            : "#";
    }

    private static string Avatar(AdminUserRow row)
    {
        return row.AvatarUrl ?? "/images/default-avatar.png";
    }

    private static string BlockedTooltip(AdminUserRow row)
    {
        var endText = row.ActiveBanEndsAtUtc.HasValue
            ? row.ActiveBanEndsAtUtc.Value.ToLocalTime().ToString("yyyy-MM-dd HH:mm")
            : "Permanent";

        var reason = string.IsNullOrWhiteSpace(row.ActiveBanReason) ? "No reason" : row.ActiveBanReason;
        var by = string.IsNullOrWhiteSpace(row.ActiveBanCreatedBy) ? "Unknown admin" : row.ActiveBanCreatedBy;

        return $"By: {by}\nEnds: {endText}\nReason: {reason}";
    }

    private sealed class AdminUserRow
    {
        public string Id { get; set; } = string.Empty;
        public string UserName { get; set; } = string.Empty;
        public string Email { get; set; } = string.Empty;
        public string? AvatarUrl { get; set; }
        public decimal Balance { get; set; }
        public List<string> Roles { get; set; } = new();
        public bool HasAdminRole { get; set; }
        public bool HasFreelancerRole { get; set; }
        public bool IsBlocked { get; set; }
        public string? ActiveBanReason { get; set; }
        public DateTime? ActiveBanEndsAtUtc { get; set; }
        public string? ActiveBanCreatedBy { get; set; }
    }
}