@page "/banned"
@using System.Security.Claims
@using Microsoft.AspNetCore.Components.Authorization
@using Microsoft.EntityFrameworkCore
@using MudBlazor
@using SkillGo.Data
@using SkillGo.Data.Models
@inject IDbContextFactory<ApplicationDbContext> DbFactory
@inject NavigationManager Nav

<PageTitle>Banned</PageTitle>

<MudContainer MaxWidth="MaxWidth.Medium" Class="py-8">
    @if (_loading)
    {
        <MudPaper Class="ban-state-card" Elevation="0">
            <MudStack Spacing="2" AlignItems="AlignItems.Center">
                <MudProgressCircular Indeterminate="true" Color="Color.Error" Size="Size.Large" />
                <MudText Typo="Typo.h6" Class="ban-state-title">Checking restriction...</MudText>
            </MudStack>
        </MudPaper>
    }
    else if (_ban is null)
    {
        <MudPaper Class="ban-state-card" Elevation="0">
            <MudStack Spacing="3" AlignItems="AlignItems.Center">
                <MudAvatar Size="Size.Large" Class="ban-ok-avatar">
                    <MudIcon Icon="@Icons.Material.Filled.Verified" />
                </MudAvatar>

                <div class="text-center">
                    <MudText Typo="Typo.h4" Class="ban-state-title">Access restored</MudText>
                    <MudText Class="ban-state-sub">No active restriction was found for your account.</MudText>
                </div>

                <MudButton Variant="Variant.Filled"
                           Color="Color.Primary"
                           Class="ban-btn"
                           OnClick="@(() => Nav.NavigateTo("/"))">
                    Go home
                </MudButton>
            </MudStack>
        </MudPaper>
    }
    else
    {
        <MudPaper Class="ban-shell" Elevation="0">
            <div class="ban-hero">
                <div class="ban-kicker">Account restriction</div>
                <div class="ban-title">Your account is restricted</div>
                <div class="ban-subtitle">You currently cannot use the platform until the restriction ends or is removed by an administrator.</div>
            </div>

            <div class="ban-content">
                <MudPaper Class="ban-reason-card" Elevation="0">
                    <div class="ban-section-label">Reason</div>
                    <div class="ban-reason-text">@_ban.Reason</div>
                </MudPaper>

                <div class="ban-grid">
                    <MudPaper Class="ban-info-card" Elevation="0">
                        <div class="ban-section-label">Started</div>
                        <div class="ban-info-value">@_ban.StartsAtUtc.ToLocalTime().ToString("yyyy-MM-dd HH:mm")</div>
                    </MudPaper>

                    <MudPaper Class="ban-info-card" Elevation="0">
                        <div class="ban-section-label">Ends</div>
                        <div class="ban-info-value">@(_ban.EndsAtUtc.HasValue ? _ban.EndsAtUtc.Value.ToLocalTime().ToString("yyyy-MM-dd HH:mm") : "Permanent")</div>
                    </MudPaper>
                </div>

                <MudAlert Severity="Severity.Warning" Variant="Variant.Outlined" Dense="true" Class="mt-4">
                    If you believe this restriction was applied by mistake, contact platform administration.
                </MudAlert>
            </div>
        </MudPaper>
    }
</MudContainer>

<style>
    .ban-shell,
    .ban-state-card {
        border-radius: 30px;
        background: rgba(255,255,255,.96);
        border: 1px solid rgba(109,40,217,.10);
        box-shadow: 0 18px 38px rgba(88,28,135,.06);
        overflow: hidden;
    }

    .ban-state-card {
        min-height: 340px;
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 28px;
        text-align: center;
    }

    .ban-ok-avatar {
        background: linear-gradient(135deg, rgba(16,185,129,.14), rgba(5,150,105,.10));
        color: #047857;
    }

    .ban-state-title {
        color: #1f1147;
        font-weight: 950;
    }

    .ban-state-sub {
        color: #6b5f8d;
        margin-top: 8px;
    }

    .ban-btn {
        border-radius: 14px;
        font-weight: 900;
        letter-spacing: .2px;
        padding: 10px 16px;
    }

    .ban-hero {
        padding: 28px;
        background: linear-gradient(135deg, #7f1d1d 0%, #b91c1c 45%, #dc2626 100%);
        color: #fff;
    }

    .ban-kicker {
        color: rgba(255,255,255,.72);
        font-size: .78rem;
        font-weight: 900;
        letter-spacing: .16em;
        text-transform: uppercase;
    }

    .ban-title {
        margin-top: 8px;
        font-size: 2rem;
        line-height: 1.04;
        font-weight: 950;
    }

    .ban-subtitle {
        margin-top: 10px;
        color: rgba(255,255,255,.82);
        font-weight: 700;
        line-height: 1.45;
    }

    .ban-content {
        padding: 24px;
    }

    .ban-reason-card,
    .ban-info-card {
        border-radius: 22px;
        background: linear-gradient(180deg, #ffffff 0%, #fbfaff 100%);
        border: 1px solid rgba(109,40,217,.10);
        box-shadow: 0 12px 28px rgba(88,28,135,.05);
    }

    .ban-reason-card {
        padding: 18px;
    }

    .ban-grid {
        margin-top: 16px;
        display: grid;
        grid-template-columns: repeat(2, minmax(0, 1fr));
        gap: 14px;
    }

    .ban-info-card {
        padding: 18px;
    }

    .ban-section-label {
        color: rgba(17,24,39,.56);
        font-size: .72rem;
        font-weight: 900;
        text-transform: uppercase;
        letter-spacing: .08em;
    }

    .ban-reason-text,
    .ban-info-value {
        margin-top: 8px;
        color: #111827;
        font-weight: 900;
        line-height: 1.45;
        word-break: break-word;
        white-space: pre-wrap;
    }

    @@media (max-width: 760px) {
        .ban-title {
            font-size: 1.6rem;
        }

        .ban-grid {
            grid-template-columns: 1fr;
        }

        .ban-shell,
        .ban-state-card {
            border-radius: 24px;
        }
    }
</style>

@code {
    [CascadingParameter] public Task<AuthenticationState> AuthenticationStateTask { get; set; } = default!;

    private bool _loading = true;
    private UserBan? _ban;

    protected override async Task OnInitializedAsync()
    {
        var auth = await AuthenticationStateTask;
        var userId = auth.User.FindFirstValue(ClaimTypes.NameIdentifier);

        if (string.IsNullOrWhiteSpace(userId))
        {
            _loading = false;
            return;
        }

        await using var db = await DbFactory.CreateDbContextAsync();
        var now = DateTime.UtcNow;

        _ban = await db.UserBans
            .AsNoTracking()
            .Where(x => x.UserId == userId && x.StartsAtUtc <= now && (!x.EndsAtUtc.HasValue || x.EndsAtUtc > now))
            .OrderByDescending(x => x.StartsAtUtc)
            .FirstOrDefaultAsync();

        _loading = false;
    }
}