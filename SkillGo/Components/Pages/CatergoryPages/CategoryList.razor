@page "/category"
@using MudBlazor
@using SkillGo.Data.Models
@using SkillGo.Repository.IRepository
@inject ICategoryRepository CategoryRepository
@inject NavigationManager Nav

<PageTitle>Categories</PageTitle>

@if (IsProcessing)
{
    <MudPaper Class="cat-loading" Elevation="0">
        <MudProgressCircular Indeterminate="true" Size="Size.Large" Color="Color.Primary" />
        <MudText Typo="Typo.h6">Loading categories...</MudText>
    </MudPaper>
}
else
{
    <MudStack Spacing="3">
        <MudPaper Class="cat-hero" Elevation="0">
            <div class="cat-hero-content">
                <div>
                    <MudText Class="cat-kicker">Administration</MudText>
                    <MudText Class="cat-title">Category management</MudText>
                    <MudText Class="cat-subtitle">Create, edit and organize marketplace categories.</MudText>
                </div>

                <MudButton Href="/category/create"
                           Variant="Variant.Filled"
                           Color="Color.Primary"
                           StartIcon="@Icons.Material.Filled.Add"
                           Class="cat-btn">
                    Add category
                </MudButton>
            </div>
        </MudPaper>

        <MudPaper Class="cat-panel" Elevation="0">
            @if (Categories.Any())
            {
                <div class="cat-list">
                    @foreach (var context in Categories)
                    {
                        <div class="cat-card">
                            <div class="cat-card-left">
                                <div class="cat-icon-wrap">
                                    <MudIcon Icon="@Icons.Material.Filled.Category" />
                                </div>

                                <div class="cat-name-copy">
                                    <div class="cat-name">@context.Name</div>
                                    <div class="cat-meta">Category ID: @context.Id</div>
                                </div>
                            </div>

                            <div class="cat-actions">
                                <MudButton Href="@($"/category/update/{context.Id}")"
                                           Variant="Variant.Outlined"
                                           Color="Color.Primary"
                                           StartIcon="@Icons.Material.Filled.Edit">
                                    Edit
                                </MudButton>

                                <MudButton Variant="Variant.Filled"
                                           Color="Color.Error"
                                           StartIcon="@Icons.Material.Filled.Delete"
                                           OnClick="@(() => DeleteCategory(context.Id))">
                                    Delete
                                </MudButton>
                            </div>
                        </div>
                    }
                </div>
            }
            else
            {
                <div class="cat-empty">
                    <MudAvatar Size="Size.Large" Class="cat-empty-avatar">
                        <MudIcon Icon="@Icons.Material.Filled.Inventory2" />
                    </MudAvatar>

                    <MudText Typo="Typo.h6" Class="cat-empty-title">No categories yet</MudText>
                    <MudText Class="cat-empty-sub">Create your first category to start organizing services.</MudText>
                </div>
            }
        </MudPaper>
    </MudStack>
}

<style>
    .cat-loading {
        min-height: 60vh;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        gap: 16px;
        border-radius: 28px;
        background: rgba(255,255,255,.92);
        border: 1px solid rgba(15,23,42,.06);
    }

    .cat-hero {
        border-radius: 30px;
        padding: 28px;
        background: linear-gradient(135deg, #1f1147 0%, #4c1d95 42%, #6d28d9 100%);
        color: #fff;
        box-shadow: 0 24px 48px rgba(31,17,71,.16);
    }

    .cat-hero-content {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 18px;
        flex-wrap: wrap;
    }

    .cat-kicker {
        color: rgba(255,255,255,.66);
        font-size: .78rem;
        font-weight: 900;
        text-transform: uppercase;
        letter-spacing: .16em;
    }

    .cat-title {
        margin-top: 8px;
        font-size: 2rem;
        line-height: 1.05;
        font-weight: 950;
    }

    .cat-subtitle {
        margin-top: 8px;
        color: rgba(255,255,255,.76);
        font-weight: 700;
    }

    .cat-btn {
        border-radius: 14px;
        font-weight: 900;
        letter-spacing: .2px;
    }

    .cat-panel {
        padding: 20px;
        border-radius: 26px;
        background: rgba(255,255,255,.94);
        border: 1px solid rgba(109,40,217,.10);
        box-shadow: 0 18px 36px rgba(88,28,135,.05);
    }

    .cat-list {
        display: flex;
        flex-direction: column;
        gap: 14px;
    }

    .cat-card {
        border-radius: 22px;
        border: 1px solid rgba(109,40,217,.10);
        background: linear-gradient(180deg, #ffffff 0%, #fbfaff 100%);
        box-shadow: 0 14px 34px rgba(88,28,135,.05);
        padding: 18px;
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 16px;
        flex-wrap: wrap;
    }

    .cat-card-left {
        display: flex;
        align-items: center;
        gap: 12px;
        min-width: 0;
    }

    .cat-icon-wrap {
        width: 48px;
        height: 48px;
        border-radius: 16px;
        display: flex;
        align-items: center;
        justify-content: center;
        background: linear-gradient(135deg, #ede9fe 0%, #ddd6fe 100%);
        color: #5b21b6;
        flex: 0 0 auto;
    }

    .cat-name-copy {
        min-width: 0;
    }

    .cat-name {
        color: #1f1147;
        font-weight: 950;
        line-height: 1.05;
    }

    .cat-meta {
        margin-top: 4px;
        color: rgba(17,24,39,.48);
        font-size: .78rem;
        font-weight: 700;
    }

    .cat-actions {
        display: flex;
        gap: 10px;
        flex-wrap: wrap;
    }

    .cat-empty {
        min-height: 280px;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        gap: 10px;
        text-align: center;
    }

    .cat-empty-avatar {
        background: linear-gradient(135deg, rgba(109,40,217,.12), rgba(139,92,246,.08));
        color: #5b21b6;
    }

    .cat-empty-title {
        color: #111827;
        font-weight: 950;
    }

    .cat-empty-sub {
        color: rgba(17,24,39,.62);
    }

    @@media (max-width: 760px) {
        .cat-title {
            font-size: 1.6rem;
        }

        .cat-card,
        .cat-panel,
        .cat-hero {
            border-radius: 22px;
        }
    }
</style>

@code {
    private bool IsProcessing { get; set; } = true;
    private List<Category> Categories { get; set; } = new();

    protected override async Task OnInitializedAsync()
    {
        await LoadCategories();
        IsProcessing = false;
    }

    private async Task LoadCategories()
    {
        Categories = (await CategoryRepository.GetAllAsync()).ToList();
    }

    private async Task DeleteCategory(int id)
    {
        await CategoryRepository.DeleteAsync(id);
        await LoadCategories();
        StateHasChanged();
    }
}