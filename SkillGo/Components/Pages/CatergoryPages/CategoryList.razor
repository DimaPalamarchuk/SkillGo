@page "/category"
@using MudBlazor
@using SkillGo.Data.Models
@using SkillGo.Repository.IRepository
@inject ICategoryRepository _categoryRepository

<PageTitle>Categories</PageTitle>

@if (IsProcessing)
{
    <MudPaper Class="cat-loading" Elevation="0">
        <MudProgressCircular Indeterminate="true" Size="Size.Large" Color="Color.Primary" />
        <MudText Typo="Typo.h6">Loading categories...</MudText>
    </MudPaper>
}
else
{
    <MudStack Spacing="3">
        <MudPaper Class="cat-hero" Elevation="0">
            <div class="cat-hero-content">
                <div>
                    <MudText Class="cat-kicker">Administration</MudText>
                    <MudText Class="cat-title">Category management</MudText>
                    <MudText Class="cat-subtitle">Create, edit and manage platform categories.</MudText>
                </div>

                <MudButton Href="/category/create"
                           Variant="Variant.Filled"
                           Color="Color.Primary"
                           StartIcon="@Icons.Material.Filled.Add">
                    Add new category
                </MudButton>
            </div>
        </MudPaper>

        <MudPaper Class="cat-panel" Elevation="0">
            @if (Categories.Any())
            {
                <MudTable Items="Categories" Hover="true" Dense="true" Class="cat-table">
                    <HeaderContent>
                        <MudTh>Name</MudTh>
                        <MudTh Align="Align.Right">Actions</MudTh>
                    </HeaderContent>

                    <RowTemplate>
                        <MudTd DataLabel="Name">
                            <div class="cat-name-cell">
                                <div class="cat-icon-wrap">
                                    <MudIcon Icon="@Icons.Material.Filled.Category" />
                                </div>

                                <div class="cat-name-copy">
                                    <div class="cat-name">@context.Name</div>
                                    <div class="cat-meta">Category ID: @context.Id</div>
                                </div>
                            </div>
                        </MudTd>

                        <MudTd DataLabel="Actions" Align="Align.Right">
                            <MudStack Row="true" Spacing="1" Justify="Justify.FlexEnd">
                                <MudButton Href="@($"/category/update/{context.Id}")"
                                           Variant="Variant.Outlined"
                                           Color="Color.Primary"
                                           StartIcon="@Icons.Material.Filled.Edit">
                                    Edit
                                </MudButton>

                                <MudButton Variant="Variant.Filled"
                                           Color="Color.Error"
                                           StartIcon="@Icons.Material.Filled.Delete"
                                           OnClick="() => DeleteCategory(context.Id)">
                                    Delete
                                </MudButton>
                            </MudStack>
                        </MudTd>
                    </RowTemplate>
                </MudTable>
            }
            else
            {
                <div class="cat-empty">
                    <MudIcon Icon="@Icons.Material.Filled.Inventory2" Size="Size.Large" />
                    <MudText Typo="Typo.h6">No categories yet</MudText>
                    <MudText Color="Color.Secondary">Create your first category to start organizing services.</MudText>
                </div>
            }
        </MudPaper>
    </MudStack>
}

<style>
    .cat-loading {
        min-height: 60vh;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        gap: 16px;
        border-radius: 28px;
        background: rgba(255,255,255,.92);
        border: 1px solid rgba(15,23,42,.06);
    }

    .cat-hero {
        border-radius: 28px;
        padding: 28px;
        background: linear-gradient(135deg, #111827 0%, #1f2937 40%, #312e81 100%);
        color: #fff;
        box-shadow: 0 24px 48px rgba(15,23,42,.16);
    }

    .cat-hero-content {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 18px;
        flex-wrap: wrap;
    }

    .cat-kicker {
        color: rgba(255,255,255,.66);
        font-size: .78rem;
        font-weight: 900;
        text-transform: uppercase;
        letter-spacing: .16em;
    }

    .cat-title {
        margin-top: 8px;
        font-size: 2rem;
        line-height: 1.05;
        font-weight: 950;
    }

    .cat-subtitle {
        margin-top: 8px;
        color: rgba(255,255,255,.76);
        font-weight: 700;
    }

    .cat-panel {
        padding: 20px;
        border-radius: 24px;
        background: rgba(255,255,255,.94);
        border: 1px solid rgba(15,23,42,.06);
        box-shadow: 0 18px 36px rgba(15,23,42,.05);
    }

    .cat-name-cell {
        display: flex;
        align-items: center;
        gap: 12px;
    }

    .cat-icon-wrap {
        width: 42px;
        height: 42px;
        border-radius: 14px;
        display: flex;
        align-items: center;
        justify-content: center;
        background: linear-gradient(135deg, #e0e7ff 0%, #c7d2fe 100%);
        color: #4338ca;
        flex: 0 0 auto;
    }

    .cat-name-copy {
        min-width: 0;
    }

    .cat-name {
        color: #111827;
        font-weight: 900;
        line-height: 1.05;
    }

    .cat-meta {
        margin-top: 4px;
        color: rgba(17,24,39,.48);
        font-size: .78rem;
        font-weight: 700;
    }

    .cat-empty {
        min-height: 280px;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        gap: 10px;
        color: #6b7280;
        text-align: center;
    }

    @@media (max-width: 760px) {
        .cat-title {
            font-size: 1.6rem;
        }
    }
</style>

@code {
    private bool IsProcessing { get; set; } = true;
    private List<Category> Categories { get; set; } = new();

    protected override async Task OnInitializedAsync()
    {
        await LoadCategories();
        IsProcessing = false;
    }

    private async Task LoadCategories()
    {
        Categories = (await _categoryRepository.GetAllAsync()).ToList();
    }

    private async Task DeleteCategory(int id)
    {
        await _categoryRepository.DeleteAsync(id);
        await LoadCategories();
    }
}