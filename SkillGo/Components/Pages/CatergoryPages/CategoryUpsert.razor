@page "/category/create"
@page "/category/update/{id:int}"
@using MudBlazor
@using SkillGo.Data
@using SkillGo.Repository.IRepository
@inject ICategoryRepository CategoryRepository
@inject NavigationManager Nav
@inject IJSRuntime JS

<PageTitle>@(Id > 0 ? "Update Category" : "Create Category")</PageTitle>

@if (IsProcessing)
{
    <MudPaper Class="cat-form-loading" Elevation="0">
        <MudProgressCircular Indeterminate="true" Size="Size.Large" Color="Color.Primary" />
        <MudText Typo="Typo.h6">Loading category form...</MudText>
    </MudPaper>
}
else
{
    <MudStack Spacing="3">
        <MudPaper Class="cat-form-hero" Elevation="0">
            <div class="cat-form-hero-content">
                <div>
                    <MudText Class="cat-form-kicker">Administration</MudText>
                    <MudText Class="cat-form-title">@((Id > 0) ? "Update category" : "Create category")</MudText>
                    <MudText Class="cat-form-subtitle">Manage marketplace taxonomy in a clean and consistent way.</MudText>
                </div>
            </div>
        </MudPaper>

        <MudPaper Class="cat-form-panel" Elevation="0">
            <EditForm Model="Category" FormName="CategoryUpsertForm" OnValidSubmit="UpsertCategory">
                <DataAnnotationsValidator />

                <MudStack Spacing="3">
                    <MudTextField @bind-Value="Category.Name"
                                  Label="Category name"
                                  Variant="Variant.Outlined"
                                  Immediate="true" />

                    <ValidationMessage For="@(() => Category.Name)" />

                    <MudStack Row="true" Spacing="2" Class="cat-form-actions">
                        <MudButton ButtonType="ButtonType.Submit"
                                   Variant="Variant.Filled"
                                   Color="Color.Primary"
                                   Disabled="@IsSaving"
                                   StartIcon="@Icons.Material.Filled.Save">
                            @((Id > 0) ? "Update" : "Create")
                        </MudButton>

                        <MudButton Variant="Variant.Outlined"
                                   Color="Color.Secondary"
                                   Disabled="@IsSaving"
                                   StartIcon="@Icons.Material.Filled.ArrowBack"
                                   OnClick="BackToList">
                            Back to list
                        </MudButton>
                    </MudStack>
                </MudStack>
            </EditForm>
        </MudPaper>
    </MudStack>
}

<style>
    .cat-form-loading {
        min-height: 60vh;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        gap: 16px;
        border-radius: 28px;
        background: rgba(255,255,255,.92);
        border: 1px solid rgba(15,23,42,.06);
    }

    .cat-form-hero {
        border-radius: 30px;
        padding: 28px;
        background: linear-gradient(135deg, #1f1147 0%, #4c1d95 42%, #6d28d9 100%);
        color: #fff;
        box-shadow: 0 24px 48px rgba(31,17,71,.16);
    }

    .cat-form-hero-content {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 18px;
        flex-wrap: wrap;
    }

    .cat-form-kicker {
        color: rgba(255,255,255,.66);
        font-size: .78rem;
        font-weight: 900;
        text-transform: uppercase;
        letter-spacing: .16em;
    }

    .cat-form-title {
        margin-top: 8px;
        font-size: 2rem;
        line-height: 1.05;
        font-weight: 950;
    }

    .cat-form-subtitle {
        margin-top: 8px;
        color: rgba(255,255,255,.76);
        font-weight: 700;
    }

    .cat-form-panel {
        padding: 24px;
        border-radius: 26px;
        background: rgba(255,255,255,.95);
        border: 1px solid rgba(109,40,217,.10);
        box-shadow: 0 18px 36px rgba(88,28,135,.05);
    }

    .cat-form-actions {
        flex-wrap: wrap;
    }

    @@media (max-width: 760px) {
        .cat-form-title {
            font-size: 1.6rem;
        }

        .cat-form-panel,
        .cat-form-hero {
            border-radius: 22px;
        }
    }
</style>

@code {
    [Parameter] public int Id { get; set; }

    [SupplyParameterFromForm]
    private Category Category { get; set; } = new();

    private bool IsProcessing { get; set; } = true;
    private bool IsSaving { get; set; }

    protected override async Task OnInitializedAsync()
    {
        await LoadCategory();
        IsProcessing = false;
    }

    private async Task LoadCategory()
    {
        if (Id <= 0)
            return;

        var entity = await CategoryRepository.GetAsync(Id);

        if (entity is not null)
        {
            Category = entity;
        }
        else
        {
            await JS.InvokeVoidAsync("alert", "Category not found");
            Nav.NavigateTo("/category");
        }
    }

    private async Task UpsertCategory()
    {
        IsSaving = true;

        if (Category.Id == 0)
        {
            await CategoryRepository.CreateAsync(Category);
            await JS.InvokeVoidAsync("alert", "Category created successfully");
        }
        else
        {
            await CategoryRepository.UpdateAsync(Category);
            await JS.InvokeVoidAsync("alert", "Category updated successfully");
        }

        IsSaving = false;
        Nav.NavigateTo("/category");
    }

    private void BackToList()
    {
        Nav.NavigateTo("/category");
    }
}