@page "/chat/{ConversationId:int}"
@rendermode InteractiveServer
@using System.Security.Claims
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Components.Authorization
@using Microsoft.AspNetCore.Components.Forms
@using Microsoft.AspNetCore.Components.Web
@using Microsoft.AspNetCore.Components.Rendering
@using Microsoft.EntityFrameworkCore
@using Microsoft.JSInterop
@using MudBlazor
@using SkillGo.Data
@using SkillGo.Data.Models.Chat
@using SkillGo.Data.Models.Orders
@using SkillGo.Data.Models.Presence
@using SkillGo.Services
@using SkillGo.Components.Shared
@inject IDbContextFactory<ApplicationDbContext> DbFactory
@inject NavigationManager Nav
@inject ChatBroadcast Broadcast
@inject UserPresenceService Presence
@inject UserPresenceBroadcast PresenceBroadcast
@inject IDialogService DialogService
@inject IJSRuntime JS
@inject IWebHostEnvironment Env
@inject ISnackbar Snackbar
@attribute [Authorize]
@implements IDisposable

<PageTitle>Chat</PageTitle>

<div class="sg-chat-page">
    <div class="sg-chat-shell">
        <MudContainer MaxWidth="MaxWidth.False" Class="pa-0 sg-chat-container">
            @if (_loading)
            {
                <MudPaper Elevation="0" Class="pa-4 sg-chat-paper">
                    <MudStack Spacing="2">
                        <MudSkeleton Height="42px" Width="40%" />
                        <MudStack Spacing="2" Style="flex:1; height: calc(100% - 120px); overflow:hidden;">
                            <MudSkeleton Height="64px" Width="72%" />
                            <MudSkeleton Height="52px" Width="58%" Style="margin-left:auto;" />
                            <MudSkeleton Height="64px" Width="78%" />
                            <MudSkeleton Height="52px" Width="54%" Style="margin-left:auto;" />
                        </MudStack>
                        <MudSkeleton Height="44px" />
                    </MudStack>
                </MudPaper>
            }
            else if (_forbidden)
            {
                <MudPaper Class="pa-4 sg-chat-paper" Elevation="0">
                    <MudText Typo="Typo.h6" Class="fw-bold">Access denied</MudText>
                    <MudText Color="Color.Secondary">You don’t have access to this conversation.</MudText>
                </MudPaper>
            }
            else
            {
                <MudPaper Elevation="0" Class="sg-chat-paper" Style="display:flex; flex-direction:column;">
                    <div class="sg-chat-header">
                        <div style="display:flex; align-items:center; justify-content:space-between; gap:12px;">
                            <div style="display:flex; align-items:center; gap:10px; min-width:0;">
                                <MudIconButton Icon="@Icons.Material.Filled.ArrowBack"
                                               Color="Color.Default"
                                               OnClick="GoBack"
                                               Style="border:1px solid rgba(0,0,0,.08); border-radius:12px;" />

                                <MudAvatar Size="Size.Medium"
                                           Style="background: rgba(99,102,241,.16); color: rgba(17,24,39,1); border:1px solid rgba(0,0,0,.06);">
                                    @_otherInitials
                                </MudAvatar>

                                <div style="min-width:0;">
                                    <MudText Typo="Typo.h6" Class="fw-bold" Style="line-height:1.1; margin:0; white-space:nowrap; overflow:hidden; text-overflow:ellipsis;">
                                        @_title
                                    </MudText>

                                    <div style="display:flex; align-items:center; gap:10px; margin-top:3px;">
                                        <span style="display:inline-flex; align-items:center; gap:6px;">
                                            <span style="width:8px; height:8px; border-radius:999px; background:@(_otherOnline ? "#22c55e" : "#94a3b8"); display:inline-block;"></span>
                                            <MudText Typo="Typo.caption" Color="Color.Secondary" Style="margin:0;">
                                                @(_otherOnline ? "Online" : _otherLastSeenText)
                                            </MudText>
                                        </span>

                                        <MudText Typo="Typo.caption" Color="Color.Secondary" Style="margin:0;">
                                            • #@ConversationId
                                        </MudText>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="sg-chat-messages" id="sg-chat-messages-host">
                        <div style="min-height:100%; padding:14px 16px 12px 16px;">
                            @if (_messages.Count == 0)
                            {
                                <MudPaper Elevation="0" Class="pa-4"
                                          Style="border:1px dashed rgba(0,0,0,.12); border-radius:12px; background: rgba(255,255,255,.70); max-width:520px;">
                                    <MudText Typo="Typo.h6" Class="fw-bold">No messages yet</MudText>
                                    <MudText Color="Color.Secondary">Say hi 👋</MudText>
                                </MudPaper>
                            }
                            else
                            {
                                <div style="display:flex; flex-direction:column; gap:12px;">
                                    @{
                                        DateOnly? currentDay = null;
                                    }

                                    @foreach (var m in _messages)
                                    {
                                        var mine = m.SenderId == _meId;
                                        var local = m.CreatedAtUtc.ToLocalTime();
                                        var day = DateOnly.FromDateTime(local);

                                        if (currentDay != day)
                                        {
                                            currentDay = day;

                                            <div style="display:flex; justify-content:center; padding:8px 0 2px 0;">
                                                <MudChip T="string"
                                                         Size="Size.Small"
                                                         Variant="Variant.Outlined"
                                                         Style="background: rgba(255,255,255,.80); border-color: rgba(0,0,0,.10); border-radius:999px;">
                                                    @FormatDayChip(day)
                                                </MudChip>
                                            </div>
                                        }

                                        <div style="width:100%; display:flex; @(mine ? "justify-content:flex-end;" : "justify-content:flex-start;")">
                                            <div style="display:flex; gap:10px; align-items:flex-end; max-width:100%; @(mine ? "flex-direction:row-reverse;" : "flex-direction:row;")">
                                                @if (!mine)
                                                {
                                                    <MudAvatar Size="Size.Small"
                                                               Style="background: rgba(15,23,42,.06); border:1px solid rgba(0,0,0,.06); color:#111827;">
                                                        @_otherInitials
                                                    </MudAvatar>
                                                }
                                                else
                                                {
                                                    <div style="width:32px;"></div>
                                                }

                                                <div style="max-width: min(760px, 78vw); width:fit-content;">
                                                    @if (m.OrderId != null && m.Order != null && !m.IsOrderDelivery && !HasVisibleContent(m))
                                                    {
                                                        <OrderMessageCard Order="m.Order"
                                                                          CurrentUserId="@(_meId ?? "")"
                                                                          OnChanged="ReloadAsync"
                                                                          OnDeliver="OpenDeliveryForOrder" />
                                                        <div style="display:flex; justify-content:flex-end; gap:8px; margin-top:7px; opacity:.70; font-size:.75rem;">
                                                            <span>@local.ToString("HH:mm")</span>
                                                        </div>
                                                    }
                                                    else
                                                    {
                                                        <div style="@BubbleShellStyle(mine)">
                                                            @if (m.IsOrderDelivery)
                                                            {
                                                                <div class="sg-delivery-head">
                                                                    <MudIcon Icon="@Icons.Material.Filled.Inventory2" Size="Size.Small" />
                                                                    <span>Delivery for order #@m.OrderId</span>
                                                                </div>
                                                            }

                                                            @if (!m.IsDeleted)
                                                            {
                                                                @if (!string.IsNullOrWhiteSpace(m.Body))
                                                                {
                                                                    <div class="sg-message-body">
                                                                        @m.Body
                                                                    </div>
                                                                }

                                                                @if (m.Attachments.Any())
                                                                {
                                                                    <div class="sg-attachments-grid">
                                                                        @foreach (var att in m.Attachments)
                                                                        {
                                                                            @if (att.IsImage)
                                                                            {
                                                                                <a href="@att.Url" target="_blank" class="sg-attachment-image-link">
                                                                                    <img src="@att.Url" alt="@att.FileName" class="sg-attachment-image" />
                                                                                </a>
                                                                            }
                                                                            else
                                                                            {
                                                                                <a href="@att.Url" target="_blank" download="@att.FileName" class="sg-file-attachment">
                                                                                    <div class="sg-file-attachment-icon">
                                                                                        <MudIcon Icon="@Icons.Material.Filled.AttachFile" />
                                                                                    </div>

                                                                                    <div class="sg-file-attachment-copy">
                                                                                        <div class="sg-file-attachment-name">@att.FileName</div>
                                                                                        <div class="sg-file-attachment-meta">@FormatBytes(att.SizeBytes)</div>
                                                                                    </div>
                                                                                </a>
                                                                            }
                                                                        }
                                                                    </div>
                                                                }

                                                                @if (m.OrderId != null && m.Order != null && !m.IsOrderDelivery && HasVisibleContent(m))
                                                                {
                                                                    <div style="margin-top:10px;">
                                                                        <OrderMessageCard Order="m.Order"
                                                                                          CurrentUserId="@(_meId ?? "")"
                                                                                          OnChanged="ReloadAsync"
                                                                                          OnDeliver="OpenDeliveryForOrder" />
                                                                    </div>
                                                                }
                                                            }
                                                            else
                                                            {
                                                                <div style="font-style:italic; opacity:.70; font-size:0.98rem;">
                                                                    message deleted
                                                                </div>
                                                            }

                                                            <div style="display:flex; justify-content:flex-end; gap:8px; margin-top:7px; opacity:.70; font-size:.75rem;">
                                                                <span>@local.ToString("HH:mm")</span>
                                                                @if (m.EditedAtUtc.HasValue && !m.IsDeleted)
                                                                {
                                                                    <span>• edited</span>
                                                                }
                                                            </div>

                                                            @if (mine && _editingId != m.Id && !m.IsDeleted && !m.IsOrderDelivery && m.OrderId == null && !m.Attachments.Any())
                                                            {
                                                                <div style="display:flex; justify-content:flex-end; margin-top:6px;">
                                                                    <MudMenu Dense="true" AnchorOrigin="Origin.TopRight" TransformOrigin="Origin.TopRight">
                                                                        <ActivatorContent>
                                                                            <MudIconButton Icon="@Icons.Material.Filled.MoreVert"
                                                                                           Size="Size.Small"
                                                                                           Color="Color.Default"
                                                                                           Style="opacity:.78;" />
                                                                        </ActivatorContent>

                                                                        <ChildContent>
                                                                            <MudMenuItem OnClick="@(() => BeginEdit(m))">
                                                                                <MudIcon Icon="@Icons.Material.Filled.Edit" Class="me-2" /> Edit
                                                                            </MudMenuItem>

                                                                            <MudMenuItem OnClick="@(() => DeleteAsync(m.Id))">
                                                                                <MudIcon Icon="@Icons.Material.Filled.Delete" Class="me-2" /> Delete
                                                                            </MudMenuItem>
                                                                        </ChildContent>
                                                                    </MudMenu>
                                                                </div>
                                                            }

                                                            @if (_editingId == m.Id)
                                                            {
                                                                <div style="margin-top:10px;">
                                                                    <MudTextField @bind-Value="_editingText"
                                                                                  Variant="Variant.Outlined"
                                                                                  Margin="Margin.Dense"
                                                                                  Lines="3"
                                                                                  Immediate="true"
                                                                                  FullWidth="true"
                                                                                  Disabled="_savingEdit"
                                                                                  Style="border-radius:12px; background: rgba(255,255,255,.75);" />

                                                                    <div style="display:flex; justify-content:flex-end; gap:10px; margin-top:8px;">
                                                                        <MudButton Variant="Variant.Text"
                                                                                   Color="Color.Default"
                                                                                   Disabled="_savingEdit"
                                                                                   OnClick="@CancelEdit">
                                                                            Cancel
                                                                        </MudButton>

                                                                        <MudButton Variant="Variant.Filled"
                                                                                   Color="Color.Primary"
                                                                                   Disabled="_savingEdit || string.IsNullOrWhiteSpace(_editingText)"
                                                                                   OnClick="@(() => SaveEditAsync(m.Id))"
                                                                                   Style="border-radius:12px;">
                                                                            Save
                                                                        </MudButton>
                                                                    </div>
                                                                </div>
                                                            }
                                                        </div>
                                                    }
                                                </div>
                                            </div>
                                        </div>
                                    }
                                </div>
                            }
                        </div>
                    </div>

                    <div class="sg-chat-composer">
                        <MudStack Spacing="1">
                            @if (!string.IsNullOrWhiteSpace(_error))
                            {
                                <MudAlert Severity="Severity.Error" Dense="true" Variant="Variant.Outlined">
                                    @_error
                                </MudAlert>
                            }

                            @if (_deliveryOrderId.HasValue)
                            {
                                <MudAlert Severity="Severity.Info" Dense="true" Variant="Variant.Outlined">
                                    Delivery mode for order #@_deliveryOrderId
                                    <MudButton Variant="Variant.Text" Size="Size.Small" OnClick="CancelDeliveryMode">Cancel</MudButton>
                                </MudAlert>
                            }

                            <InputFile id="sg-hidden-file-input"
                                       OnChange="OnFilesSelected"
                                       multiple
                                       class="sg-hidden-file-input" />

                            @if (_pendingFiles.Any())
                            {
                                <div class="sg-pending-files">
                                    @for (var i = 0; i < _pendingFiles.Count; i++)
                                    {
                                        var file = _pendingFiles[i];

                                        <div class="sg-pending-file">
                                            <div class="sg-pending-file-icon">
                                                <MudIcon Icon="@(IsImageFile(file.Name) ? Icons.Material.Filled.Image : Icons.Material.Filled.InsertDriveFile)" />
                                            </div>

                                            <div class="sg-pending-file-copy">
                                                <div class="sg-pending-file-name">@file.Name</div>
                                                <div class="sg-pending-file-meta">@FormatBytes(file.Size)</div>
                                            </div>

                                            <MudIconButton Icon="@Icons.Material.Filled.Close"
                                                           Size="Size.Small"
                                                           OnClick="@(() => RemovePendingFile(i))" />
                                        </div>
                                    }
                                </div>
                            }

                            <div class="sg-chat-composer-row">
                                <MudButton Variant="Variant.Outlined"
                                           Color="Color.Primary"
                                           Disabled="_sending || _editingId.HasValue"
                                           OnClick="OpenFilePicker"
                                           Class="sg-attach-btn">
                                    <MudIcon Icon="@Icons.Material.Filled.AttachFile" Class="me-2" />
                                    Attach
                                </MudButton>

                                <MudTextField @bind-Value="_text"
                                              Placeholder="@(_deliveryOrderId.HasValue ? "Write a delivery note..." : "Write a message...")"
                                              Variant="Variant.Outlined"
                                              Margin="Margin.Dense"
                                              Immediate="true"
                                              FullWidth="true"
                                              Lines="2"
                                              Disabled="_sending || _editingId.HasValue"
                                              @onkeydown="OnComposerKeyDownRaw"
                                              Style="border-radius:14px; background: rgba(255,255,255,.90);" />

                                <MudButton Variant="Variant.Filled"
                                           Color="Color.Primary"
                                           Disabled="@IsSendDisabled"
                                           OnClick="SendAsync"
                                           Class="sg-send-btn">
                                    @SendButtonContent()
                                </MudButton>
                            </div>

                        </MudStack>
                    </div>
                </MudPaper>
            }
        </MudContainer>
    </div>
</div>

<script>
    window.sgChat = {
        scrollToBottom: function (id) {
            const el = document.getElementById(id);
            if (!el) return;
            el.scrollTop = el.scrollHeight;
        },
        openFilePicker: function (id) {
            const el = document.getElementById(id);
            if (!el) return;
            el.click();
        }
    };
</script>

<style>
    .sg-chat-page {
        margin: -34px -32px -32px -32px;
        height: calc(100vh - 78px);
        overflow: hidden;
    }

    .sg-chat-shell {
        height: 100%;
        min-height: 520px;
        overflow: hidden;
    }

    .sg-chat-container {
        height: 100%;
    }

    .sg-chat-paper {
        height: 100%;
        border: 1px solid rgba(0,0,0,.08);
        border-radius: 0;
        overflow: hidden;
    }

    .sg-chat-header {
        padding: 12px 14px 10px 14px;
        background: linear-gradient(180deg, rgba(99,102,241,.10), rgba(99,102,241,0));
        border-bottom: 1px solid rgba(0,0,0,.06);
        flex: 0 0 auto;
    }

    .sg-chat-messages {
        flex: 1 1 auto;
        overflow: auto;
        min-height: 0;
        background: radial-gradient(1200px 400px at 20% 0%, rgba(99,102,241,.08), transparent), linear-gradient(180deg, rgba(2,6,23,.02), rgba(2,6,23,0));
    }

    .sg-chat-composer {
        padding: 12px 14px;
        background: rgba(255,255,255,.78);
        border-top: 1px solid rgba(0,0,0,.06);
        flex: 0 0 auto;
    }

    .sg-hidden-file-input {
        display: none;
    }

    .sg-chat-composer-row {
        display: grid;
        grid-template-columns: auto minmax(0,1fr) auto;
        gap: 10px;
        align-items: end;
    }

    .sg-attach-btn {
        min-width: 124px;
        height: 40px;
        border-radius: 14px;
        white-space: nowrap;
    }

    .sg-send-btn {
        min-width: 148px;
        height: 40px;
        border-radius: 14px;
        white-space: nowrap;
    }

    .sg-pending-files {
        display: flex;
        flex-wrap: wrap;
        gap: 8px;
    }

    .sg-pending-file {
        min-width: 220px;
        max-width: 340px;
        display: flex;
        align-items: center;
        gap: 10px;
        padding: 8px 10px;
        border-radius: 14px;
        background: rgba(99,102,241,.08);
        border: 1px solid rgba(99,102,241,.10);
    }

    .sg-pending-file-icon {
        width: 36px;
        height: 36px;
        border-radius: 12px;
        display: flex;
        align-items: center;
        justify-content: center;
        background: rgba(79,70,229,.12);
        color: #4338ca;
        flex: 0 0 auto;
    }

    .sg-pending-file-copy {
        min-width: 0;
        flex: 1 1 auto;
    }

    .sg-pending-file-name {
        font-weight: 800;
        color: #111827;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
    }

    .sg-pending-file-meta {
        color: rgba(17,24,39,.56);
        font-size: .78rem;
        font-weight: 700;
    }

    .sg-message-body {
        white-space: pre-wrap;
        word-break: break-word;
        font-size: 1.02rem;
        line-height: 1.28;
    }

    .sg-delivery-head {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        padding: 6px 10px;
        border-radius: 999px;
        background: rgba(16,185,129,.14);
        color: #065f46;
        font-weight: 900;
        margin-bottom: 10px;
    }

    .sg-attachments-grid {
        display: flex;
        flex-direction: column;
        gap: 10px;
        margin-top: 10px;
    }

    .sg-attachment-image-link {
        display: block;
        text-decoration: none;
    }

    .sg-attachment-image {
        display: block;
        max-width: 280px;
        max-height: 220px;
        width: auto;
        height: auto;
        border-radius: 14px;
        border: 1px solid rgba(0,0,0,.08);
        object-fit: cover;
        background: #fff;
    }

    .sg-file-attachment {
        min-width: 220px;
        display: flex;
        align-items: center;
        gap: 10px;
        padding: 10px 12px;
        border-radius: 14px;
        text-decoration: none;
        background: rgba(255,255,255,.88);
        border: 1px solid rgba(0,0,0,.08);
        color: #111827;
    }

    .sg-file-attachment-icon {
        width: 38px;
        height: 38px;
        border-radius: 12px;
        display: flex;
        align-items: center;
        justify-content: center;
        background: rgba(79,70,229,.10);
        color: #4338ca;
        flex: 0 0 auto;
    }

    .sg-file-attachment-copy {
        min-width: 0;
    }

    .sg-file-attachment-name {
        font-weight: 800;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
    }

    .sg-file-attachment-meta {
        color: rgba(17,24,39,.56);
        font-size: .78rem;
        font-weight: 700;
    }

    @@media (max-width: 900px) {
        .sg-chat-composer-row {
            grid-template-columns: 1fr;
        }

        .sg-attach-btn,
        .sg-send-btn {
            width: 100%;
        }
    }

    @@media (max-width: 760px) {
        .sg-chat-page {
            margin: -22px -14px -20px -14px;
        }
    }
</style>

@code {
    [Parameter] public int ConversationId { get; set; }
    [CascadingParameter] public Task<AuthenticationState> AuthenticationStateTask { get; set; } = default!;

    private bool _loading = true;
    private bool _forbidden;
    private bool _sending;
    private bool _pendingScrollToBottom;

    private string _title = "Chat";
    private string _otherDisplay = "User";
    private string _otherInitials = "?";

    private string? _meId;
    private string? _otherId;

    private string? _text;
    private string? _error;

    private readonly List<MessageDto> _messages = new();
    private readonly List<PendingUploadFile> _pendingFiles = new();

    private IDisposable? _msgSub;
    private IDisposable? _presenceSub;

    private bool _otherOnline;
    private string _otherLastSeenText = "Offline";

    private int? _editingId;
    private string? _editingText;
    private bool _savingEdit;
    private int? _deliveryOrderId;

    private bool IsSendDisabled =>
        _sending ||
        _editingId.HasValue ||
        (!HasTextToSend() && !_pendingFiles.Any());

    protected override async Task OnParametersSetAsync()
    {
        CleanupSubs();

        _loading = true;
        _forbidden = false;
        _error = null;
        _editingId = null;
        _editingText = null;
        _savingEdit = false;
        _pendingScrollToBottom = false;
        _deliveryOrderId = null;
        _pendingFiles.Clear();
        StateHasChanged();

        try
        {
            var authState = await AuthenticationStateTask;
            var principal = authState.User;

            if (principal?.Identity?.IsAuthenticated != true)
            {
                _forbidden = true;
                return;
            }

            _meId = principal.FindFirst(ClaimTypes.NameIdentifier)?.Value;
            if (string.IsNullOrWhiteSpace(_meId))
            {
                _forbidden = true;
                return;
            }

            await LoadConversationAndMessagesAsync();
            if (_forbidden) return;

            _pendingScrollToBottom = true;

            _msgSub = Broadcast.SubscribeMessages(ConversationId, dto =>
            {
                if (dto.ConversationId != ConversationId) return;

                lock (_messages)
                {
                    var idx = _messages.FindIndex(x => x.Id == dto.Id);
                    if (idx >= 0)
                        _messages[idx] = dto;
                    else
                        _messages.Add(dto);
                }

                _pendingScrollToBottom = true;
                _ = InvokeAsync(StateHasChanged);
            });

            _presenceSub = PresenceBroadcast.Subscribe(dto =>
            {
                if (string.IsNullOrWhiteSpace(_otherId)) return;
                if (dto.UserId != _otherId) return;

                _otherOnline = dto.IsOnline;
                _otherLastSeenText = dto.IsOnline ? "Online" : BuildLastSeenText(dto.SeenAtUtc);

                _ = InvokeAsync(StateHasChanged);
            });

            RefreshOtherPresence();
        }
        finally
        {
            _loading = false;
            StateHasChanged();
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (_pendingScrollToBottom && !_loading && !_forbidden)
        {
            _pendingScrollToBottom = false;
            await JS.InvokeVoidAsync("sgChat.scrollToBottom", "sg-chat-messages-host");
        }
    }

    private void RefreshOtherPresence()
    {
        if (string.IsNullOrWhiteSpace(_otherId))
        {
            _otherOnline = false;
            _otherLastSeenText = "Offline";
            return;
        }

        _otherOnline = Presence.IsOnline(_otherId);

        var lastSeen = Presence.LastSeenUtc(_otherId);
        _otherLastSeenText = _otherOnline
            ? "Online"
            : (lastSeen.HasValue ? BuildLastSeenText(lastSeen.Value) : "Offline");
    }

    private static string BuildLastSeenText(DateTime seenAtUtc)
    {
        var local = seenAtUtc.ToLocalTime();
        return $"Last seen {local:HH:mm}";
    }

    private async Task LoadConversationAndMessagesAsync()
    {
        await using var db = await DbFactory.CreateDbContextAsync();

        var conv = await db.Conversations.AsNoTracking()
            .FirstOrDefaultAsync(x => x.Id == ConversationId);

        if (conv == null)
        {
            _forbidden = true;
            return;
        }

        var isMember = conv.UserAId == _meId || conv.UserBId == _meId;
        if (!isMember)
        {
            _forbidden = true;
            return;
        }

        _otherId = conv.UserAId == _meId ? conv.UserBId : conv.UserAId;

        var otherUser = await db.Users.AsNoTracking()
            .Where(x => x.Id == _otherId)
            .Select(x => x.UserName)
            .FirstOrDefaultAsync();

        _otherDisplay = string.IsNullOrWhiteSpace(otherUser) ? "User" : otherUser;
        _otherInitials = _otherDisplay.Substring(0, 1).ToUpperInvariant();
        _title = $"@{_otherDisplay}";

        var list = await db.Messages.AsNoTracking()
            .Include(x => x.Order)
            .ThenInclude(x => x.ServiceOffer)
            .Include(x => x.Attachments)
            .Where(x => x.ConversationId == ConversationId)
            .OrderBy(x => x.CreatedAtUtc)
            .Take(500)
            .Select(x => new MessageDto
            {
                Id = x.Id,
                ConversationId = x.ConversationId,
                SenderId = x.SenderId,
                Body = x.Body,
                OrderId = x.OrderId,
                Order = x.Order,
                IsOrderDelivery = x.IsOrderDelivery,
                CreatedAtUtc = x.CreatedAtUtc,
                EditedAtUtc = x.EditedAtUtc,
                IsDeleted = x.IsDeleted,
                DeletedAtUtc = x.DeletedAtUtc,
                Attachments = x.Attachments
                    .OrderBy(a => a.Id)
                    .Select(a => new MessageAttachment
                    {
                        Id = a.Id,
                        MessageId = a.MessageId,
                        FileName = a.FileName,
                        Url = a.Url,
                        ContentType = a.ContentType,
                        SizeBytes = a.SizeBytes,
                        IsImage = a.IsImage
                    })
                    .ToList()
            })
            .ToListAsync();

        _messages.Clear();
        _messages.AddRange(list);
    }

