@page "/chat/{ConversationId:int}"
@rendermode InteractiveServer
@using System.Security.Claims
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Components.Authorization
@using Microsoft.AspNetCore.Components.Forms
@using Microsoft.AspNetCore.Components.Web
@using Microsoft.EntityFrameworkCore
@using Microsoft.JSInterop
@using MudBlazor
@using SkillGo.Data
@using SkillGo.Data.Models.Chat
@using SkillGo.Data.Models.Orders
@using SkillGo.Data.Models.Reports
@using SkillGo.Services
@using SkillGo.Components.Shared
@inject IDbContextFactory<ApplicationDbContext> DbFactory
@inject NavigationManager Nav
@inject ChatBroadcast Broadcast
@inject UserPresenceService Presence
@inject UserPresenceBroadcast PresenceBroadcast
@inject IDialogService DialogService
@inject IJSRuntime JS
@inject IWebHostEnvironment Env
@inject ISnackbar Snackbar
@attribute [Authorize]
@implements IDisposable

<PageTitle>Chat</PageTitle>

<div class="sg-chat-page">
    <div class="sg-chat-shell">
        <MudContainer MaxWidth="MaxWidth.False" Class="pa-0 sg-chat-container">
            @if (_loading)
            {
                <MudPaper Elevation="0" Class="pa-4 sg-chat-paper">
                    <MudStack Spacing="2">
                        <MudSkeleton Height="42px" Width="40%" />
                        <MudStack Spacing="2" Style="flex:1; height: calc(100% - 120px); overflow:hidden;">
                            <MudSkeleton Height="64px" Width="72%" />
                            <MudSkeleton Height="52px" Width="58%" Style="margin-left:auto;" />
                            <MudSkeleton Height="64px" Width="78%" />
                            <MudSkeleton Height="52px" Width="54%" Style="margin-left:auto;" />
                        </MudStack>
                        <MudSkeleton Height="44px" />
                    </MudStack>
                </MudPaper>
            }
            else if (_forbidden)
            {
                <MudPaper Class="pa-4 sg-chat-paper" Elevation="0">
                    <MudText Typo="Typo.h6" Class="fw-bold">Access denied</MudText>
                    <MudText Color="Color.Secondary">You don’t have access to this conversation.</MudText>
                </MudPaper>
            }
            else
            {
                <MudPaper Elevation="0" Class="sg-chat-paper" Style="display:flex; flex-direction:column;">
                    <div class="sg-chat-header">
                        <div class="sg-chat-header-row">
                            <div class="sg-chat-header-left">
                                <MudIconButton Icon="@Icons.Material.Filled.ArrowBack"
                                               Color="Color.Default"
                                               OnClick="GoBack"
                                               Class="sg-back-btn" />

                                @if (!string.IsNullOrWhiteSpace(_otherAvatarUrl))
                                {
                                    <img src="@_otherAvatarUrl" alt="@_title" class="sg-header-avatar-image" />
                                }
                                else
                                {
                                    <MudAvatar Size="Size.Medium" Class="sg-header-avatar">
                                        @_otherInitials
                                    </MudAvatar>
                                }

                                <div class="sg-chat-title-wrap">
                                    <MudText Typo="Typo.h6" Class="fw-bold sg-chat-title">
                                        @_title
                                    </MudText>

                                    <div class="sg-chat-title-sub">
                                        <span class="sg-chat-status-dot" style="background:@(_otherOnline ? "#22c55e" : "#94a3b8");"></span>
                                        <MudText Typo="Typo.caption" Color="Color.Secondary" Style="margin:0;">
                                            @(_otherOnline ? "Online" : _otherLastSeenText)
                                        </MudText>
                                        <MudText Typo="Typo.caption" Color="Color.Secondary" Style="margin:0;">
                                            • #@ConversationId
                                        </MudText>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="sg-chat-messages" id="sg-chat-messages-host">
                        <div class="sg-chat-messages-inner">
                            @if (_messages.Count == 0)
                            {
                                <MudPaper Elevation="0" Class="pa-4 sg-empty-messages">
                                    <MudText Typo="Typo.h6" Class="fw-bold">No messages yet</MudText>
                                    <MudText Color="Color.Secondary">Say hi 👋</MudText>
                                </MudPaper>
                            }
                            else
                            {
                                <div class="sg-message-list">
                                    @{
                                        DateOnly? currentDay = null;
                                    }

                                    @foreach (var m in _messages)
                                    {
                                        var mine = m.SenderId == _meId;
                                        var local = m.CreatedAtUtc.ToLocalTime();
                                        var day = DateOnly.FromDateTime(local);

                                        if (currentDay != day)
                                        {
                                            currentDay = day;

                                            <div class="sg-day-chip-wrap">
                                                <MudChip T="string"
                                                         Size="Size.Small"
                                                         Variant="Variant.Outlined"
                                                         Class="sg-day-chip">
                                                    @FormatDayChip(day)
                                                </MudChip>
                                            </div>
                                        }

                                        <div class="sg-message-row @(mine ? "mine" : "other")">
                                            <div class="sg-message-row-inner @(mine ? "mine" : "other")">
                                                @if (!mine)
                                                {
                                                    @if (!string.IsNullOrWhiteSpace(_otherAvatarUrl))
                                                    {
                                                        <img src="@_otherAvatarUrl" alt="@_otherDisplay" class="sg-message-avatar-image" />
                                                    }
                                                    else
                                                    {
                                                        <MudAvatar Size="Size.Small" Class="sg-message-avatar">
                                                            @_otherInitials
                                                        </MudAvatar>
                                                    }
                                                }
                                                else
                                                {
                                                    @if (!string.IsNullOrWhiteSpace(_myAvatarUrl))
                                                    {
                                                        <img src="@_myAvatarUrl" alt="Me" class="sg-message-avatar-image" />
                                                    }
                                                    else
                                                    {
                                                        <MudAvatar Size="Size.Small" Class="sg-message-avatar sg-message-avatar-mine">
                                                            @_myInitials
                                                        </MudAvatar>
                                                    }
                                                }

                                                <div class="sg-message-content-wrap">
                                                    @if (m.OrderId != null && m.Order != null && !m.IsOrderDelivery && !HasVisibleContent(m))
                                                    {
                                                        <div class="sg-order-row">
                                                            <OrderMessageCard Order="m.Order"
                                                                              CurrentUserId="@(_meId ?? "")"
                                                                              OnChanged="ReloadAsync" />

                                                            @if (!mine && !m.IsDeleted)
                                                            {
                                                                <MudMenu Dense="true" AnchorOrigin="Origin.TopRight" TransformOrigin="Origin.TopRight">
                                                                    <ActivatorContent>
                                                                        <MudIconButton Icon="@Icons.Material.Filled.MoreVert"
                                                                                       Size="Size.Small"
                                                                                       Color="Color.Default"
                                                                                       Style="opacity:.78;" />
                                                                    </ActivatorContent>

                                                                    <ChildContent>
                                                                        <MudMenuItem OnClick="@(() => OpenReportPopup(m))">
                                                                            <MudIcon Icon="@Icons.Material.Filled.ReportGmailerrorred" Class="me-2" /> Report
                                                                        </MudMenuItem>
                                                                    </ChildContent>
                                                                </MudMenu>
                                                            }
                                                        </div>

                                                        <div class="sg-bubble-meta">
                                                            <span>@local.ToString("HH:mm")</span>
                                                        </div>
                                                    }
                                                    else
                                                    {
                                                        <div class="sg-bubble-with-menu">
                                                            <div class="sg-message-bubble @(mine ? "mine" : "other")">
                                                                @if (m.IsOrderDelivery)
                                                                {
                                                                    <div class="sg-delivery-head">
                                                                        <MudIcon Icon="@Icons.Material.Filled.Inventory2" Size="Size.Small" />
                                                                        <span>Delivery for order #@m.OrderId</span>
                                                                    </div>
                                                                }

                                                                @if (!m.IsDeleted)
                                                                {
                                                                    @if (!string.IsNullOrWhiteSpace(m.Body))
                                                                    {
                                                                        <div class="sg-message-body">
                                                                            @m.Body
                                                                        </div>
                                                                    }

                                                                    @if (m.Attachments.Any())
                                                                    {
                                                                        <div class="sg-attachments-grid">
                                                                            @foreach (var att in m.Attachments)
                                                                            {
                                                                                @if (att.IsImage)
                                                                                {
                                                                                    <a href="@att.Url" target="_blank" class="sg-attachment-image-link">
                                                                                        <img src="@att.Url" alt="@att.FileName" class="sg-attachment-image" />
                                                                                    </a>
                                                                                }
                                                                                else
                                                                                {
                                                                                    <a href="@att.Url" target="_blank" download="@att.FileName" class="sg-file-attachment">
                                                                                        <div class="sg-file-attachment-icon">
                                                                                            <MudIcon Icon="@Icons.Material.Filled.AttachFile" />
                                                                                        </div>

                                                                                        <div class="sg-file-attachment-copy">
                                                                                            <div class="sg-file-attachment-name">@att.FileName</div>
                                                                                            <div class="sg-file-attachment-meta">@FormatBytes(att.SizeBytes)</div>
                                                                                        </div>
                                                                                    </a>
                                                                                }
                                                                            }
                                                                        </div>
                                                                    }

                                                                    @if (m.OrderId != null && m.Order != null && !m.IsOrderDelivery && HasVisibleContent(m))
                                                                    {
                                                                        <div style="margin-top:10px;">
                                                                            <OrderMessageCard Order="m.Order"
                                                                                              CurrentUserId="@(_meId ?? "")"
                                                                                              OnChanged="ReloadAsync" />
                                                                        </div>
                                                                    }
                                                                }
                                                                else
                                                                {
                                                                    <div class="sg-deleted-text">
                                                                        message deleted
                                                                    </div>
                                                                }

                                                                <div class="sg-bubble-meta">
                                                                    <span>@local.ToString("HH:mm")</span>
                                                                    @if (m.EditedAtUtc.HasValue && !m.IsDeleted)
                                                                    {
                                                                        <span>• edited</span>
                                                                    }
                                                                </div>

                                                                @if (_editingId == m.Id)
                                                                {
                                                                    <div style="margin-top:10px;">
                                                                        <MudTextField @bind-Value="_editingText"
                                                                                      Variant="Variant.Outlined"
                                                                                      Margin="Margin.Dense"
                                                                                      Lines="3"
                                                                                      Immediate="true"
                                                                                      FullWidth="true"
                                                                                      Disabled="_savingEdit"
                                                                                      Style="border-radius:12px; background: rgba(255,255,255,.75);" />

                                                                        <div style="display:flex; justify-content:flex-end; gap:10px; margin-top:8px;">
                                                                            <MudButton Variant="Variant.Text"
                                                                                       Color="Color.Default"
                                                                                       Disabled="_savingEdit"
                                                                                       OnClick="@CancelEdit">
                                                                                Cancel
                                                                            </MudButton>

                                                                            <MudButton Variant="Variant.Filled"
                                                                                       Color="Color.Primary"
                                                                                       Disabled="_savingEdit || string.IsNullOrWhiteSpace(_editingText)"
                                                                                       OnClick="@(() => SaveEditAsync(m.Id))"
                                                                                       Style="border-radius:12px;">
                                                                                Save
                                                                            </MudButton>
                                                                        </div>
                                                                    </div>
                                                                }
                                                            </div>

                                                            @if (mine && _editingId != m.Id && !m.IsDeleted && !m.IsOrderDelivery && m.OrderId == null && !m.Attachments.Any())
                                                            {
                                                                <MudMenu Dense="true" AnchorOrigin="Origin.TopRight" TransformOrigin="Origin.TopRight">
                                                                    <ActivatorContent>
                                                                        <MudIconButton Icon="@Icons.Material.Filled.MoreVert"
                                                                                       Size="Size.Small"
                                                                                       Color="Color.Default"
                                                                                       Style="opacity:.78;" />
                                                                    </ActivatorContent>

                                                                    <ChildContent>
                                                                        <MudMenuItem OnClick="@(() => BeginEdit(m))">
                                                                            <MudIcon Icon="@Icons.Material.Filled.Edit" Class="me-2" /> Edit
                                                                        </MudMenuItem>

                                                                        <MudMenuItem OnClick="@(() => DeleteAsync(m.Id))">
                                                                            <MudIcon Icon="@Icons.Material.Filled.Delete" Class="me-2" /> Delete
                                                                        </MudMenuItem>
                                                                    </ChildContent>
                                                                </MudMenu>
                                                            }
                                                            else if (!mine && !m.IsDeleted)
                                                            {
                                                                <MudMenu Dense="true" AnchorOrigin="Origin.TopRight" TransformOrigin="Origin.TopRight">
                                                                    <ActivatorContent>
                                                                        <MudIconButton Icon="@Icons.Material.Filled.MoreVert"
                                                                                       Size="Size.Small"
                                                                                       Color="Color.Default"
                                                                                       Style="opacity:.78;" />
                                                                    </ActivatorContent>

                                                                    <ChildContent>
                                                                        <MudMenuItem OnClick="@(() => OpenReportPopup(m))">
                                                                            <MudIcon Icon="@Icons.Material.Filled.ReportGmailerrorred" Class="me-2" /> Report
                                                                        </MudMenuItem>
                                                                    </ChildContent>
                                                                </MudMenu>
                                                            }
                                                        </div>
                                                    }
                                                </div>
                                            </div>
                                        </div>
                                    }
                                </div>
                            }
                        </div>
                    </div>

                    <div class="sg-chat-composer">
                        <MudStack Spacing="1">
                            @if (!string.IsNullOrWhiteSpace(_error))
                            {
                                <MudAlert Severity="Severity.Error" Dense="true" Variant="Variant.Outlined">
                                    @_error
                                </MudAlert>
                            }

                            <InputFile id="sg-hidden-file-input"
                                       OnChange="OnFilesSelected"
                                       multiple
                                       class="sg-hidden-file-input" />

                            @if (_pendingFiles.Any())
                            {
                                <div class="sg-pending-files">
                                    @for (var i = 0; i < _pendingFiles.Count; i++)
                                    {
                                        var file = _pendingFiles[i];

                                        <div class="sg-pending-file">
                                            <div class="sg-pending-file-icon">
                                                <MudIcon Icon="@(IsImageFile(file.Name) ? Icons.Material.Filled.Image : Icons.Material.Filled.InsertDriveFile)" />
                                            </div>

                                            <div class="sg-pending-file-copy">
                                                <div class="sg-pending-file-name">@file.Name</div>
                                                <div class="sg-pending-file-meta">@FormatBytes(file.Size)</div>
                                            </div>

                                            <MudIconButton Icon="@Icons.Material.Filled.Close"
                                                           Size="Size.Small"
                                                           OnClick="@(() => RemovePendingFile(i))" />
                                        </div>
                                    }
                                </div>
                            }

                            <div class="sg-chat-composer-row">
                                <MudButton Variant="Variant.Outlined"
                                           Color="Color.Primary"
                                           Disabled="_sending || _editingId.HasValue"
                                           OnClick="OpenFilePicker"
                                           Class="sg-attach-btn">
                                    <MudIcon Icon="@Icons.Material.Filled.AttachFile" Class="me-2" />
                                    Attach
                                </MudButton>

                                <MudTextField @bind-Value="_text"
                                              Placeholder="Write a message..."
                                              Variant="Variant.Outlined"
                                              Margin="Margin.Dense"
                                              Immediate="true"
                                              FullWidth="true"
                                              Lines="2"
                                              Disabled="_sending || _editingId.HasValue"
                                              @onkeydown="OnComposerKeyDownRaw"
                                              Style="border-radius:14px; background: rgba(255,255,255,.90);" />

                                <MudButton Variant="Variant.Filled"
                                           Color="Color.Primary"
                                           Disabled="@IsSendDisabled"
                                           OnClick="SendAsync"
                                           Class="sg-send-btn">
                                    @SendButtonContent()
                                </MudButton>
                            </div>
                        </MudStack>
                    </div>
                </MudPaper>
            }
        </MudContainer>
    </div>
</div>

@if (_reportPopupOpen)
{
    <div class="sg-report-overlay" @onclick="CloseReportPopup">
        <div class="sg-report-modal" @onclick:stopPropagation="true">
            <div class="sg-report-head">
                <div>
                    <div class="sg-report-kicker">Safety</div>
                    <div class="sg-report-title">Report message</div>
                </div>

                <MudIconButton Icon="@Icons.Material.Filled.Close"
                               Color="Color.Default"
                               OnClick="CloseReportPopup" />
            </div>

            @if (_reportTargetMessage is not null)
            {
                <div class="sg-report-preview">
                    <div class="sg-report-preview-label">Selected message</div>
                    <div class="sg-report-preview-text">@PreviewMessage(_reportTargetMessage)</div>
                </div>
            }

            <MudTextField @bind-Value="_reportReason"
                          Label="Reason"
                          Variant="Variant.Outlined"
                          Lines="5"
                          Immediate="true"
                          Counter="500"
                          MaxLength="500"
                          Class="mt-4" />

            @if (!string.IsNullOrWhiteSpace(_reportError))
            {
                <MudAlert Severity="Severity.Error" Dense="true" Variant="Variant.Outlined" Class="mt-3">
                    @_reportError
                </MudAlert>
            }

            <div class="sg-report-actions">
                <MudButton Variant="Variant.Text"
                           Color="Color.Default"
                           Disabled="_reportSubmitting"
                           OnClick="CloseReportPopup">
                    Cancel
                </MudButton>

                <MudButton Variant="Variant.Filled"
                           Color="Color.Error"
                           Disabled="_reportSubmitting || string.IsNullOrWhiteSpace(_reportReason)"
                           OnClick="SubmitReportAsync">
                    @(_reportSubmitting ? "Sending..." : "Send report")
                </MudButton>
            </div>
        </div>
    </div>
}

<script>
    window.sgChat = {
        scrollToBottom: function (id) {
            const el = document.getElementById(id);
            if (!el) return;
            el.scrollTop = el.scrollHeight;
        },
        openFilePicker: function (id) {
            const el = document.getElementById(id);
            if (!el) return;
            el.click();
        }
    };
</script>

<style>
    .sg-chat-page {
        margin: -34px -32px -32px -32px;
        height: calc(100vh - 78px);
        overflow: hidden;
    }

    .sg-chat-shell {
        height: 100%;
        min-height: 520px;
        overflow: hidden;
    }

    .sg-chat-container {
        height: 100%;
    }

    .sg-chat-paper {
        height: 100%;
        border: 1px solid rgba(0,0,0,.08);
        border-radius: 0;
        overflow: hidden;
    }

    .sg-chat-header {
        padding: 12px 14px 10px 14px;
        background: linear-gradient(180deg, rgba(99,102,241,.10), rgba(99,102,241,0));
        border-bottom: 1px solid rgba(0,0,0,.06);
        flex: 0 0 auto;
    }

    .sg-chat-header-row {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 12px;
    }

    .sg-chat-header-left {
        display: flex;
        align-items: center;
        gap: 10px;
        min-width: 0;
    }

    .sg-back-btn {
        border: 1px solid rgba(0,0,0,.08);
        border-radius: 12px;
    }

    .sg-header-avatar,
    .sg-header-avatar-image {
        width: 40px;
        height: 40px;
        border-radius: 999px;
        flex: 0 0 auto;
    }

    .sg-header-avatar {
        background: rgba(99,102,241,.16);
        color: rgba(17,24,39,1);
        border: 1px solid rgba(0,0,0,.06);
    }

    .sg-header-avatar-image {
        object-fit: cover;
        display: block;
        border: 1px solid rgba(0,0,0,.08);
        background: #fff;
    }

    .sg-chat-title-wrap {
        min-width: 0;
    }

    .sg-chat-title {
        line-height: 1.1;
        margin: 0;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
    }

    .sg-chat-title-sub {
        display: flex;
        align-items: center;
        gap: 10px;
        margin-top: 3px;
        flex-wrap: wrap;
    }

    .sg-chat-status-dot {
        width: 8px;
        height: 8px;
        border-radius: 999px;
        display: inline-block;
    }

    .sg-chat-messages {
        flex: 1 1 auto;
        overflow: auto;
        min-height: 0;
        background: radial-gradient(1200px 400px at 20% 0%, rgba(99,102,241,.08), transparent), linear-gradient(180deg, rgba(2,6,23,.02), rgba(2,6,23,0));
    }

    .sg-chat-messages-inner {
        min-height: 100%;
        padding: 14px 16px 12px 16px;
    }

    .sg-empty-messages {
        border: 1px dashed rgba(0,0,0,.12);
        border-radius: 12px;
        background: rgba(255,255,255,.70);
        max-width: 520px;
    }

    .sg-message-list {
        display: flex;
        flex-direction: column;
        gap: 12px;
    }

    .sg-day-chip-wrap {
        display: flex;
        justify-content: center;
        padding: 8px 0 2px 0;
    }

    .sg-day-chip {
        background: rgba(255,255,255,.80);
        border-color: rgba(0,0,0,.10);
        border-radius: 999px;
    }

    .sg-message-row {
        width: 100%;
        display: flex;
    }

    .sg-message-row.mine {
        justify-content: flex-end;
    }

    .sg-message-row.other {
        justify-content: flex-start;
    }

    .sg-message-row-inner {
        display: flex;
        gap: 10px;
        align-items: flex-end;
        max-width: 100%;
    }

    .sg-message-row-inner.mine {
        flex-direction: row-reverse;
    }

    .sg-message-row-inner.other {
        flex-direction: row;
    }

    .sg-message-avatar,
    .sg-message-avatar-image {
        width: 32px;
        height: 32px;
        border-radius: 999px;
        flex: 0 0 auto;
    }

    .sg-message-avatar {
        background: rgba(15,23,42,.06);
        border: 1px solid rgba(0,0,0,.06);
        color: #111827;
    }

    .sg-message-avatar-mine {
        background: rgba(99,102,241,.16);
    }

    .sg-message-avatar-image {
        object-fit: cover;
        display: block;
        border: 1px solid rgba(0,0,0,.08);
        background: #fff;
    }

    .sg-message-content-wrap {
        max-width: min(760px, 78vw);
        width: fit-content;
    }

    .sg-order-row {
        display: flex;
        align-items: flex-start;
        gap: 6px;
    }

    .sg-bubble-with-menu {
        display: flex;
        align-items: flex-start;
        gap: 6px;
    }

    .sg-message-bubble {
        padding: 10px 12px;
        border-radius: 18px;
        box-shadow: 0 14px 30px rgba(2,6,23,.06);
        max-width: 100%;
    }

    .sg-message-bubble.mine {
        background: linear-gradient(180deg,#6366f1,#4f46e5);
        color: white;
        box-shadow: 0 14px 30px rgba(79,70,229,.18);
        border: 1px solid rgba(255,255,255,.12);
    }

    .sg-message-bubble.other {
        background: rgba(255,255,255,.92);
        border: 1px solid rgba(0,0,0,.08);
        color: #0f172a;
    }

    .sg-chat-composer {
        padding: 12px 14px;
        background: rgba(255,255,255,.78);
        border-top: 1px solid rgba(0,0,0,.06);
        flex: 0 0 auto;
    }

    .sg-hidden-file-input {
        display: none;
    }

    .sg-chat-composer-row {
        display: grid;
        grid-template-columns: auto minmax(0,1fr) auto;
        gap: 10px;
        align-items: end;
    }

    .sg-attach-btn {
        min-width: 124px;
        height: 40px;
        border-radius: 14px;
        white-space: nowrap;
    }

    .sg-send-btn {
        min-width: 148px;
        height: 40px;
        border-radius: 14px;
        white-space: nowrap;
    }

    .sg-pending-files {
        display: flex;
        flex-wrap: wrap;
        gap: 8px;
    }

    .sg-pending-file {
        min-width: 220px;
        max-width: 340px;
        display: flex;
        align-items: center;
        gap: 10px;
        padding: 8px 10px;
        border-radius: 14px;
        background: rgba(99,102,241,.08);
        border: 1px solid rgba(99,102,241,.10);
    }

    .sg-pending-file-icon {
        width: 36px;
        height: 36px;
        border-radius: 12px;
        display: flex;
        align-items: center;
        justify-content: center;
        background: rgba(79,70,229,.12);
        color: #4338ca;
        flex: 0 0 auto;
    }

    .sg-pending-file-copy {
        min-width: 0;
