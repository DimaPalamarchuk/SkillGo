@code {
    [Parameter] public int ConversationId { get; set; }
    [CascadingParameter] public Task<AuthenticationState> AuthenticationStateTask { get; set; } = default!;

    private bool _loading = true;
    private bool _forbidden;
    private bool _sending;
    private bool _pendingScrollToBottom;

    private string _title = "Chat";
    private string _otherDisplay = "User";
    private string _otherInitials = "?";
    private string _myInitials = "M";

    private string? _meId;
    private string? _otherId;
    private string? _myAvatarUrl;
    private string? _otherAvatarUrl;

    private string? _text;
    private string? _error;

    private readonly List<MessageDto> _messages = new();
    private readonly List<PendingUploadFile> _pendingFiles = new();

    private IDisposable? _msgSub;
    private IDisposable? _presenceSub;

    private bool _otherOnline;
    private string _otherLastSeenText = "Offline";

    private int? _editingId;
    private string? _editingText;
    private bool _savingEdit;

    private bool _reportPopupOpen;
    private bool _reportSubmitting;
    private string? _reportReason;
    private string? _reportError;
    private MessageDto? _reportTargetMessage;

    private bool IsSendDisabled =>
        _sending ||
        _editingId.HasValue ||
        (!HasTextToSend() && !_pendingFiles.Any());

    protected override async Task OnParametersSetAsync()
    {
        CleanupSubs();

        _loading = true;
        _forbidden = false;
        _error = null;
        _editingId = null;
        _editingText = null;
        _savingEdit = false;
        _pendingScrollToBottom = false;
        _pendingFiles.Clear();
        _reportPopupOpen = false;
        _reportSubmitting = false;
        _reportReason = null;
        _reportError = null;
        _reportTargetMessage = null;
        StateHasChanged();

        try
        {
            var authState = await AuthenticationStateTask;
            var principal = authState.User;

            if (principal?.Identity?.IsAuthenticated != true)
            {
                _forbidden = true;
                return;
            }

            _meId = principal.FindFirst(ClaimTypes.NameIdentifier)?.Value;
            if (string.IsNullOrWhiteSpace(_meId))
            {
                _forbidden = true;
                return;
            }

            await LoadConversationAndMessagesAsync();
            if (_forbidden) return;

            await MarkConversationAsReadAsync();

            _pendingScrollToBottom = true;

            _msgSub = Broadcast.SubscribeMessages(ConversationId, dto =>
            {
                if (dto.ConversationId != ConversationId) return;

                lock (_messages)
                {
                    var idx = _messages.FindIndex(x => x.Id == dto.Id);
                    if (idx >= 0)
                        _messages[idx] = dto;
                    else
                        _messages.Add(dto);
                }

                _ = InvokeAsync(async () =>
                {
                    await MarkConversationAsReadAsync();
                    _pendingScrollToBottom = true;
                    StateHasChanged();
                });
            });

            _presenceSub = PresenceBroadcast.Subscribe(dto =>
            {
                if (string.IsNullOrWhiteSpace(_otherId)) return;
                if (dto.UserId != _otherId) return;

                _otherOnline = dto.IsOnline;
                _otherLastSeenText = dto.IsOnline ? "Online" : BuildLastSeenText(dto.SeenAtUtc);

                _ = InvokeAsync(StateHasChanged);
            });

            RefreshOtherPresence();
        }
        finally
        {
            _loading = false;
            StateHasChanged();
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (_pendingScrollToBottom && !_loading && !_forbidden)
        {
            _pendingScrollToBottom = false;
            await JS.InvokeVoidAsync("sgChat.scrollToBottom", "sg-chat-messages-host");
        }
    }

    private async Task MarkConversationAsReadAsync()
    {
        if (string.IsNullOrWhiteSpace(_meId))
            return;

        await using var db = await DbFactory.CreateDbContextAsync();

        var conv = await db.Conversations.FirstOrDefaultAsync(x => x.Id == ConversationId);
        if (conv == null)
            return;

        var now = DateTime.UtcNow;

        if (conv.UserAId == _meId)
            conv.LastReadByUserAAtUtc = now;
        else if (conv.UserBId == _meId)
            conv.LastReadByUserBAtUtc = now;
        else
            return;

        await db.SaveChangesAsync();
    }

    private void RefreshOtherPresence()
    {
        if (string.IsNullOrWhiteSpace(_otherId))
        {
            _otherOnline = false;
            _otherLastSeenText = "Offline";
            return;
        }

        _otherOnline = Presence.IsOnline(_otherId);

        var lastSeen = Presence.LastSeenUtc(_otherId);
        _otherLastSeenText = _otherOnline
            ? "Online"
            : (lastSeen.HasValue ? BuildLastSeenText(lastSeen.Value) : "Offline");
    }

    private static string BuildLastSeenText(DateTime seenAtUtc)
    {
        var local = seenAtUtc.ToLocalTime();
        return $"Last seen {local:HH:mm}";
    }

    private async Task LoadConversationAndMessagesAsync()
    {
        await using var db = await DbFactory.CreateDbContextAsync();

        var conv = await db.Conversations
            .AsNoTracking()
            .FirstOrDefaultAsync(x => x.Id == ConversationId);

        if (conv == null)
        {
            _forbidden = true;
            return;
        }

        var isMember = conv.UserAId == _meId || conv.UserBId == _meId;
        if (!isMember)
        {
            _forbidden = true;
            return;
        }

        _otherId = conv.UserAId == _meId ? conv.UserBId : conv.UserAId;

        var users = await db.Users
            .AsNoTracking()
            .Where(x => x.Id == _otherId || x.Id == _meId)
            .Select(x => new
            {
                x.Id,
                x.UserName,
                x.DisplayName,
                x.AvatarUrl
            })
            .ToListAsync();

        var otherUser = users.FirstOrDefault(x => x.Id == _otherId);
        var myUser = users.FirstOrDefault(x => x.Id == _meId);

        _otherDisplay = !string.IsNullOrWhiteSpace(otherUser?.DisplayName)
            ? otherUser.DisplayName!
            : (!string.IsNullOrWhiteSpace(otherUser?.UserName) ? otherUser.UserName! : "User");

        _otherAvatarUrl = otherUser?.AvatarUrl;
        _otherInitials = string.IsNullOrWhiteSpace(_otherDisplay) ? "U" : _otherDisplay.Substring(0, 1).ToUpperInvariant();

        var myName = !string.IsNullOrWhiteSpace(myUser?.DisplayName)
            ? myUser.DisplayName!
            : (!string.IsNullOrWhiteSpace(myUser?.UserName) ? myUser.UserName! : "Me");

        _myAvatarUrl = myUser?.AvatarUrl;
        _myInitials = string.IsNullOrWhiteSpace(myName) ? "M" : myName.Substring(0, 1).ToUpperInvariant();

        _title = $"@{_otherDisplay}";

        var list = await db.Messages
            .AsNoTracking()
            .Include(x => x.Order)
            .ThenInclude(x => x.ServiceOffer)
            .Include(x => x.Attachments)
            .Where(x => x.ConversationId == ConversationId)
            .OrderBy(x => x.CreatedAtUtc)
            .Take(500)
            .Select(x => new MessageDto
            {
                Id = x.Id,
                ConversationId = x.ConversationId,
                SenderId = x.SenderId,
                Body = x.Body,
                OrderId = x.OrderId,
                Order = x.Order,
                IsOrderDelivery = x.IsOrderDelivery,
                CreatedAtUtc = x.CreatedAtUtc,
                EditedAtUtc = x.EditedAtUtc,
                IsDeleted = x.IsDeleted,
                DeletedAtUtc = x.DeletedAtUtc,
                Attachments = x.Attachments
                    .OrderBy(a => a.Id)
                    .Select(a => new MessageAttachment
                    {
                        Id = a.Id,
                        MessageId = a.MessageId,
                        FileName = a.FileName,
                        Url = a.Url,
                        ContentType = a.ContentType,
                        SizeBytes = a.SizeBytes,
                        IsImage = a.IsImage
                    })
                    .ToList()
            })
            .ToListAsync();

        _messages.Clear();
        _messages.AddRange(list);
    }

    private async Task ReloadAsync()
    {
        if (_sending) return;

        _error = null;

        try
        {
            await LoadConversationAndMessagesAsync();
            await MarkConversationAsReadAsync();
            RefreshOtherPresence();
            _pendingScrollToBottom = true;
            StateHasChanged();
        }
        catch (Exception ex)
        {
            _error = ex.Message;
            StateHasChanged();
        }
    }

    private async Task OpenFilePicker()
    {
        await JS.InvokeVoidAsync("sgChat.openFilePicker", "sg-hidden-file-input");
    }

    private async Task OnFilesSelected(InputFileChangeEventArgs e)
    {
        _error = null;

        foreach (var file in e.GetMultipleFiles(6))
        {
            if (_pendingFiles.Count >= 6)
            {
                Snackbar.Add("You can attach up to 6 files", Severity.Warning);
                break;
            }

            if (file.Size > 25 * 1024 * 1024)
            {
                Snackbar.Add($"{file.Name} is larger than 25 MB", Severity.Warning);
                continue;
            }

            _pendingFiles.Add(new PendingUploadFile(file));
        }

        await InvokeAsync(StateHasChanged);
    }

    private void RemovePendingFile(int index)
    {
        if (index < 0 || index >= _pendingFiles.Count)
            return;

        _pendingFiles.RemoveAt(index);
    }

    private async Task SendAsync()
    {
        if (_sending) return;
        if (_editingId.HasValue) return;
        if (string.IsNullOrWhiteSpace(_meId)) return;
        if (!HasTextToSend() && !_pendingFiles.Any()) return;

        var body = string.IsNullOrWhiteSpace(_text) ? null : _text.Trim();

        _sending = true;
        _error = null;
        StateHasChanged();

        try
        {
            await using var db = await DbFactory.CreateDbContextAsync();

            var conv = await db.Conversations.FirstOrDefaultAsync(x => x.Id == ConversationId);
            if (conv == null)
            {
                _error = "Chat not found.";
                return;
            }

            var isMember = conv.UserAId == _meId || conv.UserBId == _meId;
            if (!isMember)
            {
                _error = "Access denied.";
                return;
            }

            var msg = new Message
            {
                ConversationId = ConversationId,
                SenderId = _meId!,
                Body = body,
                CreatedAtUtc = DateTime.UtcNow
            };

            db.Messages.Add(msg);
            conv.LastMessageAtUtc = msg.CreatedAtUtc;

            await db.SaveChangesAsync();

            if (_pendingFiles.Any())
            {
                var saved = await SaveUploadedFilesAsync(msg.Id, _pendingFiles);

                if (saved.Any())
                {
                    db.MessageAttachments.AddRange(saved);
                    await db.SaveChangesAsync();
                    msg.Attachments = saved;
                }
            }

            _text = null;
            _pendingFiles.Clear();

            var dto = new MessageDto
            {
                Id = msg.Id,
                ConversationId = msg.ConversationId,
                SenderId = msg.SenderId,
                Body = msg.Body,
                OrderId = msg.OrderId,
                Order = null,
                IsOrderDelivery = msg.IsOrderDelivery,
                CreatedAtUtc = msg.CreatedAtUtc,
                EditedAtUtc = msg.EditedAtUtc,
                IsDeleted = msg.IsDeleted,
                DeletedAtUtc = msg.DeletedAtUtc,
                Attachments = msg.Attachments
                    .Select(a => new MessageAttachment
                    {
                        Id = a.Id,
                        MessageId = a.MessageId,
                        FileName = a.FileName,
                        Url = a.Url,
                        ContentType = a.ContentType,
                        SizeBytes = a.SizeBytes,
                        IsImage = a.IsImage
                    })
                    .ToList()
            };

            lock (_messages)
            {
                _messages.Add(dto);
            }

            _pendingScrollToBottom = true;
            Broadcast.PublishMessage(dto);
            await MarkConversationAsReadAsync();
        }
        finally
        {
            _sending = false;
            StateHasChanged();
        }
    }

    private async Task<List<MessageAttachment>> SaveUploadedFilesAsync(int messageId, List<PendingUploadFile> files)
    {
        var result = new List<MessageAttachment>();

        var now = DateTime.UtcNow;

        var root = Path.Combine(
            Env.WebRootPath,
            "uploads",
            "chat",
            now.ToString("yyyy"),
            now.ToString("MM"));

        Directory.CreateDirectory(root);

        var relativeFolder = Path.Combine(
            "uploads",
            "chat",
            now.ToString("yyyy"),
            now.ToString("MM"))
            .Replace("\\", "/");

        foreach (var pending in files)
        {
            var file = pending.File;
            var ext = Path.GetExtension(file.Name);
            var safeName = MakeSafeFileName(Path.GetFileNameWithoutExtension(file.Name));
            var storedName = $"{Guid.NewGuid():N}_{safeName}{ext}";
            var physicalPath = Path.Combine(root, storedName);

            await using var source = file.OpenReadStream(25 * 1024 * 1024);
            await using var target = File.Create(physicalPath);
            await source.CopyToAsync(target);

            var url = $"/{relativeFolder}/{storedName}";
            var contentType = string.IsNullOrWhiteSpace(file.ContentType) ? "application/octet-stream" : file.ContentType;

            result.Add(new MessageAttachment
            {
                MessageId = messageId,
                FileName = file.Name,
                Url = url,
                ContentType = contentType,
                SizeBytes = file.Size,
                IsImage = contentType.StartsWith("image/", StringComparison.OrdinalIgnoreCase)
            });
        }

        return result;
    }

    private static string MakeSafeFileName(string name)
    {
        var invalid = Path.GetInvalidFileNameChars();
        var cleaned = new string(name.Where(c => !invalid.Contains(c)).ToArray()).Trim();

        if (string.IsNullOrWhiteSpace(cleaned))
            cleaned = "file";

        if (cleaned.Length > 80)
            cleaned = cleaned[..80];

        return cleaned.Replace(" ", "_");
    }

    private bool HasTextToSend()
    {
        return !string.IsNullOrWhiteSpace(_text);
    }

    private static bool HasVisibleContent(MessageDto m)
    {
        return !string.IsNullOrWhiteSpace(m.Body) || m.Attachments.Any();
    }

    private void BeginEdit(MessageDto m)
    {
        if (m.SenderId != _meId) return;
        if (m.IsDeleted) return;
        if (m.OrderId != null) return;
        if (m.IsOrderDelivery) return;
        if (m.Attachments.Any()) return;

        _editingId = m.Id;
        _editingText = m.Body ?? "";
        _error = null;
        StateHasChanged();
    }

    private void CancelEdit()
    {
        _editingId = null;
        _editingText = null;
        _savingEdit = false;
        StateHasChanged();
    }

    private async Task SaveEditAsync(int messageId)
    {
        if (_savingEdit) return;
        if (string.IsNullOrWhiteSpace(_meId)) return;
        if (_editingId != messageId) return;

        var text = (_editingText ?? "").Trim();
        if (text.Length == 0) return;

        _savingEdit = true;
        _error = null;
        StateHasChanged();

        try
        {
            await using var db = await DbFactory.CreateDbContextAsync();

            var msg = await db.Messages
                .Include(x => x.Attachments)
                .FirstOrDefaultAsync(x => x.Id == messageId && x.ConversationId == ConversationId);

            if (msg == null) { _error = "Message not found."; return; }
            if (msg.SenderId != _meId) { _error = "Access denied."; return; }
            if (msg.IsDeleted) { _error = "Message deleted."; return; }
            if (msg.OrderId != null) { _error = "Can't edit order message."; return; }
            if (msg.IsOrderDelivery) { _error = "Can't edit delivery message."; return; }
            if (msg.Attachments.Any()) { _error = "Can't edit attachment message."; return; }

            msg.Body = text;
            msg.EditedAtUtc = DateTime.UtcNow;

            await db.SaveChangesAsync();

            var dto = new MessageDto
            {
                Id = msg.Id,
                ConversationId = msg.ConversationId,
                SenderId = msg.SenderId,
                Body = msg.Body,
                OrderId = msg.OrderId,
                Order = null,
                IsOrderDelivery = msg.IsOrderDelivery,
                CreatedAtUtc = msg.CreatedAtUtc,
                EditedAtUtc = msg.EditedAtUtc,
                IsDeleted = msg.IsDeleted,
                DeletedAtUtc = msg.DeletedAtUtc,
                Attachments = new List<MessageAttachment>()
            };

            lock (_messages)
            {
                var idx = _messages.FindIndex(x => x.Id == dto.Id);
                if (idx >= 0) _messages[idx] = dto;
            }

            Broadcast.PublishMessage(dto);

            _editingId = null;
            _editingText = null;
            await MarkConversationAsReadAsync();
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
        finally
        {
            _savingEdit = false;
            StateHasChanged();
        }
    }

    private async Task DeleteAsync(int messageId)
    {
        if (string.IsNullOrWhiteSpace(_meId)) return;

        var ok = await DialogService.ShowMessageBox(
            "Delete message",
            "Delete this message?",
            yesText: "Delete",
            cancelText: "Cancel");

        if (ok != true) return;

        _error = null;
        StateHasChanged();

        try
        {
            await using var db = await DbFactory.CreateDbContextAsync();

            var msg = await db.Messages
                .Include(x => x.Attachments)
                .FirstOrDefaultAsync(x => x.Id == messageId && x.ConversationId == ConversationId);

            if (msg == null) { _error = "Message not found."; return; }
            if (msg.SenderId != _meId) { _error = "Access denied."; return; }
            if (msg.IsDeleted) return;
            if (msg.OrderId != null) { _error = "Can't delete order message."; return; }
            if (msg.IsOrderDelivery) { _error = "Can't delete delivery message."; return; }
            if (msg.Attachments.Any()) { _error = "Can't delete attachment message."; return; }

            msg.IsDeleted = true;
            msg.DeletedAtUtc = DateTime.UtcNow;
            msg.Body = null;

            await db.SaveChangesAsync();

            var dto = new MessageDto
            {
                Id = msg.Id,
                ConversationId = msg.ConversationId,
                SenderId = msg.SenderId,
                Body = msg.Body,
                OrderId = msg.OrderId,
                Order = null,
                IsOrderDelivery = msg.IsOrderDelivery,
                CreatedAtUtc = msg.CreatedAtUtc,
                EditedAtUtc = msg.EditedAtUtc,
                IsDeleted = msg.IsDeleted,
                DeletedAtUtc = msg.DeletedAtUtc,
                Attachments = new List<MessageAttachment>()
            };

            lock (_messages)
            {
                var idx = _messages.FindIndex(x => x.Id == dto.Id);
                if (idx >= 0) _messages[idx] = dto;
            }

            Broadcast.PublishMessage(dto);

            if (_editingId == messageId)
                CancelEdit();

            await MarkConversationAsReadAsync();
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
        finally
        {
            StateHasChanged();
        }
    }

    private void OpenReportPopup(MessageDto message)
    {
        _reportTargetMessage = message;
        _reportReason = null;
        _reportError = null;
        _reportSubmitting = false;
        _reportPopupOpen = true;
        StateHasChanged();
    }

    private void CloseReportPopup()
    {
        _reportPopupOpen = false;
        _reportSubmitting = false;
        _reportReason = null;
        _reportError = null;
        _reportTargetMessage = null;
        StateHasChanged();
    }

    private async Task SubmitReportAsync()
    {
        if (_reportSubmitting) return;
        if (_reportTargetMessage is null) return;
        if (string.IsNullOrWhiteSpace(_reportReason)) return;
        if (string.IsNullOrWhiteSpace(_meId)) return;

        _reportSubmitting = true;
        _reportError = null;
        StateHasChanged();

        try
        {
            await using var db = await DbFactory.CreateDbContextAsync();

            var msg = await db.Messages.AsNoTracking()
                .FirstOrDefaultAsync(x => x.Id == _reportTargetMessage.Id && x.ConversationId == ConversationId);

            if (msg == null)
            {
                _reportError = "Message not found.";
                return;
            }

            if (msg.SenderId == _meId)
            {
                _reportError = "You cannot report your own message.";
                return;
            }

            var report = new Report
            {
                ReporterUserId = _meId,
                TargetUserId = msg.SenderId,
                TargetType = ReportTargetType.Message,
                MessageId = msg.Id,
                Reason = _reportReason.Trim(),
                CreatedAt = DateTime.UtcNow
            };

            db.Reports.Add(report);
            await db.SaveChangesAsync();

            Snackbar.Add("Report submitted successfully", Severity.Success);
            CloseReportPopup();
        }
        catch (Exception ex)
        {
            _reportError = ex.Message;
        }
        finally
        {
            _reportSubmitting = false;
            StateHasChanged();
        }
    }

    private string PreviewMessage(MessageDto m)
    {
        if (!string.IsNullOrWhiteSpace(m.Body))
            return m.Body.Length <= 220 ? m.Body : m.Body.Substring(0, 220) + "...";

        if (m.Attachments.Any())
            return $"Message contains {m.Attachments.Count} attachment(s).";

        if (m.IsDeleted)
            return "Deleted message.";

        return "Empty message.";
    }

    private async Task OnComposerKeyDownRaw(KeyboardEventArgs e)
    {
        if (e.Key == "Enter" && !e.ShiftKey)
            await SendAsync();
    }

    private string FormatDayChip(DateOnly day)
    {
        var today = DateOnly.FromDateTime(DateTime.Now);

        if (day == today) return "Today";
        if (day == today.AddDays(-1)) return "Yesterday";

        return day.ToString("yyyy-MM-dd");
    }

    private static string FormatBytes(long bytes)
    {
        if (bytes < 1024) return $"{bytes} B";
        if (bytes < 1024 * 1024) return $"{bytes / 1024d:0.#} KB";
        if (bytes < 1024 * 1024 * 1024) return $"{bytes / 1024d / 1024d:0.#} MB";
        return $"{bytes / 1024d / 1024d / 1024d:0.#} GB";
    }

    private static bool IsImageFile(string name)
    {
        var ext = Path.GetExtension(name)?.ToLowerInvariant();
        return ext is ".png" or ".jpg" or ".jpeg" or ".gif" or ".webp" or ".bmp";
    }

