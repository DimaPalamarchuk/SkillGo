@page "/chats"
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Components.Authorization
@using Microsoft.AspNetCore.Identity
@using Microsoft.EntityFrameworkCore
@using MudBlazor
@using SkillGo.Data
@using SkillGo.Data.Models.Chat
@inject IDbContextFactory<ApplicationDbContext> DbFactory
@inject UserManager<ApplicationUser> UserManager
@inject NavigationManager Nav
@attribute [Authorize]

<PageTitle>Chats</PageTitle>

<MudContainer MaxWidth="MaxWidth.False" Class="chats-page-shell pa-0">
    <MudContainer MaxWidth="MaxWidth.ExtraLarge" Class="pt-6 pb-8">
        <MudPaper Class="chats-shell" Elevation="0">
            <div class="chats-hero">
                <div class="chats-hero-left">
                    <div class="hero-badge">
                        <MudIcon Icon="@Icons.Material.Filled.Chat" Size="Size.Small" />
                        <span>Your conversations</span>
                    </div>

                    <MudText Typo="Typo.h4" Class="hero-title mt-4">Chats</MudText>
                    <MudText Typo="Typo.body2" Class="hero-sub mt-2">Open conversations with freelancers and clients in one place.</MudText>
                </div>

                <div class="chats-hero-right">
                    <MudTextField T="string"
                                  Placeholder="Search chats..."
                                  Variant="Variant.Outlined"
                                  Margin="Margin.Dense"
                                  Adornment="Adornment.Start"
                                  AdornmentIcon="@Icons.Material.Filled.Search"
                                  Immediate="true"
                                  @bind-Value="_search"
                                  Class="chats-search" />
                </div>
            </div>

            <div class="chats-list">
                @if (_loading)
                {
                    <div class="chats-loading">
                        @for (var i = 0; i < 6; i++)
                        {
                            <div class="chat-row-skeleton">
                                <MudSkeleton Height="56px" Width="56px" Class="chat-avatar-skeleton" />
                                <div class="chat-row-skeleton-content">
                                    <MudSkeleton Height="18px" Width="42%" />
                                    <MudSkeleton Height="14px" Width="70%" />
                                </div>
                            </div>
                        }
                    </div>
                }
                else if (!FilteredItems.Any())
                {
                    <div class="chats-empty">
                        <MudAvatar Size="Size.Large" Class="chats-empty-icon">
                            <MudIcon Icon="@Icons.Material.Filled.ChatBubbleOutline" />
                        </MudAvatar>

                        @if (string.IsNullOrWhiteSpace(_search))
                        {
                            <MudText Typo="Typo.h6" Class="fw-bold">No chats yet</MudText>
                            <MudText Class="chats-empty-sub">Your conversations will appear here.</MudText>
                        }
                        else
                        {
                            <MudText Typo="Typo.h6" Class="fw-bold">Nothing found</MudText>
                            <MudText Class="chats-empty-sub">No chats match your search.</MudText>
                        }
                    </div>
                }
                else
                {
                    @foreach (var c in FilteredItems)
                    {
                        <div class="chat-row @(c.UnreadCount > 0 ? "chat-row-unread" : "")" @onclick="@(() => OpenChat(c.ConversationId))">
                            <div class="chat-avatar-wrap">
                                <div class="chat-avatar">
                                    @GetInitial(c.Title)
                                </div>

                                @if (c.UnreadCount > 0)
                                {
                                    <div class="chat-unread-badge">
                                        @(c.UnreadCount > 99 ? "99+" : c.UnreadCount.ToString())
                                    </div>
                                }
                            </div>

                            <div class="chat-main">
                                <div class="chat-top">
                                    <div class="chat-title-wrap">
                                        <div class="chat-title">@c.Title</div>
                                        @if (c.UnreadCount > 0)
                                        {
                                            <div class="chat-unread-text">@($"{c.UnreadCount} unread")</div>
                                        }
                                    </div>

                                    <div class="chat-time">@FormatChatDate(c.LastAt)</div>
                                </div>

                                <div class="chat-bottom">
                                    <div class="chat-preview @(c.UnreadCount > 0 ? "chat-preview-unread" : "")">@GetPreview(c)</div>
                                </div>
                            </div>
                        </div>
                    }
                }
            </div>
        </MudPaper>
    </MudContainer>
</MudContainer>

<style>
    .chats-page-shell {
        min-height: calc(100vh - 78px);
        background:
            radial-gradient(circle at top left, rgba(124,58,237,.10), transparent 22%),
            radial-gradient(circle at top right, rgba(99,102,241,.08), transparent 24%),
            linear-gradient(180deg, #fbfaff 0%, #f7f4ff 42%, #ffffff 100%);
    }

    .chats-shell {
        border-radius: 28px;
        background: rgba(255,255,255,.94);
        border: 1px solid rgba(109,40,217,.10);
        box-shadow: 0 16px 40px rgba(88,28,135,.05);
        overflow: hidden;
    }

    .chats-hero {
        padding: 22px 22px 18px 22px;
        border-bottom: 1px solid rgba(109,40,217,.08);
        background: linear-gradient(180deg, rgba(109,40,217,.06), rgba(109,40,217,0));
        display: flex;
        justify-content: space-between;
        gap: 18px;
        align-items: end;
        flex-wrap: wrap;
    }

    .chats-hero-left {
        min-width: 0;
    }

    .hero-badge {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        padding: 8px 14px;
        border-radius: 999px;
        background: rgba(109,40,217,.08);
        border: 1px solid rgba(109,40,217,.10);
        font-size: 13px;
        font-weight: 700;
        color: #5b21b6;
    }

    .hero-title {
        color: #1f1147;
        font-weight: 900;
        line-height: 1.05;
        letter-spacing: -.02em;
    }

    .hero-sub {
        color: #6b5f8d;
        line-height: 1.6;
    }

    .chats-hero-right {
        width: min(100%, 360px);
    }

    .chats-search {
        width: 100%;
    }

    .chats-list {
        display: flex;
        flex-direction: column;
    }

    .chat-row {
        display: flex;
        align-items: center;
        gap: 14px;
        padding: 14px 18px;
        cursor: pointer;
        transition: background .16s ease, transform .16s ease;
        border-bottom: 1px solid rgba(109,40,217,.06);
    }

    .chat-row:last-child {
        border-bottom: none;
    }

    .chat-row:hover {
        background: rgba(109,40,217,.05);
    }

    .chat-row-unread {
        background: rgba(109,40,217,.03);
    }

    .chat-avatar-wrap {
        position: relative;
        flex: 0 0 auto;
    }

    .chat-avatar {
        width: 56px;
        height: 56px;
        border-radius: 18px;
        display: flex;
        align-items: center;
        justify-content: center;
        background: linear-gradient(135deg, #f3e8ff 0%, #ede9fe 100%);
        color: #6d28d9;
        font-weight: 950;
        font-size: 1rem;
        border: 1px solid rgba(109,40,217,.10);
        flex: 0 0 auto;
    }

    .chat-unread-badge {
        position: absolute;
        top: -6px;
        right: -6px;
        min-width: 22px;
        height: 22px;
        padding: 0 6px;
        border-radius: 999px;
        background: linear-gradient(135deg, #ef4444 0%, #dc2626 100%);
        color: #fff;
        font-size: .72rem;
        font-weight: 900;
        display: flex;
        align-items: center;
        justify-content: center;
        border: 2px solid #fff;
        box-shadow: 0 8px 18px rgba(220,38,38,.22);
    }

    .chat-main {
        min-width: 0;
        flex: 1 1 auto;
    }

    .chat-top {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 12px;
    }

    .chat-title-wrap {
        min-width: 0;
        display: flex;
        flex-direction: column;
        gap: 2px;
    }

    .chat-title {
        min-width: 0;
        color: #1f1147;
        font-weight: 900;
        font-size: 1rem;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
    }

    .chat-unread-text {
        color: #6d28d9;
        font-size: .78rem;
        font-weight: 800;
    }

    .chat-time {
        flex: 0 0 auto;
        color: #6b5f8d;
        font-size: .8rem;
        font-weight: 800;
        white-space: nowrap;
    }

    .chat-bottom {
        margin-top: 4px;
    }

    .chat-preview {
        color: rgba(31,17,71,.68);
        font-size: .92rem;
        line-height: 1.35;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
    }

    .chat-preview-unread {
        color: #1f1147;
        font-weight: 800;
    }

    .chats-empty {
        padding: 52px 24px;
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 10px;
        text-align: center;
    }

    .chats-empty-icon {
        background: linear-gradient(135deg, rgba(109,40,217,.12), rgba(99,102,241,.08));
        color: #6d28d9;
    }

    .chats-empty-sub {
        color: #6b5f8d;
    }

    .chats-loading {
        padding: 8px 0;
    }

    .chat-row-skeleton {
        display: flex;
        align-items: center;
        gap: 14px;
        padding: 14px 18px;
        border-bottom: 1px solid rgba(109,40,217,.06);
    }

    .chat-avatar-skeleton {
        border-radius: 18px;
        flex: 0 0 auto;
    }

    .chat-row-skeleton-content {
        flex: 1 1 auto;
        display: flex;
        flex-direction: column;
        gap: 8px;
    }

    @@media (max-width: 760px) {
        .chats-hero {
            padding: 18px 16px 14px 16px;
        }

        .chat-row {
            padding: 12px 14px;
            gap: 12px;
        }

        .chat-avatar {
            width: 50px;
            height: 50px;
            border-radius: 16px;
        }
    }
</style>

@code {
    [CascadingParameter] public Task<AuthenticationState> AuthenticationStateTask { get; set; } = default!;

    private bool _loading = true;
    private List<Row> _items = new();
    private string _search = string.Empty;

    private IEnumerable<Row> FilteredItems
    {
        get
        {
            IEnumerable<Row> query = _items;

            if (!string.IsNullOrWhiteSpace(_search))
            {
                var term = _search.Trim().ToLowerInvariant();
                query = query.Where(x =>
                    x.Title.ToLowerInvariant().Contains(term) ||
                    (!string.IsNullOrWhiteSpace(x.LastMessage) && x.LastMessage.ToLowerInvariant().Contains(term)));
            }

            return query.OrderByDescending(x => x.LastAt).ToList();
        }
    }

    private sealed class Row
    {
        public int ConversationId { get; set; }
        public string Title { get; set; } = "Chat";
        public string? LastMessage { get; set; }
        public bool HasAttachments { get; set; }
        public bool IsOrderMessage { get; set; }
        public bool IsDeliveryMessage { get; set; }
        public DateTime LastAt { get; set; }
        public int UnreadCount { get; set; }
    }

    protected override async Task OnInitializedAsync()
    {
        _loading = true;

        var auth = await AuthenticationStateTask;
        var me = await UserManager.GetUserAsync(auth.User);

        if (me == null)
        {
            _items = new();
            _loading = false;
            return;
        }

        await using var db = await DbFactory.CreateDbContextAsync();

        var conversations = await db.Conversations.AsNoTracking()
            .Where(x => x.UserAId == me.Id || x.UserBId == me.Id)
            .OrderByDescending(x => x.LastMessageAtUtc ?? x.CreatedAtUtc)
            .Take(100)
            .ToListAsync();

        var ids = conversations.Select(x => x.Id).ToList();

        var lastMessages = await db.Messages.AsNoTracking()
            .Include(x => x.Attachments)
            .Where(m => ids.Contains(m.ConversationId))
            .GroupBy(m => m.ConversationId)
            .Select(g => g.OrderByDescending(x => x.CreatedAtUtc).FirstOrDefault())
            .ToListAsync();

        var otherIds = conversations
            .Select(x => x.UserAId == me.Id ? x.UserBId : x.UserAId)
            .Distinct()
            .ToList();

        var users = await db.Users.AsNoTracking()
            .Where(u => otherIds.Contains(u.Id))
            .Select(u => new { u.Id, u.UserName })
            .ToListAsync();

        var unreadData = await db.Messages.AsNoTracking()
            .Where(m => ids.Contains(m.ConversationId) && m.SenderId != me.Id && !m.IsDeleted)
            .Select(m => new
            {
                m.ConversationId,
                m.CreatedAtUtc
            })
            .ToListAsync();

        var userMap = users.ToDictionary(x => x.Id, x => x.UserName);
        var lastMap = lastMessages.Where(x => x != null).ToDictionary(x => x!.ConversationId, x => x!);

        _items = conversations.Select(c =>
        {
            var otherId = c.UserAId == me.Id ? c.UserBId : c.UserAId;

            userMap.TryGetValue(otherId, out var userName);
            lastMap.TryGetValue(c.Id, out var lm);

            var lastReadAt = c.UserAId == me.Id
                ? c.LastReadByUserAAtUtc
                : c.LastReadByUserBAtUtc;

            var unreadCount = unreadData.Count(x =>
                x.ConversationId == c.Id &&
                (!lastReadAt.HasValue || x.CreatedAtUtc > lastReadAt.Value));

            return new Row
            {
                ConversationId = c.Id,
                Title = !string.IsNullOrWhiteSpace(userName) ? $"@{userName}" : "Chat",
                LastMessage = lm?.Body,
                HasAttachments = lm?.Attachments.Any() == true,
                IsOrderMessage = lm?.OrderId != null,
                IsDeliveryMessage = lm?.IsOrderDelivery == true,
                LastAt = c.LastMessageAtUtc ?? c.CreatedAtUtc,
                UnreadCount = unreadCount
            };
        }).ToList();

        _loading = false;
    }

    private void OpenChat(int id)
    {
        Nav.NavigateTo($"/chat/{id}");
    }

    private static string GetInitial(string? title)
    {
        if (string.IsNullOrWhiteSpace(title))
            return "C";

        var clean = title.Trim().TrimStart('@');
        return string.IsNullOrWhiteSpace(clean) ? "C" : clean.Substring(0, 1).ToUpperInvariant();
    }

    private static string FormatChatDate(DateTime utc)
    {
        var local = utc.ToLocalTime();
        var today = DateTime.Now.Date;
        var date = local.Date;

        if (date == today)
            return local.ToString("HH:mm");

        if (date == today.AddDays(-1))
            return "Yesterday";

        return local.ToString("dd.MM.yyyy");
    }

    private static string GetPreview(Row row)
    {
        if (row.IsDeliveryMessage)
            return "Delivery files sent";

        if (row.IsOrderMessage && string.IsNullOrWhiteSpace(row.LastMessage) && !row.HasAttachments)
            return "Order update";

        if (row.HasAttachments && string.IsNullOrWhiteSpace(row.LastMessage))
            return "Attachment";

        if (row.HasAttachments && !string.IsNullOrWhiteSpace(row.LastMessage))
            return $"{row.LastMessage} · Attachment";

        if (!string.IsNullOrWhiteSpace(row.LastMessage))
            return row.LastMessage;

        return "Open conversation";
    }
}