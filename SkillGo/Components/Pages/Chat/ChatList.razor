@page "/chats"
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Components.Authorization
@using Microsoft.AspNetCore.Identity
@using Microsoft.EntityFrameworkCore
@using MudBlazor
@using SkillGo.Data
@using SkillGo.Data.Models.Chat
@inject IDbContextFactory<ApplicationDbContext> DbFactory
@inject UserManager<ApplicationUser> UserManager
@inject NavigationManager Nav
@attribute [Authorize]

<PageTitle>Chats</PageTitle>

<MudContainer MaxWidth="MaxWidth.Medium" Class="py-4">
    <MudPaper Class="chats-shell" Elevation="0">
        <div class="chats-header">
            <MudText Typo="Typo.h5" Class="fw-bold">Chats</MudText>

            <MudTextField T="string"
                          Placeholder="Search chats..."
                          Variant="Variant.Outlined"
                          Margin="Margin.Dense"
                          Adornment="Adornment.Start"
                          AdornmentIcon="@Icons.Material.Filled.Search"
                          Immediate="true"
                          @bind-Value="_search"
                          Class="chats-search" />
        </div>

        <div class="chats-list">
            @if (_loading)
            {
                <div class="chats-loading">
                    @for (var i = 0; i < 6; i++)
                    {
                        <div class="chat-row-skeleton">
                            <MudSkeleton Height="56px" Width="56px" Class="chat-avatar-skeleton" />
                            <div class="chat-row-skeleton-content">
                                <MudSkeleton Height="18px" Width="42%" />
                                <MudSkeleton Height="14px" Width="70%" />
                            </div>
                        </div>
                    }
                </div>
            }
            else if (!FilteredItems.Any())
            {
                <div class="chats-empty">
                    <MudAvatar Size="Size.Large" Class="chats-empty-icon">
                        <MudIcon Icon="@Icons.Material.Filled.ChatBubbleOutline" />
                    </MudAvatar>

                    @if (string.IsNullOrWhiteSpace(_search))
                    {
                        <MudText Typo="Typo.h6" Class="fw-bold">No chats yet</MudText>
                        <MudText Class="chats-empty-sub">Your conversations will appear here.</MudText>
                    }
                    else
                    {
                        <MudText Typo="Typo.h6" Class="fw-bold">Nothing found</MudText>
                        <MudText Class="chats-empty-sub">No chats match your search.</MudText>
                    }
                </div>
            }
            else
            {
                @foreach (var c in FilteredItems)
                {
                    <div class="chat-row" @onclick="@(() => OpenChat(c.ConversationId))">
                        <div class="chat-avatar">
                            @GetInitial(c.Title)
                        </div>

                        <div class="chat-main">
                            <div class="chat-top">
                                <div class="chat-title">@c.Title</div>
                                <div class="chat-time">@FormatChatDate(c.LastAt)</div>
                            </div>

                            <div class="chat-bottom">
                                <div class="chat-preview">@GetPreview(c)</div>
                            </div>
                        </div>
                    </div>
                }
            }
        </div>
    </MudPaper>
</MudContainer>

<style>
    .chats-shell {
        border-radius: 24px;
        background: rgba(255,255,255,.94);
        border: 1px solid rgba(15,23,42,.06);
        box-shadow: 0 16px 40px rgba(15,23,42,.05);
        overflow: hidden;
    }

    .chats-header {
        padding: 18px 18px 14px 18px;
        border-bottom: 1px solid rgba(15,23,42,.06);
        background: linear-gradient(180deg, rgba(99,102,241,.06), rgba(99,102,241,0));
    }

    .chats-search {
        margin-top: 12px;
    }

    .chats-list {
        display: flex;
        flex-direction: column;
    }

    .chat-row {
        display: flex;
        align-items: center;
        gap: 14px;
        padding: 14px 18px;
        cursor: pointer;
        transition: background .16s ease, transform .16s ease;
        border-bottom: 1px solid rgba(15,23,42,.05);
    }

    .chat-row:last-child {
        border-bottom: none;
    }

    .chat-row:hover {
        background: rgba(79,70,229,.05);
    }

    .chat-avatar {
        width: 56px;
        height: 56px;
        border-radius: 18px;
        display: flex;
        align-items: center;
        justify-content: center;
        background: linear-gradient(135deg, rgba(79,70,229,.14), rgba(99,102,241,.10));
        color: #4338ca;
        font-weight: 950;
        font-size: 1rem;
        border: 1px solid rgba(79,70,229,.10);
        flex: 0 0 auto;
    }

    .chat-main {
        min-width: 0;
        flex: 1 1 auto;
    }

    .chat-top {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 12px;
    }

    .chat-title {
        min-width: 0;
        color: #111827;
        font-weight: 900;
        font-size: 1rem;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
    }

    .chat-time {
        flex: 0 0 auto;
        color: rgba(17,24,39,.46);
        font-size: .8rem;
        font-weight: 800;
        white-space: nowrap;
    }

    .chat-bottom {
        margin-top: 4px;
    }

    .chat-preview {
        color: rgba(17,24,39,.62);
        font-size: .92rem;
        line-height: 1.35;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
    }

    .chats-empty {
        padding: 52px 24px;
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 10px;
        text-align: center;
    }

    .chats-empty-icon {
        background: linear-gradient(135deg, rgba(79,70,229,.12), rgba(99,102,241,.08));
        color: #4338ca;
    }

    .chats-empty-sub {
        color: rgba(17,24,39,.60);
    }

    .chats-loading {
        padding: 8px 0;
    }

    .chat-row-skeleton {
        display: flex;
        align-items: center;
        gap: 14px;
        padding: 14px 18px;
        border-bottom: 1px solid rgba(15,23,42,.05);
    }

    .chat-avatar-skeleton {
        border-radius: 18px;
        flex: 0 0 auto;
    }

    .chat-row-skeleton-content {
        flex: 1 1 auto;
        display: flex;
        flex-direction: column;
        gap: 8px;
    }

    @@media (max-width: 760px) {
        .chat-row {
            padding: 12px 14px;
            gap: 12px;
        }

        .chat-avatar {
            width: 50px;
            height: 50px;
            border-radius: 16px;
        }

        .chats-header {
            padding: 16px 14px 12px 14px;
        }
    }
</style>

@code {
    [CascadingParameter] public Task<AuthenticationState> AuthenticationStateTask { get; set; } = default!;

    private bool _loading = true;
    private List<Row> _items = new();
    private string _search = string.Empty;

    private IEnumerable<Row> FilteredItems
    {
        get
        {
            IEnumerable<Row> query = _items;

            if (!string.IsNullOrWhiteSpace(_search))
            {
                var term = _search.Trim().ToLowerInvariant();
                query = query.Where(x =>
                    x.Title.ToLowerInvariant().Contains(term) ||
                    (!string.IsNullOrWhiteSpace(x.LastMessage) && x.LastMessage.ToLowerInvariant().Contains(term)));
            }

            return query.OrderByDescending(x => x.LastAt).ToList();
        }
    }

    private sealed class Row
    {
        public int ConversationId { get; set; }
        public string Title { get; set; } = "Chat";
        public string? LastMessage { get; set; }
        public bool HasAttachments { get; set; }
        public bool IsOrderMessage { get; set; }
        public bool IsDeliveryMessage { get; set; }
        public DateTime LastAt { get; set; }
    }

    protected override async Task OnInitializedAsync()
    {
        _loading = true;

        var auth = await AuthenticationStateTask;
        var me = await UserManager.GetUserAsync(auth.User);

        if (me == null)
        {
            _items = new();
            _loading = false;
            return;
        }

        await using var db = await DbFactory.CreateDbContextAsync();

        var conversations = await db.Conversations.AsNoTracking()
            .Where(x => x.UserAId == me.Id || x.UserBId == me.Id)
            .OrderByDescending(x => x.LastMessageAtUtc ?? x.CreatedAtUtc)
            .Take(100)
            .ToListAsync();

        var ids = conversations.Select(x => x.Id).ToList();

        var lastMessages = await db.Messages.AsNoTracking()
            .Include(x => x.Attachments)
            .Where(m => ids.Contains(m.ConversationId))
            .GroupBy(m => m.ConversationId)
            .Select(g => g.OrderByDescending(x => x.CreatedAtUtc).FirstOrDefault())
            .ToListAsync();

        var otherIds = conversations
            .Select(x => x.UserAId == me.Id ? x.UserBId : x.UserAId)
            .Distinct()
            .ToList();

        var users = await db.Users.AsNoTracking()
            .Where(u => otherIds.Contains(u.Id))
            .Select(u => new { u.Id, u.UserName })
            .ToListAsync();

        var userMap = users.ToDictionary(x => x.Id, x => x.UserName);
        var lastMap = lastMessages.Where(x => x != null).ToDictionary(x => x!.ConversationId, x => x!);

        _items = conversations.Select(c =>
        {
            var otherId = c.UserAId == me.Id ? c.UserBId : c.UserAId;

            userMap.TryGetValue(otherId, out var userName);
            lastMap.TryGetValue(c.Id, out var lm);

            return new Row
            {
                ConversationId = c.Id,
                Title = !string.IsNullOrWhiteSpace(userName) ? $"@{userName}" : "Chat",
                LastMessage = lm?.Body,
                HasAttachments = lm?.Attachments.Any() == true,
                IsOrderMessage = lm?.OrderId != null,
                IsDeliveryMessage = lm?.IsOrderDelivery == true,
                LastAt = c.LastMessageAtUtc ?? c.CreatedAtUtc
            };
        }).ToList();

        _loading = false;
    }

    private void OpenChat(int id)
    {
        Nav.NavigateTo($"/chat/{id}");
    }

    private static string GetInitial(string? title)
    {
        if (string.IsNullOrWhiteSpace(title))
            return "C";

        var clean = title.Trim().TrimStart('@');
        return string.IsNullOrWhiteSpace(clean) ? "C" : clean.Substring(0, 1).ToUpperInvariant();
    }

    private static string FormatChatDate(DateTime utc)
    {
        var local = utc.ToLocalTime();
        var today = DateTime.Now.Date;
        var date = local.Date;

        if (date == today)
            return local.ToString("HH:mm");

        if (date == today.AddDays(-1))
            return "Yesterday";

        return local.ToString("dd.MM.yyyy");
    }

    private static string GetPreview(Row row)
    {
        if (row.IsDeliveryMessage)
            return "Delivery files sent";

        if (row.IsOrderMessage && string.IsNullOrWhiteSpace(row.LastMessage) && !row.HasAttachments)
            return "Order update";

        if (row.HasAttachments && string.IsNullOrWhiteSpace(row.LastMessage))
            return "Attachment";

        if (row.HasAttachments && !string.IsNullOrWhiteSpace(row.LastMessage))
            return $"{row.LastMessage} · Attachment";

        if (!string.IsNullOrWhiteSpace(row.LastMessage))
            return row.LastMessage;

        return "Open conversation";
    }
}