@page "/"
@using SkillGo.Data
@using SkillGo.Repository.IRepository
@using MudBlazor
@inject ICategoryRepository CategoryRepo
@inject NavigationManager Nav

<PageTitle>SkillGo</PageTitle>

<MudContainer MaxWidth="MaxWidth.Large" Class="mt-6">
    <div class="hero">
        <div class="hero-inner">
            <div class="hero-copy">
                <div class="hero-badge">SkillGo Marketplace</div>
                <div class="hero-title">Find the right freelancer for your project</div>
                <div class="hero-sub">
                    Browse services by category, compare offers and start working with freelancers faster.
                </div>

                <div class="hero-actions">
                    <MudButton Variant="Variant.Filled"
                               Color="Color.Primary"
                               Class="btn-strong"
                               Href="/services/category">
                        Browse services
                    </MudButton>

                    <MudButton Variant="Variant.Outlined"
                               Class="btn-soft"
                               Href="/services/create">
                        Create service
                    </MudButton>
                </div>
            </div>

            <div class="hero-panel">
                <div class="panel-title">Start with a category</div>
                <div class="panel-sub">Choose the area you need and explore services with filters, ratings and prices.</div>

                <div class="panel-points">
                    <div class="panel-point">
                        <div class="point-dot"></div>
                        <div class="point-text">Browse categories</div>
                    </div>

                    <div class="panel-point">
                        <div class="point-dot"></div>
                        <div class="point-text">Compare services</div>
                    </div>

                    <div class="panel-point">
                        <div class="point-dot"></div>
                        <div class="point-text">Order and chat</div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="section-head mt-6">
        <div>
            <div class="section-title">Categories</div>
            <div class="section-sub">Choose a category to browse available services.</div>
        </div>

        <MudButton Variant="Variant.Text" Class="section-link" Href="/services/category">
            View all services
        </MudButton>
    </div>

    @if (_loading)
    {
        <MudGrid Spacing="4" Class="mt-2">
            @for (int i = 0; i < 8; i++)
            {
                <MudItem xs="12" sm="6" md="4" lg="3">
                    <div class="cat-card skeleton"></div>
                </MudItem>
            }
        </MudGrid>
    }
    else if (_categories == null || _categories.Count == 0)
    {
        <div class="empty-shell mt-3">
            <div class="empty-title">No categories yet</div>
            <div class="empty-sub">They will appear here once they are added.</div>
        </div>
    }
    else
    {
        <MudGrid Spacing="4" Class="mt-2">
            @foreach (var c in _categories)
            {
                <MudItem xs="12" sm="6" md="4" lg="3">
                    <a class="cat-link" href="@($"/services/category/{c.Id}")">
                        <div class="cat-card">
                            <div class="cat-top">
                                <div class="cat-title">@c.Name</div>
                                <div class="cat-arrow">
                                    <MudIcon Icon="@Icons.Material.Filled.ArrowForward" Size="Size.Small" />
                                </div>
                            </div>

                            <div class="cat-sub">
                                Browse services in this category
                            </div>
                        </div>
                    </a>
                </MudItem>
            }
        </MudGrid>
    }
</MudContainer>

<style>
    .hero {
        border-radius: 30px;
        border: 1px solid rgba(99,102,241,.16);
        background: linear-gradient(135deg,#eef2ff 0%,#e8ecff 55%,#e4e8ff 100%);
        box-shadow: 0 20px 50px rgba(15,23,42,.06);
        position: relative;
        overflow: hidden;
    }

        .hero::before {
            content: "";
            position: absolute;
            inset: -60px auto auto -40px;
            width: 260px;
            height: 260px;
            background: radial-gradient(circle at center, rgba(255,255,255,.55), transparent 70%);
            pointer-events: none;
        }

        .hero::after {
            content: "";
            position: absolute;
            right: -40px;
            bottom: -60px;
            width: 300px;
            height: 220px;
            background: radial-gradient(circle at center, rgba(255,255,255,.42), transparent 70%);
            pointer-events: none;
        }

    .hero-inner {
        position: relative;
        z-index: 1;
        padding: 32px;
        display: grid;
        grid-template-columns: minmax(0,1.35fr) 360px;
        gap: 20px;
        align-items: stretch;
    }

    .hero-copy {
        min-width: 0;
        display: flex;
        flex-direction: column;
        justify-content: center;
    }

    .hero-badge {
        align-self: flex-start;
        display: inline-flex;
        align-items: center;
        min-height: 34px;
        padding: 7px 12px;
        border-radius: 999px;
        background: rgba(255,255,255,.72);
        border: 1px solid rgba(0,0,0,.08);
        color: rgba(17,24,39,.82);
        font-size: .85rem;
        font-weight: 900;
        letter-spacing: .2px;
    }

    .hero-title {
        margin-top: 16px;
        font-weight: 950;
        color: #111827;
        font-size: 2.35rem;
        line-height: 1.02;
        letter-spacing: -.03em;
        max-width: 760px;
    }

    .hero-sub {
        margin-top: 14px;
        color: rgba(17,24,39,.68);
        font-size: 1.03rem;
        line-height: 1.5;
        max-width: 700px;
    }

    .hero-actions {
        margin-top: 22px;
        display: flex;
        flex-wrap: wrap;
        gap: 12px;
    }

    .btn-strong {
        border-radius: 14px;
        font-weight: 900;
        letter-spacing: .2px;
        padding: 10px 16px;
    }

    .btn-soft {
        border-radius: 14px;
        font-weight: 900;
        letter-spacing: .2px;
        padding: 10px 16px;
        background: rgba(255,255,255,.55);
        border: 1px solid rgba(0,0,0,.08);
    }

    .hero-panel {
        border-radius: 24px;
        border: 1px solid rgba(255,255,255,.65);
        background: rgba(255,255,255,.62);
        backdrop-filter: blur(8px);
        padding: 22px;
        box-shadow: inset 0 1px 0 rgba(255,255,255,.4);
        display: flex;
        flex-direction: column;
        justify-content: center;
    }

    .panel-title {
        font-weight: 950;
        color: #111827;
        font-size: 1.15rem;
        letter-spacing: .2px;
    }

    .panel-sub {
        margin-top: 8px;
        color: rgba(17,24,39,.65);
        line-height: 1.4;
    }

    .panel-points {
        margin-top: 18px;
        display: grid;
        gap: 12px;
    }

    .panel-point {
        display: flex;
        align-items: center;
        gap: 10px;
        min-width: 0;
    }

    .point-dot {
        width: 10px;
        height: 10px;
        border-radius: 999px;
        background: #4f46e5;
        box-shadow: 0 0 0 6px rgba(79,70,229,.10);
        flex: 0 0 auto;
    }

    .point-text {
        font-weight: 800;
        color: #111827;
        min-width: 0;
    }

    .section-head {
        display: flex;
        justify-content: space-between;
        gap: 16px;
        align-items: end;
        flex-wrap: wrap;
    }

    .section-title {
        font-weight: 950;
        color: #111827;
        font-size: 1.35rem;
        letter-spacing: .2px;
    }

    .section-sub {
        color: rgba(17,24,39,.62);
        margin-top: 6px;
        line-height: 1.35;
    }

    .section-link {
        font-weight: 900;
        letter-spacing: .2px;
    }

    .cat-link {
        display: block;
        text-decoration: none;
        color: inherit;
    }

    .cat-card {
        height: 196px;
        border-radius: 24px;
        padding: 24px;
        background: linear-gradient(135deg,#eef2ff,#e5e9ff);
        display: flex;
        flex-direction: column;
        justify-content: space-between;
        gap: 10px;
        box-shadow: 0 14px 30px rgba(99,102,241,.14);
        transition: transform .18s ease, box-shadow .18s ease, border-color .18s ease;
        position: relative;
        overflow: hidden;
        cursor: pointer;
        border: 1px solid rgba(99,102,241,.10);
    }

        .cat-card::before {
            content: "";
            position: absolute;
            inset: -40% -60%;
            background: radial-gradient(circle at 30% 30%, rgba(255,255,255,.45), transparent 55%);
            transform: rotate(12deg);
            opacity: .85;
            pointer-events: none;
        }

    .cat-link:hover .cat-card {
        transform: translateY(-6px);
        box-shadow: 0 24px 50px rgba(99,102,241,.22);
        border-color: rgba(99,102,241,.18);
    }

    .cat-top {
        position: relative;
        z-index: 1;
        display: flex;
        justify-content: space-between;
        gap: 12px;
        align-items: flex-start;
    }

    .cat-title {
        color: #111827;
        font-weight: 950;
        font-size: 1.18rem;
        line-height: 1.12;
        word-break: break-word;
        letter-spacing: .2px;
    }

    .cat-arrow {
        width: 36px;
        height: 36px;
        border-radius: 999px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        background: rgba(255,255,255,.7);
        color: #111827;
        border: 1px solid rgba(0,0,0,.08);
        flex: 0 0 auto;
    }

    .cat-sub {
        position: relative;
        z-index: 1;
        color: rgba(17,24,39,.65);
        font-size: .95rem;
        line-height: 1.35;
        max-width: 220px;
    }

    .empty-shell {
        border-radius: 24px;
        border: 1px solid rgba(0,0,0,.07);
        background: #fff;
        box-shadow: 0 18px 46px rgba(15,23,42,.05);
        padding: 30px;
        text-align: center;
    }

    .empty-title {
        font-weight: 950;
        color: #111827;
        font-size: 1.1rem;
    }

    .empty-sub {
        color: rgba(17,24,39,.65);
        margin-top: 8px;
        line-height: 1.35;
    }

    .skeleton {
        background: #fff;
        border-radius: 24px;
        position: relative;
        overflow: hidden;
    }

        .skeleton::before {
            content: "";
            position: absolute;
            inset: 0;
            background: linear-gradient(90deg,#f3f4f6,#fafafa,#f3f4f6);
            background-size: 200% 100%;
            animation: shimmer 1.2s infinite linear;
        }

    @@keyframes shimmer {
        0% {
            background-position: 0% 0;
        }

        100% {
            background-position: 200% 0;
        }
    }

    @@media (max-width: 1100px) {
        .hero-inner {
            grid-template-columns: minmax(0,1fr);
        }
    }

    @@media (max-width: 700px) {
        .hero-inner {
            padding: 24px;
        }

        .hero-title {
            font-size: 1.95rem;
        }
    }
</style>

@code {
    private List<Category>? _categories;
    private bool _loading = true;

    protected override async Task OnInitializedAsync()
    {
        _categories = (await CategoryRepo.GetAllAsync()).ToList();
        _loading = false;
    }
}