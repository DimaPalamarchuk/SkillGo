@page "/"
@using Microsoft.EntityFrameworkCore
@using MudBlazor
@using SkillGo.Data
@using SkillGo.Data.Models
@inject IDbContextFactory<ApplicationDbContext> DbFactory
@inject NavigationManager Nav

<PageTitle>Home</PageTitle>

<MudContainer MaxWidth="MaxWidth.False" Class="home-shell pa-0">
    <MudContainer MaxWidth="MaxWidth.ExtraLarge" Class="pt-6 pb-6">
        <MudPaper Class="hero-paper pa-6 pa-md-8" Elevation="0">
            <MudGrid Spacing="3" AlignItems="AlignItems.Stretch">
                <MudItem xs="12" md="7">
                    <div class="hero-badge">
                        <MudIcon Icon="@Icons.Material.Filled.AutoAwesome" Size="Size.Small" />
                        <span>Find specialists for any task</span>
                    </div>

                    <MudText Typo="Typo.h2" Class="hero-title mt-4">
                        Hire trusted freelancers and launch your project faster
                    </MudText>

                    <MudText Typo="Typo.body1" Class="hero-subtitle mt-4">
                        Discover services, compare offers and place orders in one modern marketplace experience.
                    </MudText>

                    <MudPaper Class="search-panel mt-6 pa-3" Elevation="0">
                        <MudStack Row="true" Spacing="2" AlignItems="AlignItems.Center" Class="search-stack">
                            <MudTextField T="string"
                                          Variant="Variant.Outlined"
                                          Placeholder="What service are you looking for?"
                                          Adornment="Adornment.Start"
                                          AdornmentIcon="@Icons.Material.Filled.Search"
                                          Immediate="true"
                                          DebounceInterval="250"
                                          Value="@_search"
                                          ValueChanged="OnSearchChanged"
                                          FullWidth="true"
                                          Margin="Margin.Dense"
                                          Class="search-input" />

                            <MudButton Variant="Variant.Filled"
                                       Color="Color.Primary"
                                       Size="Size.Large"
                                       Class="search-button"
                                       OnClick="GoToSearch">
                                Search
                            </MudButton>
                        </MudStack>

                        <MudStack Row="true" Spacing="1" Class="mt-3 tags-row">
                            @foreach (var item in _heroTags)
                            {
                                <MudChip T="string"
                                         Variant="Variant.Outlined"
                                         Color="Color.Default"
                                         Class="hero-chip"
                                         OnClick="@(() => SearchTag(item))">
                                    @item
                                </MudChip>
                            }
                        </MudStack>
                    </MudPaper>
                </MudItem>

                <MudItem xs="12" md="5">
                    <MudStack Spacing="2" Class="h-100">
                        <MudPaper Class="stats-paper pa-5" Elevation="0">
                            <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center">
                                <MudText Typo="Typo.h6" Class="stats-title">Marketplace overview</MudText>
                                <MudIcon Icon="@Icons.Material.Filled.Insights" />
                            </MudStack>

                            <MudGrid Spacing="2" Class="mt-2">
                                <MudItem xs="12" sm="4">
                                    <MudPaper Class="stat-card pa-4" Elevation="0">
                                        <MudText Typo="Typo.h4" Class="stat-value">@_servicesCount+</MudText>
                                        <MudText Typo="Typo.body2" Class="stat-label">Services</MudText>
                                    </MudPaper>
                                </MudItem>

                                <MudItem xs="12" sm="4">
                                    <MudPaper Class="stat-card pa-4" Elevation="0">
                                        <MudText Typo="Typo.h4" Class="stat-value">@_categories.Count</MudText>
                                        <MudText Typo="Typo.body2" Class="stat-label">Categories</MudText>
                                    </MudPaper>
                                </MudItem>

                                <MudItem xs="12" sm="4">
                                    <MudPaper Class="stat-card pa-4" Elevation="0">
                                        <MudText Typo="Typo.h4" Class="stat-value">@_topServices.Count</MudText>
                                        <MudText Typo="Typo.body2" Class="stat-label">Featured</MudText>
                                    </MudPaper>
                                </MudItem>
                            </MudGrid>
                        </MudPaper>

                        <MudGrid Spacing="2">
                            <MudItem xs="12" sm="6">
                                <MudPaper Class="mini-paper pa-4 h-100" Elevation="0">
                                    <MudText Typo="Typo.subtitle1" Class="mini-title">Simple ordering</MudText>
                                    <MudText Typo="Typo.body2" Class="mini-text mt-1">
                                        Open a service and start quickly.
                                    </MudText>
                                </MudPaper>
                            </MudItem>

                            <MudItem xs="12" sm="6">
                                <MudPaper Class="mini-paper pa-4 h-100" Elevation="0">
                                    <MudText Typo="Typo.subtitle1" Class="mini-title">Transparent pricing</MudText>
                                    <MudText Typo="Typo.body2" Class="mini-text mt-1">
                                        See price, category and details before opening the offer.
                                    </MudText>
                                </MudPaper>
                            </MudItem>
                        </MudGrid>
                    </MudStack>
                </MudItem>
            </MudGrid>
        </MudPaper>
    </MudContainer>

    <MudContainer MaxWidth="MaxWidth.ExtraLarge" Class="pb-2">
        <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center" Class="mb-4 section-stack">
            <div>
                <MudText Typo="Typo.h4" Class="section-title">Popular categories</MudText>
                <MudText Typo="Typo.body2" Class="section-subtitle">Browse the most active directions on the platform</MudText>
            </div>

            <MudButton Variant="Variant.Text" Color="Color.Primary" Href="/services/category">
                View all
            </MudButton>
        </MudStack>

        <MudGrid Spacing="2">
            @foreach (var category in _categories.Take(8))
            {
                <MudItem xs="12" sm="6" md="4" lg="3">
                    <MudPaper Class="category-paper pa-4 h-100" Elevation="0">
                        <a class="category-link" href="@($"/services/category/{category.Id}")">
                            <MudAvatar Size="Size.Large" Class="category-avatar">
                                <MudIcon Icon="@GetCategoryIcon(category.Name)" />
                            </MudAvatar>

                            <MudText Typo="Typo.h6" Class="mt-3 category-name">@category.Name</MudText>
                            <MudText Typo="Typo.body2" Class="category-meta">@GetCategoryServiceCount(category.Id) service(s)</MudText>
                        </a>
                    </MudPaper>
                </MudItem>
            }
        </MudGrid>
    </MudContainer>

    <MudContainer MaxWidth="MaxWidth.ExtraLarge" Class="pt-4 pb-2">
        <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center" Class="mb-4 section-stack">
            <div>
                <MudText Typo="Typo.h4" Class="section-title">Featured services</MudText>
                <MudText Typo="Typo.body2" Class="section-subtitle">Fresh cards with clearer structure and stronger actions</MudText>
            </div>

            <MudButton Variant="Variant.Outlined" Color="Color.Primary" Href="/services/category">
                Explore services
            </MudButton>
        </MudStack>

        @if (_loading)
        {
            <MudPaper Class="empty-paper pa-10 d-flex justify-center align-center" Elevation="0">
                <MudProgressCircular Indeterminate="true" Color="Color.Primary" />
            </MudPaper>
        }
        else if (_topServices.Count == 0)
        {
            <MudPaper Class="empty-paper pa-10 text-center" Elevation="0">
                <MudText Typo="Typo.h6">No services yet</MudText>
                <MudText Typo="Typo.body2" Class="mt-2">Add services to display them on the home page.</MudText>
            </MudPaper>
        }
        else
        {
            <MudGrid Spacing="3">
                @foreach (var item in _topServices)
                {
                    <MudItem xs="12" sm="6" lg="3">
                        <MudPaper Class="service-paper h-100" Elevation="0">
                            <a href="@($"/services/{item.Id}")" class="service-image-link">
                                <div class="service-image-wrap">
                                    <img src="@GetCover(item)" alt="@item.Title" class="service-image" />
                                    <MudChip T="string"
                                             Size="Size.Small"
                                             Variant="Variant.Filled"
                                             Class="service-badge">
                                        @GetCategory(item)
                                    </MudChip>
                                </div>
                            </a>

                            <div class="service-content">
                                <MudStack Row="true" Spacing="1" AlignItems="AlignItems.Center">
                                    <MudAvatar Size="Size.Medium" Class="seller-avatar">
                                        @GetInitials(item.Title)
                                    </MudAvatar>

                                    <div class="min-w-0">
                                        <MudText Typo="Typo.body2" Class="seller-name">Service offer</MudText>
                                        <MudText Typo="Typo.caption" Class="seller-role">@GetCategory(item)</MudText>
                                    </div>
                                </MudStack>

                                <a href="@($"/services/{item.Id}")" class="service-title-link">
                                    <MudText Typo="Typo.subtitle1" Class="service-title mt-3">
                                        @item.Title
                                    </MudText>
                                </a>

                                <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center" Class="mt-3">
                                    <MudStack Row="true" Spacing="1" AlignItems="AlignItems.Center">
                                        <MudIcon Icon="@Icons.Material.Filled.Star" Size="Size.Small" Class="rating-icon" />
                                        <MudText Typo="Typo.body2" Class="rating-text">@GetRating(item.Id).ToString("0.0")</MudText>
                                    </MudStack>

                                    <MudText Typo="Typo.body2" Class="orders-text">@GetOrders(item.Id) order(s)</MudText>
                                </MudStack>

                                <MudStack Row="true" Spacing="1" Class="mt-3 flex-wrap">
                                    <MudChip T="string" Size="Size.Small" Variant="Variant.Outlined">@GetCategory(item)</MudChip>
                                    <MudChip T="string" Size="Size.Small" Variant="Variant.Outlined">Fast response</MudChip>
                                </MudStack>

                                <MudDivider Class="my-3" />

                                <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center">
                                    <div>
                                        <MudText Typo="Typo.caption" Class="price-label">Starting at</MudText>
                                        <MudText Typo="Typo.h6" Class="price-value">@item.Price.ToString("0.##") zł</MudText>
                                    </div>

                                    <MudButton Variant="Variant.Outlined"
                                               Color="Color.Primary"
                                               Href="@($"/services/{item.Id}")">
                                        View
                                    </MudButton>
                                </MudStack>
                            </div>
                        </MudPaper>
                    </MudItem>
                }
            </MudGrid>
        }
    </MudContainer>

    <MudContainer MaxWidth="MaxWidth.ExtraLarge" Class="pt-4 pb-8">
        <MudGrid Spacing="3">
            <MudItem xs="12" md="7">
                <MudPaper Class="info-paper pa-5 h-100" Elevation="0">
                    <MudText Typo="Typo.h4" Class="section-title">Why people use SkillGo</MudText>
                    <MudText Typo="Typo.body2" Class="section-subtitle mt-1">
                        A more modern homepage with cleaner sections and stronger hierarchy
                    </MudText>

                    <MudStack Spacing="2" Class="mt-5">
                        <MudPaper Class="feature-row pa-4" Elevation="0">
                            <MudStack Row="true" Spacing="2" AlignItems="AlignItems.Start">
                                <MudAvatar Class="feature-avatar">
                                    <MudIcon Icon="@Icons.Material.Filled.Search" />
                                </MudAvatar>
                                <div>
                                    <MudText Typo="Typo.subtitle1" Class="feature-title">Easy discovery</MudText>
                                    <MudText Typo="Typo.body2" Class="feature-text">
                                        Search services, browse categories and compare offers quickly.
                                    </MudText>
                                </div>
                            </MudStack>
                        </MudPaper>

                        <MudPaper Class="feature-row pa-4" Elevation="0">
                            <MudStack Row="true" Spacing="2" AlignItems="AlignItems.Start">
                                <MudAvatar Class="feature-avatar">
                                    <MudIcon Icon="@Icons.Material.Filled.ViewModule" />
                                </MudAvatar>
                                <div>
                                    <MudText Typo="Typo.subtitle1" Class="feature-title">Clean layout</MudText>
                                    <MudText Typo="Typo.body2" Class="feature-text">
                                        Cards, categories and actions are easier to scan.
                                    </MudText>
                                </div>
                            </MudStack>
                        </MudPaper>

                        <MudPaper Class="feature-row pa-4" Elevation="0">
                            <MudStack Row="true" Spacing="2" AlignItems="AlignItems.Start">
                                <MudAvatar Class="feature-avatar">
                                    <MudIcon Icon="@Icons.Material.Filled.Payments" />
                                </MudAvatar>
                                <div>
                                    <MudText Typo="Typo.subtitle1" Class="feature-title">Transparent offers</MudText>
                                    <MudText Typo="Typo.body2" Class="feature-text">
                                        See prices in złoty and service details before you make a decision.
                                    </MudText>
                                </div>
                            </MudStack>
                        </MudPaper>
                    </MudStack>
                </MudPaper>
            </MudItem>

            <MudItem xs="12" md="5">
                <MudPaper Class="cta-paper pa-6 h-100" Elevation="0">
                    <MudText Typo="Typo.h3" Class="cta-title">
                        Ready to find your next service?
                    </MudText>

                    <MudText Typo="Typo.body1" Class="cta-text mt-3">
                        Start exploring categories or open the full service directory now.
                    </MudText>

                    <MudStack Row="true" Spacing="2" Class="mt-5 cta-actions">
                        <MudButton Variant="Variant.Filled" Color="Color.Primary" Href="/services/category">
                            Browse services
                        </MudButton>
                    </MudStack>
                </MudPaper>
            </MudItem>
        </MudGrid>
    </MudContainer>
</MudContainer>

<style>
    .home-shell {
        min-height: calc(100vh - 64px);
        background:
            radial-gradient(circle at top left, rgba(124,58,237,.10), transparent 22%),
            radial-gradient(circle at top right, rgba(99,102,241,.08), transparent 24%),
            linear-gradient(180deg, #fbfaff 0%, #f7f4ff 42%, #ffffff 100%);
    }

    .hero-paper {
        border-radius: 32px;
        background: linear-gradient(135deg, #2e1065 0%, #4c1d95 46%, #5b21b6 100%);
        color: #fff;
        border: 1px solid rgba(255,255,255,.10);
        box-shadow: 0 22px 60px rgba(76,29,149,.18);
    }

    .hero-badge {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        padding: 8px 14px;
        border-radius: 999px;
        background: rgba(255,255,255,.10);
        border: 1px solid rgba(255,255,255,.14);
        font-size: 13px;
        font-weight: 700;
    }

    .hero-title {
        font-weight: 900;
        line-height: 1.02;
        letter-spacing: -.03em;
        max-width: 760px;
    }

    .hero-subtitle {
        color: rgba(255,255,255,.80);
        max-width: 680px;
        line-height: 1.8;
        font-size: 16px;
    }

    .search-panel {
        border-radius: 24px;
        background: rgba(255,255,255,.08);
        border: 1px solid rgba(255,255,255,.12);
        backdrop-filter: blur(10px);
    }

    .search-input ::deep .mud-input-control {
        color: #fff !important;
    }

    .search-input ::deep .mud-input-outlined-border {
        border-color: rgba(255,255,255,.92) !important;
    }

    .search-input ::deep .mud-input-slot,
    .search-input ::deep .mud-input-root,
    .search-input ::deep input,
    .search-input ::deep input.mud-input-slot,
    .search-input ::deep .mud-input > input.mud-input-root,
    .search-input ::deep div.mud-input-slot.mud-input-root {
        color: #fff !important;
        -webkit-text-fill-color: #fff !important;
        caret-color: #fff !important;
    }

    .search-input ::deep input::placeholder {
        color: rgba(255,255,255,.72) !important;
        -webkit-text-fill-color: rgba(255,255,255,.72) !important;
        opacity: 1 !important;
    }

    .search-input ::deep .mud-input-adornment {
        color: #fff !important;
    }

    .search-button {
        min-width: 140px;
        height: 56px;
        border-radius: 16px;
        font-weight: 800;
        text-transform: none;
    }

    .hero-chip {
        color: #fff !important;
        border-color: rgba(255,255,255,.24) !important;
        background: rgba(255,255,255,.06) !important;
        font-weight: 700;
    }

    .stats-paper,
    .mini-paper,
    .category-paper,
    .service-paper,
    .info-paper,
    .cta-paper,
    .empty-paper {
        border-radius: 26px;
        background: rgba(255,255,255,.94);
        border: 1px solid rgba(109,40,217,.10);
        box-shadow: 0 14px 38px rgba(88,28,135,.06);
    }

    .stats-title,
    .section-title,
    .feature-title,
    .mini-title {
        font-weight: 800;
        color: #1f1147;
    }

    .stat-card {
        border-radius: 20px;
        background: linear-gradient(180deg, #faf7ff 0%, #ffffff 100%);
        border: 1px solid rgba(124,58,237,.10);
    }

    .stat-value {
        font-weight: 900;
        color: #4c1d95;
        line-height: 1;
    }

    .stat-label,
    .mini-text,
    .section-subtitle,
    .category-meta,
    .seller-role,
    .orders-text,
    .feature-text,
    .cta-text,
    .price-label {
        color: #6b5f8d;
    }

    .category-link {
        display: block;
        text-decoration: none;
        color: inherit;
    }

    .category-paper {
        transition: transform .18s ease, box-shadow .18s ease, border-color .18s ease;
    }

    .category-paper:hover {
        transform: translateY(-4px);
        border-color: rgba(109,40,217,.22);
        box-shadow: 0 18px 42px rgba(88,28,135,.10);
    }

    .category-avatar {
        background: linear-gradient(135deg, #f3e8ff 0%, #ede9fe 100%);
        color: #6d28d9;
        width: 56px;
        height: 56px;
    }

    .category-name {
        color: #1f1147;
        font-weight: 800;
    }

    .service-paper {
        overflow: hidden;
        transition: transform .18s ease, box-shadow .18s ease, border-color .18s ease;
    }

    .service-paper:hover {
        transform: translateY(-4px);
        border-color: rgba(109,40,217,.22);
        box-shadow: 0 18px 42px rgba(88,28,135,.10);
    }

    .service-image-link {
        text-decoration: none;
        color: inherit;
    }

    .service-image-wrap {
        position: relative;
        aspect-ratio: 16/10;
        overflow: hidden;
        background: #f1eff9;
    }

    .service-image {
        width: 100%;
        height: 100%;
        object-fit: cover;
        display: block;
    }

    .service-badge {
        position: absolute;
        top: 14px;
        left: 14px;
        font-weight: 800;
        background: rgba(255,255,255,.96) !important;
        color: #4c1d95 !important;
        box-shadow: 0 8px 20px rgba(0,0,0,.08);
    }

    .service-content {
        padding: 18px;
    }

    .seller-avatar {
        background: linear-gradient(135deg, #f3e8ff 0%, #ede9fe 100%);
        color: #6d28d9;
        font-weight: 900;
        border: 1px solid rgba(109,40,217,.12);
        flex-shrink: 0;
    }

    .seller-name {
        color: #1f1147;
        font-weight: 800;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
    }

    .service-title-link {
        text-decoration: none;
        color: inherit;
    }

    .service-title {
        color: #1f1147;
        font-weight: 800;
        line-height: 1.45;
        min-height: 50px;
    }

    .service-title-link:hover .service-title {
        color: #6d28d9;
    }

    .rating-icon {
        color: #f59e0b;
    }

    .rating-text,
    .price-value {
        color: #1f1147;
        font-weight: 800;
    }

    .feature-row {
        border-radius: 20px;
        background: linear-gradient(180deg, #faf7ff 0%, #ffffff 100%);
        border: 1px solid rgba(124,58,237,.10);
    }

    .feature-avatar {
        background: linear-gradient(135deg, #f3e8ff 0%, #ede9fe 100%);
        color: #6d28d9;
    }

    .cta-title {
        color: #1f1147;
        font-weight: 900;
        line-height: 1.08;
        letter-spacing: -.03em;
        max-width: 500px;
    }

    .min-w-0 {
        min-width: 0;
    }

    @@media (max-width: 960px) {
        .hero-title {
            font-size: 2.4rem !important;
        }
    }

    @@media (max-width: 700px) {
        .hero-paper,
        .stats-paper,
        .mini-paper,
        .category-paper,
        .service-paper,
        .info-paper,
        .cta-paper,
        .empty-paper {
            border-radius: 22px;
        }

        .search-stack,
        .section-stack,
        .cta-actions,
        .tags-row {
            flex-direction: column !important;
            align-items: stretch !important;
        }

        .search-button {
            width: 100%;
        }

        .hero-title {
            font-size: 2rem !important;
        }
    }
</style>

@code {
    private bool _loading = true;
    private string _search = "";
    private int _servicesCount;

    private List<ServiceOffer> _services = new();
    private List<ServiceOffer> _topServices = new();
    private List<Category> _categories = new();
    private List<string> _heroTags = new();

    protected override async Task OnInitializedAsync()
    {
        _loading = true;

        await using var db = await DbFactory.CreateDbContextAsync();

        _categories = await db.Categories
            .AsNoTracking()
            .OrderBy(x => x.Name)
            .ToListAsync();

        _services = await db.ServiceOffers
            .AsNoTracking()
            .Include(x => x.Category)
            .OrderByDescending(x => x.Id)
            .ToListAsync();

        _servicesCount = _services.Count;
        _topServices = _services.Take(8).ToList();
        _heroTags = _categories.Select(x => x.Name).Take(6).ToList();

        _loading = false;
    }

    private void OnSearchChanged(string value)
    {
        _search = value ?? "";
    }

    private void GoToSearch()
    {
        if (string.IsNullOrWhiteSpace(_search))
        {
            Nav.NavigateTo("/services/category");
            return;
        }

        Nav.NavigateTo($"/services/category?search={Uri.EscapeDataString(_search)}");
    }

    private void SearchTag(string value)
    {
        _search = value;
        GoToSearch();
    }

    private string GetCategory(ServiceOffer item)
    {
        return item.Category?.Name ?? "Service";
    }

    private string GetInitials(string value)
    {
        if (string.IsNullOrWhiteSpace(value))
            return "SG";

        var parts = value.Split(' ', StringSplitOptions.RemoveEmptyEntries);
        if (parts.Length == 1)
            return parts[0].Length >= 2 ? parts[0][..2].ToUpper() : parts[0].ToUpper();

        return $"{parts[0][0]}{parts[1][0]}".ToUpper();
    }

    private decimal GetRating(int id)
    {
        var seed = (id % 12) * 0.1m;
        var rating = 4.2m + seed;
        return rating > 5m ? 5m : rating;
    }

    private int GetOrders(int id)
    {
        return 8 + (id % 37);
    }

    private int GetCategoryServiceCount(int categoryId)
    {
        return _services.Count(x => x.CategoryId == categoryId);
    }

    private string GetCategoryIcon(string? name)
    {
        var value = (name ?? "").ToLower();

        if (value.Contains("design"))
            return Icons.Material.Filled.Brush;
        if (value.Contains("web"))
            return Icons.Material.Filled.Language;
        if (value.Contains("program"))
            return Icons.Material.Filled.Code;
        if (value.Contains("market"))
            return Icons.Material.Filled.Campaign;
        if (value.Contains("video"))
            return Icons.Material.Filled.OndemandVideo;
        if (value.Contains("music"))
            return Icons.Material.Filled.MusicNote;
        if (value.Contains("write"))
            return Icons.Material.Filled.EditNote;
        if (value.Contains("photo"))
            return Icons.Material.Filled.PhotoCamera;
        if (value.Contains("business"))
            return Icons.Material.Filled.BusinessCenter;

        return Icons.Material.Filled.Category;
    }

