@page "/orders/{OrderId:int}"
@attribute [Microsoft.AspNetCore.Authorization.Authorize]
@using Microsoft.AspNetCore.Components.Authorization
@using Microsoft.AspNetCore.Identity
@using Microsoft.EntityFrameworkCore
@using MudBlazor
@using SkillGo.Data
@using SkillGo.Data.Models
@using SkillGo.Data.Models.Orders
@using SkillGo.Repository.IRepository
@inject IDbContextFactory<ApplicationDbContext> DbFactory
@inject UserManager<ApplicationUser> UserManager
@inject NavigationManager Nav
@inject IDialogService DialogService
@inject ISnackbar Snackbar
@inject IOrderRepository OrderRepo

<PageTitle>Order</PageTitle>

<MudContainer MaxWidth="MaxWidth.Large" Class="mt-6">
    @if (_loading)
    {
        <MudGrid Spacing="4">
            <MudItem xs="12" md="8">
                <div class="shell skeleton"></div>
            </MudItem>
            <MudItem xs="12" md="4">
                <div class="side skeleton"></div>
            </MudItem>
        </MudGrid>
    }
    else if (_forbidden)
    {
        <MudPaper Class="state-shell" Elevation="0">
            <div class="state-title">Access denied</div>
            <div class="state-sub">You do not have access to this order.</div>
        </MudPaper>
    }
    else if (_order == null)
    {
        <MudPaper Class="state-shell" Elevation="0">
            <div class="state-title">Order not found</div>
            <div class="state-sub">The order may have been removed or never existed.</div>
        </MudPaper>
    }
    else
    {
        <div class="hero">
            <div class="hero-inner">
                <div class="hero-left">
                    <div class="hero-title">Order #@_order.Id</div>
                    <div class="hero-sub">@(_order.ServiceOffer?.Title ?? "Service")</div>
                </div>

                <MudChip T="string"
                         Size="Size.Medium"
                         Color="@StatusColor(_order.Status)"
                         Variant="Variant.Filled">
                    @_order.Status.ToString()
                </MudChip>
            </div>

            <div class="hero-stats">
                <div class="stat-chip">
                    <div class="stat-label">Amount</div>
                    <div class="stat-value">@_order.Amount.ToString("0.00") zł</div>
                </div>

                <div class="stat-chip">
                    <div class="stat-label">Escrow</div>
                    <div class="stat-value">@_order.EscrowAmount.ToString("0.00") zł</div>
                </div>

                <div class="stat-chip">
                    <div class="stat-label">Created</div>
                    <div class="stat-value small">@_order.CreatedAtUtc.ToString("yyyy-MM-dd HH:mm") UTC</div>
                </div>

                @if (_order.CompletedAtUtc != null)
                {
                    <div class="stat-chip">
                        <div class="stat-label">Completed</div>
                        <div class="stat-value small">@_order.CompletedAtUtc.Value.ToString("yyyy-MM-dd HH:mm") UTC</div>
                    </div>
                }
            </div>
        </div>

        <MudGrid Spacing="4" Class="mt-4">
            <MudItem xs="12" md="8">
                <div class="shell">
                    <div class="section-head">
                        <div class="section-title">Order actions</div>
                        <div class="section-sub">Open related pages or contact support.</div>
                    </div>

                    <div class="section-body">
                        <div class="actions">
                            <MudButton Variant="Variant.Filled"
                                       Color="Color.Primary"
                                       Class="btn-strong"
                                       OnClick="GoService"
                                       Disabled="@(_order.ServiceOfferId <= 0)">
                                View service
                            </MudButton>

                            <MudButton Variant="Variant.Outlined"
                                       Color="Color.Primary"
                                       Class="btn-strong"
                                       OnClick="GoChat">
                                Open chat
                            </MudButton>

                            <MudButton Variant="Variant.Outlined"
                                       Color="Color.Error"
                                       Class="btn-strong"
                                       OnClick="OpenDispute">
                                Report to admin
                            </MudButton>
                        </div>

                        @if (_order.Status == OrderStatus.Completed && _order.ReviewId == null && _meId == _order.BuyerId)
                        {
                            <div class="review-callout">
                                <div class="review-callout-title">Order completed</div>
                                <div class="review-callout-sub">Leave a review to support the freelancer’s profile.</div>

                                <MudButton Variant="Variant.Filled"
                                           Color="Color.Success"
                                           Class="btn-strong mt-3"
                                           OnClick="OpenReview">
                                    Leave review
                                </MudButton>
                            </div>
                        }
                    </div>
                </div>

                <div class="shell mt-4">
                    <div class="section-head">
                        <div class="section-title">Disputes</div>
                        <div class="section-sub">Reports related to this order.</div>
                    </div>

                    <div class="section-body">
                        @if (_disputes.Count == 0)
                        {
                            <div class="empty-inline">No disputes yet.</div>
                        }
                        else
                        {
                            <div class="disputes-list">
                                @foreach (var item in _disputes)
                                {
                                    <div class="dispute-card">
                                        <div class="dispute-top">
                                            <div class="dispute-id">Dispute #@item.Id</div>
                                            <MudChip T="string" Size="Size.Small" Variant="Variant.Filled">
                                                @item.Status.ToString()
                                            </MudChip>
                                        </div>

                                        <div class="dispute-subject">@item.Subject</div>
                                        <div class="dispute-date">@item.CreatedAtUtc.ToString("yyyy-MM-dd HH:mm") UTC</div>
                                    </div>
                                }
                            </div>
                        }
                    </div>
                </div>
            </MudItem>

            <MudItem xs="12" md="4">
                <div class="side">
                    <div class="side-title">Summary</div>
                    <div class="side-sub">Important details at a glance.</div>

                    <div class="info-list mt-4">
                        <div class="info-row">
                            <div class="info-label">Order ID</div>
                            <div class="info-value">#@_order.Id</div>
                        </div>

                        <div class="info-row">
                            <div class="info-label">Status</div>
                            <div class="info-value">@_order.Status.ToString()</div>
                        </div>

                        <div class="info-row">
                            <div class="info-label">Buyer</div>
                            <div class="info-value ellipsis">@_order.BuyerId</div>
                        </div>

                        <div class="info-row">
                            <div class="info-label">Seller</div>
                            <div class="info-value ellipsis">@_order.SellerId</div>
                        </div>

                        <div class="info-row">
                            <div class="info-label">Conversation</div>
                            <div class="info-value">#@_order.ConversationId</div>
                        </div>
                    </div>
                </div>
            </MudItem>
        </MudGrid>
    }
</MudContainer>

<style>
    .hero {
        border-radius: 24px;
        border: 1px solid rgba(0,0,0,.08);
        background: linear-gradient(135deg,#eef2ff,#e0e7ff);
        box-shadow: 0 18px 46px rgba(0,0,0,.06);
        position: relative;
        overflow: hidden;
    }

        .hero::before {
            content: "";
            position: absolute;
            inset: -45% -70%;
            background: radial-gradient(circle at 30% 30%, rgba(255,255,255,.55), transparent 55%);
            transform: rotate(12deg);
            opacity: .9;
            pointer-events: none;
        }

    .hero-inner {
        position: relative;
        z-index: 1;
        padding: 26px 26px 12px 26px;
        display: flex;
        justify-content: space-between;
        gap: 16px;
        align-items: center;
        flex-wrap: wrap;
    }

    .hero-left {
        min-width: 0;
    }

    .hero-title {
        font-weight: 950;
        color: #111827;
        font-size: 1.7rem;
        letter-spacing: .2px;
        line-height: 1.12;
    }

    .hero-sub {
        color: rgba(17,24,39,.65);
        font-size: 1rem;
        line-height: 1.35;
        margin-top: 6px;
        word-break: break-word;
    }

    .hero-stats {
        position: relative;
        z-index: 1;
        display: flex;
        flex-wrap: wrap;
        gap: 10px;
        padding: 0 26px 26px 26px;
    }

    .stat-chip {
        min-width: 150px;
        border-radius: 16px;
        border: 1px solid rgba(0,0,0,.08);
        background: rgba(255,255,255,.72);
        backdrop-filter: blur(6px);
        padding: 10px 12px;
    }

    .stat-label {
        color: rgba(17,24,39,.6);
        font-size: .9rem;
        font-weight: 800;
    }

    .stat-value {
        margin-top: 4px;
        font-weight: 950;
        color: #111827;
        font-size: 1.15rem;
        line-height: 1.1;
    }

        .stat-value.small {
            font-size: .95rem;
            line-height: 1.3;
        }

    .shell,
    .side,
    .state-shell {
        border-radius: 22px;
        border: 1px solid rgba(0,0,0,.08);
        background: #fff;
        box-shadow: 0 18px 46px rgba(0,0,0,.06);
        overflow: hidden;
    }

    .section-head {
        padding: 18px 22px 14px 22px;
        border-bottom: 1px solid rgba(0,0,0,.06);
    }

    .section-title {
        font-weight: 950;
        color: #111827;
        font-size: 1.05rem;
        letter-spacing: .2px;
    }

    .section-sub {
        color: rgba(17,24,39,.6);
        font-size: .95rem;
        margin-top: 4px;
    }

    .section-body {
        padding: 22px;
    }

    .actions {
        display: flex;
        flex-wrap: wrap;
        gap: 10px;
    }

    .btn-strong {
        border-radius: 14px;
        font-weight: 900;
        letter-spacing: .2px;
        padding: 10px 14px;
    }

    .review-callout {
        margin-top: 18px;
        border-radius: 18px;
        border: 1px dashed rgba(0,0,0,.14);
        background: rgba(99,102,241,.05);
        padding: 16px;
    }

    .review-callout-title {
        font-weight: 950;
        color: #111827;
    }

    .review-callout-sub {
        color: rgba(17,24,39,.65);
        margin-top: 6px;
        line-height: 1.35;
    }

    .disputes-list {
        display: grid;
        gap: 12px;
    }

    .dispute-card {
        border-radius: 18px;
        border: 1px solid rgba(0,0,0,.08);
        background: #fff;
        box-shadow: 0 12px 28px rgba(0,0,0,.06);
        padding: 16px;
    }

    .dispute-top {
        display: flex;
        justify-content: space-between;
        gap: 12px;
        align-items: center;
    }

    .dispute-id {
        font-weight: 950;
        color: #111827;
        letter-spacing: .2px;
    }

    .dispute-subject {
        margin-top: 10px;
        color: #111827;
        font-weight: 800;
        line-height: 1.3;
        word-break: break-word;
    }

    .dispute-date {
        margin-top: 8px;
        color: rgba(17,24,39,.6);
        font-size: .9rem;
    }

    .empty-inline {
        border-radius: 16px;
        border: 1px dashed rgba(0,0,0,.14);
        padding: 18px;
        color: rgba(17,24,39,.65);
        background: rgba(99,102,241,.03);
    }

    .side {
        padding: 22px;
    }

    .side-title {
        font-weight: 950;
        color: #111827;
        font-size: 1.05rem;
        letter-spacing: .2px;
    }

    .side-sub {
        color: rgba(17,24,39,.6);
        font-size: .95rem;
        margin-top: 4px;
    }

    .info-list {
        display: grid;
        gap: 10px;
    }

    .info-row {
        display: flex;
        justify-content: space-between;
        gap: 12px;
        align-items: center;
        border-radius: 16px;
        border: 1px solid rgba(0,0,0,.08);
        background: rgba(99,102,241,.04);
        padding: 12px 14px;
    }

    .info-label {
        color: rgba(17,24,39,.6);
        font-weight: 800;
        min-width: 0;
    }

    .info-value {
        color: #111827;
        font-weight: 950;
        text-align: right;
        min-width: 0;
    }

    .ellipsis {
        overflow: hidden;
        text-overflow: ellipsis;
        white-space: nowrap;
    }

    .state-shell {
        padding: 28px;
        text-align: center;
    }

    .state-title {
        font-weight: 950;
        color: #111827;
        font-size: 1.15rem;
    }

    .state-sub {
        color: rgba(17,24,39,.65);
        margin-top: 8px;
    }

    .skeleton {
        min-height: 320px;
        position: relative;
    }

        .skeleton::before {
            content: "";
            position: absolute;
            inset: 0;
            background: linear-gradient(90deg,#f3f4f6,#fafafa,#f3f4f6);
            background-size: 200% 100%;
            animation: shimmer 1.2s infinite linear;
        }

    @@keyframes shimmer {
        0% {
            background-position: 0% 0;
        }

        100% {
            background-position: 200% 0;
        }
    }
</style>

@code {
    [Parameter] public int OrderId { get; set; }
    [CascadingParameter] public Task<AuthenticationState> AuthenticationStateTask { get; set; } = default!;

    bool _loading = true;
    bool _forbidden;

    string? _meId;
    Order? _order;
    List<OrderDispute> _disputes = new();

    protected override async Task OnParametersSetAsync()
    {
        _loading = true;
        _forbidden = false;
        _order = null;
        _disputes = new();
        StateHasChanged();

        var authState = await AuthenticationStateTask;
        var principal = authState.User;

        if (principal?.Identity?.IsAuthenticated != true)
        {
            _forbidden = true;
            _loading = false;
            return;
        }

        _meId = principal.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value;
        if (string.IsNullOrWhiteSpace(_meId))
        {
            _forbidden = true;
            _loading = false;
            return;
        }

        await using var db = await DbFactory.CreateDbContextAsync();

        _order = await db.Orders
            .Include(x => x.ServiceOffer)
            .FirstOrDefaultAsync(x => x.Id == OrderId);

        if (_order == null)
        {
            _loading = false;
            return;
        }

        if (_order.BuyerId != _meId && _order.SellerId != _meId)
        {
            _forbidden = true;
            _loading = false;
            return;
        }

        _disputes = await db.OrderDisputes.AsNoTracking()
            .Where(x => x.OrderId == OrderId)
            .OrderByDescending(x => x.CreatedAtUtc)
            .ToListAsync();

        _loading = false;
        StateHasChanged();
    }

    void GoService()
    {
        if (_order == null) return;
        Nav.NavigateTo($"/services/{_order.ServiceOfferId}");
    }

    void GoChat()
    {
        if (_order == null) return;
        Nav.NavigateTo($"/chat/{_order.ConversationId}");
    }

    async Task OpenDispute()
    {
        if (_order == null) return;
        if (string.IsNullOrWhiteSpace(_meId)) return;

        var p = new DialogParameters
            {
                ["OrderId"] = _order.Id,
                ["ReporterId"] = _meId
            };

        var o = new DialogOptions { CloseButton = true, MaxWidth = MaxWidth.Small, FullWidth = true };
        var d = DialogService.Show<OrderDisputeDialog>("Report to admin", p, o);
        var r = await d.Result;

        if (!r.Canceled)
        {
            await OnParametersSetAsync();
            Snackbar.Add("Dispute submitted", Severity.Success);
        }
    }

    async Task OpenReview()
    {
        if (_order == null) return;
        if (string.IsNullOrWhiteSpace(_meId)) return;

        var p = new DialogParameters
            {
                ["OrderId"] = _order.Id,
                ["TargetUserId"] = _order.SellerId,
                ["AuthorUserId"] = _meId
            };

        var o = new DialogOptions { CloseButton = true, MaxWidth = MaxWidth.Small, FullWidth = true };
        var d = DialogService.Show<OrderReviewDialog>("Leave review", p, o);
        var r = await d.Result;

        if (!r.Canceled)
        {
            await OnParametersSetAsync();
            Snackbar.Add("Review submitted", Severity.Success);
        }
    }

    static Color StatusColor(OrderStatus status)
        => status switch
        {
            OrderStatus.InProgress => Color.Warning,
            OrderStatus.Completed => Color.Success,
            OrderStatus.Cancelled => Color.Error,
            _ => Color.Default
        };
}