@page "/orders/{OrderId:int}"
@attribute [Microsoft.AspNetCore.Authorization.Authorize]
@using Microsoft.AspNetCore.Components.Authorization
@using Microsoft.EntityFrameworkCore
@using MudBlazor
@using SkillGo.Data
@using SkillGo.Data.Models
@using SkillGo.Data.Models.Orders
@inject IDbContextFactory<ApplicationDbContext> DbFactory
@inject NavigationManager Nav
@inject IDialogService DialogService
@inject ISnackbar Snackbar

<PageTitle>Order</PageTitle>

<MudContainer MaxWidth="MaxWidth.False" Class="order-details-page-shell pa-0">
    <MudContainer MaxWidth="MaxWidth.ExtraLarge" Class="pt-6 pb-8">
        @if (_loading)
        {
            <MudGrid Spacing="3">
                <MudItem xs="12">
                    <div class="hero-skeleton skeleton"></div>
                </MudItem>
                <MudItem xs="12" md="8">
                    <div class="shell skeleton"></div>
                </MudItem>
                <MudItem xs="12" md="4">
                    <div class="side skeleton"></div>
                </MudItem>
            </MudGrid>
        }
        else if (_forbidden)
        {
            <MudPaper Class="state-paper pa-8 text-center" Elevation="0">
                <MudText Typo="Typo.h5" Class="state-title">Access denied</MudText>
                <MudText Typo="Typo.body2" Class="state-sub mt-2">You do not have access to this order.</MudText>
            </MudPaper>
        }
        else if (_order == null)
        {
            <MudPaper Class="state-paper pa-8 text-center" Elevation="0">
                <MudText Typo="Typo.h5" Class="state-title">Order not found</MudText>
                <MudText Typo="Typo.body2" Class="state-sub mt-2">The order may have been removed or never existed.</MudText>
            </MudPaper>
        }
        else
        {
            <MudPaper Class="hero-paper pa-6 pa-md-8" Elevation="0">
                <MudGrid Spacing="3" AlignItems="AlignItems.Center">
                    <MudItem xs="12" md="8">
                        <div class="hero-badge">
                            <MudIcon Icon="@Icons.Material.Filled.ReceiptLong" Size="Size.Small" />
                            <span>Order workflow</span>
                        </div>

                        <MudText Typo="Typo.h3" Class="hero-title mt-4">
                            Order #@_order.Id
                        </MudText>

                        <MudText Typo="Typo.body1" Class="hero-sub mt-4">
                            @(_order.ServiceOffer?.Title ?? "Service")
                        </MudText>

                        <MudStack Row="true" Spacing="1" Class="mt-4 hero-tags">
                            <MudChip T="string" Variant="Variant.Outlined" Class="hero-chip">Amount: @_order.Amount.ToString("0.00") zł</MudChip>
                            <MudChip T="string" Variant="Variant.Outlined" Class="hero-chip">Escrow: @_order.EscrowAmount.ToString("0.00") zł</MudChip>
                            <MudChip T="string" Variant="Variant.Outlined" Class="hero-chip">Chat #@_order.ConversationId</MudChip>
                        </MudStack>
                    </MudItem>

                    <MudItem xs="12" md="4">
                        <MudPaper Class="hero-side pa-5" Elevation="0">
                            <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center">
                                <MudText Typo="Typo.h6" Class="hero-side-title">Status</MudText>
                                <MudChip T="string"
                                         Size="Size.Small"
                                         Color="@StatusColor(_order.Status)"
                                         Variant="Variant.Filled">
                                    @_order.Status.ToString()
                                </MudChip>
                            </MudStack>

                            <MudGrid Spacing="2" Class="mt-3">
                                <MudItem xs="6">
                                    <MudPaper Class="stat-card pa-4" Elevation="0">
                                        <MudText Typo="Typo.h6" Class="stat-value">@_order.Amount.ToString("0.00") zł</MudText>
                                        <MudText Typo="Typo.body2" Class="stat-label">Amount</MudText>
                                    </MudPaper>
                                </MudItem>

                                <MudItem xs="6">
                                    <MudPaper Class="stat-card pa-4" Elevation="0">
                                        <MudText Typo="Typo.h6" Class="stat-value">@_order.EscrowAmount.ToString("0.00") zł</MudText>
                                        <MudText Typo="Typo.body2" Class="stat-label">Escrow</MudText>
                                    </MudPaper>
                                </MudItem>
                            </MudGrid>
                        </MudPaper>
                    </MudItem>
                </MudGrid>
            </MudPaper>

            <MudGrid Spacing="3" Class="mt-4">
                <MudItem xs="12" md="8">
                    <MudPaper Class="shell" Elevation="0">
                        <div class="section-head">
                            <div class="section-title">Order actions</div>
                            <div class="section-sub">Open related pages or contact support.</div>
                        </div>

                        <div class="section-body">
                            <MudStack Row="true" Wrap="Wrap.Wrap" Spacing="1" Class="actions">
                                <MudButton Variant="Variant.Filled"
                                           Color="Color.Primary"
                                           Class="btn-strong"
                                           OnClick="GoService"
                                           Disabled="@(_order.ServiceOfferId <= 0)">
                                    View service
                                </MudButton>

                                <MudButton Variant="Variant.Outlined"
                                           Color="Color.Primary"
                                           Class="btn-strong"
                                           OnClick="GoChat">
                                    Open chat
                                </MudButton>

                                <MudButton Variant="Variant.Outlined"
                                           Color="Color.Error"
                                           Class="btn-strong"
                                           OnClick="OpenDispute">
                                    Report to admin
                                </MudButton>
                            </MudStack>

                            @if (_order.Status == OrderStatus.Completed && _order.ReviewId == null && _meId == _order.BuyerId)
                            {
                                <MudPaper Class="review-callout pa-4 mt-4" Elevation="0">
                                    <MudText Typo="Typo.subtitle1" Class="review-callout-title">Order completed</MudText>
                                    <MudText Typo="Typo.body2" Class="review-callout-sub mt-1">
                                        Leave a review to support the freelancer’s profile.
                                    </MudText>

                                    <MudButton Variant="Variant.Filled"
                                               Color="Color.Success"
                                               Class="btn-strong mt-3"
                                               OnClick="OpenReview">
                                        Leave review
                                    </MudButton>
                                </MudPaper>
                            }
                        </div>
                    </MudPaper>

                    <MudPaper Class="shell mt-4" Elevation="0">
                        <div class="section-head">
                            <div class="section-title">Disputes</div>
                            <div class="section-sub">Reports related to this order.</div>
                        </div>

                        <div class="section-body">
                            @if (_disputes.Count == 0)
                            {
                                <MudPaper Class="empty-inline pa-4" Elevation="0">
                                    No disputes yet.
                                </MudPaper>
                            }
                            else
                            {
                                <MudStack Spacing="2">
                                    @foreach (var item in _disputes)
                                    {
                                        <MudPaper Class="dispute-card pa-4" Elevation="0">
                                            <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center">
                                                <MudText Typo="Typo.subtitle1" Class="dispute-id">Dispute #@item.Id</MudText>
                                                <MudChip T="string" Size="Size.Small" Variant="Variant.Filled">
                                                    @item.Status.ToString()
                                                </MudChip>
                                            </MudStack>

                                            <MudText Typo="Typo.body1" Class="dispute-subject mt-3">@item.Subject</MudText>
                                            <MudText Typo="Typo.body2" Class="dispute-date mt-2">@item.CreatedAtUtc.ToString("yyyy-MM-dd HH:mm") UTC</MudText>
                                        </MudPaper>
                                    }
                                </MudStack>
                            }
                        </div>
                    </MudPaper>
                </MudItem>

                <MudItem xs="12" md="4">
                    <MudPaper Class="side" Elevation="0">
                        <MudText Typo="Typo.h6" Class="side-title">Summary</MudText>
                        <MudText Typo="Typo.body2" Class="side-sub mt-1">Important details at a glance.</MudText>

                        <MudStack Spacing="2" Class="mt-4">
                            <MudPaper Class="info-row pa-3" Elevation="0">
                                <MudText Typo="Typo.caption" Class="info-label">Order ID</MudText>
                                <MudText Typo="Typo.body1" Class="info-value mt-1">#@_order.Id</MudText>
                            </MudPaper>

                            <MudPaper Class="info-row pa-3" Elevation="0">
                                <MudText Typo="Typo.caption" Class="info-label">Status</MudText>
                                <MudText Typo="Typo.body1" Class="info-value mt-1">@_order.Status.ToString()</MudText>
                            </MudPaper>

                            <MudPaper Class="info-row pa-3" Elevation="0">
                                <MudText Typo="Typo.caption" Class="info-label">Buyer</MudText>
                                <MudText Typo="Typo.body2" Class="info-value mt-1 ellipsis">@_order.BuyerId</MudText>
                            </MudPaper>

                            <MudPaper Class="info-row pa-3" Elevation="0">
                                <MudText Typo="Typo.caption" Class="info-label">Seller</MudText>
                                <MudText Typo="Typo.body2" Class="info-value mt-1 ellipsis">@_order.SellerId</MudText>
                            </MudPaper>

                            <MudPaper Class="info-row pa-3" Elevation="0">
                                <MudText Typo="Typo.caption" Class="info-label">Conversation</MudText>
                                <MudText Typo="Typo.body1" Class="info-value mt-1">#@_order.ConversationId</MudText>
                            </MudPaper>
                        </MudStack>
                    </MudPaper>
                </MudItem>
            </MudGrid>
        }
    </MudContainer>
</MudContainer>

<style>
    .order-details-page-shell {
        min-height: calc(100vh - 78px);
        background:
            radial-gradient(circle at top left, rgba(124,58,237,.10), transparent 22%),
            radial-gradient(circle at top right, rgba(99,102,241,.08), transparent 24%),
            linear-gradient(180deg, #fbfaff 0%, #f7f4ff 42%, #ffffff 100%);
    }

    .hero-paper {
        border-radius: 32px;
        background: linear-gradient(135deg, #2e1065 0%, #4c1d95 46%, #5b21b6 100%);
        color: #fff;
        border: 1px solid rgba(255,255,255,.10);
        box-shadow: 0 22px 60px rgba(76,29,149,.18);
    }

    .hero-badge {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        padding: 8px 14px;
        border-radius: 999px;
        background: rgba(255,255,255,.10);
        border: 1px solid rgba(255,255,255,.14);
        font-size: 13px;
        font-weight: 700;
    }

    .hero-title {
        font-weight: 900;
        line-height: 1.02;
        letter-spacing: -.03em;
    }

    .hero-sub {
        color: rgba(255,255,255,.82);
        line-height: 1.8;
        font-size: 16px;
        max-width: 760px;
    }

    .hero-tags {
        flex-wrap: wrap;
    }

    .hero-chip {
        color: #fff !important;
        border-color: rgba(255,255,255,.24) !important;
        background: rgba(255,255,255,.06) !important;
        font-weight: 700;
    }

    .hero-side,
    .stat-card,
    .shell,
    .side,
    .dispute-card,
    .review-callout,
    .state-paper,
    .empty-inline,
    .info-row {
        border-radius: 26px;
        background: rgba(255,255,255,.94);
        border: 1px solid rgba(109,40,217,.10);
        box-shadow: 0 14px 38px rgba(88,28,135,.06);
    }

    .hero-side-title,
    .section-title,
    .side-title,
    .state-title,
    .dispute-id,
    .review-callout-title,
    .stat-value,
    .info-value {
        color: #1f1147;
        font-weight: 800;
    }

    .hero-side-sub,
    .section-sub,
    .side-sub,
    .state-sub,
    .dispute-date,
    .review-callout-sub,
    .stat-label,
    .info-label {
        color: #6b5f8d;
    }

    .stat-card {
        background: linear-gradient(180deg, #faf7ff 0%, #ffffff 100%);
    }

    .section-head {
        padding: 22px 24px 18px 24px;
        border-bottom: 1px solid rgba(109,40,217,.08);
    }

    .section-body {
        padding: 24px;
    }

    .actions {
        flex-wrap: wrap;
    }

    .side {
        padding: 24px;
    }

    .dispute-subject {
        color: rgba(31,17,71,.86);
        line-height: 1.5;
    }

    .btn-strong {
        border-radius: 14px;
        font-weight: 900;
        letter-spacing: .2px;
        text-transform: none;
        padding: 10px 14px;
    }

    .ellipsis {
        overflow: hidden;
        text-overflow: ellipsis;
        white-space: nowrap;
    }

    .hero-skeleton,
    .skeleton {
        background: #fff;
        border-radius: 26px;
        position: relative;
        overflow: hidden;
        min-height: 320px;
        border: 1px solid rgba(109,40,217,.10);
    }

    .hero-skeleton {
        min-height: 240px;
    }

    .hero-skeleton::before,
    .skeleton::before {
        content: "";
        position: absolute;
        inset: 0;
        background: linear-gradient(90deg,#f3f4f6,#fafafa,#f3f4f6);
        background-size: 200% 100%;
        animation: shimmer 1.2s infinite linear;
    }

    @@keyframes shimmer {
        0% { background-position: 0% 0; }
        100% { background-position: 200% 0; }
    }

    @@media (max-width: 700px) {
        .hero-paper,
        .hero-side,
        .stat-card,
        .shell,
        .side,
        .dispute-card,
        .review-callout,
        .state-paper,
        .empty-inline,
        .info-row {
            border-radius: 22px;
        }

        .hero-title {
            font-size: 2rem !important;
        }
    }
</style>

@code {
    [Parameter] public int OrderId { get; set; }
    [CascadingParameter] public Task<AuthenticationState> AuthenticationStateTask { get; set; } = default!;

    bool _loading = true;
    bool _forbidden;

    string? _meId;
    Order? _order;
    List<OrderDispute> _disputes = new();

    protected override async Task OnParametersSetAsync()
    {
        _loading = true;
        _forbidden = false;
        _order = null;
        _disputes = new();
        StateHasChanged();

        var authState = await AuthenticationStateTask;
        var principal = authState.User;

        if (principal?.Identity?.IsAuthenticated != true)
        {
            _forbidden = true;
            _loading = false;
            return;
        }

        _meId = principal.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value;
        if (string.IsNullOrWhiteSpace(_meId))
        {
            _forbidden = true;
            _loading = false;
            return;
        }

        await using var db = await DbFactory.CreateDbContextAsync();

        _order = await db.Orders
            .Include(x => x.ServiceOffer)
            .FirstOrDefaultAsync(x => x.Id == OrderId);

        if (_order == null)
        {
            _loading = false;
            return;
        }

        if (_order.BuyerId != _meId && _order.SellerId != _meId)
        {
            _forbidden = true;
            _loading = false;
            return;
        }

        _disputes = await db.OrderDisputes.AsNoTracking()
            .Where(x => x.OrderId == OrderId)
            .OrderByDescending(x => x.CreatedAtUtc)
            .ToListAsync();

        _loading = false;
        StateHasChanged();
    }

    void GoService()
    {
        if (_order == null) return;
        Nav.NavigateTo($"/services/{_order.ServiceOfferId}");
    }

    void GoChat()
    {
        if (_order == null) return;
        Nav.NavigateTo($"/chat/{_order.ConversationId}");
    }

    async Task OpenDispute()
    {
        if (_order == null) return;
        if (string.IsNullOrWhiteSpace(_meId)) return;

        var p = new DialogParameters
        {
            ["OrderId"] = _order.Id,
            ["ReporterId"] = _meId
        };

        var o = new DialogOptions { CloseButton = true, MaxWidth = MaxWidth.Small, FullWidth = true };
        var d = DialogService.Show<OrderDisputeDialog>("Report to admin", p, o);
        var r = await d.Result;

        if (!r.Canceled)
        {
            await OnParametersSetAsync();
            Snackbar.Add("Dispute submitted", Severity.Success);
        }
    }

    async Task OpenReview()
    {
        if (_order == null) return;
        if (string.IsNullOrWhiteSpace(_meId)) return;

        var p = new DialogParameters
        {
            ["OrderId"] = _order.Id,
            ["TargetUserId"] = _order.SellerId,
            ["AuthorUserId"] = _meId
        };

        var o = new DialogOptions { CloseButton = true, MaxWidth = MaxWidth.Small, FullWidth = true };
        var d = DialogService.Show<OrderReviewDialog>("Leave review", p, o);
        var r = await d.Result;

        if (!r.Canceled)
        {
            await OnParametersSetAsync();
            Snackbar.Add("Review submitted", Severity.Success);
        }
    }

    static Color StatusColor(OrderStatus status)
        => status switch
        {
            OrderStatus.InProgress => Color.Warning,
            OrderStatus.Completed => Color.Success,
            OrderStatus.Cancelled => Color.Error,
            _ => Color.Default
        };
}