@using MudBlazor
@using SkillGo.Data.Models.Orders
@inject SkillGo.Repository.IRepository.IOrderRepository OrderRepo
@inject SkillGo.Repository.WalletState WalletState
@inject NavigationManager Nav
@inject IDialogService DialogService
@inject ISnackbar Snackbar

<MudPaper Class="message-card" Elevation="0">
    <MudStack Spacing="2">
        <div class="top-row">
            <div class="title-wrap">
                <div class="title">Order #@Order.Id</div>
                <div class="sub">@Order.ServiceOffer?.Title</div>
            </div>

            <MudChip T="string"
                     Size="Size.Small"
                     Color="@GetStatusColor(Order.Status)"
                     Variant="Variant.Filled">
                @Order.Status.ToString()
            </MudChip>
        </div>

        <div class="stats-grid">
            <div class="stat-box">
                <div class="stat-label">Amount</div>
                <div class="stat-value">@Order.Amount.ToString("0.00") zł</div>
            </div>

            <div class="stat-box">
                <div class="stat-label">Escrow</div>
                <div class="stat-value">@Order.EscrowAmount.ToString("0.00") zł</div>
            </div>
        </div>

        <div class="date-line">
            Created: @Order.CreatedAtUtc.ToString("yyyy-MM-dd HH:mm") UTC
            @if (Order.CompletedAtUtc != null)
            {
                <span> • Completed: @Order.CompletedAtUtc.Value.ToString("yyyy-MM-dd HH:mm") UTC</span>
            }
        </div>

        @if (Order.Status == OrderStatus.Completed && Order.ReviewId == null && IsBuyer)
        {
            <div class="callout">
                <div class="callout-title">Order completed</div>
                <div class="callout-sub">Leave a review to help this freelancer.</div>

                <MudButton Variant="Variant.Filled"
                           Color="Color.Primary"
                           Size="Size.Small"
                           Disabled="_busy"
                           Class="btn-strong mt-2"
                           OnClick="OpenReview">
                    Leave review
                </MudButton>
            </div>
        }

        <div class="actions">
            <MudButton Variant="Variant.Outlined"
                       Color="Color.Primary"
                       Size="Size.Small"
                       Class="btn-strong"
                       OnClick="GoService">
                View service
            </MudButton>

            <MudButton Variant="Variant.Outlined"
                       Color="Color.Primary"
                       Size="Size.Small"
                       Class="btn-strong"
                       OnClick="GoOrder">
                Open order
            </MudButton>

            <MudButton Variant="Variant.Outlined"
                       Color="Color.Error"
                       Size="Size.Small"
                       Class="btn-strong"
                       Disabled="_busy"
                       OnClick="OpenDispute">
                Report
            </MudButton>

            @if (Order.Status == OrderStatus.InProgress)
            {
                <MudButton Variant="Variant.Filled"
                           Color="Color.Success"
                           Size="Size.Small"
                           Class="btn-strong"
                           Disabled="@(!IsBuyer || _busy)"
                           OnClick="Complete">
                    @(_busy ? "Completing..." : "Complete")
                </MudButton>
            }
        </div>

        @if (Order.Status == OrderStatus.InProgress && !IsBuyer)
        {
            <div class="hint">Only buyer can complete the order.</div>
        }
    </MudStack>
</MudPaper>

<style>
    .message-card {
        border: 1px solid rgba(109,40,217,.10);
        border-radius: 22px;
        background: rgba(255,255,255,.96);
        box-shadow: 0 18px 46px rgba(31,17,71,.06);
        padding: 18px;
    }

    .top-row {
        display: flex;
        justify-content: space-between;
        gap: 12px;
        align-items: flex-start;
    }

    .title-wrap {
        min-width: 0;
    }

    .title {
        font-weight: 950;
        color: #1f1147;
        font-size: 1.05rem;
        line-height: 1.15;
        letter-spacing: .2px;
    }

    .sub {
        color: #6b5f8d;
        margin-top: 6px;
        line-height: 1.3;
        word-break: break-word;
    }

    .stats-grid {
        display: grid;
        grid-template-columns: repeat(2,minmax(0,1fr));
        gap: 10px;
    }

    .stat-box {
        border-radius: 16px;
        border: 1px solid rgba(109,40,217,.10);
        background: linear-gradient(180deg, #faf7ff 0%, #ffffff 100%);
        padding: 12px 14px;
    }

    .stat-label {
        color: #6b5f8d;
        font-size: .86rem;
        font-weight: 800;
    }

    .stat-value {
        margin-top: 6px;
        color: #1f1147;
        font-weight: 950;
        line-height: 1.2;
    }

    .date-line {
        color: #6b5f8d;
        font-size: .88rem;
        line-height: 1.35;
    }

    .callout {
        border-radius: 18px;
        border: 1px dashed rgba(109,40,217,.18);
        background: rgba(109,40,217,.05);
        padding: 14px;
    }

    .callout-title {
        font-weight: 950;
        color: #1f1147;
    }

    .callout-sub {
        color: #6b5f8d;
        margin-top: 4px;
        line-height: 1.3;
    }

    .actions {
        display: flex;
        flex-wrap: wrap;
        gap: 10px;
    }

    .btn-strong {
        border-radius: 14px;
        font-weight: 900;
        letter-spacing: .2px;
        text-transform: none;
    }

    .hint {
        color: #6b5f8d;
        font-size: .85rem;
    }

    @@media (max-width: 700px) {
        .stats-grid {
            grid-template-columns: 1fr;
        }
    }
</style>

@code {
    [Parameter] public Order Order { get; set; } = default!;
    [Parameter] public string CurrentUserId { get; set; } = "";
    [Parameter] public EventCallback OnChanged { get; set; }

    bool _busy;

    bool IsBuyer => Order.BuyerId == CurrentUserId;

    void GoService()
    {
        if (Order.ServiceOfferId <= 0) return;
        Nav.NavigateTo($"/services/{Order.ServiceOfferId}");
    }

    void GoOrder()
    {
        Nav.NavigateTo($"/orders/{Order.Id}");
    }

    async Task OpenDispute()
    {
        if (_busy) return;
        if (string.IsNullOrWhiteSpace(CurrentUserId)) return;

        var p = new DialogParameters
        {
            ["OrderId"] = Order.Id,
            ["ReporterId"] = CurrentUserId
        };

        var o = new DialogOptions { CloseButton = true, MaxWidth = MaxWidth.Small, FullWidth = true };
        var d = DialogService.Show<OrderDisputeDialog>("Report to admin", p, o);
        var r = await d.Result;

        if (!r.Canceled)
        {
            Snackbar.Add("Dispute submitted", Severity.Success);
        }
    }

    async Task OpenReview()
    {
        if (_busy) return;
        if (string.IsNullOrWhiteSpace(CurrentUserId)) return;

        var p = new DialogParameters
        {
            ["OrderId"] = Order.Id,
            ["TargetUserId"] = Order.SellerId,
            ["AuthorUserId"] = CurrentUserId
        };

        var o = new DialogOptions { CloseButton = true, MaxWidth = MaxWidth.Small, FullWidth = true };
        var d = DialogService.Show<OrderReviewDialog>("Leave review", p, o);
        var r = await d.Result;

        if (!r.Canceled)
        {
            if (OnChanged.HasDelegate)
                await OnChanged.InvokeAsync();
        }
    }

    Color GetStatusColor(OrderStatus status)
        => status switch
        {
            OrderStatus.InProgress => Color.Warning,
            OrderStatus.Completed => Color.Success,
            OrderStatus.Cancelled => Color.Error,
            _ => Color.Default
        };

    async Task Complete()
    {
        if (_busy) return;

        _busy = true;
        try
        {
            var ok = await OrderRepo.CompleteAsync(Order.Id, CurrentUserId);
            if (!ok)
            {
                Snackbar.Add("Can't complete this order", Severity.Error);
                return;
            }

            await WalletState.RefreshAsync();
            Snackbar.Add("Order completed. Money sent to freelancer.", Severity.Success);

            if (OnChanged.HasDelegate)
                await OnChanged.InvokeAsync();

            if (IsBuyer)
                await OpenReview();
        }
        finally
        {
            _busy = false;
        }
    }
}