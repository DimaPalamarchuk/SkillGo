@page "/orders"
@attribute [Microsoft.AspNetCore.Authorization.Authorize]
@using Microsoft.AspNetCore.Components.Authorization
@using Microsoft.AspNetCore.Identity
@using Microsoft.EntityFrameworkCore
@using MudBlazor
@using SkillGo.Data
@using SkillGo.Data.Models
@using SkillGo.Data.Models.Orders
@using SkillGo.Repository.IRepository
@inject IDbContextFactory<ApplicationDbContext> DbFactory
@inject UserManager<ApplicationUser> UserManager
@inject NavigationManager Nav
@inject IOrderRepository OrderRepo

<PageTitle>Orders</PageTitle>

<MudContainer MaxWidth="MaxWidth.Large" Class="mt-6">
    <div class="hero">
        <div class="hero-inner">
            <div class="hero-left">
                <div class="hero-title">Orders</div>
                <div class="hero-sub">Track purchases, deliveries and completed work in one place.</div>
            </div>

            <div class="hero-right">
                <MudSelect T="string"
                           Variant="Variant.Outlined"
                           Value="@_mode"
                           ValueChanged="OnModeChanged"
                           Class="mode-select">
                    <MudSelectItem T="string" Value="@("All")">All</MudSelectItem>
                    <MudSelectItem T="string" Value="@("Buying")">Buying</MudSelectItem>
                    <MudSelectItem T="string" Value="@("Selling")">Selling</MudSelectItem>
                </MudSelect>
            </div>
        </div>

        <div class="hero-stats">
            <div class="stat-chip">
                <div class="stat-label">Total</div>
                <div class="stat-value">@_totalItems</div>
            </div>

            <div class="stat-chip">
                <div class="stat-label">In progress</div>
                <div class="stat-value">@_allOrders.Count(x => x.Status == OrderStatus.InProgress)</div>
            </div>

            <div class="stat-chip">
                <div class="stat-label">Completed</div>
                <div class="stat-value">@_allOrders.Count(x => x.Status == OrderStatus.Completed)</div>
            </div>
        </div>
    </div>

    @if (_loading)
    {
        <MudGrid Spacing="4" Class="mt-4">
            @for (var i = 0; i < 6; i++)
            {
                <MudItem xs="12" md="6">
                    <div class="order-card skeleton"></div>
                </MudItem>
            }
        </MudGrid>
    }
    else if (_orders.Count == 0)
    {
        <MudPaper Class="empty-shell mt-4" Elevation="0">
            <div class="empty-title">No orders yet</div>
            <div class="empty-sub">When you buy or sell a service, it will appear here.</div>
            <MudButton Variant="Variant.Filled" Color="Color.Primary" Class="btn-strong mt-4" Href="/services/category">
                Browse services
            </MudButton>
        </MudPaper>
    }
    else
    {
        <MudGrid Spacing="4" Class="mt-4">
            @foreach (var order in _orders)
            {
                var otherUserId = order.BuyerId == _meId ? order.SellerId : order.BuyerId;
                var user = GetUser(otherUserId);

                <MudItem xs="12" md="6">
                    <div class="order-card">
                        <div class="order-top">
                            <div class="order-title-wrap">
                                <div class="order-id">Order #@order.Id</div>
                                <div class="order-service">
                                    @(order.ServiceOffer?.Title ?? "Service")
                                </div>
                            </div>

                            <MudChip T="string"
                                     Size="Size.Small"
                                     Color="@StatusColor(order.Status)"
                                     Variant="Variant.Filled">
                                @order.Status.ToString()
                            </MudChip>
                        </div>

                        <div class="order-meta-grid">
                            <div class="meta-box">
                                <div class="meta-label">Amount</div>
                                <div class="meta-value">@order.Amount.ToString("0.00") zł</div>
                            </div>

                            <div class="meta-box">
                                <div class="meta-label">Escrow</div>
                                <div class="meta-value">@order.EscrowAmount.ToString("0.00") zł</div>
                            </div>

                            <div class="meta-box">
                                <div class="meta-label">User</div>
                                <div class="meta-value ellipsis">
                                    @if (user != null && !string.IsNullOrWhiteSpace(user.UserName))
                                    {
                                        <MudLink Href="@($"/profile/{user.UserName}")" Class="text-link">
                                            @DisplayName(user)
                                        </MudLink>
                                    }
                                    else
                                    {
                                        <span>@otherUserId</span>
                                    }
                                </div>
                            </div>

                            <div class="meta-box">
                                <div class="meta-label">Created</div>
                                <div class="meta-value">@order.CreatedAtUtc.ToLocalTime().ToString("yyyy-MM-dd")</div>
                            </div>
                        </div>

                        <div class="order-actions">
                            <MudButton Variant="Variant.Filled"
                                       Color="Color.Primary"
                                       Class="btn-strong"
                                       OnClick="@(() => Nav.NavigateTo($"/orders/{order.Id}"))">
                                Details
                            </MudButton>

                            <MudButton Variant="Variant.Outlined"
                                       Color="Color.Primary"
                                       Class="btn-strong"
                                       Disabled="@(order.ServiceOfferId <= 0)"
                                       OnClick="@(() => Nav.NavigateTo($"/services/{order.ServiceOfferId}"))">
                                Service
                            </MudButton>

                            <MudButton Variant="Variant.Outlined"
                                       Color="Color.Primary"
                                       Class="btn-strong"
                                       OnClick="@(() => Nav.NavigateTo($"/chat/{order.ConversationId}"))">
                                Chat
                            </MudButton>
                        </div>
                    </div>
                </MudItem>
            }
        </MudGrid>

        <div class="orders-pagination">
            <MudPagination Count="@_totalPages"
                           Selected="@_page"
                           SelectedChanged="OnPageChanged"
                           Color="Color.Primary"
                           Variant="Variant.Outlined" />
        </div>
    }
</MudContainer>

<style>
    .hero {
        border-radius: 24px;
        border: 1px solid rgba(0,0,0,.08);
        background: linear-gradient(135deg,#eef2ff,#e0e7ff);
        box-shadow: 0 18px 46px rgba(0,0,0,.06);
        position: relative;
        overflow: hidden;
    }

        .hero::before {
            content: "";
            position: absolute;
            inset: -45% -70%;
            background: radial-gradient(circle at 30% 30%, rgba(255,255,255,.55), transparent 55%);
            transform: rotate(12deg);
            opacity: .9;
            pointer-events: none;
        }

    .hero-inner {
        position: relative;
        z-index: 1;
        padding: 26px 26px 12px 26px;
        display: flex;
        justify-content: space-between;
        gap: 16px;
        align-items: center;
        flex-wrap: wrap;
    }

    .hero-left {
        min-width: 0;
    }

    .hero-title {
        font-weight: 950;
        color: #111827;
        font-size: 1.7rem;
        letter-spacing: .2px;
        line-height: 1.12;
    }

    .hero-sub {
        color: rgba(17,24,39,.65);
        font-size: 1rem;
        line-height: 1.35;
        margin-top: 6px;
    }

    .hero-right {
        min-width: 220px;
    }

    .mode-select {
        min-width: 220px;
    }

    .hero-stats {
        position: relative;
        z-index: 1;
        display: flex;
        flex-wrap: wrap;
        gap: 10px;
        padding: 0 26px 26px 26px;
    }

    .stat-chip {
        min-width: 140px;
        border-radius: 16px;
        border: 1px solid rgba(0,0,0,.08);
        background: rgba(255,255,255,.72);
        backdrop-filter: blur(6px);
        padding: 10px 12px;
    }

    .stat-label {
        color: rgba(17,24,39,.6);
        font-size: .9rem;
        font-weight: 800;
    }

    .stat-value {
        margin-top: 4px;
        font-weight: 950;
        color: #111827;
        font-size: 1.15rem;
        line-height: 1.1;
    }

    .order-card {
        border-radius: 22px;
        border: 1px solid rgba(0,0,0,.08);
        background: #fff;
        box-shadow: 0 18px 46px rgba(0,0,0,.06);
        padding: 20px;
        display: flex;
        flex-direction: column;
        gap: 16px;
        height: 100%;
    }

    .order-top {
        display: flex;
        justify-content: space-between;
        gap: 12px;
        align-items: flex-start;
    }

    .order-title-wrap {
        min-width: 0;
    }

    .order-id {
        font-weight: 950;
        color: #111827;
        font-size: 1.08rem;
        letter-spacing: .2px;
        line-height: 1.15;
    }

    .order-service {
        color: rgba(17,24,39,.65);
        margin-top: 6px;
        line-height: 1.3;
        word-break: break-word;
    }

    .order-meta-grid {
        display: grid;
        grid-template-columns: repeat(2,minmax(0,1fr));
        gap: 12px;
    }

    .meta-box {
        border-radius: 16px;
        border: 1px solid rgba(0,0,0,.08);
        background: rgba(99,102,241,.04);
        padding: 12px 14px;
        min-width: 0;
    }

    .meta-label {
        color: rgba(17,24,39,.6);
        font-size: .88rem;
        font-weight: 800;
    }

    .meta-value {
        margin-top: 6px;
        color: #111827;
        font-weight: 950;
        line-height: 1.2;
        min-width: 0;
    }

    .ellipsis {
        overflow: hidden;
        text-overflow: ellipsis;
        white-space: nowrap;
    }

    .text-link {
        font-weight: 950;
        color: #111827;
        text-decoration: none;
    }

    .order-actions {
        display: flex;
        flex-wrap: wrap;
        gap: 10px;
        margin-top: auto;
    }

    .btn-strong {
        border-radius: 14px;
        font-weight: 900;
        letter-spacing: .2px;
        padding: 10px 14px;
    }

    .empty-shell {
        margin-top: 16px;
        border-radius: 22px;
        border: 1px solid rgba(0,0,0,.08);
        background: #fff;
        box-shadow: 0 18px 46px rgba(0,0,0,.06);
        padding: 28px;
        text-align: center;
    }

    .empty-title {
        font-weight: 950;
        color: #111827;
        font-size: 1.15rem;
    }

    .empty-sub {
        color: rgba(17,24,39,.65);
        margin-top: 8px;
    }

    .orders-pagination {
        margin-top: 22px;
        display: flex;
        justify-content: center;
    }

    .skeleton {
        background: #fff;
        position: relative;
        overflow: hidden;
        min-height: 250px;
    }

        .skeleton::before {
            content: "";
            position: absolute;
            inset: 0;
            background: linear-gradient(90deg,#f3f4f6,#fafafa,#f3f4f6);
            background-size: 200% 100%;
            animation: shimmer 1.2s infinite linear;
        }

    @@keyframes shimmer {
        0% {
            background-position: 0% 0;
        }

        100% {
            background-position: 200% 0;
        }
    }

    @@media (max-width: 900px) {
        .order-meta-grid {
            grid-template-columns: 1fr;
        }
    }
</style>

@code {
    [CascadingParameter] public Task<AuthenticationState> AuthenticationStateTask { get; set; } = default!;

    private bool _loading = true;
    private string _mode = "All";
    private string? _meId;

    private List<Order> _allOrders = new();
    private List<Order> _orders = new();
    private Dictionary<string, ApplicationUser> _users = new();

    private int _page = 1;
    private int _pageSize = 8;
    private int _totalItems;
    private int _totalPages = 1;

    protected override async Task OnInitializedAsync()
    {
        await LoadAsync();
    }

    private async Task OnModeChanged(string v)
    {
        _mode = v ?? "All";
        _page = 1;
        await LoadAsync();
    }

    private async Task OnPageChanged(int page)
    {
        _page = page;
        await ApplyPagingAsync();
    }

    private async Task LoadAsync()
    {
        if (_loading && _allOrders.Count == 0)
            StateHasChanged();

        _loading = true;
        _allOrders.Clear();
        _orders.Clear();
        _users.Clear();

        var authState = await AuthenticationStateTask;
        var principal = authState.User;

        if (principal?.Identity?.IsAuthenticated != true)
        {
            Nav.NavigateTo("/Account/Login");
            _loading = false;
            return;
        }

        var me = await UserManager.GetUserAsync(principal);
        if (me == null)
        {
            Nav.NavigateTo("/Account/Login");
            _loading = false;
            return;
        }

        _meId = me.Id;

        var orders = await OrderRepo.GetForUserAsync(me.Id);

        if (_mode == "Buying")
            orders = orders.Where(x => x.BuyerId == me.Id).ToList();

        if (_mode == "Selling")
            orders = orders.Where(x => x.SellerId == me.Id).ToList();

        _allOrders = orders
            .OrderByDescending(x => x.CreatedAtUtc)
            .ToList();

        var ids = _allOrders.SelectMany(o => new[] { o.BuyerId, o.SellerId }).Distinct().ToList();

        await using var db = await DbFactory.CreateDbContextAsync();
        var users = await db.Users
            .AsNoTracking()
            .Where(u => ids.Contains(u.Id))
            .ToListAsync();

        _users = users.ToDictionary(x => x.Id, x => x);

        await ApplyPagingAsync();

        _loading = false;
        StateHasChanged();
    }

    private Task ApplyPagingAsync()
    {
        _totalItems = _allOrders.Count;
        _totalPages = Math.Max(1, (int)Math.Ceiling(_totalItems / (double)_pageSize));

        if (_page > _totalPages)
            _page = _totalPages;

        _orders = _allOrders
            .Skip((_page - 1) * _pageSize)
            .Take(_pageSize)
            .ToList();

        return Task.CompletedTask;
    }

    private ApplicationUser? GetUser(string id)
        => _users.TryGetValue(id, out var u) ? u : null;

    private static string DisplayName(ApplicationUser u)
        => !string.IsNullOrWhiteSpace(u.DisplayName) ? u.DisplayName : (u.UserName ?? "User");

    private static Color StatusColor(OrderStatus status)
        => status switch
        {
            OrderStatus.InProgress => Color.Warning,
            OrderStatus.Completed => Color.Success,
            OrderStatus.Cancelled => Color.Error,
            _ => Color.Default
        };
}