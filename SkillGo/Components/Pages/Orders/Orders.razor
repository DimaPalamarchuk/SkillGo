@page "/orders"
@attribute [Microsoft.AspNetCore.Authorization.Authorize]
@using Microsoft.AspNetCore.Components.Authorization
@using Microsoft.EntityFrameworkCore
@using MudBlazor
@using SkillGo.Data
@using SkillGo.Data.Models
@using SkillGo.Data.Models.Orders
@inject IDbContextFactory<ApplicationDbContext> DbFactory
@inject NavigationManager Nav

<PageTitle>Orders</PageTitle>

<MudContainer MaxWidth="MaxWidth.False" Class="orders-page-shell pa-0">
    <MudContainer MaxWidth="MaxWidth.ExtraLarge" Class="pt-6 pb-8">
        <MudPaper Class="orders-hero pa-6 pa-md-8" Elevation="0">
            <MudGrid Spacing="3" AlignItems="AlignItems.Center">
                <MudItem xs="12" md="8">
                    <div class="orders-hero-badge">
                        <MudIcon Icon="@Icons.Material.Filled.Inventory2" Size="Size.Small" />
                        <span>Manage your workflow</span>
                    </div>

                    <MudText Typo="Typo.h3" Class="orders-hero-title mt-4">
                        Orders
                    </MudText>

                    <MudText Typo="Typo.body1" Class="orders-hero-sub mt-4">
                        Track purchases, deliveries and completed work in one place.
                    </MudText>

                    <MudStack Row="true" Spacing="1" Class="mt-4 orders-stats-row">
                        <MudChip T="string" Variant="Variant.Outlined" Class="orders-hero-chip">Total: @_totalItems</MudChip>
                        <MudChip T="string" Variant="Variant.Outlined" Class="orders-hero-chip">In progress: @_allOrders.Count(x => x.Status == OrderStatus.InProgress)</MudChip>
                        <MudChip T="string" Variant="Variant.Outlined" Class="orders-hero-chip">Completed: @_allOrders.Count(x => x.Status == OrderStatus.Completed)</MudChip>
                    </MudStack>
                </MudItem>

                <MudItem xs="12" md="4">
                    <MudPaper Class="orders-hero-side pa-5" Elevation="0">
                        <MudText Typo="Typo.h6" Class="hero-side-title">View mode</MudText>
                        <MudText Typo="Typo.body2" Class="hero-side-sub mt-1">Choose which orders to display.</MudText>

                        <MudSelect T="string"
                                   Variant="Variant.Outlined"
                                   Value="@_mode"
                                   ValueChanged="OnModeChanged"
                                   Class="mode-select mt-4"
                                   FullWidth="true">
                            <MudSelectItem T="string" Value="@("All")">All</MudSelectItem>
                            <MudSelectItem T="string" Value="@("Buying")">Buying</MudSelectItem>
                            <MudSelectItem T="string" Value="@("Selling")">Selling</MudSelectItem>
                        </MudSelect>
                    </MudPaper>
                </MudItem>
            </MudGrid>
        </MudPaper>

        @if (_loading)
        {
            <MudGrid Spacing="3" Class="mt-4">
                @for (var i = 0; i < 6; i++)
                {
                    <MudItem xs="12" md="6">
                        <div class="order-card skeleton"></div>
                    </MudItem>
                }
            </MudGrid>
        }
        else if (_orders.Count == 0)
        {
            <MudPaper Class="empty-paper mt-4 pa-8 text-center" Elevation="0">
                <MudText Typo="Typo.h5" Class="empty-title">No orders yet</MudText>
                <MudText Typo="Typo.body2" Class="empty-sub mt-2">When you buy or sell a service, it will appear here.</MudText>
                <MudButton Variant="Variant.Filled" Color="Color.Primary" Class="btn-strong mt-4" Href="/services/category">
                    Browse services
                </MudButton>
            </MudPaper>
        }
        else
        {
            <MudGrid Spacing="3" Class="mt-4">
                @foreach (var order in _orders)
                {
                    var otherUserId = order.BuyerId == _meId ? order.SellerId : order.BuyerId;
                    var user = GetUser(otherUserId);

                    <MudItem xs="12" md="6">
                        <MudPaper Class="order-card" Elevation="0">
                            <MudStack Spacing="2" Class="h-100">
                                <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Start" Spacing="2">
                                    <div class="order-title-wrap">
                                        <MudText Typo="Typo.h6" Class="order-id">Order #@order.Id</MudText>
                                        <MudText Typo="Typo.body2" Class="order-service mt-1">
                                            @(order.ServiceOffer?.Title ?? "Service")
                                        </MudText>
                                    </div>

                                    <MudChip T="string"
                                             Size="Size.Small"
                                             Color="@StatusColor(order.Status)"
                                             Variant="Variant.Filled">
                                        @order.Status.ToString()
                                    </MudChip>
                                </MudStack>

                                <MudGrid Spacing="2">
                                    <MudItem xs="12" sm="6">
                                        <MudPaper Class="meta-box pa-3" Elevation="0">
                                            <MudText Typo="Typo.caption" Class="meta-label">Amount</MudText>
                                            <MudText Typo="Typo.body1" Class="meta-value mt-1">@order.Amount.ToString("0.00") zł</MudText>
                                        </MudPaper>
                                    </MudItem>

                                    <MudItem xs="12" sm="6">
                                        <MudPaper Class="meta-box pa-3" Elevation="0">
                                            <MudText Typo="Typo.caption" Class="meta-label">Escrow</MudText>
                                            <MudText Typo="Typo.body1" Class="meta-value mt-1">@order.EscrowAmount.ToString("0.00") zł</MudText>
                                        </MudPaper>
                                    </MudItem>

                                    <MudItem xs="12" sm="6">
                                        <MudPaper Class="meta-box pa-3" Elevation="0">
                                            <MudText Typo="Typo.caption" Class="meta-label">User</MudText>
                                            <div class="mt-1">
                                                @if (user != null && !string.IsNullOrWhiteSpace(user.UserName))
                                                {
                                                    <MudLink Href="@($"/profile/{user.UserName}")" Class="meta-link">
                                                        @DisplayName(user)
                                                    </MudLink>
                                                }
                                                else
                                                {
                                                    <span class="meta-value">@otherUserId</span>
                                                }
                                            </div>
                                        </MudPaper>
                                    </MudItem>

                                    <MudItem xs="12" sm="6">
                                        <MudPaper Class="meta-box pa-3" Elevation="0">
                                            <MudText Typo="Typo.caption" Class="meta-label">Created</MudText>
                                            <MudText Typo="Typo.body2" Class="meta-value mt-1">@order.CreatedAtUtc.ToLocalTime().ToString("yyyy-MM-dd")</MudText>
                                        </MudPaper>
                                    </MudItem>
                                </MudGrid>

                                <MudStack Row="true" Wrap="Wrap.Wrap" Spacing="1" Class="mt-auto">
                                    <MudButton Variant="Variant.Filled"
                                               Color="Color.Primary"
                                               Class="btn-strong"
                                               OnClick="@(() => Nav.NavigateTo($"/orders/{order.Id}"))">
                                        Details
                                    </MudButton>

                                    <MudButton Variant="Variant.Outlined"
                                               Color="Color.Primary"
                                               Class="btn-strong"
                                               Disabled="@(order.ServiceOfferId <= 0)"
                                               OnClick="@(() => Nav.NavigateTo($"/services/{order.ServiceOfferId}"))">
                                        Service
                                    </MudButton>

                                    <MudButton Variant="Variant.Outlined"
                                               Color="Color.Primary"
                                               Class="btn-strong"
                                               OnClick="@(() => Nav.NavigateTo($"/chat/{order.ConversationId}"))">
                                        Chat
                                    </MudButton>
                                </MudStack>
                            </MudStack>
                        </MudPaper>
                    </MudItem>
                }
            </MudGrid>

            <div class="orders-pagination">
                <MudPagination Count="@_totalPages"
                               Selected="@_page"
                               SelectedChanged="OnPageChanged"
                               Color="Color.Primary"
                               Variant="Variant.Outlined" />
            </div>
        }
    </MudContainer>
</MudContainer>

<style>
    .orders-page-shell {
        min-height: calc(100vh - 78px);
        background:
            radial-gradient(circle at top left, rgba(124,58,237,.10), transparent 22%),
            radial-gradient(circle at top right, rgba(99,102,241,.08), transparent 24%),
            linear-gradient(180deg, #fbfaff 0%, #f7f4ff 42%, #ffffff 100%);
    }

    .orders-hero {
        border-radius: 32px;
        background: linear-gradient(135deg, #2e1065 0%, #4c1d95 46%, #5b21b6 100%);
        color: #fff;
        border: 1px solid rgba(255,255,255,.10);
        box-shadow: 0 22px 60px rgba(76,29,149,.18);
    }

    .orders-hero-badge {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        padding: 8px 14px;
        border-radius: 999px;
        background: rgba(255,255,255,.10);
        border: 1px solid rgba(255,255,255,.14);
        font-size: 13px;
        font-weight: 700;
    }

    .orders-hero-title {
        font-weight: 900;
        line-height: 1.02;
        letter-spacing: -.03em;
    }

    .orders-hero-sub {
        color: rgba(255,255,255,.82);
        line-height: 1.8;
        font-size: 16px;
        max-width: 760px;
    }

    .orders-stats-row {
        flex-wrap: wrap;
    }

    .orders-hero-chip {
        color: #fff !important;
        border-color: rgba(255,255,255,.24) !important;
        background: rgba(255,255,255,.06) !important;
        font-weight: 700;
    }

    .orders-hero-side,
    .order-card,
    .meta-box,
    .empty-paper {
        border-radius: 26px;
        background: rgba(255,255,255,.94);
        border: 1px solid rgba(109,40,217,.10);
        box-shadow: 0 14px 38px rgba(88,28,135,.06);
    }

    .hero-side-title,
    .order-id,
    .meta-value,
    .empty-title {
        color: #1f1147;
        font-weight: 800;
    }

    .hero-side-sub,
    .order-service,
    .meta-label,
    .empty-sub {
        color: #6b5f8d;
    }

    .order-card {
        height: 100%;
        padding: 20px;
        transition: transform .18s ease, box-shadow .18s ease, border-color .18s ease;
    }

    .order-card:hover {
        transform: translateY(-4px);
        border-color: rgba(109,40,217,.22);
        box-shadow: 0 18px 42px rgba(88,28,135,.10);
    }

    .order-title-wrap {
        min-width: 0;
    }

    .order-service {
        line-height: 1.45;
        word-break: break-word;
    }

    .meta-box {
        background: linear-gradient(180deg, #faf7ff 0%, #ffffff 100%);
    }

    .meta-link {
        color: #1f1147 !important;
        font-weight: 800;
        text-decoration: none !important;
    }

    .meta-link:hover {
        color: #6d28d9 !important;
    }

    .btn-strong {
        border-radius: 14px;
        font-weight: 900;
        letter-spacing: .2px;
        text-transform: none;
        padding: 10px 14px;
    }

    .orders-pagination {
        margin-top: 22px;
        display: flex;
        justify-content: center;
    }

    .skeleton {
        background: #fff;
        position: relative;
        overflow: hidden;
        min-height: 250px;
        border-radius: 26px;
        border: 1px solid rgba(109,40,217,.10);
    }

    .skeleton::before {
        content: "";
        position: absolute;
        inset: 0;
        background: linear-gradient(90deg,#f3f4f6,#fafafa,#f3f4f6);
        background-size: 200% 100%;
        animation: shimmer 1.2s infinite linear;
    }

    @@keyframes shimmer {
        0% { background-position: 0% 0; }
        100% { background-position: 200% 0; }
    }

    @@media (max-width: 700px) {
        .orders-hero,
        .orders-hero-side,
        .order-card,
        .meta-box,
        .empty-paper {
            border-radius: 22px;
        }

        .orders-hero-title {
            font-size: 2rem !important;
        }
    }
</style>

@code {
    [CascadingParameter] public Task<AuthenticationState> AuthenticationStateTask { get; set; } = default!;

    private bool _loading = true;
    private string _mode = "All";
    private string? _meId;

    private List<Order> _allOrders = new();
    private List<Order> _orders = new();
    private Dictionary<string, ApplicationUser> _users = new();

    private int _page = 1;
    private int _pageSize = 8;
    private int _totalItems;
    private int _totalPages = 1;

    protected override async Task OnInitializedAsync()
    {
        await LoadAsync();
    }

    private async Task OnModeChanged(string v)
    {
        _mode = v ?? "All";
        _page = 1;
        await LoadAsync();
    }

    private async Task OnPageChanged(int page)
    {
        _page = page;
        ApplyPaging();
        await InvokeAsync(StateHasChanged);
    }

    private async Task LoadAsync()
    {
        _loading = true;
        _allOrders.Clear();
        _orders.Clear();
        _users.Clear();
        StateHasChanged();

        var authState = await AuthenticationStateTask;
        var principal = authState.User;

        if (principal?.Identity?.IsAuthenticated != true)
        {
            Nav.NavigateTo("/Account/Login");
            _loading = false;
            return;
        }

        _meId = principal.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value;

        if (string.IsNullOrWhiteSpace(_meId))
        {
            Nav.NavigateTo("/Account/Login");
            _loading = false;
            return;
        }

        await using var db = await DbFactory.CreateDbContextAsync();

        var ordersQuery = db.Orders
            .AsNoTracking()
            .Include(x => x.ServiceOffer)
            .Where(x => x.BuyerId == _meId || x.SellerId == _meId);

        if (_mode == "Buying")
            ordersQuery = ordersQuery.Where(x => x.BuyerId == _meId);

        if (_mode == "Selling")
            ordersQuery = ordersQuery.Where(x => x.SellerId == _meId);

        _allOrders = await ordersQuery
            .OrderByDescending(x => x.CreatedAtUtc)
            .ToListAsync();

        var ids = _allOrders
            .SelectMany(o => new[] { o.BuyerId, o.SellerId })
            .Where(x => !string.IsNullOrWhiteSpace(x))
            .Distinct()
            .ToList();

        var users = await db.Users
            .AsNoTracking()
            .Where(u => ids.Contains(u.Id))
            .ToListAsync();

        _users = users.ToDictionary(x => x.Id, x => x);

        ApplyPaging();

        _loading = false;
        StateHasChanged();
    }

    private void ApplyPaging()
    {
        _totalItems = _allOrders.Count;
        _totalPages = Math.Max(1, (int)Math.Ceiling(_totalItems / (double)_pageSize));

        if (_page > _totalPages)
            _page = _totalPages;

        _orders = _allOrders
            .Skip((_page - 1) * _pageSize)
            .Take(_pageSize)
            .ToList();
    }

    private ApplicationUser? GetUser(string id)
        => _users.TryGetValue(id, out var u) ? u : null;

    private static string DisplayName(ApplicationUser u)
        => !string.IsNullOrWhiteSpace(u.DisplayName) ? u.DisplayName : (u.UserName ?? "User");

    private static Color StatusColor(OrderStatus status)
        => status switch
        {
            OrderStatus.InProgress => Color.Warning,
            OrderStatus.Completed => Color.Success,
            OrderStatus.Cancelled => Color.Error,
            _ => Color.Default
        };
}