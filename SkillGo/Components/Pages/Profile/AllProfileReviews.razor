@page "/profile/{UserName}/reviews"
@using Microsoft.EntityFrameworkCore
@using MudBlazor
@using SkillGo.Data
@using SkillGo.Data.Models
@inject ApplicationDbContext Db
@inject NavigationManager Nav

<PageTitle>Reviews</PageTitle>

<MudContainer MaxWidth="MaxWidth.False" Class="profile-reviews-shell pa-0">
    <MudContainer MaxWidth="MaxWidth.ExtraLarge" Class="pt-6 pb-8">
        @if (_loading)
        {
            <MudGrid Spacing="3">
                @for (var i = 0; i < 6; i++)
                {
                    <MudItem xs="12" md="6">
                        <div class="review-card skeleton"></div>
                    </MudItem>
                }
            </MudGrid>
        }
        else if (_user is null)
        {
            <MudPaper Class="empty-paper pa-8 text-center" Elevation="0">
                <MudText Typo="Typo.h5" Class="empty-title">User not found</MudText>
                <MudText Typo="Typo.body2" Class="empty-sub mt-2">The requested profile does not exist.</MudText>
            </MudPaper>
        }
        else
        {
            <MudPaper Class="reviews-hero pa-6 pa-md-8" Elevation="0">
                <MudGrid Spacing="3" AlignItems="AlignItems.Stretch">
                    <MudItem xs="12" md="8">
                        <div class="hero-badge">
                            <MudIcon Icon="@Icons.Material.Filled.RateReview" Size="Size.Small" />
                            <span>Profile feedback</span>
                        </div>

                        <MudText Typo="Typo.h3" Class="hero-title mt-4">
                            Reviews for @DisplayName(_user)
                        </MudText>

                        <MudText Typo="Typo.body1" Class="hero-sub mt-4">
                            @_totalItems review(s) found for this profile.
                        </MudText>

                        <MudStack Row="true" Spacing="2" Class="mt-5 hero-actions">
                            <MudButton Variant="Variant.Outlined"
                                       Color="Color.Inherit"
                                       Class="btn-soft"
                                       OnClick="@(() => Nav.NavigateTo($"/profile/{_user.UserName}"))">
                                Back to profile
                            </MudButton>
                        </MudStack>
                    </MudItem>

                    <MudItem xs="12" md="4">
                        <MudPaper Class="hero-side pa-5 h-100" Elevation="0">
                            <MudText Typo="Typo.h6" Class="side-title">Filters</MudText>

                            <MudStack Spacing="2" Class="mt-3">
                                <MudSelect T="int?"
                                           Label="Rating"
                                           Variant="Variant.Outlined"
                                           Value="@_ratingFilter"
                                           ValueChanged="OnRatingChanged">
                                    <MudSelectItem T="int?" Value="@((int?)null)">All ratings</MudSelectItem>
                                    <MudSelectItem T="int?" Value="@((int?)5)">5 stars</MudSelectItem>
                                    <MudSelectItem T="int?" Value="@((int?)4)">4 stars</MudSelectItem>
                                    <MudSelectItem T="int?" Value="@((int?)3)">3 stars</MudSelectItem>
                                    <MudSelectItem T="int?" Value="@((int?)2)">2 stars</MudSelectItem>
                                    <MudSelectItem T="int?" Value="@((int?)1)">1 star</MudSelectItem>
                                </MudSelect>

                                <MudSelect T="string"
                                           Label="Sort by date"
                                           Variant="Variant.Outlined"
                                           Value="@_sort"
                                           ValueChanged="OnSortChanged">
                                    <MudSelectItem T="string" Value="@("newest")">Newest first</MudSelectItem>
                                    <MudSelectItem T="string" Value="@("oldest")">Oldest first</MudSelectItem>
                                </MudSelect>
                            </MudStack>
                        </MudPaper>
                    </MudItem>
                </MudGrid>
            </MudPaper>

            @if (_reviews.Count == 0)
            {
                <MudPaper Class="empty-paper mt-4 pa-8 text-center" Elevation="0">
                    <MudText Typo="Typo.h5" Class="empty-title">No reviews found</MudText>
                    <MudText Typo="Typo.body2" Class="empty-sub mt-2">Try changing the filters.</MudText>
                </MudPaper>
            }
            else
            {
                <MudGrid Spacing="3" Class="mt-4">
                    @foreach (var r in _reviews)
                    {
                        <MudItem xs="12" md="6">
                            <MudPaper Class="review-card pa-4" Elevation="0">
                                <a class="review-author" href="@AuthorProfileUrl(r.AuthorUser)">
                                    <img class="review-author-avatar" src="@AuthorAvatar(r.AuthorUser)" />
                                    <div class="review-author-copy">
                                        <div class="review-author-name">@DisplayName(r.AuthorUser)</div>
                                        <div class="review-author-username">@("@" + (r.AuthorUser?.UserName ?? ""))</div>
                                    </div>
                                </a>

                                <div class="review-top">
                                    <div class="stars">@Stars(r.Stars)</div>
                                    <div class="muted">@r.CreatedAt.ToLocalTime().ToString("yyyy-MM-dd")</div>
                                </div>

                                @if (!string.IsNullOrWhiteSpace(r.Comment))
                                {
                                    <div class="review-text">@r.Comment</div>
                                }
                            </MudPaper>
                        </MudItem>
                    }
                </MudGrid>

                <div class="reviews-pagination">
                    <MudPagination Count="@_totalPages"
                                   Selected="@_page"
                                   SelectedChanged="OnPageChanged"
                                   Color="Color.Primary"
                                   Variant="Variant.Outlined" />
                </div>
            }
        }
    </MudContainer>
</MudContainer>

<style>
    .profile-reviews-shell {
        min-height: calc(100vh - 78px);
        background:
            radial-gradient(circle at top left, rgba(124,58,237,.10), transparent 22%),
            radial-gradient(circle at top right, rgba(99,102,241,.08), transparent 24%),
            linear-gradient(180deg, #fbfaff 0%, #f7f4ff 42%, #ffffff 100%);
    }

    .reviews-hero {
        border-radius: 32px;
        background: linear-gradient(135deg, #2e1065 0%, #4c1d95 46%, #5b21b6 100%);
        color: #fff;
        border: 1px solid rgba(255,255,255,.10);
        box-shadow: 0 22px 60px rgba(76,29,149,.18);
    }

    .hero-badge {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        padding: 8px 14px;
        border-radius: 999px;
        background: rgba(255,255,255,.10);
        border: 1px solid rgba(255,255,255,.14);
        font-size: 13px;
        font-weight: 700;
    }

    .hero-title {
        font-weight: 900;
        line-height: 1.02;
        letter-spacing: -.03em;
        max-width: 760px;
    }

    .hero-sub {
        color: rgba(255,255,255,.82);
        max-width: 700px;
        line-height: 1.8;
        font-size: 16px;
    }

    .hero-actions {
        flex-wrap: wrap;
    }

    .hero-side,
    .review-card,
    .empty-paper {
        border-radius: 26px;
        background: rgba(255,255,255,.94);
        border: 1px solid rgba(109,40,217,.10);
        box-shadow: 0 14px 38px rgba(88,28,135,.06);
    }

    .side-title,
    .empty-title,
    .review-author-name {
        color: #1f1147;
        font-weight: 900;
    }

    .hero-side {
        background: rgba(255,255,255,.16);
        border-color: rgba(255,255,255,.12);
        box-shadow: none;
    }

    .hero-side .side-title {
        color: #fff;
    }

    .btn-soft {
        border-radius: 14px;
        font-weight: 900;
        letter-spacing: .2px;
        padding: 10px 14px;
        text-transform: none;
        color: #fff !important;
        border-color: rgba(255,255,255,.24) !important;
        background: rgba(255,255,255,.08) !important;
    }

    .review-card {
        height: 100%;
        background: linear-gradient(180deg, #faf7ff 0%, #ffffff 100%);
    }

    .review-author {
        display: flex;
        align-items: center;
        gap: 10px;
        text-decoration: none;
        color: inherit;
        margin-bottom: 12px;
    }

    .review-author-avatar {
        width: 44px;
        height: 44px;
        border-radius: 50%;
        object-fit: cover;
        border: 1px solid rgba(109,40,217,.12);
        background: #fff;
        flex: 0 0 auto;
    }

    .review-author-copy {
        min-width: 0;
    }

    .review-author-name {
        line-height: 1.1;
    }

    .review-author-username,
    .muted,
    .empty-sub {
        color: #6b5f8d;
    }

    .review-author-username {
        margin-top: 3px;
        font-size: .88rem;
        font-weight: 800;
    }

    .review-top {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 10px;
    }

    .stars {
        font-weight: 950;
        letter-spacing: .6px;
        color: #1f1147;
    }

    .review-text {
        margin-top: 10px;
        color: rgba(31,17,71,.80);
        line-height: 1.5;
        white-space: pre-wrap;
    }

    .reviews-pagination {
        margin-top: 22px;
        display: flex;
        justify-content: center;
    }

    .skeleton {
        min-height: 190px;
        position: relative;
        overflow: hidden;
    }

    .skeleton::before {
        content: "";
        position: absolute;
        inset: 0;
        background: linear-gradient(90deg,#f3f4f6,#fafafa,#f3f4f6);
        background-size: 200% 100%;
        animation: shimmer 1.2s infinite linear;
    }

    @@keyframes shimmer {
        0% {
            background-position: 0% 0;
        }

        100% {
            background-position: 200% 0;
        }
    }

    @@media (max-width: 700px) {
        .reviews-hero,
        .hero-side,
        .review-card,
        .empty-paper {
            border-radius: 22px;
        }

        .hero-title {
            font-size: 2rem !important;
        }
    }
</style>

@code {
    [Parameter] public string UserName { get; set; } = default!;

    private bool _loading = true;
    private ApplicationUser? _user;
    private List<Review> _reviews = new();

    private int? _ratingFilter;
    private string _sort = "newest";

    private int _page = 1;
    private int _pageSize = 8;
    private int _totalItems;
    private int _totalPages = 1;

    protected override async Task OnParametersSetAsync()
    {
        _loading = true;

        var userName = (UserName ?? "").Trim();
        if (string.IsNullOrWhiteSpace(userName))
        {
            _user = null;
            _loading = false;
            return;
        }

        _user = await Db.Users.FirstOrDefaultAsync(u => u.UserName == userName);

        if (_user is null)
        {
            _loading = false;
            return;
        }

        await LoadReviewsAsync();
        _loading = false;
    }

    private async Task LoadReviewsAsync()
    {
        if (_user is null)
            return;

        var query = Db.Reviews
            .AsNoTracking()
            .Include(x => x.AuthorUser)
            .Where(x => x.TargetUserId == _user.Id);

        if (_ratingFilter.HasValue)
            query = query.Where(x => x.Stars == _ratingFilter.Value);

        query = _sort == "oldest"
            ? query.OrderBy(x => x.CreatedAt)
            : query.OrderByDescending(x => x.CreatedAt);

        _totalItems = await query.CountAsync();
        _totalPages = Math.Max(1, (int)Math.Ceiling(_totalItems / (double)_pageSize));

        if (_page > _totalPages)
            _page = _totalPages;

        _reviews = await query
            .Skip((_page - 1) * _pageSize)
            .Take(_pageSize)
            .ToListAsync();
    }

    private async Task OnRatingChanged(int? value)
    {
        _ratingFilter = value;
        _page = 1;
        await LoadReviewsAsync();
    }

    private async Task OnSortChanged(string value)
    {
        _sort = value ?? "newest";
        _page = 1;
        await LoadReviewsAsync();
    }

    private async Task OnPageChanged(int page)
    {
        _page = page;
        await LoadReviewsAsync();
    }

    private static string DisplayName(ApplicationUser? u)
        => u is null
            ? "User"
            : !string.IsNullOrWhiteSpace(u.DisplayName)
                ? u.DisplayName!
                : (u.UserName ?? "User");

    private static string Stars(int rating)
    {
        var full = Math.Clamp(rating, 0, 5);
        return new string('★', full) + new string('☆', 5 - full);
    }

    private static string AuthorAvatar(ApplicationUser? user)
        => user?.AvatarUrl ?? "/images/default-avatar.png";

    private static string AuthorProfileUrl(ApplicationUser? user)
        => !string.IsNullOrWhiteSpace(user?.UserName) ? $"/profile/{user!.UserName}" : "#";
}