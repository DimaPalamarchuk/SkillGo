@page "/profile/{UserName}"
@using System.Security.Claims
@using Microsoft.AspNetCore.Components.Authorization
@using Microsoft.EntityFrameworkCore
@using MudBlazor
@using SkillGo.Data
@using SkillGo.Data.Models
@using SkillGo.Data.Models.Chat
@inject IDbContextFactory<ApplicationDbContext> DbFactory
@inject NavigationManager Nav

<PageTitle>Profile</PageTitle>

<MudContainer MaxWidth="MaxWidth.Large" Class="mt-6">
    @if (_loading)
    {
        <MudGrid Spacing="4">
            <MudItem xs="12" md="8">
                <div class="shell skeleton"></div>
            </MudItem>
            <MudItem xs="12" md="4">
                <div class="side skeleton"></div>
            </MudItem>
        </MudGrid>
    }
    else if (_user is null)
    {
        <MudPaper Class="pa-5" Elevation="0" Style="border-radius:20px;border:1px solid rgba(109,40,217,.10);">
            User not found.
        </MudPaper>
    }
    else
    {
        <div class="hero">
            <div class="hero-inner">
                <div class="hero-left">
                    <img class="avatar" src="@(_user.AvatarUrl ?? "/images/default-avatar.png")" />
                    <div class="name-block">
                        <div class="name-row">
                            <div class="name">@DisplayName(_user)</div>

                            @if (_isTargetAdmin)
                            {
                                <div class="admin-badge">Admin</div>
                            }

                            @if (_hasActiveBan)
                            {
                                <div class="ban-badge">Banned</div>
                            }
                        </div>

                        <div class="username">@("@" + (_user.UserName ?? ""))</div>
                    </div>
                </div>

                <div class="hero-right">
                    <div class="chip">
                        <div class="chip-label">Rating</div>
                        <div class="chip-value">@avgRating.ToString("0.0")</div>
                        <div class="chip-sub">(@reviewsCount)</div>
                    </div>

                    <div class="chip">
                        <div class="chip-label">Services</div>
                        <div class="chip-value">@_offers.Count</div>
                        <div class="chip-sub">published</div>
                    </div>
                </div>
            </div>

            @if (!string.IsNullOrWhiteSpace(_user.Bio))
            {
                <div class="bio">@_user.Bio</div>
            }

            <div class="profile-actions">
                @if (_canStartChat)
                {
                    <MudButton Variant="Variant.Filled"
                               Color="Color.Primary"
                               Class="btn-strong"
                               Disabled="_startingChat"
                               OnClick="StartChatAsync">
                        @(_startingChat ? "Opening..." : "Start chat")
                    </MudButton>
                }

                @if (!_isOwnProfile)
                {
                    <MudButton Variant="Variant.Outlined"
                               Color="Color.Error"
                               Class="btn-strong"
                               Href="@($"/reports/create?type=profile&targetUserId={_user.Id}")">
                        Report profile
                    </MudButton>
                }
            </div>
        </div>

        <MudGrid Spacing="4" Class="mt-4">
            <MudItem xs="12" md="8">
                <div class="shell">
                    <div class="head">
                        <div class="head-title">Services</div>
                        <div class="head-sub">Choose a service to view details</div>
                    </div>

                    <div class="body">
                        @if (_offers.Count == 0)
                        {
                            <div class="muted">No services yet.</div>
                        }
                        else
                        {
                            <MudGrid Spacing="3">
                                @foreach (var s in _offers)
                                {
                                    <MudItem xs="12" sm="6">
                                        <a class="card-link" href="@($"/services/{s.Id}")">
                                            <div class="card">
                                                <div class="card-title">@s.Title</div>
                                                <div class="card-desc">@TrimText(s.Description, 120)</div>
                                                <div class="card-row">
                                                    <div class="muted">Price</div>
                                                    <div class="price">@s.Price.ToString("0.##") zł</div>
                                                </div>
                                            </div>
                                        </a>
                                    </MudItem>
                                }
                            </MudGrid>
                        }
                    </div>
                </div>
            </MudItem>

            <MudItem xs="12" md="4">
                <div class="side">
                    <div class="side-title">Reviews</div>
                    <div class="side-sub">@avgRating.ToString("0.0") from @reviewsCount review(s)</div>

                    <div class="side-body">
                        @if (_reviews.Count == 0)
                        {
                            <div class="muted">No reviews yet.</div>
                        }
                        else
                        {
                            <MudStack Spacing="2">
                                @foreach (var r in _reviews)
                                {
                                    <MudPaper Class="pa-3" Elevation="0" Style="border-radius:16px;border:1px solid rgba(109,40,217,.10);">
                                        <a class="review-author" href="@AuthorProfileUrl(r.AuthorUser)">
                                            <img class="review-author-avatar" src="@AuthorAvatar(r.AuthorUser)" />
                                            <div class="review-author-copy">
                                                <div class="review-author-name">@DisplayName(r.AuthorUser)</div>
                                                <div class="review-author-username">@("@" + (r.AuthorUser?.UserName ?? ""))</div>
                                            </div>
                                        </a>

                                        <div class="review-top">
                                            <div class="stars">@Stars(r.Stars)</div>
                                            <div class="muted">@r.CreatedAt.ToLocalTime().ToString("yyyy-MM-dd")</div>
                                        </div>

                                        @if (!string.IsNullOrWhiteSpace(r.Comment))
                                        {
                                            <div class="review-text">@r.Comment</div>
                                        }
                                    </MudPaper>
                                }
                            </MudStack>

                            @if (reviewsCount > 0 && !string.IsNullOrWhiteSpace(_user.UserName))
                            {
                                <div class="reviews-more">
                                    <MudButton Variant="Variant.Text"
                                               Color="Color.Primary"
                                               Href="@($"/profile/{_user.UserName}/reviews")">
                                        View all reviews
                                    </MudButton>
                                </div>
                            }
                        }
                    </div>
                </div>
            </MudItem>
        </MudGrid>
    }
</MudContainer>

