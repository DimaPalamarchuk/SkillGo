@page "/profile/{UserName}"
@using System.Security.Claims
@using Microsoft.AspNetCore.Components.Authorization
@using Microsoft.EntityFrameworkCore
@using MudBlazor
@using SkillGo.Data
@using SkillGo.Data.Models
@using SkillGo.Data.Models.Chat
@inject ApplicationDbContext Db
@inject NavigationManager Nav

<PageTitle>Profile</PageTitle>

<MudContainer MaxWidth="MaxWidth.False" Class="public-profile-shell pa-0">
    <MudContainer MaxWidth="MaxWidth.ExtraLarge" Class="pt-6 pb-8">
        @if (_loading)
        {
            <MudGrid Spacing="3">
                <MudItem xs="12">
                    <div class="hero-skeleton skeleton"></div>
                </MudItem>
                <MudItem xs="12" md="8">
                    <div class="shell skeleton"></div>
                </MudItem>
                <MudItem xs="12" md="4">
                    <div class="side skeleton"></div>
                </MudItem>
            </MudGrid>
        }
        else if (_user is null)
        {
            <MudPaper Class="empty-paper pa-8 text-center" Elevation="0">
                <MudText Typo="Typo.h5" Class="empty-title">User not found</MudText>
                <MudText Typo="Typo.body2" Class="empty-sub mt-2">The requested profile does not exist.</MudText>
            </MudPaper>
        }
        else
        {
            <MudPaper Class="hero-paper pa-6 pa-md-8" Elevation="0">
                <MudGrid Spacing="3" AlignItems="AlignItems.Stretch">
                    <MudItem xs="12" md="8">
                        <div class="hero-profile-row">
                            <img class="avatar" src="@(_user.AvatarUrl ?? "/images/default-avatar.png")" />

                            <div class="name-block">
                                <div class="hero-badge">
                                    <MudIcon Icon="@Icons.Material.Filled.Person" Size="Size.Small" />
                                    <span>Public profile</span>
                                </div>

                                <div class="name-row mt-3">
                                    <div class="name">@DisplayName(_user)</div>

                                    @if (_isTargetAdmin)
                                    {
                                        <div class="admin-badge">Admin</div>
                                    }

                                    @if (_hasActiveBan)
                                    {
                                        <div class="ban-badge">Banned</div>
                                    }
                                </div>

                                <div class="username">@("@" + (_user.UserName ?? ""))</div>
                            </div>
                        </div>

                        @if (!string.IsNullOrWhiteSpace(_user.Bio))
                        {
                            <MudText Typo="Typo.body1" Class="hero-sub mt-4">@_user.Bio</MudText>
                        }

                        <MudStack Row="true" Spacing="2" Class="mt-5 hero-actions">
                            @if (_canStartChat)
                            {
                                <MudButton Variant="Variant.Filled"
                                           Color="Color.Primary"
                                           Class="btn-strong"
                                           Disabled="_startingChat"
                                           OnClick="StartChatAsync">
                                    @(_startingChat ? "Opening..." : "Start chat")
                                </MudButton>
                            }

                            @if (!_isOwnProfile)
                            {
                                <MudButton Variant="Variant.Outlined"
                                           Color="Color.Error"
                                           Class="btn-strong"
                                           Href="@($"/reports/create?type=profile&targetUserId={_user.Id}")">
                                    Report profile
                                </MudButton>
                            }
                        </MudStack>
                    </MudItem>

                    <MudItem xs="12" md="4">
                        <MudPaper Class="hero-side pa-5 h-100" Elevation="0">
                            <MudText Typo="Typo.h6" Class="side-title">Overview</MudText>

                            <MudGrid Spacing="2" Class="mt-2">
                                <MudItem xs="6">
                                    <MudPaper Class="stat-card pa-4" Elevation="0">
                                        <MudText Typo="Typo.h5" Class="stat-value">@avgRating.ToString("0.0")</MudText>
                                        <MudText Typo="Typo.body2" Class="stat-label">Rating</MudText>
                                    </MudPaper>
                                </MudItem>

                                <MudItem xs="6">
                                    <MudPaper Class="stat-card pa-4" Elevation="0">
                                        <MudText Typo="Typo.h5" Class="stat-value">@_offers.Count</MudText>
                                        <MudText Typo="Typo.body2" Class="stat-label">Services</MudText>
                                    </MudPaper>
                                </MudItem>
                            </MudGrid>

                            <MudPaper Class="stat-box pa-4 mt-3" Elevation="0">
                                <MudText Typo="Typo.caption" Class="stat-box-label">Reviews</MudText>
                                <MudText Typo="Typo.h5" Class="stat-box-value mt-1">@reviewsCount</MudText>
                            </MudPaper>
                        </MudPaper>
                    </MudItem>
                </MudGrid>
            </MudPaper>

            <MudGrid Spacing="3" Class="mt-4">
                <MudItem xs="12" md="8">
                    <MudPaper Class="shell" Elevation="0">
                        <div class="head">
                            <div class="head-title">Services</div>
                            <div class="head-sub">Choose a service to view details</div>
                        </div>

                        <div class="body">
                            @if (_offers.Count == 0)
                            {
                                <div class="muted">No services yet.</div>
                            }
                            else
                            {
                                <MudGrid Spacing="3">
                                    @foreach (var s in _offers)
                                    {
                                        <MudItem xs="12" sm="6">
                                            <a class="card-link" href="@($"/services/{s.Id}")">
                                                <div class="card">
                                                    <div class="card-title">@s.Title</div>
                                                    <div class="card-desc">@TrimText(s.Description, 120)</div>
                                                    <div class="card-row">
                                                        <div class="muted">Price</div>
                                                        <div class="price">@s.Price.ToString("0.##") zł</div>
                                                    </div>
                                                </div>
                                            </a>
                                        </MudItem>
                                    }
                                </MudGrid>
                            }
                        </div>
                    </MudPaper>
                </MudItem>

                <MudItem xs="12" md="4">
                    <MudPaper Class="side" Elevation="0">
                        <div class="side-title">Reviews</div>
                        <div class="side-sub">@avgRating.ToString("0.0") from @reviewsCount review(s)</div>

                        <div class="side-body">
                            @if (_reviews.Count == 0)
                            {
                                <div class="muted">No reviews yet.</div>
                            }
                            else
                            {
                                <MudStack Spacing="2">
                                    @foreach (var r in _reviews)
                                    {
                                        <MudPaper Class="review-mini pa-3" Elevation="0">
                                            <a class="review-author" href="@AuthorProfileUrl(r.AuthorUser)">
                                                <img class="review-author-avatar" src="@AuthorAvatar(r.AuthorUser)" />
                                                <div class="review-author-copy">
                                                    <div class="review-author-name">@DisplayName(r.AuthorUser)</div>
                                                    <div class="review-author-username">@("@" + (r.AuthorUser?.UserName ?? ""))</div>
                                                </div>
                                            </a>

                                            <div class="review-top">
                                                <div class="stars">@Stars(r.Stars)</div>
                                                <div class="muted">@r.CreatedAt.ToLocalTime().ToString("yyyy-MM-dd")</div>
                                            </div>

                                            @if (!string.IsNullOrWhiteSpace(r.Comment))
                                            {
                                                <div class="review-text">@r.Comment</div>
                                            }
                                        </MudPaper>
                                    }
                                </MudStack>

                                @if (reviewsCount > 0 && !string.IsNullOrWhiteSpace(_user.UserName))
                                {
                                    <div class="reviews-more">
                                        <MudButton Variant="Variant.Text"
                                                   Color="Color.Primary"
                                                   Href="@($"/profile/{_user.UserName}/reviews")">
                                            View all reviews
                                        </MudButton>
                                    </div>
                                }
                            }
                        </div>
                    </MudPaper>
                </MudItem>
            </MudGrid>
        }
    </MudContainer>
</MudContainer>

<style>
    .public-profile-shell {
        min-height: calc(100vh - 78px);
        background:
            radial-gradient(circle at top left, rgba(124,58,237,.10), transparent 22%),
            radial-gradient(circle at top right, rgba(99,102,241,.08), transparent 24%),
            linear-gradient(180deg, #fbfaff 0%, #f7f4ff 42%, #ffffff 100%);
    }

    .hero-paper {
        border-radius: 32px;
        background: linear-gradient(135deg, #2e1065 0%, #4c1d95 46%, #5b21b6 100%);
        color: #fff;
        border: 1px solid rgba(255,255,255,.10);
        box-shadow: 0 22px 60px rgba(76,29,149,.18);
    }

    .hero-profile-row {
        display: flex;
        align-items: center;
        gap: 16px;
        min-width: 0;
    }

    .avatar {
        width: 96px;
        height: 96px;
        border-radius: 50%;
        object-fit: cover;
        border: 2px solid rgba(255,255,255,.18);
        background: #fff;
        flex: 0 0 auto;
    }

    .name-block {
        min-width: 0;
    }

    .hero-badge {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        padding: 8px 14px;
        border-radius: 999px;
        background: rgba(255,255,255,.10);
        border: 1px solid rgba(255,255,255,.14);
        font-size: 13px;
        font-weight: 700;
    }

    .name-row {
        display: flex;
        align-items: center;
        gap: 10px;
        flex-wrap: wrap;
    }

    .name {
        font-weight: 900;
        color: #fff;
        font-size: 2rem;
        letter-spacing: -.03em;
        line-height: 1.02;
        max-width: 580px;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
    }

    .admin-badge,
    .ban-badge {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        height: 30px;
        padding: 0 12px;
        border-radius: 999px;
        font-size: .78rem;
        font-weight: 900;
        letter-spacing: .04em;
        text-transform: uppercase;
    }

    .admin-badge {
        background: rgba(255,255,255,.14);
        color: #fff;
        border: 1px solid rgba(255,255,255,.18);
    }

    .ban-badge {
        background: rgba(220,38,38,.90);
        color: #fff;
    }

    .username {
        color: rgba(255,255,255,.76);
        font-weight: 800;
        margin-top: 6px;
    }

    .hero-sub {
        color: rgba(255,255,255,.82);
        max-width: 820px;
        line-height: 1.8;
        font-size: 16px;
        white-space: pre-wrap;
    }

    .hero-actions {
        flex-wrap: wrap;
    }

    .hero-side,
    .stat-card,
    .stat-box,
    .shell,
    .side,
    .card,
    .review-mini,
    .empty-paper {
        border-radius: 26px;
        background: rgba(255,255,255,.94);
        border: 1px solid rgba(109,40,217,.10);
        box-shadow: 0 14px 38px rgba(88,28,135,.06);
    }

    .side-title,
    .head-title,
    .card-title,
    .review-author-name,
    .empty-title {
        color: #1f1147;
        font-weight: 900;
    }

    .hero-side {
        background: rgba(255,255,255,.16);
        border-color: rgba(255,255,255,.12);
        box-shadow: none;
    }

    .hero-side .side-title,
    .hero-side .stat-label,
    .hero-side .stat-box-label {
        color: rgba(255,255,255,.84);
    }

    .hero-side .stat-value,
    .hero-side .stat-box-value {
        color: #fff;
    }

    .stat-card,
    .stat-box {
        background: rgba(255,255,255,.10);
        border-color: rgba(255,255,255,.12);
        box-shadow: none;
    }

    .stat-label,
    .side-sub,
    .head-sub,
    .muted,
    .review-author-username,
    .empty-sub {
        color: #6b5f8d;
    }

    .stat-value,
    .stat-box-value,
    .price,
    .stars {
        color: #1f1147;
        font-weight: 900;
    }

    .btn-strong {
        border-radius: 14px;
        font-weight: 900;
        letter-spacing: .2px;
        padding: 10px 14px;
        text-transform: none;
    }

    .shell,
    .side {
        overflow: hidden;
    }

    .head {
        padding: 20px 22px 16px 22px;
        border-bottom: 1px solid rgba(109,40,217,.08);
    }

    .body,
    .side-body {
        padding: 22px;
    }

    .card-link {
        display: block;
        text-decoration: none;
        color: inherit;
    }

    .card {
        padding: 16px;
        background: linear-gradient(180deg, #faf7ff 0%, #ffffff 100%);
        transition: transform .18s ease, box-shadow .18s ease, border-color .18s ease;
        height: 100%;
        display: flex;
        flex-direction: column;
        gap: 10px;
    }

    .card:hover {
        transform: translateY(-4px);
        border-color: rgba(109,40,217,.22);
        box-shadow: 0 18px 42px rgba(88,28,135,.10);
    }

    .card-desc {
        color: rgba(31,17,71,.68);
        font-size: .92rem;
        line-height: 1.35;
        flex: 1;
    }

    .card-row,
    .review-top {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 10px;
    }

    .review-mini {
        background: linear-gradient(180deg, #faf7ff 0%, #ffffff 100%);
    }

    .review-author {
        display: flex;
        align-items: center;
        gap: 10px;
        text-decoration: none;
        color: inherit;
        margin-bottom: 10px;
    }

    .review-author-avatar {
        width: 42px;
        height: 42px;
        border-radius: 50%;
        object-fit: cover;
        border: 1px solid rgba(109,40,217,.12);
        background: #fff;
        flex: 0 0 auto;
    }

    .review-author-copy {
        min-width: 0;
    }

    .review-author-username {
        margin-top: 3px;
        font-size: .88rem;
        font-weight: 800;
    }

    .review-text {
        margin-top: 8px;
        color: rgba(31,17,71,.80);
        line-height: 1.45;
        white-space: pre-wrap;
    }

    .reviews-more {
        margin-top: 12px;
        display: flex;
        justify-content: center;
    }

    .empty-paper {
        text-align: center;
    }

    .skeleton {
        min-height: 340px;
        position: relative;
        overflow: hidden;
    }

    .hero-skeleton {
        min-height: 250px;
    }

    .skeleton::before {
        content: "";
        position: absolute;
        inset: 0;
        background: linear-gradient(90deg,#f3f4f6,#fafafa,#f3f4f6);
        background-size: 200% 100%;
        animation: shimmer 1.2s infinite linear;
    }

    @@keyframes shimmer {
        0% {
            background-position: 0% 0;
        }

        100% {
            background-position: 200% 0;
        }
    }

    @@media (max-width: 960px) {
        .body,
        .side-body {
            padding: 18px;
        }

        .head {
            padding: 18px 18px 16px 18px;
        }

        .name {
            max-width: 340px;
        }
    }

    @@media (max-width: 700px) {
        .hero-paper,
        .hero-side,
        .stat-card,
        .stat-box,
        .shell,
        .side,
        .card,
        .review-mini,
        .empty-paper {
            border-radius: 22px;
        }

        .hero-profile-row {
            align-items: flex-start;
        }

        .name {
            font-size: 1.9rem !important;
            white-space: normal;
        }

        .hero-actions {
            flex-direction: column !important;
            align-items: stretch !important;
        }
    }
</style>

@code {
    [Parameter] public string UserName { get; set; } = default!;
    [CascadingParameter] public Task<AuthenticationState> AuthenticationStateTask { get; set; } = default!;

    private bool _loading = true;
    private bool _startingChat;

    private ApplicationUser? _user;
    private List<ServiceOffer> _offers = new();
    private List<Review> _reviews = new();

    private double avgRating;
    private int reviewsCount;

    private string? _meId;
    private bool _isOwnProfile;
    private bool _isTargetAdmin;
    private bool _hasActiveBan;

    private bool _canStartChat => !string.IsNullOrWhiteSpace(_meId) && _user is not null && !_isOwnProfile;

    protected override async Task OnParametersSetAsync()
    {
        _loading = true;

        var auth = await AuthenticationStateTask;
        _meId = auth.User.FindFirstValue(ClaimTypes.NameIdentifier);

        var userName = (UserName ?? "").Trim();
        if (string.IsNullOrWhiteSpace(userName))
        {
            _user = null;
            _loading = false;
            return;
        }

        _user = await Db.Users.FirstOrDefaultAsync(u => u.UserName == userName);

        if (_user is null)
        {
            _loading = false;
            return;
        }

        _isOwnProfile = _meId == _user.Id;

        _isTargetAdmin = await Db.UserRoles
            .Join(Db.Roles,
                ur => ur.RoleId,
                r => r.Id,
                (ur, r) => new { ur.UserId, r.Name })
            .AnyAsync(x => x.UserId == _user.Id && x.Name == "Admin");

        var now = DateTime.UtcNow;
        _hasActiveBan = await Db.UserBans
            .AnyAsync(x => x.UserId == _user.Id && x.StartsAtUtc <= now && (!x.EndsAtUtc.HasValue || x.EndsAtUtc > now));

        _offers = await Db.ServiceOffers
            .Where(x => x.OwnerUserId == _user.Id)
            .OrderByDescending(x => x.CreatedAt)
            .ToListAsync();

        var q = Db.Reviews.Where(r => r.TargetUserId == _user.Id);
        reviewsCount = await q.CountAsync();
        avgRating = reviewsCount == 0 ? 0 : await q.AverageAsync(r => (double)r.Stars);

        _reviews = await Db.Reviews
            .Include(r => r.AuthorUser)
            .Where(r => r.TargetUserId == _user.Id)
            .OrderByDescending(r => r.CreatedAt)
            .Take(3)
            .ToListAsync();

        _loading = false;
    }

    private async Task StartChatAsync()
    {
        if (_startingChat || string.IsNullOrWhiteSpace(_meId) || _user is null || _meId == _user.Id)
            return;

        _startingChat = true;

        try
        {
            var a = _meId;
            var b = _user.Id;

            if (string.CompareOrdinal(a, b) > 0)
            {
                var t = a;
                a = b;
                b = t;
            }

            var existing = await Db.Conversations.FirstOrDefaultAsync(x => x.UserAId == a && x.UserBId == b);

            if (existing is null)
            {
                existing = new Conversation
                {
                    UserAId = a,
                    UserBId = b,
                    CreatedAtUtc = DateTime.UtcNow
                };

                Db.Conversations.Add(existing);
                await Db.SaveChangesAsync();
            }

            Nav.NavigateTo($"/chat/{existing.Id}");
        }
        finally
        {
            _startingChat = false;
        }
    }

    private static string DisplayName(ApplicationUser? u)
        => u is null
            ? "User"
            : !string.IsNullOrWhiteSpace(u.DisplayName)
                ? u.DisplayName!
                : (u.UserName ?? "User");

    private static string TrimText(string? s, int max)
    {
        if (string.IsNullOrWhiteSpace(s))
            return string.Empty;

        return s.Length <= max ? s : s.Substring(0, max) + "...";
    }

    private static string Stars(int rating)
    {
        var full = Math.Clamp(rating, 0, 5);
        return new string('★', full) + new string('☆', 5 - full);
    }

    private static string AuthorAvatar(ApplicationUser? user)
        => user?.AvatarUrl ?? "/images/default-avatar.png";

    private static string AuthorProfileUrl(ApplicationUser? user)
        => !string.IsNullOrWhiteSpace(user?.UserName) ? $"/profile/{user!.UserName}" : "#";
}