@page "/reports/create"
@attribute [Authorize]
@using System.ComponentModel.DataAnnotations
@using System.Security.Claims
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Components.Authorization
@using Microsoft.EntityFrameworkCore
@using MudBlazor
@using SkillGo.Data
@using SkillGo.Data.Models
@using SkillGo.Data.Models.Chat
@using SkillGo.Data.Models.Orders
@using SkillGo.Data.Models.Reports
@inject IDbContextFactory<ApplicationDbContext> DbFactory
@inject AuthenticationStateProvider AuthStateProvider
@inject NavigationManager Nav
@inject ISnackbar Snackbar

<PageTitle>Create Report</PageTitle>

@if (_loading)
{
    <MudPaper Class="report-loading" Elevation="0">
        <MudProgressCircular Indeterminate="true" Size="Size.Large" Color="Color.Error" />
        <MudText Typo="Typo.h6">Loading report form...</MudText>
    </MudPaper>
}
else if (_targetUser is null)
{
    <MudPaper Class="report-empty" Elevation="0">
        <MudIcon Icon="@Icons.Material.Filled.ErrorOutline" Size="Size.Large" />
        <MudText Typo="Typo.h6">Target not found</MudText>
    </MudPaper>
}
else
{
    <MudStack Spacing="3">
        <MudPaper Class="report-hero" Elevation="0">
            <div class="report-hero-content">
                <div>
                    <MudText Class="report-kicker">Safety</MudText>
                    <MudText Class="report-title">Submit a report</MudText>
                    <MudText Class="report-subtitle">Type: @_targetType.ToString()</MudText>
                </div>
            </div>
        </MudPaper>

        <MudPaper Class="report-panel" Elevation="0">
            <MudStack Spacing="3">
                <div class="report-info-grid">
                    <div class="report-info-card">
                        <div class="report-info-label">Reported user</div>
                        <div class="report-info-value">@DisplayUserName(_targetUser)</div>
                    </div>

                    <div class="report-info-card">
                        <div class="report-info-label">Target type</div>
                        <div class="report-info-value">@_targetType</div>
                    </div>

                    @if (_serviceOffer is not null)
                    {
                        <div class="report-info-card">
                            <div class="report-info-label">Service</div>
                            <div class="report-info-value">@_serviceOffer.Title</div>
                        </div>
                    }

                    @if (_order is not null)
                    {
                        <div class="report-info-card">
                            <div class="report-info-label">Order</div>
                            <div class="report-info-value">Order #@_order.Id</div>
                        </div>
                    }

                    @if (_message is not null)
                    {
                        <div class="report-info-card">
                            <div class="report-info-label">Message</div>
                            <div class="report-info-value">@TrimText(_message.Body, 120)</div>
                        </div>
                    }
                </div>

                <EditForm Model="_model" OnValidSubmit="SubmitAsync">
                    <DataAnnotationsValidator />

                    <MudStack Spacing="3">
                        <MudTextField @bind-Value="_model.Reason"
                                      Label="Reason"
                                      Variant="Variant.Outlined"
                                      Lines="6"
                                      Immediate="true"
                                      Counter="500"
                                      MaxLength="500" />

                        <ValidationMessage For="@(() => _model.Reason)" />

                        <MudStack Row="true" Spacing="2" Class="report-actions">
                            <MudButton ButtonType="ButtonType.Submit"
                                       Variant="Variant.Filled"
                                       Color="Color.Error"
                                       Disabled="@_saving"
                                       StartIcon="@Icons.Material.Filled.Report">
                                Send report
                            </MudButton>

                            <MudButton Variant="Variant.Outlined"
                                       Color="Color.Secondary"
                                       Disabled="@_saving"
                                       StartIcon="@Icons.Material.Filled.ArrowBack"
                                       OnClick="GoBack">
                                Back
                            </MudButton>
                        </MudStack>
                    </MudStack>
                </EditForm>
            </MudStack>
        </MudPaper>
    </MudStack>
}

<style>
    .report-loading,
    .report-empty {
        min-height: 60vh;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        gap: 16px;
        border-radius: 28px;
        background: rgba(255,255,255,.92);
        border: 1px solid rgba(15,23,42,.06);
        text-align: center;
    }

    .report-hero {
        border-radius: 28px;
        padding: 28px;
        background: linear-gradient(135deg, #450a0a 0%, #7f1d1d 50%, #be123c 100%);
        color: #fff;
        box-shadow: 0 24px 48px rgba(127,29,29,.16);
    }

    .report-hero-content {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 18px;
        flex-wrap: wrap;
    }

    .report-kicker {
        color: rgba(255,255,255,.68);
        font-size: .78rem;
        font-weight: 900;
        text-transform: uppercase;
        letter-spacing: .16em;
    }

    .report-title {
        margin-top: 8px;
        font-size: 2rem;
        line-height: 1.05;
        font-weight: 950;
    }

    .report-subtitle {
        margin-top: 8px;
        color: rgba(255,255,255,.78);
        font-weight: 700;
    }

    .report-panel {
        padding: 24px;
        border-radius: 24px;
        background: rgba(255,255,255,.95);
        border: 1px solid rgba(15,23,42,.06);
        box-shadow: 0 18px 36px rgba(15,23,42,.05);
    }

    .report-info-grid {
        display: grid;
        grid-template-columns: repeat(2, minmax(0, 1fr));
        gap: 12px;
    }

    .report-info-card {
        padding: 16px;
        border-radius: 18px;
        background: #f8fafc;
        border: 1px solid rgba(15,23,42,.06);
    }

    .report-info-label {
        color: rgba(17,24,39,.56);
        font-size: .78rem;
        font-weight: 800;
        text-transform: uppercase;
        letter-spacing: .08em;
    }

    .report-info-value {
        margin-top: 8px;
        color: #111827;
        font-size: 1rem;
        font-weight: 900;
        line-height: 1.3;
        word-break: break-word;
    }

    .report-actions {
        flex-wrap: wrap;
    }

    @@media (max-width: 760px) {
        .report-title {
            font-size: 1.6rem;
        }

        .report-info-grid {
            grid-template-columns: 1fr;
        }
    }
</style>

@code {
    [SupplyParameterFromQuery] public ReportTargetType? Type { get; set; }
    [SupplyParameterFromQuery] public string? TargetUserId { get; set; }
    [SupplyParameterFromQuery] public int? ServiceOfferId { get; set; }
    [SupplyParameterFromQuery] public int? OrderId { get; set; }
    [SupplyParameterFromQuery] public int? MessageId { get; set; }

    private bool _loading = true;
    private bool _saving;

    private ReportTargetType _targetType;
    private ApplicationUser? _targetUser;
    private ServiceOffer? _serviceOffer;
    private Order? _order;
    private Message? _message;

    private ReportInputModel _model = new();

    protected override async Task OnInitializedAsync()
    {
        if (Type is null || string.IsNullOrWhiteSpace(TargetUserId))
        {
            _loading = false;
            return;
        }

        _targetType = Type.Value;

        await using var db = await DbFactory.CreateDbContextAsync();

        _targetUser = await db.Users.FirstOrDefaultAsync(x => x.Id == TargetUserId);

        if (_targetUser is null)
        {
            _loading = false;
            return;
        }

        if (ServiceOfferId.HasValue)
            _serviceOffer = await db.ServiceOffers.FirstOrDefaultAsync(x => x.Id == ServiceOfferId.Value);

        if (OrderId.HasValue)
            _order = await db.Orders.FirstOrDefaultAsync(x => x.Id == OrderId.Value);

        if (MessageId.HasValue)
            _message = await db.Messages.FirstOrDefaultAsync(x => x.Id == MessageId.Value);

        _loading = false;
    }

    private async Task SubmitAsync()
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        var user = authState.User;
        var reporterUserId = user.FindFirstValue(ClaimTypes.NameIdentifier);

        if (string.IsNullOrWhiteSpace(reporterUserId))
        {
            Snackbar.Add("You must be logged in", Severity.Error);
            return;
        }

        if (_targetUser is null)
        {
            Snackbar.Add("Target user not found", Severity.Error);
            return;
        }

        if (reporterUserId == _targetUser.Id)
        {
            Snackbar.Add("You cannot report yourself", Severity.Warning);
            return;
        }

        _saving = true;

        await using var db = await DbFactory.CreateDbContextAsync();

        var report = new Report
            {
                ReporterUserId = reporterUserId,
                TargetUserId = _targetUser.Id,
                TargetType = _targetType,
                ServiceOfferId = _targetType == ReportTargetType.Service ? ServiceOfferId : null,
                OrderId = _targetType == ReportTargetType.Order ? OrderId : null,
                MessageId = _targetType == ReportTargetType.Message ? MessageId : null,
                Reason = _model.Reason.Trim(),
                CreatedAt = DateTime.UtcNow
            };

        db.Reports.Add(report);
        await db.SaveChangesAsync();

        _saving = false;

        Snackbar.Add("Report submitted successfully", Severity.Success);
        GoBack();
    }

    private void GoBack()
    {
        switch (_targetType)
        {
            case ReportTargetType.Service:
                if (ServiceOfferId.HasValue)
                {
                    Nav.NavigateTo($"/services/{ServiceOfferId.Value}");
                    return;
                }
                break;

            case ReportTargetType.Profile:
                if (!string.IsNullOrWhiteSpace(_targetUser?.UserName))
                {
                    Nav.NavigateTo($"/profile/{_targetUser.UserName}");
                    return;
                }
                break;

            case ReportTargetType.Order:
                if (OrderId.HasValue)
                {
                    Nav.NavigateTo($"/orders/{OrderId.Value}");
                    return;
                }
                break;

            case ReportTargetType.Message:
                if (_message?.ConversationId is int conversationId)
                {
                    Nav.NavigateTo($"/chat/{conversationId}");
                    return;
                }
                break;
        }

        Nav.NavigateTo("/");
    }

    private static string DisplayUserName(ApplicationUser user)
        => !string.IsNullOrWhiteSpace(user.DisplayName) ? user.DisplayName : (user.UserName ?? "User");

    private static string TrimText(string? text, int max)
    {
        if (string.IsNullOrWhiteSpace(text))
            return "Message without text";

        return text.Length <= max ? text : text.Substring(0, max) + "...";
    }

    private sealed class ReportInputModel
    {
        [Required]
        [MaxLength(500)]
        public string Reason { get; set; } = string.Empty;
    }
}