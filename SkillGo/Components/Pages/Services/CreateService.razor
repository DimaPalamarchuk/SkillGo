@page "/services/create"
@using System.ComponentModel.DataAnnotations
@using Microsoft.AspNetCore.Components.Authorization
@using Microsoft.AspNetCore.Identity
@using Microsoft.EntityFrameworkCore
@using MudBlazor
@using SkillGo.Data
@using SkillGo.Data.Models
@inject ApplicationDbContext Db
@inject UserManager<ApplicationUser> UserManager
@inject NavigationManager Nav

<PageTitle>Create service</PageTitle>

<MudContainer MaxWidth="MaxWidth.False" Class="create-shell pa-0">
    <MudContainer MaxWidth="MaxWidth.ExtraLarge" Class="pt-6 pb-8">
        <MudPaper Class="create-hero pa-6 pa-md-8" Elevation="0">
            <MudGrid Spacing="3" AlignItems="AlignItems.Stretch">
                <MudItem xs="12" md="8">
                    <div class="hero-badge">
                        <MudIcon Icon="@Icons.Material.Filled.AutoAwesome" Size="Size.Small" />
                        <span>Publish a new offer</span>
                    </div>

                    <MudText Typo="Typo.h3" Class="hero-title mt-4">Create service</MudText>

                    <MudText Typo="Typo.body1" Class="hero-sub mt-4">
                        Publish your offer so clients can find you and place orders faster.
                    </MudText>
                </MudItem>

                <MudItem xs="12" md="4">
                    <MudPaper Class="hero-side pa-5 h-100" Elevation="0">
                        <MudText Typo="Typo.h6" Class="side-title">Quick notes</MudText>
                        <MudText Typo="Typo.body2" Class="side-sub mt-2">
                            Clear title, strong description and fair pricing usually perform better.
                        </MudText>
                    </MudPaper>
                </MudItem>
            </MudGrid>
        </MudPaper>

        <div class="grid mt-4">
            <div class="card">
                <AuthorizeView>
                    <NotAuthorized>
                        <MudPaper Class="login-box pa-4" Elevation="0">
                            You must be logged in to create a service.
                            <MudButton Variant="Variant.Filled" Color="Color.Primary" Class="btn-strong mt-3" Href="/Account/Login">
                                Login
                            </MudButton>
                        </MudPaper>
                    </NotAuthorized>

                    <Authorized Context="authContext">
                        <EditForm Model="_input" OnValidSubmit="CreateAsync">
                            <DataAnnotationsValidator />

                            <div class="section-head">
                                <div class="section-title">Details</div>
                                <div class="section-sub">Category, title, description, and price.</div>
                            </div>

                            <div class="form-grid">
                                <div class="col-12">
                                    <MudSelect T="int" @bind-Value="_input.CategoryId" Label="Category" Variant="Variant.Outlined" FullWidth="true">
                                        @foreach (var c in _categories)
                                        {
                                            <MudSelectItem T="int" Value="@c.Id">@c.Name</MudSelectItem>
                                        }
                                    </MudSelect>
                                </div>

                                <div class="col-12">
                                    <MudTextField T="string" @bind-Value="_input.Title" Label="Title" Variant="Variant.Outlined" FullWidth="true" />
                                </div>

                                <div class="col-12">
                                    <MudTextField T="string" @bind-Value="_input.Description" Label="Description" Variant="Variant.Outlined" Lines="7" FullWidth="true" />
                                </div>

                                <div class="col-12">
                                    <MudNumericField T="decimal" @bind-Value="_input.Price" Label="Price (zł)" Variant="Variant.Outlined" Min="0" FullWidth="true" />
                                </div>
                            </div>

                            @if (!string.IsNullOrWhiteSpace(_error))
                            {
                                <MudAlert Severity="Severity.Error" Variant="Variant.Outlined" Class="mt-4">@_error</MudAlert>
                            }

                            <div class="actions mt-4">
                                <MudButton Variant="Variant.Outlined" Class="btn-strong" OnClick="@Cancel">
                                    Cancel
                                </MudButton>

                                <MudButton Variant="Variant.Filled" Color="Color.Primary" Class="btn-strong" ButtonType="ButtonType.Submit">
                                    Publish
                                </MudButton>
                            </div>
                        </EditForm>
                    </Authorized>
                </AuthorizeView>
            </div>

            <div class="side">
                <div class="side-card">
                    <div class="side-title">Publishing tips</div>
                    <div class="side-sub">A good service converts better.</div>

                    <ul class="tips">
                        <li><span class="dot"></span><span><b>Title:</b> clear and specific (max 120 chars)</span></li>
                        <li><span class="dot"></span><span><b>Description:</b> include deliverables and timeline</span></li>
                        <li><span class="dot"></span><span><b>Price:</b> start competitive, adjust later</span></li>
                        <li><span class="dot"></span><span><b>Category:</b> pick the closest match</span></li>
                    </ul>
                </div>

                <div class="side-card mt-3">
                    <div class="side-title">Preview</div>
                    <div class="side-sub">How it may look in the list.</div>

                    <div class="preview">
                        <div class="preview-title">@PreviewTitle</div>
                        <div class="preview-desc">@PreviewDesc</div>
                        <div class="preview-row">
                            <div class="pill">@PreviewCategory</div>
                            <div class="preview-price">@_input.Price.ToString("0.##") zł</div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </MudContainer>
</MudContainer>

<style>
    .create-shell {
        min-height: calc(100vh - 78px);
        background:
            radial-gradient(circle at top left, rgba(124,58,237,.10), transparent 22%),
            radial-gradient(circle at top right, rgba(99,102,241,.08), transparent 24%),
            linear-gradient(180deg, #fbfaff 0%, #f7f4ff 42%, #ffffff 100%);
    }

    .create-hero {
        border-radius: 32px;
        background: linear-gradient(135deg, #2e1065 0%, #4c1d95 46%, #5b21b6 100%);
        color: #fff;
        border: 1px solid rgba(255,255,255,.10);
        box-shadow: 0 22px 60px rgba(76,29,149,.18);
    }

    .hero-badge {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        padding: 8px 14px;
        border-radius: 999px;
        background: rgba(255,255,255,.10);
        border: 1px solid rgba(255,255,255,.14);
        font-size: 13px;
        font-weight: 700;
    }

    .hero-title {
        font-weight: 900;
        line-height: 1.02;
        letter-spacing: -.03em;
    }

    .hero-sub {
        color: rgba(255,255,255,.82);
        line-height: 1.8;
        font-size: 16px;
        max-width: 760px;
    }

    .hero-side,
    .card,
    .side-card,
    .preview,
    .login-box {
        border-radius: 26px;
        background: rgba(255,255,255,.94);
        border: 1px solid rgba(109,40,217,.10);
        box-shadow: 0 14px 38px rgba(88,28,135,.06);
    }

    .hero-side {
        background: rgba(255,255,255,.16);
        border-color: rgba(255,255,255,.12);
        box-shadow: none;
    }

    .hero-side .side-title,
    .hero-side .side-sub {
        color: #fff;
    }

    .grid {
        display: grid;
        grid-template-columns: 1fr 340px;
        gap: 18px;
        align-items: start;
    }

    .card {
        overflow: hidden;
        padding: 22px;
    }

    .section-head {
        display: flex;
        flex-direction: column;
        gap: 4px;
        margin-bottom: 14px;
    }

    .section-title,
    .side-title,
    .preview-title {
        font-weight: 900;
        color: #1f1147;
        font-size: 1.05rem;
        letter-spacing: .2px;
    }

    .section-sub,
    .side-sub,
    .preview-desc {
        color: #6b5f8d;
        font-size: .95rem;
    }

    .form-grid {
        display: grid;
        grid-template-columns: 1fr;
        gap: 12px;
    }

    .col-12 {
        min-width: 0;
    }

    .actions {
        display: flex;
        gap: 10px;
        justify-content: flex-end;
        flex-wrap: wrap;
    }

    .btn-strong {
        border-radius: 14px;
        font-weight: 900;
        letter-spacing: .2px;
        padding: 10px 14px;
        text-transform: none;
    }

    .side {
        position: sticky;
        top: 92px;
        display: flex;
        flex-direction: column;
        gap: 12px;
    }

    .side-card {
        padding: 18px;
        overflow: hidden;
    }

    .tips {
        margin: 14px 0 0 0;
        padding: 0;
        list-style: none;
        display: flex;
        flex-direction: column;
        gap: 10px;
    }

    .tips li {
        display: flex;
        gap: 10px;
        align-items: flex-start;
        color: rgba(31,17,71,.78);
        line-height: 1.35;
        font-size: .95rem;
    }

    .dot {
        width: 10px;
        height: 10px;
        border-radius: 999px;
        background: rgba(109,40,217,.45);
        margin-top: 4px;
        flex: 0 0 auto;
    }

    .preview {
        margin-top: 14px;
        padding: 14px;
        background: linear-gradient(180deg, #faf7ff 0%, #ffffff 100%);
    }

    .preview-desc {
        margin-top: 6px;
        line-height: 1.45;
        white-space: pre-wrap;
    }

    .preview-row {
        margin-top: 12px;
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 12px;
    }

    .pill {
        display: inline-flex;
        padding: 6px 10px;
        border-radius: 999px;
        background: rgba(109,40,217,.08);
        border: 1px solid rgba(109,40,217,.18);
        color: #5b21b6;
        font-weight: 800;
        font-size: .85rem;
        max-width: 190px;
        overflow: hidden;
        text-overflow: ellipsis;
        white-space: nowrap;
    }

    .preview-price {
        font-weight: 900;
        color: #1f1147;
        white-space: nowrap;
    }

    @@media (max-width: 960px) {
        .grid {
            grid-template-columns: 1fr;
        }

        .side {
            position: static;
            top: auto;
        }
    }

    @@media (max-width: 700px) {
        .create-hero,
        .hero-side,
        .card,
        .side-card,
        .preview,
        .login-box {
            border-radius: 22px;
        }

        .hero-title {
            font-size: 2rem !important;
        }
    }
</style>

@code {
    [CascadingParameter] public Task<AuthenticationState> AuthenticationStateTask { get; set; } = default!;

    private List<Category> _categories = new List<Category>();
    private string? _error;

    private InputModel _input = new InputModel();

    protected override async Task OnInitializedAsync()
    {
        _categories = await Db.Categories.OrderBy(x => x.Name).ToListAsync();
        if (_categories.Count > 0) _input.CategoryId = _categories[0].Id;
    }

    private string PreviewTitle => string.IsNullOrWhiteSpace(_input.Title) ? "Service title" : _input.Title.Trim();

    private string PreviewDesc
    {
        get
        {
            var s = (_input.Description ?? "").Trim();
            if (string.IsNullOrWhiteSpace(s)) return "Short description of what you will deliver.";
            return s.Length <= 140 ? s : s.Substring(0, 140) + "...";
        }
    }

    private string PreviewCategory
    {
        get
        {
            var c = _categories.FirstOrDefault(x => x.Id == _input.CategoryId);
            return c?.Name ?? "Category";
        }
    }

    private async Task CreateAsync()
    {
        _error = null;

        var auth = await AuthenticationStateTask;
        var principal = auth.User;

        if (principal?.Identity?.IsAuthenticated != true)
        {
            Nav.NavigateTo("/Account/Login");
            return;
        }

        var me = await UserManager.GetUserAsync(principal);
        if (me is null)
        {
            Nav.NavigateTo("/Account/Login");
            return;
        }

        var offer = new ServiceOffer
        {
            CategoryId = _input.CategoryId,
            OwnerUserId = me.Id,
            Title = (_input.Title ?? "").Trim(),
            Description = (_input.Description ?? "").Trim(),
            Price = _input.Price,
            CreatedAt = DateTime.UtcNow
        };

        if (string.IsNullOrWhiteSpace(offer.Title) || string.IsNullOrWhiteSpace(offer.Description))
        {
            _error = "Fill in all required fields.";
            return;
        }

        Db.ServiceOffers.Add(offer);
        await Db.SaveChangesAsync();

        Nav.NavigateTo($"/services/{offer.Id}");
    }

    private void Cancel()
    {
        Nav.NavigateTo("/");
    }

    private sealed class InputModel
    {
        [Required]
        public int CategoryId { get; set; }

        [Required, StringLength(120)]
        public string Title { get; set; } = "";

        [Required, StringLength(2000)]
        public string Description { get; set; } = "";

        [Range(0, 999999)]
        public decimal Price { get; set; } = 0;
    }
}