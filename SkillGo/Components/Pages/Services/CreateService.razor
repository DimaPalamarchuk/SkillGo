@page "/services/create"
@using System.ComponentModel.DataAnnotations
@using Microsoft.AspNetCore.Components.Authorization
@using Microsoft.AspNetCore.Identity
@using Microsoft.EntityFrameworkCore
@using MudBlazor
@using SkillGo.Data
@using SkillGo.Data.Models
@inject ApplicationDbContext Db
@inject UserManager<ApplicationUser> UserManager
@inject NavigationManager Nav

<PageTitle>Create service</PageTitle>

<MudContainer MaxWidth="MaxWidth.Medium" Class="mt-6">

    <div class="hero">
        <div class="hero-inner">
            <div class="hero-title">Create service</div>
            <div class="hero-sub">Publish your offer so clients can find you.</div>
        </div>
    </div>

    <div class="grid mt-4">
        <div class="card">
            <AuthorizeView>
                <NotAuthorized>
                    <MudPaper Class="pa-4" Elevation="0" Style="border-radius:18px;border:1px solid rgba(0,0,0,.08);">
                        You must be logged in to create a service.
                        <MudButton Variant="Variant.Filled" Color="Color.Primary" Class="btn-strong mt-3" Href="/Account/Login">
                            Login
                        </MudButton>
                    </MudPaper>
                </NotAuthorized>

                <Authorized Context="authContext">
                    <EditForm Model="_input" OnValidSubmit="CreateAsync">
                        <DataAnnotationsValidator />

                        <div class="section-head">
                            <div class="section-title">Details</div>
                            <div class="section-sub">Category, title, description, and price.</div>
                        </div>

                        <div class="form-grid">
                            <div class="col-12">
                                <MudSelect T="int" @bind-Value="_input.CategoryId" Label="Category" Variant="Variant.Outlined" FullWidth="true">
                                    @foreach (var c in _categories)
                                    {
                                        <MudSelectItem T="int" Value="@c.Id">@c.Name</MudSelectItem>
                                    }
                                </MudSelect>
                            </div>

                            <div class="col-12">
                                <MudTextField T="string" @bind-Value="_input.Title" Label="Title" Variant="Variant.Outlined" FullWidth="true" />
                            </div>

                            <div class="col-12">
                                <MudTextField T="string" @bind-Value="_input.Description" Label="Description" Variant="Variant.Outlined" Lines="7" FullWidth="true" />
                            </div>

                            <div class="col-12">
                                <MudNumericField T="decimal" @bind-Value="_input.Price" Label="Price (zł)" Variant="Variant.Outlined" Min="0" FullWidth="true" />
                            </div>
                        </div>

                        @if (!string.IsNullOrWhiteSpace(_error))
                        {
                            <MudAlert Severity="Severity.Error" Variant="Variant.Outlined" Class="mt-4">@_error</MudAlert>
                        }

                        <div class="actions mt-4">
                            <MudButton Variant="Variant.Outlined" Class="btn-strong" OnClick="@Cancel">
                                Cancel
                            </MudButton>

                            <MudButton Variant="Variant.Filled" Color="Color.Primary" Class="btn-strong" ButtonType="ButtonType.Submit">
                                Publish
                            </MudButton>
                        </div>
                    </EditForm>
                </Authorized>
            </AuthorizeView>
        </div>

        <div class="side">
            <div class="side-card">
                <div class="side-title">Publishing tips</div>
                <div class="side-sub">A good service converts better.</div>

                <ul class="tips">
                    <li><span class="dot"></span><span><b>Title:</b> clear and specific (max 120 chars)</span></li>
                    <li><span class="dot"></span><span><b>Description:</b> include deliverables and timeline</span></li>
                    <li><span class="dot"></span><span><b>Price:</b> start competitive, adjust later</span></li>
                    <li><span class="dot"></span><span><b>Category:</b> pick the closest match</span></li>
                </ul>
            </div>

            <div class="side-card mt-3">
                <div class="side-title">Preview</div>
                <div class="side-sub">How it may look in the list.</div>

                <div class="preview">
                    <div class="preview-title">@PreviewTitle</div>
                    <div class="preview-desc">@PreviewDesc</div>
                    <div class="preview-row">
                        <div class="pill">@PreviewCategory</div>
                        <div class="preview-price">@_input.Price.ToString("0.##") zł</div>
                    </div>
                </div>
            </div>
        </div>
    </div>

</MudContainer>

<style>
    .hero {
        border-radius: 22px;
        border: 1px solid rgba(0,0,0,.08);
        background: linear-gradient(135deg,#eef2ff,#e0e7ff);
        box-shadow: 0 18px 46px rgba(0,0,0,.06);
        position: relative;
        overflow: hidden;
    }

        .hero::before {
            content: "";
            position: absolute;
            inset: -40% -60%;
            background: radial-gradient(circle at 30% 30%, rgba(255,255,255,.55), transparent 55%);
            transform: rotate(12deg);
            opacity: .9;
            pointer-events: none;
        }

    .hero-inner {
        position: relative;
        z-index: 1;
        padding: 26px;
    }

    .hero-title {
        font-weight: 950;
        color: #111827;
        font-size: 1.65rem;
        letter-spacing: .2px;
        line-height: 1.12;
        margin-bottom: 6px;
    }

    .hero-sub {
        color: rgba(17,24,39,.65);
        font-size: 1rem;
        line-height: 1.35;
    }

    .grid {
        display: grid;
        grid-template-columns: 1fr 340px;
        gap: 18px;
        align-items: start;
    }

    .card {
        border-radius: 22px;
        border: 1px solid rgba(0,0,0,.08);
        background: #fff;
        box-shadow: 0 18px 46px rgba(0,0,0,.06);
        overflow: hidden;
        padding: 22px;
    }

    .section-head {
        display: flex;
        flex-direction: column;
        gap: 4px;
        margin-bottom: 14px;
    }

    .section-title {
        font-weight: 950;
        color: #111827;
        font-size: 1.05rem;
        letter-spacing: .2px;
    }

    .section-sub {
        color: rgba(17,24,39,.6);
        font-size: .95rem;
    }

    .form-grid {
        display: grid;
        grid-template-columns: 1fr;
        gap: 12px;
    }

    .col-12 {
        min-width: 0;
    }

    .actions {
        display: flex;
        gap: 10px;
        justify-content: flex-end;
        flex-wrap: wrap;
    }

    .btn-strong {
        border-radius: 14px;
        font-weight: 900;
        letter-spacing: .2px;
        padding: 10px 14px;
    }

    .side {
        position: sticky;
        top: 92px;
        display: flex;
        flex-direction: column;
        gap: 12px;
    }

    .side-card {
        border-radius: 22px;
        border: 1px solid rgba(0,0,0,.08);
        background: #fff;
        box-shadow: 0 18px 46px rgba(0,0,0,.06);
        padding: 18px;
        overflow: hidden;
    }

    .side-title {
        font-weight: 950;
        color: #111827;
        font-size: 1.02rem;
        letter-spacing: .2px;
    }

    .side-sub {
        color: rgba(17,24,39,.6);
        margin-top: 4px;
        font-size: .95rem;
    }

    .tips {
        margin: 14px 0 0 0;
        padding: 0;
        list-style: none;
        display: flex;
        flex-direction: column;
        gap: 10px;
    }

        .tips li {
            display: flex;
            gap: 10px;
            align-items: flex-start;
            color: rgba(17,24,39,.78);
            line-height: 1.25;
            font-size: .95rem;
        }

    .dot {
        width: 10px;
        height: 10px;
        border-radius: 999px;
        background: rgba(99,102,241,.5);
        margin-top: 4px;
        flex: 0 0 auto;
    }

    .preview {
        margin-top: 14px;
        border-radius: 18px;
        border: 1px solid rgba(0,0,0,.08);
        padding: 14px;
        background: linear-gradient(135deg, rgba(99,102,241,.06), rgba(99,102,241,.02));
    }

    .preview-title {
        font-weight: 950;
        color: #111827;
        letter-spacing: .2px;
        line-height: 1.15;
    }

    .preview-desc {
        margin-top: 6px;
        color: rgba(17,24,39,.65);
        font-size: .92rem;
        line-height: 1.25;
        white-space: pre-wrap;
    }

    .preview-row {
        margin-top: 12px;
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 12px;
    }

    .pill {
        display: inline-flex;
        padding: 6px 10px;
        border-radius: 999px;
        background: rgba(99,102,241,.10);
        border: 1px solid rgba(99,102,241,.22);
        color: rgba(17,24,39,.75);
        font-weight: 800;
        font-size: .85rem;
        max-width: 190px;
        overflow: hidden;
        text-overflow: ellipsis;
        white-space: nowrap;
    }

    .preview-price {
        font-weight: 950;
        color: #111827;
        white-space: nowrap;
    }

    @@media (max-width: 960px) {
        .grid {
            grid-template-columns: 1fr;
        }

        .side {
            position: static;
            top: auto;
        }
    }
</style>

@code {
    [CascadingParameter] public Task<AuthenticationState> AuthenticationStateTask { get; set; } = default!;

    private List<Category> _categories = new List<Category>();
    private string? _error;

    private InputModel _input = new InputModel();

    protected override async Task OnInitializedAsync()
    {
        _categories = await Db.Categories.OrderBy(x => x.Name).ToListAsync();
        if (_categories.Count > 0) _input.CategoryId = _categories[0].Id;
    }

    private string PreviewTitle => string.IsNullOrWhiteSpace(_input.Title) ? "Service title" : _input.Title.Trim();
    private string PreviewDesc
    {
        get
        {
            var s = (_input.Description ?? "").Trim();
            if (string.IsNullOrWhiteSpace(s)) return "Short description of what you will deliver.";
            return s.Length <= 140 ? s : s.Substring(0, 140) + "...";
        }
    }

    private string PreviewCategory
    {
        get
        {
            var c = _categories.FirstOrDefault(x => x.Id == _input.CategoryId);
            return c?.Name ?? "Category";
        }
    }

    private async Task CreateAsync()
    {
        _error = null;

        var auth = await AuthenticationStateTask;
        var principal = auth.User;

        if (principal?.Identity?.IsAuthenticated != true)
        {
            Nav.NavigateTo("/Account/Login");
            return;
        }

        var me = await UserManager.GetUserAsync(principal);
        if (me is null)
        {
            Nav.NavigateTo("/Account/Login");
            return;
        }

        var offer = new ServiceOffer
            {
                CategoryId = _input.CategoryId,
                OwnerUserId = me.Id,
                Title = (_input.Title ?? "").Trim(),
                Description = (_input.Description ?? "").Trim(),
                Price = _input.Price,
                CreatedAt = DateTime.UtcNow
            };

        if (string.IsNullOrWhiteSpace(offer.Title) || string.IsNullOrWhiteSpace(offer.Description))
        {
            _error = "Fill in all required fields.";
            return;
        }

        Db.ServiceOffers.Add(offer);
        await Db.SaveChangesAsync();

        Nav.NavigateTo($"/services/{offer.Id}");
    }

    private void Cancel()
    {
        Nav.NavigateTo("/");
    }

    private sealed class InputModel
    {
        [Required]
        public int CategoryId { get; set; }

        [Required, StringLength(120)]
        public string Title { get; set; } = "";

        [Required, StringLength(2000)]
        public string Description { get; set; } = "";

        [Range(0, 999999)]
        public decimal Price { get; set; } = 0;
    }
}