@page "/my-services"
@rendermode InteractiveServer
@attribute [Microsoft.AspNetCore.Authorization.Authorize]

@using System.Security.Claims
@using Microsoft.AspNetCore.Components.Authorization
@using Microsoft.EntityFrameworkCore
@using MudBlazor
@using SkillGo.Data
@using SkillGo.Data.Models

@inject ApplicationDbContext Db
@inject AuthenticationStateProvider AuthenticationStateProvider
@inject ISnackbar Snackbar
@inject NavigationManager Nav

<PageTitle>My Services</PageTitle>

<MudContainer MaxWidth="MaxWidth.False" Class="my-services-shell pa-0">
    <MudContainer MaxWidth="MaxWidth.ExtraLarge" Class="pt-6 pb-8">
        <MudStack Spacing="3">
            <MudPaper Class="my-services-hero pa-6 pa-md-8" Elevation="0">
                <MudGrid Spacing="3" AlignItems="AlignItems.Stretch">
                    <MudItem xs="12" md="8">
                        <div class="hero-badge">
                            <MudIcon Icon="@Icons.Material.Filled.Workspaces" Size="Size.Small" />
                            <span>Manage your freelance offers</span>
                        </div>

                        <MudText Typo="Typo.h3" Class="hero-title mt-4">My Services</MudText>

                        <MudText Typo="Typo.body1" Class="hero-sub mt-4">
                            Manage your services, update content, open pages and remove outdated offers.
                        </MudText>

                        <MudStack Row="true" Spacing="2" Class="mt-5 hero-actions">
                            <MudButton Href="/services/create"
                                       Variant="Variant.Filled"
                                       Color="Color.Primary"
                                       StartIcon="@Icons.Material.Filled.Add"
                                       Class="btn-strong">
                                Create Service
                            </MudButton>
                        </MudStack>
                    </MudItem>

                    <MudItem xs="12" md="4">
                        <MudPaper Class="hero-side pa-5 h-100" Elevation="0">
                            <MudText Typo="Typo.h6" Class="side-box-title">Overview</MudText>

                            <MudGrid Spacing="2" Class="mt-2">
                                <MudItem xs="12" sm="4" md="12">
                                    <MudPaper Class="my-stat-card pa-4" Elevation="0">
                                        <MudText Class="my-stat-label">Total services</MudText>
                                        <MudText Typo="Typo.h5" Class="stat-value">@_totalItems</MudText>
                                    </MudPaper>
                                </MudItem>

                                <MudItem xs="12" sm="4" md="12">
                                    <MudPaper Class="my-stat-card pa-4" Elevation="0">
                                        <MudText Class="my-stat-label">Average price</MudText>
                                        <MudText Typo="Typo.h5" Class="stat-value">@($"{AveragePrice:0.##} zł")</MudText>
                                    </MudPaper>
                                </MudItem>

                                <MudItem xs="12" sm="4" md="12">
                                    <MudPaper Class="my-stat-card pa-4" Elevation="0">
                                        <MudText Class="my-stat-label">Highest price</MudText>
                                        <MudText Typo="Typo.h5" Class="stat-value">@($"{HighestPrice:0.##} zł")</MudText>
                                    </MudPaper>
                                </MudItem>
                            </MudGrid>
                        </MudPaper>
                    </MudItem>
                </MudGrid>
            </MudPaper>

            <MudPaper Class="my-toolbar pa-4" Elevation="0">
                <MudStack Row="true" Wrap="Wrap.Wrap" Spacing="2" AlignItems="AlignItems.Center">
                    <MudTextField T="string"
                                  Placeholder="Search in my services..."
                                  Variant="Variant.Outlined"
                                  Margin="Margin.Dense"
                                  Adornment="Adornment.Start"
                                  AdornmentIcon="@Icons.Material.Filled.Search"
                                  Immediate="true"
                                  Value="@_search"
                                  ValueChanged="OnSearchChanged"
                                  Class="toolbar-search" />

                    <MudSpacer />

                    <MudSelect T="string"
                               Label="Sort"
                               Variant="Variant.Outlined"
                               Margin="Margin.Dense"
                               Value="@_sort"
                               ValueChanged="OnSortChanged"
                               Class="toolbar-sort">
                        <MudSelectItem T="string" Value="@("newest")">Newest</MudSelectItem>
                        <MudSelectItem T="string" Value="@("oldest")">Oldest</MudSelectItem>
                        <MudSelectItem T="string" Value="@("price_desc")">Price: high to low</MudSelectItem>
                        <MudSelectItem T="string" Value="@("price_asc")">Price: low to high</MudSelectItem>
                        <MudSelectItem T="string" Value="@("title_asc")">Title: A-Z</MudSelectItem>
                        <MudSelectItem T="string" Value="@("title_desc")">Title: Z-A</MudSelectItem>
                    </MudSelect>
                </MudStack>
            </MudPaper>

            @if (_isLoading)
            {
                <MudGrid Spacing="3">
                    @for (var i = 0; i < 6; i++)
                    {
                        <MudItem xs="12" md="6" xl="4">
                            <div class="my-service-card skeleton"></div>
                        </MudItem>
                    }
                </MudGrid>
            }
            else if (!_pagedServices.Any())
            {
                <MudPaper Class="my-services-empty" Elevation="0">
                    <MudStack AlignItems="AlignItems.Center" Spacing="2">
                        <MudAvatar Size="Size.Large" Class="my-services-empty-icon">
                            <MudIcon Icon="@Icons.Material.Filled.Storefront" />
                        </MudAvatar>

                        @if (string.IsNullOrWhiteSpace(_search))
                        {
                            <MudText Typo="Typo.h5" Class="empty-title">You have no services yet</MudText>
                            <MudText Align="Align.Center" Class="empty-sub">
                                Create your first service and start receiving orders.
                            </MudText>

                            <MudButton Href="/services/create"
                                       Variant="Variant.Filled"
                                       Color="Color.Primary"
                                       StartIcon="@Icons.Material.Filled.AddCircleOutline"
                                       Class="btn-strong">
                                Create Service
                            </MudButton>
                        }
                        else
                        {
                            <MudText Typo="Typo.h5" Class="empty-title">Nothing found</MudText>
                            <MudText Align="Align.Center" Class="empty-sub">
                                No services match your search.
                            </MudText>
                        }
                    </MudStack>
                </MudPaper>
            }
            else
            {
                <MudGrid Spacing="3">
                    @foreach (var service in _pagedServices)
                    {
                        <MudItem xs="12" md="6" xl="4">
                            <MudPaper Class="my-service-card" Elevation="0">
                                <MudStack Spacing="2" Class="h-100">
                                    <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Start" Spacing="2">
                                        <MudChip T="string"
                                                 Text="@($"Service #{service.Id}")"
                                                 Variant="Variant.Outlined"
                                                 Size="Size.Small"
                                                 Class="service-chip" />

                                        <MudMenu Icon="@Icons.Material.Filled.MoreVert">
                                            <MudMenuItem Href="@GetServiceUrl(service.Id)" Icon="@Icons.Material.Filled.OpenInNew">
                                                Open service
                                            </MudMenuItem>

                                            <MudMenuItem OnClick="@(() => StartEdit(service.Id))" Icon="@Icons.Material.Filled.Edit">
                                                Edit
                                            </MudMenuItem>

                                            <MudMenuItem OnClick="@(() => DeleteService(service.Id))" Icon="@Icons.Material.Filled.Delete" Class="text-danger">
                                                Delete
                                            </MudMenuItem>
                                        </MudMenu>
                                    </MudStack>

                                    <MudStack Spacing="0">
                                        <MudText Typo="Typo.h6" Class="my-service-title">@service.Title</MudText>
                                        <MudText Class="my-service-price">@($"{service.Price:0.##} zł")</MudText>
                                    </MudStack>

                                    <MudText Class="my-service-desc">@service.Description</MudText>

                                    @if (_editingServiceId == service.Id)
                                    {
                                        <MudPaper Class="my-service-editor" Elevation="0">
                                            <MudStack Spacing="2">
                                                <MudTextField T="string"
                                                              Label="Title"
                                                              Variant="Variant.Outlined"
                                                              @bind-Value="_editTitle" />

                                                <MudTextField T="string"
                                                              Label="Description"
                                                              Variant="Variant.Outlined"
                                                              Lines="5"
                                                              Text="@_editDescription"
                                                              TextChanged="@(v => _editDescription = v ?? string.Empty)" />

                                                <MudNumericField T="decimal"
                                                                 Label="Price"
                                                                 Variant="Variant.Outlined"
                                                                 Min="1"
                                                                 HideSpinButtons="true"
                                                                 @bind-Value="_editPrice" />

                                                <MudStack Row="true" Justify="Justify.FlexEnd" Spacing="2">
                                                    <MudButton Variant="Variant.Text"
                                                               OnClick="CancelEdit">
                                                        Cancel
                                                    </MudButton>

                                                    <MudButton Variant="Variant.Filled"
                                                               Color="Color.Primary"
                                                               Loading="_isSaving && _editingServiceId == service.Id"
                                                               OnClick="@(() => SaveService(service.Id))"
                                                               Class="btn-strong">
                                                        Save changes
                                                    </MudButton>
                                                </MudStack>
                                            </MudStack>
                                        </MudPaper>
                                    }
                                    else
                                    {
                                        <MudStack Row="true" Wrap="Wrap.Wrap" Spacing="1" Class="mt-auto action-wrap">
                                            <MudButton Href="@GetServiceUrl(service.Id)"
                                                       Variant="Variant.Filled"
                                                       Color="Color.Primary"
                                                       StartIcon="@Icons.Material.Filled.Visibility"
                                                       Class="btn-strong">
                                                Open
                                            </MudButton>

                                            <MudButton Variant="Variant.Outlined"
                                                       Color="Color.Primary"
                                                       StartIcon="@Icons.Material.Filled.Edit"
                                                       OnClick="@(() => StartEdit(service.Id))"
                                                       Class="btn-strong">
                                                Edit
                                            </MudButton>

                                            <MudButton Variant="Variant.Outlined"
                                                       Color="Color.Error"
                                                       StartIcon="@Icons.Material.Filled.DeleteOutline"
                                                       OnClick="@(() => DeleteService(service.Id))"
                                                       Class="btn-strong">
                                                Delete
                                            </MudButton>
                                        </MudStack>
                                    }
                                </MudStack>
                            </MudPaper>
                        </MudItem>
                    }
                </MudGrid>

                <div class="my-services-pagination">
                    <MudPagination Count="@_totalPages"
                                   Selected="@_page"
                                   SelectedChanged="OnPageChanged"
                                   Color="Color.Primary"
                                   Variant="Variant.Outlined" />
                </div>
            }
        </MudStack>
    </MudContainer>
</MudContainer>

<style>
    .my-services-shell {
        min-height: calc(100vh - 78px);
        background:
            radial-gradient(circle at top left, rgba(124,58,237,.10), transparent 22%),
            radial-gradient(circle at top right, rgba(99,102,241,.08), transparent 24%),
            linear-gradient(180deg, #fbfaff 0%, #f7f4ff 42%, #ffffff 100%);
    }

    .my-services-hero {
        border-radius: 32px;
        background: linear-gradient(135deg, #2e1065 0%, #4c1d95 46%, #5b21b6 100%);
        color: #fff;
        border: 1px solid rgba(255,255,255,.10);
        box-shadow: 0 22px 60px rgba(76,29,149,.18);
    }

    .hero-badge {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        padding: 8px 14px;
        border-radius: 999px;
        background: rgba(255,255,255,.10);
        border: 1px solid rgba(255,255,255,.14);
        font-size: 13px;
        font-weight: 700;
    }

    .hero-title {
        font-weight: 900;
        line-height: 1.02;
        letter-spacing: -.03em;
        max-width: 760px;
    }

    .hero-sub {
        color: rgba(255,255,255,.82);
        max-width: 720px;
        line-height: 1.8;
        font-size: 16px;
    }

    .hero-side,
    .my-stat-card,
    .my-toolbar,
    .my-services-empty,
    .my-service-card,
    .my-service-editor {
        border-radius: 26px;
        background: rgba(255,255,255,.94);
        border: 1px solid rgba(109,40,217,.10);
        box-shadow: 0 14px 38px rgba(88,28,135,.06);
    }

    .side-box-title,
    .empty-title,
    .my-service-title {
        color: #1f1147;
        font-weight: 900;
    }

    .my-stat-card {
        background: linear-gradient(180deg, #faf7ff 0%, #ffffff 100%);
    }

    .my-stat-label,
    .empty-sub,
    .my-services-sub,
    .my-service-desc {
        color: #6b5f8d;
    }

    .stat-value,
    .my-service-price {
        color: #4c1d95;
        font-weight: 900;
    }

    .my-toolbar {
        padding: 16px;
    }

    .toolbar-search {
        min-width: 320px;
    }

    .toolbar-sort {
        min-width: 220px;
    }

    .my-services-empty {
        padding: 48px 24px;
        border: 1px dashed rgba(109,40,217,.18);
        background: rgba(255,255,255,.82);
    }

    .my-services-empty-icon {
        background: linear-gradient(135deg, rgba(109,40,217,.12), rgba(139,92,246,.08));
        color: #6d28d9;
    }

    .my-service-card {
        height: 100%;
        padding: 22px;
        transition: transform .18s ease, box-shadow .18s ease, border-color .18s ease;
    }

    .my-service-card:hover {
        transform: translateY(-4px);
        border-color: rgba(109,40,217,.22);
        box-shadow: 0 18px 42px rgba(88,28,135,.10);
    }

    .service-chip {
        color: #5b21b6 !important;
        border-color: rgba(109,40,217,.18) !important;
        background: rgba(109,40,217,.06) !important;
        font-weight: 800;
    }

    .my-service-title {
        line-height: 1.25;
    }

    .my-service-price {
        margin-top: 4px;
        font-size: 1rem;
    }

    .my-service-desc {
        line-height: 1.6;
        min-height: 88px;
        white-space: pre-wrap;
        word-break: break-word;
    }

    .my-service-editor {
        padding: 16px;
        background: rgba(109,40,217,.04);
    }

    .btn-strong {
        border-radius: 14px;
        font-weight: 900;
        letter-spacing: .2px;
        padding: 10px 14px;
        text-transform: none;
    }

    .my-services-pagination {
        margin-top: 20px;
        display: flex;
        justify-content: center;
    }

    .text-danger {
        color: #b91c1c !important;
    }

    .skeleton {
        position: relative;
        overflow: hidden;
        min-height: 300px;
    }

    .skeleton::before {
        content: "";
        position: absolute;
        inset: 0;
        background: linear-gradient(90deg,#f3f4f6,#fafafa,#f3f4f6);
        background-size: 200% 100%;
        animation: shimmer 1.2s infinite linear;
    }

    @@keyframes shimmer {
        0% {
            background-position: 0% 0;
        }

        100% {
            background-position: 200% 0;
        }
    }

    @@media (max-width: 960px) {
        .toolbar-search,
        .toolbar-sort {
            min-width: 0;
            width: 100%;
        }
    }

    @@media (max-width: 700px) {
        .my-services-hero,
        .hero-side,
        .my-stat-card,
        .my-toolbar,
        .my-services-empty,
        .my-service-card,
        .my-service-editor {
            border-radius: 22px;
        }

        .hero-title {
            font-size: 2rem !important;
        }

        .hero-actions,
        .action-wrap {
            flex-direction: column !important;
            align-items: stretch !important;
        }
    }
</style>

@code {
    private List<ServiceOffer> _services = new();
    private List<ServiceOffer> _pagedServices = new();
    private bool _isLoading = true;
    private bool _isSaving;
    private int? _editingServiceId;
    private string _editTitle = string.Empty;
    private string _editDescription = string.Empty;
    private decimal _editPrice;
    private string _search = string.Empty;
    private string _sort = "newest";

    private int _page = 1;
    private int _pageSize = 9;
    private int _totalItems;
    private int _totalPages = 1;

    private IEnumerable<ServiceOffer> FilteredServices
    {
        get
        {
            IEnumerable<ServiceOffer> query = _services;

            if (!string.IsNullOrWhiteSpace(_search))
            {
                var term = _search.Trim().ToLowerInvariant();
                query = query.Where(x =>
                    (!string.IsNullOrWhiteSpace(x.Title) && x.Title.ToLowerInvariant().Contains(term)) ||
                    (!string.IsNullOrWhiteSpace(x.Description) && x.Description.ToLowerInvariant().Contains(term)));
            }

            query = _sort switch
            {
                "oldest" => query.OrderBy(x => x.Id),
                "price_desc" => query.OrderByDescending(x => x.Price),
                "price_asc" => query.OrderBy(x => x.Price),
                "title_asc" => query.OrderBy(x => x.Title),
                "title_desc" => query.OrderByDescending(x => x.Title),
                _ => query.OrderByDescending(x => x.Id)
            };

            return query.ToList();
        }
    }

    private decimal AveragePrice => _services.Count == 0 ? 0 : _services.Average(x => x.Price);
    private decimal HighestPrice => _services.Count == 0 ? 0 : _services.Max(x => x.Price);

    protected override async Task OnInitializedAsync()
    {
        await LoadServices();
    }

    private async Task LoadServices()
    {
        _isLoading = true;

        var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
        var userId = authState.User.FindFirstValue(ClaimTypes.NameIdentifier);

        if (string.IsNullOrWhiteSpace(userId))
        {
            _services = new();
            _pagedServices = new();
            _isLoading = false;
            return;
        }

        _services = await Db.ServiceOffers
            .Where(x => x.OwnerUserId == userId)
            .OrderByDescending(x => x.Id)
            .ToListAsync();

        _page = 1;
        ApplyPaging();

        _isLoading = false;
    }

    private Task OnSearchChanged(string value)
    {
        _search = value ?? string.Empty;
        _page = 1;
        ApplyPaging();
        return Task.CompletedTask;
    }

    private Task OnSortChanged(string value)
    {
        _sort = value ?? "newest";
        _page = 1;
        ApplyPaging();
        return Task.CompletedTask;
    }

    private Task OnPageChanged(int page)
    {
        _page = page;
        ApplyPaging();
        return Task.CompletedTask;
    }

    private void ApplyPaging()
    {
        var filtered = FilteredServices.ToList();

        _totalItems = filtered.Count;
        _totalPages = Math.Max(1, (int)Math.Ceiling(_totalItems / (double)_pageSize));

        if (_page > _totalPages)
            _page = _totalPages;

        _pagedServices = filtered
            .Skip((_page - 1) * _pageSize)
            .Take(_pageSize)
            .ToList();

        StateHasChanged();
    }

    private string GetServiceUrl(int id)
    {
        return $"/services/{id}";
    }

    private void StartEdit(int id)
    {
        var service = _services.FirstOrDefault(x => x.Id == id);
        if (service == null)
            return;

        _editingServiceId = id;
        _editTitle = service.Title ?? string.Empty;
        _editDescription = service.Description ?? string.Empty;
        _editPrice = service.Price;
    }

    private void CancelEdit()
    {
        _editingServiceId = null;
        _editTitle = string.Empty;
        _editDescription = string.Empty;
        _editPrice = 0;
    }

    private async Task SaveService(int id)
    {
        if (string.IsNullOrWhiteSpace(_editTitle))
        {
            Snackbar.Add("Title is required", Severity.Warning);
            return;
        }

        if (string.IsNullOrWhiteSpace(_editDescription))
        {
            Snackbar.Add("Description is required", Severity.Warning);
            return;
        }

        if (_editPrice <= 0)
        {
            Snackbar.Add("Price must be greater than 0", Severity.Warning);
            return;
        }

        _isSaving = true;

        var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
        var userId = authState.User.FindFirstValue(ClaimTypes.NameIdentifier);

        var service = await Db.ServiceOffers.FirstOrDefaultAsync(x => x.Id == id && x.OwnerUserId == userId);

        if (service == null)
        {
            _isSaving = false;
            Snackbar.Add("Service not found", Severity.Error);
            return;
        }

        service.Title = _editTitle.Trim();
        service.Description = _editDescription.Trim();
        service.Price = _editPrice;

        await Db.SaveChangesAsync();

        var local = _services.First(x => x.Id == id);
        local.Title = service.Title;
        local.Description = service.Description;
        local.Price = service.Price;

        _isSaving = false;
        CancelEdit();
        ApplyPaging();

        Snackbar.Add("Service updated", Severity.Success);
    }

    private async Task DeleteService(int id)
    {
        var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
        var userId = authState.User.FindFirstValue(ClaimTypes.NameIdentifier);

        var service = await Db.ServiceOffers.FirstOrDefaultAsync(x => x.Id == id && x.OwnerUserId == userId);

        if (service == null)
        {
            Snackbar.Add("Service not found", Severity.Error);
            return;
        }

        Db.ServiceOffers.Remove(service);
        await Db.SaveChangesAsync();

        _services.RemoveAll(x => x.Id == id);

        if (_editingServiceId == id)
            CancelEdit();

        ApplyPaging();

        Snackbar.Add("Service deleted", Severity.Success);
    }
}