@code {
    [Parameter] public int ServiceId { get; set; }

    [CascadingParameter] public Task<AuthenticationState> AuthenticationStateTask { get; set; } = default!;

    private bool _loading = true;
    private bool _ordering;
    private string? _orderError;

    private ServiceOffer? service;

    private double avgRating;
    private int reviewsCount;

    private List<Review>? _topReviews;

    private CancellationTokenSource? _cts;
    private int _loadVersion;

    protected override async Task OnParametersSetAsync()
    {
        _cts?.Cancel();
        _cts?.Dispose();
        _cts = new CancellationTokenSource();

        var ct = _cts.Token;
        var myVersion = ++_loadVersion;

        _loading = true;
        _orderError = null;
        StateHasChanged();

        try
        {
            await using var db = await DbFactory.CreateDbContextAsync(ct);

            service = await db.ServiceOffers
                .Include(x => x.OwnerUser)
                .FirstOrDefaultAsync(x => x.Id == ServiceId, ct);

            if (service is null)
            {
                _topReviews = new List<Review>();
                avgRating = 0;
                reviewsCount = 0;
                return;
            }

            var q = db.Reviews.AsNoTracking().Where(r => r.TargetUserId == service.OwnerUserId);

            reviewsCount = await q.CountAsync(ct);
            avgRating = reviewsCount == 0 ? 0 : await q.AverageAsync(r => (double)r.Stars, ct);

            _topReviews = await db.Reviews.AsNoTracking()
                .Where(r => r.TargetUserId == service.OwnerUserId)
                .OrderByDescending(r => r.CreatedAt)
                .Take(3)
                .ToListAsync(ct);

            if (ct.IsCancellationRequested || myVersion != _loadVersion)
                return;
        }
        catch (OperationCanceledException)
        {
            return;
        }
        finally
        {
            if (!ct.IsCancellationRequested && myVersion == _loadVersion)
            {
                _loading = false;
                StateHasChanged();
            }
        }
    }

    private async Task PlaceOrderAsync()
    {
        if (_ordering) return;
        if (service is null) return;

        _ordering = true;
        _orderError = null;

        try
        {
            var authState = await AuthenticationStateTask;
            var principal = authState.User;

            if (principal?.Identity?.IsAuthenticated != true)
            {
                Nav.NavigateTo("/Account/Login");
                return;
            }

            var me = await UserManager.GetUserAsync(principal);
            if (me is null)
            {
                Nav.NavigateTo("/Account/Login");
                return;
            }

            var result = await OrderService.CreateOrderAsync(ServiceId, me.Id);

            if (result.NeedTopUp)
            {
                _orderError = $"Not enough balance. Missing {result.MissingAmount:0.##} zł.";

                var options = new DialogOptions { CloseButton = true, MaxWidth = MaxWidth.Small, FullWidth = true };
                var parameters = new DialogParameters { ["SuggestedAmount"] = result.MissingAmount };

                var dialog = DialogService.Show<TopUpDialog>("Top up balance", parameters, options);
                var dlgRes = await dialog.Result;

                if (dlgRes.Canceled) return;
                if (dlgRes.Data is not TopUpDialogResult data) return;

                var note = $"Top up via card **** {data.Last4}";
                await WalletRepo.TopUpAsync(me.Id, data.Amount, note);

                await WalletState.RefreshAsync();

                result = await OrderService.CreateOrderAsync(ServiceId, me.Id);

                if (result.NeedTopUp)
                {
                    _orderError = $"Still not enough balance. Missing {result.MissingAmount:0.##} zł.";
                    return;
                }

                if (!result.Success || result.ConversationId == null)
                {
                    _orderError = result.Error ?? "Failed to create order";
                    return;
                }

                Nav.NavigateTo($"/chat/{result.ConversationId}");
                return;
            }

            if (!result.Success || result.ConversationId == null)
            {
                _orderError = result.Error ?? "Failed to create order";
                return;
            }

            Nav.NavigateTo($"/chat/{result.ConversationId}");
        }
        finally
        {
            _ordering = false;
        }
    }

    private void NavToProfile(ApplicationUser u)
    {
        var name = (u.UserName ?? "").Trim();
        if (!string.IsNullOrWhiteSpace(name))
            Nav.NavigateTo($"/profile/{name}");
    }

    private async Task OpenReportDialog()
    {
        if (service is null) return;

        var authState = await AuthenticationStateTask;
        var principal = authState.User;

        if (principal?.Identity?.IsAuthenticated != true)
        {
            var p = new DialogParameters
                {
                    ["TitleText"] = "Login required",
                    ["BodyText"] = "You must be logged in to submit a report."
                };

            var o = new DialogOptions { CloseButton = true, MaxWidth = MaxWidth.Small, FullWidth = true };
            DialogService.Show<InfoDialog>("Info", p, o);
            return;
        }

        var me = await UserManager.GetUserAsync(principal);
        if (me is null) return;

        var parameters = new DialogParameters
            {
                ["ReporterUserId"] = me.Id,
                ["TargetUserId"] = service.OwnerUserId,
                ["ServiceOfferId"] = service.Id
            };

        var options = new DialogOptions { CloseButton = true, MaxWidth = MaxWidth.Small, FullWidth = true };
        var dialog = DialogService.Show<ReportDialog>("Report", parameters, options);

        var result = await dialog.Result;
        if (!result.Canceled)
        {
            await OnParametersSetAsync();
            StateHasChanged();
        }
    }

    private static string DisplayName(ApplicationUser u)
        => !string.IsNullOrWhiteSpace(u.DisplayName) ? u.DisplayName : (u.UserName ?? "User");

    private static string Trim(string s, int max) => s.Length <= max ? s : s.Substring(0, max) + "...";

    private static string Stars(double rating)
    {
        var full = (int)Math.Round(rating);
        full = Math.Clamp(full, 0, 5);
        return new string('★', full) + new string('☆', 5 - full);
    }
}