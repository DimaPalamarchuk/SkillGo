@page "/services/{ServiceId:int}"
@using Microsoft.AspNetCore.Components.Authorization
@using Microsoft.AspNetCore.Identity
@using Microsoft.EntityFrameworkCore
@using MudBlazor
@using SkillGo.Data
@using SkillGo.Data.Models
@using SkillGo.Components.Shared
@using SkillGo.Components.Pages.WalletPage
@using SkillGo.Repository.IRepository
@using SkillGo.Services
@inject IDbContextFactory<ApplicationDbContext> DbFactory
@inject UserManager<ApplicationUser> UserManager
@inject WalletState WalletState
@inject IWalletRepository WalletRepo
@inject IDialogService DialogService
@inject NavigationManager Nav
@inject OrderService OrderService

<PageTitle>Service</PageTitle>

<MudContainer MaxWidth="MaxWidth.False" Class="service-page-shell pa-0">
    <MudContainer MaxWidth="MaxWidth.ExtraLarge" Class="pt-6 pb-8">
        @if (_loading)
        {
            <MudGrid Spacing="3">
                <MudItem xs="12">
                    <div class="hero-skeleton skeleton"></div>
                </MudItem>
                <MudItem xs="12" md="8">
                    <div class="card-shell skeleton"></div>
                </MudItem>
                <MudItem xs="12" md="4">
                    <div class="side-shell skeleton"></div>
                </MudItem>
            </MudGrid>
        }
        else if (service is null)
        {
            <MudPaper Class="empty-paper pa-8 text-center" Elevation="0">
                <MudText Typo="Typo.h5" Class="empty-title">Service not found</MudText>
                <MudText Typo="Typo.body2" Class="empty-sub mt-2">The service may have been removed or does not exist.</MudText>
            </MudPaper>
        }
        else
        {
            <MudPaper Class="hero-paper pa-6 pa-md-8" Elevation="0">
                <MudGrid Spacing="3" AlignItems="AlignItems.Stretch">
                    <MudItem xs="12" md="8">
                        <div class="hero-badge">
                            <MudIcon Icon="@Icons.Material.Filled.AutoAwesome" Size="Size.Small" />
                            <span>@DisplayName(service.OwnerUser)</span>
                        </div>

                        <MudText Typo="Typo.h3" Class="hero-title mt-4">
                            @service.Title
                        </MudText>

                        <MudText Typo="Typo.body1" Class="hero-sub mt-4">
                            @Trim(service.Description, 220)
                        </MudText>

                        <MudStack Row="true" Spacing="1" Class="mt-5 hero-tags">
                            <MudChip T="string" Variant="Variant.Outlined" Class="hero-chip">@GetCategoryName(service)</MudChip>
                            <MudChip T="string" Variant="Variant.Outlined" Class="hero-chip">Fast response</MudChip>
                            <MudChip T="string" Variant="Variant.Outlined" Class="hero-chip">@reviewsCount review(s)</MudChip>
                        </MudStack>
                    </MudItem>

                    <MudItem xs="12" md="4">
                        <MudPaper Class="hero-side pa-5 h-100" Elevation="0">
                            <MudText Typo="Typo.h6" Class="side-box-title">Offer summary</MudText>

                            <MudGrid Spacing="2" Class="mt-2">
                                <MudItem xs="6">
                                    <MudPaper Class="stat-card pa-4" Elevation="0">
                                        <MudText Typo="Typo.h5" Class="stat-value">@avgRating.ToString("0.0")</MudText>
                                        <MudText Typo="Typo.body2" Class="stat-label">Rating</MudText>
                                    </MudPaper>
                                </MudItem>

                                <MudItem xs="6">
                                    <MudPaper Class="stat-card pa-4" Elevation="0">
                                        <MudText Typo="Typo.h5" Class="stat-value">@reviewsCount</MudText>
                                        <MudText Typo="Typo.body2" Class="stat-label">Reviews</MudText>
                                    </MudPaper>
                                </MudItem>
                            </MudGrid>

                            <MudPaper Class="price-box pa-4 mt-3" Elevation="0">
                                <MudText Typo="Typo.caption" Class="price-label">Starting at</MudText>
                                <MudText Typo="Typo.h4" Class="price-value mt-1">@service.Price.ToString("0.##") zł</MudText>
                            </MudPaper>

                            <MudButton FullWidth="true"
                                       Variant="Variant.Filled"
                                       Color="Color.Primary"
                                       Class="btn-strong mt-4"
                                       Disabled="_ordering"
                                       OnClick="PlaceOrderAsync">
                                @(_ordering ? "Creating..." : "Place order")
                            </MudButton>

                            <MudButton FullWidth="true"
                                       Variant="Variant.Outlined"
                                       Color="Color.Primary"
                                       Class="btn-strong mt-2"
                                       OnClick="@(() => NavToProfile(service.OwnerUser))">
                                View freelancer profile
                            </MudButton>
                        </MudPaper>
                    </MudItem>
                </MudGrid>
            </MudPaper>

            <MudGrid Spacing="3" Class="mt-4">
                <MudItem xs="12" md="8">
                    <MudPaper Class="content-paper" Elevation="0">
                        <div class="content-head">
                            <MudText Typo="Typo.h5" Class="content-title">Service description</MudText>
                            <MudText Typo="Typo.body2" Class="content-sub">Details and scope of work</MudText>
                        </div>

                        <div class="content-body">
                            <div class="desc">@service.Description</div>

                            <MudDivider Class="my-4" />

                            <MudStack Row="true" Spacing="2" Class="action-row">
                                <MudButton Variant="Variant.Filled"
                                           Color="Color.Primary"
                                           Class="btn-strong"
                                           OnClick="@(() => NavToProfile(service.OwnerUser))">
                                    View freelancer profile
                                </MudButton>

                                <MudButton Variant="Variant.Outlined"
                                           Color="Color.Error"
                                           Class="btn-strong"
                                           Href="@($"/reports/create?type=service&targetUserId={service.OwnerUserId}&serviceOfferId={service.Id}")">
                                    Report service
                                </MudButton>
                            </MudStack>
                        </div>
                    </MudPaper>

                    <MudPaper Class="reviews-paper mt-4" Elevation="0">
                        <div class="reviews-head">
                            <div>
                                <MudText Typo="Typo.h5" Class="reviews-title">Rating</MudText>
                                <MudText Typo="Typo.body2" Class="reviews-sub">@avgRating.ToString("0.0") from @reviewsCount review(s)</MudText>
                            </div>

                            @if (reviewsCount > 0 && !string.IsNullOrWhiteSpace(service.OwnerUser?.UserName))
                            {
                                <MudButton Variant="Variant.Outlined"
                                           Color="Color.Primary"
                                           Class="btn-strong"
                                           Href="@($"/profile/{service.OwnerUser.UserName}/reviews")">
                                    View all reviews
                                </MudButton>
                            }
                        </div>

                        <div class="reviews-body">
                            @if (_reviewsLoading)
                            {
                                <MudStack Spacing="2">
                                    @for (var i = 0; i < 3; i++)
                                    {
                                        <div class="review-card skeleton review-skeleton"></div>
                                    }
                                </MudStack>
                            }
                            else if (_reviews.Count == 0)
                            {
                                <div class="meta-muted">No reviews yet.</div>
                            }
                            else
                            {
                                <MudStack Spacing="2">
                                    @foreach (var r in _reviews)
                                    {
                                        <MudPaper Class="review-card pa-4" Elevation="0">
                                            <div class="review-top">
                                                <div class="review-author-block">
                                                    <img class="review-avatar" src="@GetReviewAvatar(r.AuthorAvatarUrl)" alt="@r.AuthorName" />
                                                    <div class="review-author-copy">
                                                        <div class="review-author-name">@r.AuthorName</div>
                                                        <div class="review-author-date">@r.CreatedAt.ToLocalTime().ToString("yyyy-MM-dd")</div>
                                                    </div>
                                                </div>

                                                <div class="review-rating-block">
                                                    <div class="stars">@Stars(r.Stars)</div>
                                                    <div class="meta-muted">@r.Stars.ToString("0.0")</div>
                                                </div>
                                            </div>

                                            @if (!string.IsNullOrWhiteSpace(r.Comment))
                                            {
                                                <div class="review-text">@r.Comment</div>
                                            }
                                        </MudPaper>
                                    }
                                </MudStack>
                            }
                        </div>
                    </MudPaper>
                </MudItem>

                <MudItem xs="12" md="4">
                    <MudPaper Class="side-paper" Elevation="0">
                        <MudText Typo="Typo.h6" Class="side-title">Freelancer</MudText>
                        <MudText Typo="Typo.body2" Class="side-sub">Service provider</MudText>

                        <div class="profile-card mt-4" @onclick="@(() => NavToProfile(service.OwnerUser))">
                            <img class="avatar" src="@(service.OwnerUser.AvatarUrl ?? "/images/default-avatar.png")" />
                            <div class="profile-name">@DisplayName(service.OwnerUser)</div>
                            <div class="profile-muted">@("@" + (service.OwnerUser.UserName ?? ""))</div>
                        </div>

                        <div class="side-info mt-4">
                            <div class="info-row">
                                <div class="meta-muted">Category</div>
                                <div class="info-strong">@GetCategoryName(service)</div>
                            </div>
                            <div class="info-row">
                                <div class="meta-muted">Rating</div>
                                <div class="info-strong">@avgRating.ToString("0.0")</div>
                            </div>
                            <div class="info-row">
                                <div class="meta-muted">Reviews</div>
                                <div class="info-strong">@reviewsCount</div>
                            </div>
                            <div class="info-row">
                                <div class="meta-muted">Price</div>
                                <div class="info-strong">@service.Price.ToString("0.##") zł</div>
                            </div>
                        </div>

                        @if (!string.IsNullOrWhiteSpace(_orderError))
                        {
                            <MudAlert Severity="Severity.Error" Variant="Variant.Outlined" Class="mt-4">
                                @_orderError
                            </MudAlert>
                        }

                        <MudButton FullWidth="true"
                                   Variant="Variant.Filled"
                                   Color="Color.Primary"
                                   Class="btn-strong mt-4"
                                   Disabled="_ordering"
                                   OnClick="PlaceOrderAsync">
                            @(_ordering ? "Creating..." : "Place order")
                        </MudButton>

                        <MudButton FullWidth="true"
                                   Variant="Variant.Outlined"
                                   Color="Color.Primary"
                                   Class="btn-strong mt-2"
                                   OnClick="@(() => NavToProfile(service.OwnerUser))">
                            View freelancer profile
                        </MudButton>

                        <MudButton FullWidth="true"
                                   Variant="Variant.Outlined"
                                   Color="Color.Error"
                                   Class="btn-strong mt-2"
                                   Href="@($"/reports/create?type=service&targetUserId={service.OwnerUserId}&serviceOfferId={service.Id}")">
                            Report service
                        </MudButton>
                    </MudPaper>
                </MudItem>
            </MudGrid>
        }
    </MudContainer>
</MudContainer>

