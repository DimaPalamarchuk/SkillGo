@page "/services/{ServiceId:int}"
@using Microsoft.AspNetCore.Components.Authorization
@using Microsoft.AspNetCore.Identity
@using Microsoft.EntityFrameworkCore
@using MudBlazor
@using SkillGo.Data
@using SkillGo.Data.Models
@using SkillGo.Components.Shared
@using SkillGo.Components.Pages.WalletPage
@using SkillGo.Repository.IRepository
@using SkillGo.Services
@inject IDbContextFactory<ApplicationDbContext> DbFactory
@inject UserManager<ApplicationUser> UserManager
@inject WalletState WalletState
@inject IWalletRepository WalletRepo
@inject IDialogService DialogService
@inject NavigationManager Nav
@inject OrderService OrderService

<PageTitle>Service</PageTitle>

<MudContainer MaxWidth="MaxWidth.Large" Class="mt-6">
    @if (_loading)
    {
        <MudGrid Spacing="4">
            <MudItem xs="12" md="8">
                <div class="card-shell skeleton"></div>
            </MudItem>
            <MudItem xs="12" md="4">
                <div class="side-shell skeleton"></div>
            </MudItem>
        </MudGrid>
    }
    else if (service is null)
    {
        <MudPaper Class="pa-5" Elevation="0" Style="border-radius:20px;border:1px solid rgba(0,0,0,.08);">
            Service not found.
        </MudPaper>
    }
    else
    {
        <div class="hero">
            <div class="hero-inner">
                <div class="hero-title">@service.Title</div>
                <div class="hero-sub">@Trim(service.Description, 180)</div>

                <div class="hero-meta">
                    <div class="meta-chip">
                        <span class="stars">@Stars(avgRating)</span>
                        <span class="meta-muted">@avgRating.ToString("0.0")</span>
                        <span class="meta-muted">(@reviewsCount)</span>
                    </div>

                    <div class="meta-chip">
                        <span class="meta-muted">Price</span>
                        <span class="price">@service.Price.ToString("0.##") zł</span>
                    </div>
                </div>
            </div>
        </div>

        <MudGrid Spacing="4" Class="mt-4">
            <MudItem xs="12" md="8">
                <div class="card-shell">
                    <div class="card-head">
                        <div class="card-head-title">Service description</div>
                        <div class="card-head-sub">Details and scope of work</div>
                    </div>

                    <div class="card-body">
                        <div class="desc">@service.Description</div>

                        <div class="divider"></div>

                        <div class="actions">
                            <MudButton Variant="Variant.Filled" Color="Color.Primary" Class="btn-strong"
                                       OnClick="@(() => NavToProfile(service.OwnerUser))">
                                View freelancer profile
                            </MudButton>

                            <MudButton Variant="Variant.Outlined" Color="Color.Error" Class="btn-strong"
                                       OnClick="@OpenReportDialog">
                                Report
                            </MudButton>
                        </div>
                    </div>
                </div>

                <div class="reviews-shell mt-4">
                    <div class="reviews-head">
                        <div class="reviews-title">Rating</div>
                        <div class="reviews-sub">@avgRating.ToString("0.0") from @reviewsCount review(s)</div>
                    </div>

                    <div class="reviews-body">
                        @if (_topReviews is null)
                        {
                            <div class="meta-muted">Loading...</div>
                        }
                        else if (_topReviews.Count == 0)
                        {
                            <div class="meta-muted">No reviews yet.</div>
                        }
                        else
                        {
                            <MudStack Spacing="2">
                                @foreach (var r in _topReviews)
                                {
                                    <MudPaper Class="pa-3" Elevation="0" Style="border-radius:16px;border:1px solid rgba(0,0,0,.08);">
                                        <div class="review-row">
                                            <div class="stars">@Stars(r.Stars)</div>
                                            <div class="meta-muted">@r.CreatedAt.ToLocalTime().ToString("yyyy-MM-dd")</div>
                                        </div>
                                        @if (!string.IsNullOrWhiteSpace(r.Comment))
                                        {
                                            <div class="review-text">@r.Comment</div>
                                        }
                                    </MudPaper>
                                }
                            </MudStack>
                        }
                    </div>
                </div>
            </MudItem>

            <MudItem xs="12" md="4">
                <div class="side-shell">
                    <div class="side-title">Freelancer</div>
                    <div class="side-sub">Service provider</div>

                    <div class="profile-card mt-4" @onclick="@(() => NavToProfile(service.OwnerUser))">
                        <img class="avatar" src="@(service.OwnerUser.AvatarUrl ?? "/images/default-avatar.png")" />
                        <div class="profile-name">@DisplayName(service.OwnerUser)</div>
                        <div class="profile-muted">@("@" + (service.OwnerUser.UserName ?? ""))</div>
                    </div>

                    <div class="side-info mt-4">
                        <div class="info-row">
                            <div class="meta-muted">Rating</div>
                            <div class="info-strong">@avgRating.ToString("0.0")</div>
                        </div>
                        <div class="info-row">
                            <div class="meta-muted">Reviews</div>
                            <div class="info-strong">@reviewsCount</div>
                        </div>
                        <div class="info-row">
                            <div class="meta-muted">Price</div>
                            <div class="info-strong">@service.Price.ToString("0.##") zł</div>
                        </div>
                    </div>

                    <MudButton FullWidth="true" Variant="Variant.Filled" Color="Color.Primary" Class="btn-strong mt-4"
                               Disabled="_ordering" OnClick="PlaceOrderAsync">
                        @(_ordering ? "Creating..." : "Place order")
                    </MudButton>

                    @if (!string.IsNullOrWhiteSpace(_orderError))
                    {
                        <MudText Color="Color.Error" Class="mt-2">@_orderError</MudText>
                    }

                    <MudButton FullWidth="true" Variant="Variant.Outlined" Color="Color.Primary" Class="btn-strong mt-2"
                               OnClick="@(() => NavToProfile(service.OwnerUser))">
                        View freelancer profile
                    </MudButton>

                    <MudButton FullWidth="true" Variant="Variant.Outlined" Color="Color.Error" Class="btn-strong mt-2"
                               OnClick="@OpenReportDialog">
                        Report
                    </MudButton>
                </div>
            </MudItem>
        </MudGrid>
    }
</MudContainer>

