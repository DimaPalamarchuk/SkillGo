@page "/services/category"

@using Microsoft.EntityFrameworkCore
@using MudBlazor
@using SkillGo.Data
@using SkillGo.Data.Models

@inject ApplicationDbContext Db

<PageTitle>Services</PageTitle>

<MudContainer MaxWidth="MaxWidth.Large" Class="mt-6">

    <div class="hero">
        <div class="hero-inner">
            <div class="hero-title">All services</div>
            <div class="hero-sub">Search and filter by category, price and rating.</div>

            <div class="hero-controls">
                <MudTextField T="string"
                              Variant="Variant.Outlined"
                              Placeholder="Search services..."
                              Adornment="Adornment.Start"
                              AdornmentIcon="@Icons.Material.Filled.Search"
                              Immediate="true"
                              DebounceInterval="350"
                              Value="@_search"
                              ValueChanged="OnSearchChanged"
                              Class="control search" />

                <MudSelect T="string"
                           Variant="Variant.Outlined"
                           Label="Sort"
                           Value="@_sort"
                           ValueChanged="OnSortChanged"
                           Class="control sort">
                    <MudSelectItem T="string" Value="@("new")">Newest</MudSelectItem>
                    <MudSelectItem T="string" Value="@("price_asc")">Price: low to high</MudSelectItem>
                    <MudSelectItem T="string" Value="@("price_desc")">Price: high to low</MudSelectItem>
                    <MudSelectItem T="string" Value="@("rating_desc")">Rating: high to low</MudSelectItem>
                    <MudSelectItem T="string" Value="@("reviews_desc")">Most reviews</MudSelectItem>
                </MudSelect>
            </div>

            <div class="hero-chips">
                @if (_categoryId.HasValue)
                {
                    <span class="chip">Category: @_categories.FirstOrDefault(x => x.Id == _categoryId)?.Name</span>
                }
                @if (_minPrice.HasValue)
                {
                    <span class="chip">Min: @_minPrice.Value.ToString("0.##") zł</span>
                }
                @if (_maxPrice.HasValue)
                {
                    <span class="chip">Max: @_maxPrice.Value.ToString("0.##") zł</span>
                }
                @if (_minRating > 0)
                {
                    <span class="chip">Rating: @_minRating+</span>
                }
                @if (_onlyWithReviews)
                {
                    <span class="chip">Only reviewed</span>
                }
            </div>
        </div>
    </div>

    <div class="layout mt-4">
        <aside class="filters">
            <div class="filters-head">
                <div class="filters-title">Filters</div>
                <MudButton Variant="Variant.Text" Class="reset" OnClick="@ResetAsync">Reset</MudButton>
            </div>

            <div class="filters-body">
                <MudSelect T="int?" Variant="Variant.Outlined" Label="Category"
                           Value="@_categoryId" ValueChanged="OnCategoryChanged" FullWidth="true">
                    <MudSelectItem T="int?" Value="@(null)">All categories</MudSelectItem>
                    @foreach (var c in _categories)
                    {
                        <MudSelectItem T="int?" Value="@((int?)c.Id)">@c.Name</MudSelectItem>
                    }
                </MudSelect>

                <div class="two">
                    <MudNumericField T="decimal?" Variant="Variant.Outlined" Label="Min price (zł)"
                                     Min="0" Value="@_minPrice" ValueChanged="OnMinPriceChanged" />
                    <MudNumericField T="decimal?" Variant="Variant.Outlined" Label="Max price (zł)"
                                     Min="0" Value="@_maxPrice" ValueChanged="OnMaxPriceChanged" />
                </div>

                <MudSelect T="int" Variant="Variant.Outlined" Label="Min rating"
                           Value="@_minRating" ValueChanged="OnMinRatingChanged" FullWidth="true">
                    <MudSelectItem T="int" Value="0">Any</MudSelectItem>
                    <MudSelectItem T="int" Value="1">1+</MudSelectItem>
                    <MudSelectItem T="int" Value="2">2+</MudSelectItem>
                    <MudSelectItem T="int" Value="3">3+</MudSelectItem>
                    <MudSelectItem T="int" Value="4">4+</MudSelectItem>
                    <MudSelectItem T="int" Value="5">5</MudSelectItem>
                </MudSelect>

                <MudSwitch T="bool" Color="Color.Primary" Label="Only with reviews"
                           Checked="@_onlyWithReviews" CheckedChanged="OnOnlyWithReviewsChanged" />

                <MudButton Variant="Variant.Filled" Color="Color.Primary" FullWidth="true" Class="apply"
                           OnClick="@LoadAsync">
                    Apply
                </MudButton>
            </div>
        </aside>

        <main class="results">
            @if (_loading)
            {
                <MudGrid Spacing="4">
                    @for (int i = 0; i < 12; i++)
                    {
                        <MudItem xs="12" sm="6" md="4" lg="3">
                            <div class="card skeleton"></div>
                        </MudItem>
                    }
                </MudGrid>
            }
            else if (_services.Count == 0)
            {
                <MudPaper Class="pa-4" Elevation="0" Style="border-radius:18px;border:1px solid rgba(0,0,0,.08);">
                    No services found.
                </MudPaper>
            }
            else
            {
                <MudGrid Spacing="4">
                    @foreach (var s in _services)
                    {
                        <MudItem xs="12" sm="6" md="4" lg="3">
                            <MudLink Href="@($"/services/{s.Id}")" Class="link">
                                <div class="card">
                                    <div class="top">
                                        <div class="title">@s.Title</div>
                                        <div class="pill">@((s.Category?.Name) ?? "Category")</div>
                                    </div>

                                    <div class="desc">@Trim(s.Description, 115)</div>

                                    <div class="meta">
                                        <div class="rating">
                                            <span class="stars">@Stars(s.RatingAvg)</span>
                                            <span class="muted">@s.RatingAvg.ToString("0.0")</span>
                                            <span class="muted">(@s.ReviewsCount)</span>
                                        </div>
                                        <div class="price">@s.Price.ToString("0.##") zł</div>
                                    </div>

                                    <div class="user">
                                        <img class="avatar" src="@(s.OwnerUser?.AvatarUrl ?? "/images/default-avatar.png")" />
                                        <div class="uname">@DisplayName(s.OwnerUser)</div>
                                    </div>
                                </div>
                            </MudLink>
                        </MudItem>
                    }
                </MudGrid>
            }
        </main>
    </div>

</MudContainer>

<style>
    .hero {
        border-radius: 24px;
        border: 1px solid rgba(0,0,0,.08);
        background: linear-gradient(135deg,#eef2ff,#e0e7ff);
        box-shadow: 0 18px 46px rgba(0,0,0,.06);
        position: relative;
        overflow: hidden;
    }

        .hero::before {
            content: "";
            position: absolute;
            inset: -45% -70%;
            background: radial-gradient(circle at 30% 30%, rgba(255,255,255,.55), transparent 55%);
            transform: rotate(12deg);
            opacity: .9;
            pointer-events: none;
        }

    .hero-inner {
        position: relative;
        z-index: 1;
        padding: 26px;
        display: grid;
        gap: 14px;
        min-width: 0;
    }

    .hero-title {
        font-weight: 950;
        color: #111827;
        font-size: 1.7rem;
        letter-spacing: .2px;
        line-height: 1.12;
        min-width: 0;
    }

    .hero-sub {
        color: rgba(17,24,39,.65);
        font-size: 1rem;
        line-height: 1.35;
        margin-top: -10px;
        min-width: 0;
    }

    .hero-controls {
        display: grid;
        grid-template-columns: minmax(0, 1fr) 260px;
        gap: 12px;
        align-items: start;
        min-width: 0;
    }

    .control {
        min-width: 0;
    }

    .hero-chips {
        display: flex;
        flex-wrap: wrap;
        gap: 8px;
        min-width: 0;
    }

    .chip {
        display: inline-flex;
        align-items: center;
        padding: 6px 10px;
        border-radius: 999px;
        border: 1px solid rgba(0,0,0,.08);
        background: rgba(255,255,255,.65);
        font-weight: 900;
        letter-spacing: .15px;
        color: rgba(17,24,39,.8);
        font-size: .85rem;
        max-width: 100%;
        overflow: hidden;
        text-overflow: ellipsis;
        white-space: nowrap;
    }

    .layout {
        display: grid;
        grid-template-columns: 340px minmax(0, 1fr);
        gap: 16px;
        align-items: start;
        min-width: 0;
    }

    .filters {
        position: sticky;
        top: 92px;
        border-radius: 22px;
        border: 1px solid rgba(0,0,0,.08);
        background: #fff;
        box-shadow: 0 18px 46px rgba(0,0,0,.06);
        overflow: hidden;
        min-width: 0;
    }

    .filters-head {
        padding: 16px 18px;
        border-bottom: 1px solid rgba(0,0,0,.06);
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 10px;
        min-width: 0;
    }

    .filters-title {
        font-weight: 950;
        color: #111827;
        letter-spacing: .2px;
        min-width: 0;
    }

    .reset {
        font-weight: 950;
        letter-spacing: .2px;
    }

    .filters-body {
        padding: 16px 18px 18px 18px;
        display: grid;
        gap: 12px;
        min-width: 0;
    }

    .two {
        display: grid;
        grid-template-columns: minmax(0, 1fr) minmax(0, 1fr);
        gap: 10px;
        min-width: 0;
    }

    .apply {
        border-radius: 14px;
        font-weight: 950;
        letter-spacing: .2px;
        padding: 10px 14px;
    }

    .results {
        min-width: 0;
    }

    .link {
        display: block;
        text-decoration: none;
        color: inherit;
        min-width: 0;
    }

    .card {
        height: 270px;
        border-radius: 20px;
        padding: 18px;
        background: #fff;
        border: 1px solid rgba(0,0,0,.08);
        box-shadow: 0 12px 28px rgba(0,0,0,.06);
        transition: transform .18s ease, box-shadow .18s ease;
        display: flex;
        flex-direction: column;
        gap: 10px;
        min-width: 0;
    }

    .link:hover .card {
        transform: translateY(-6px);
        box-shadow: 0 20px 48px rgba(0,0,0,.10);
    }

    .top {
        display: grid;
        gap: 8px;
        min-width: 0;
    }

    .title {
        font-weight: 950;
        color: #111827;
        font-size: 1.05rem;
        letter-spacing: .2px;
        line-height: 1.15;
        min-width: 0;
        overflow: hidden;
        display: -webkit-box;
        -webkit-line-clamp: 2;
        -webkit-box-orient: vertical;
    }

    .pill {
        justify-self: start;
        display: inline-flex;
        padding: 6px 10px;
        border-radius: 999px;
        background: rgba(99,102,241,.10);
        border: 1px solid rgba(99,102,241,.22);
        color: rgba(17,24,39,.75);
        font-weight: 950;
        font-size: .85rem;
        max-width: 100%;
        overflow: hidden;
        text-overflow: ellipsis;
        white-space: nowrap;
        min-width: 0;
    }

    .desc {
        color: rgba(17,24,39,.65);
        font-size: .92rem;
        line-height: 1.25;
        flex: 1;
        white-space: pre-wrap;
        min-width: 0;
        overflow: hidden;
        display: -webkit-box;
        -webkit-line-clamp: 4;
        -webkit-box-orient: vertical;
    }

    .meta {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 12px;
        margin-top: auto;
        min-width: 0;
    }

    .rating {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        min-width: 0;
        overflow: hidden;
    }

    .stars {
        font-weight: 950;
        letter-spacing: .6px;
        color: #111827;
        white-space: nowrap;
    }

    .muted {
        color: rgba(17,24,39,.65);
        font-weight: 950;
        font-size: .88rem;
        white-space: nowrap;
    }

    .price {
        font-weight: 950;
        color: #111827;
        white-space: nowrap;
        flex: 0 0 auto;
    }

    .user {
        display: flex;
        align-items: center;
        gap: 10px;
        min-width: 0;
        margin-top: 10px;
    }

    .avatar {
        width: 34px;
        height: 34px;
        border-radius: 50%;
        object-fit: cover;
        border: 1px solid rgba(0,0,0,.12);
        flex: 0 0 auto;
        background: #fff;
    }

    .uname {
        font-weight: 950;
        color: #111827;
        font-size: .92rem;
        min-width: 0;
        overflow: hidden;
        text-overflow: ellipsis;
        white-space: nowrap;
    }

    .skeleton {
        background: #fff;
        border-radius: 20px;
        position: relative;
        overflow: hidden;
        height: 270px;
        border: 1px solid rgba(0,0,0,.08);
    }

        .skeleton::before {
            content: "";
            position: absolute;
            inset: 0;
            background: linear-gradient(90deg,#f3f4f6,#fafafa,#f3f4f6);
            background-size: 200% 100%;
            animation: shimmer 1.2s infinite linear;
        }

    @@keyframes shimmer {
        0% {
            background-position: 0% 0
        }

        100% {
            background-position: 200% 0
        }
    }

    @@media (max-width: 1200px) {
        .layout {
            grid-template-columns: 320px minmax(0, 1fr);
        }

        .hero-controls {
            grid-template-columns: minmax(0, 1fr) 240px;
        }
    }

    @@media (max-width: 992px) {
        .layout {
            grid-template-columns: minmax(0, 1fr);
        }

        .filters {
            position: static;
            top: auto;
        }

        .hero-controls {
            grid-template-columns: minmax(0, 1fr);
        }

        .two {
            grid-template-columns: minmax(0, 1fr);
        }
    }
</style>

@code {
    private bool _loading = true;

    private List<Category> _categories = new();
    private List<ServiceCardVm> _services = new();

    private string _search = "";
    private int? _categoryId = null;
    private decimal? _minPrice = null;
    private decimal? _maxPrice = null;
    private int _minRating = 0;
    private bool _onlyWithReviews = false;
    private string _sort = "new";

    protected override async Task OnInitializedAsync()
    {
        _categories = await Db.Categories.AsNoTracking().OrderBy(x => x.Name).ToListAsync();
        await LoadAsync();
    }

    private async Task LoadAsync()
    {
        _loading = true;

        IQueryable<ServiceOffer> qBase = Db.ServiceOffers
            .AsNoTracking()
            .Include(x => x.OwnerUser)
            .Include(x => x.Category);

        if (_categoryId.HasValue)
            qBase = qBase.Where(x => x.CategoryId == _categoryId.Value);

        var s = (_search ?? "").Trim();
        if (!string.IsNullOrWhiteSpace(s))
            qBase = qBase.Where(x => x.Title.Contains(s) || x.Description.Contains(s));

        if (_minPrice.HasValue)
            qBase = qBase.Where(x => x.Price >= _minPrice.Value);

        if (_maxPrice.HasValue)
            qBase = qBase.Where(x => x.Price <= _maxPrice.Value);

        var q = qBase.Select(x => new ServiceCardVm
            {
                Id = x.Id,
                Title = x.Title,
                Description = x.Description,
                Price = x.Price,
                CreatedAt = x.CreatedAt,
                OwnerUser = x.OwnerUser,
                Category = x.Category,
                ReviewsCount = Db.Reviews.Count(r => r.TargetUserId == x.OwnerUserId),
                RatingAvg = (Db.Reviews.Where(r => r.TargetUserId == x.OwnerUserId).Select(r => (double?)r.Stars).Average() ?? 0)
            });

        if (_onlyWithReviews)
            q = q.Where(x => x.ReviewsCount > 0);

        if (_minRating > 0)
            q = q.Where(x => x.RatingAvg >= _minRating);

        q = _sort switch
        {
            "price_asc" => q.OrderBy(x => x.Price).ThenByDescending(x => x.CreatedAt),
            "price_desc" => q.OrderByDescending(x => x.Price).ThenByDescending(x => x.CreatedAt),
            "rating_desc" => q.OrderByDescending(x => x.RatingAvg).ThenByDescending(x => x.ReviewsCount).ThenByDescending(x => x.CreatedAt),
            "reviews_desc" => q.OrderByDescending(x => x.ReviewsCount).ThenByDescending(x => x.RatingAvg).ThenByDescending(x => x.CreatedAt),
            _ => q.OrderByDescending(x => x.CreatedAt)
        };

        _services = await q.Take(200).ToListAsync();

        _loading = false;
        StateHasChanged();
    }

    private async Task ResetAsync()
    {
        _search = "";
        _categoryId = null;
        _minPrice = null;
        _maxPrice = null;
        _minRating = 0;
        _onlyWithReviews = false;
        _sort = "new";
        await LoadAsync();
    }

    private async Task OnSearchChanged(string v) { _search = v ?? ""; await LoadAsync(); }
    private async Task OnSortChanged(string v) { _sort = string.IsNullOrWhiteSpace(v) ? "new" : v; await LoadAsync(); }
    private Task OnCategoryChanged(int? v) { _categoryId = v; return Task.CompletedTask; }
    private Task OnMinPriceChanged(decimal? v) { _minPrice = v; return Task.CompletedTask; }
    private Task OnMaxPriceChanged(decimal? v) { _maxPrice = v; return Task.CompletedTask; }
    private Task OnMinRatingChanged(int v) { _minRating = v; return Task.CompletedTask; }
    private Task OnOnlyWithReviewsChanged(bool v) { _onlyWithReviews = v; return Task.CompletedTask; }

    private static string Trim(string? s, int max)
        => string.IsNullOrWhiteSpace(s) ? "" : (s.Length <= max ? s : s.Substring(0, max) + "...");

    private static string DisplayName(ApplicationUser? u)
        => u is null ? "User"
           : (!string.IsNullOrWhiteSpace(u.DisplayName) ? u.DisplayName : (u.UserName ?? "User"));

    private static string Stars(double rating)
    {
        var full = (int)Math.Round(rating);
        full = Math.Clamp(full, 0, 5);
        return new string('★', full) + new string('☆', 5 - full);
    }

    private sealed class ServiceCardVm
    {
        public int Id { get; set; }
        public string Title { get; set; } = "";
        public string Description { get; set; } = "";
        public decimal Price { get; set; }
        public DateTime CreatedAt { get; set; }
        public ApplicationUser? OwnerUser { get; set; }
        public Category? Category { get; set; }
        public int ReviewsCount { get; set; }
        public double RatingAvg { get; set; }
    }
}