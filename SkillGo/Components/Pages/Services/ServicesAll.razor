@page "/services/category"

@using Microsoft.AspNetCore.Components
@using Microsoft.EntityFrameworkCore
@using MudBlazor
@using SkillGo.Data
@using SkillGo.Data.Models

@inject ApplicationDbContext Db

<PageTitle>Services</PageTitle>

<MudContainer MaxWidth="MaxWidth.False" Class="services-shell pa-0">
    <MudContainer MaxWidth="MaxWidth.ExtraLarge" Class="pt-6 pb-6">
        <MudPaper Class="hero-paper pa-6 pa-md-8" Elevation="0">
            <div class="hero-orb hero-orb-left"></div>
            <div class="hero-orb hero-orb-right"></div>

            <div class="hero-inner">
                <div class="hero-copy">
                    <div class="hero-badge">
                        <MudIcon Icon="@Icons.Material.Filled.TravelExplore" Size="Size.Small" />
                        <span>Explore the full marketplace</span>
                    </div>

                    <div class="hero-title mt-4">All services</div>
                    <div class="hero-sub">Search, filter and compare offers by category, price and rating.</div>
                </div>

                <div class="hero-controls mt-6">
                    <MudTextField T="string"
                                  Variant="Variant.Outlined"
                                  Placeholder="Search services..."
                                  Adornment="Adornment.Start"
                                  AdornmentIcon="@Icons.Material.Filled.Search"
                                  Immediate="true"
                                  DebounceInterval="350"
                                  Value="@_search"
                                  ValueChanged="OnSearchChanged"
                                  Class="search-control" />

                    <MudSelect T="string"
                               Variant="Variant.Outlined"
                               Placeholder="Sort"
                               Value="@_sort"
                               ValueChanged="OnSortChanged"
                               Class="sort-control">
                        <MudSelectItem T="string" Value="@("new")">Newest</MudSelectItem>
                        <MudSelectItem T="string" Value="@("price_asc")">Price: low to high</MudSelectItem>
                        <MudSelectItem T="string" Value="@("price_desc")">Price: high to low</MudSelectItem>
                        <MudSelectItem T="string" Value="@("rating_desc")">Rating: high to low</MudSelectItem>
                        <MudSelectItem T="string" Value="@("reviews_desc")">Most reviews</MudSelectItem>
                    </MudSelect>
                </div>

                <div class="hero-chips">
                    <span class="chip">Services: @_services.Count</span>

                    @if (_categoryId.HasValue)
                    {
                        <span class="chip">Category: @_categories.FirstOrDefault(x => x.Id == _categoryId)?.Name</span>
                    }
                    @if (_minPrice.HasValue)
                    {
                        <span class="chip">Min: @_minPrice.Value.ToString("0.##") zł</span>
                    }
                    @if (_maxPrice.HasValue)
                    {
                        <span class="chip">Max: @_maxPrice.Value.ToString("0.##") zł</span>
                    }
                    @if (_minRating > 0)
                    {
                        <span class="chip">Rating: @_minRating+</span>
                    }
                    @if (_onlyWithReviews)
                    {
                        <span class="chip">Only reviewed</span>
                    }
                </div>
            </div>
        </MudPaper>
    </MudContainer>

    <MudContainer MaxWidth="MaxWidth.ExtraLarge" Class="pb-8">
        <div class="layout">
            <aside class="filters-shell">
                <div class="filters-head">
                    <div>
                        <div class="filters-title">Filters</div>
                        <div class="filters-sub">Choose a category, price range and rating.</div>
                    </div>

                    <MudButton Variant="Variant.Text" Class="reset-btn" OnClick="@ResetAsync">
                        Reset
                    </MudButton>
                </div>

                <div class="filters-body">
                    <MudSelect T="int?"
                               Variant="Variant.Outlined"
                               Label="Category"
                               Value="@_categoryId"
                               ValueChanged="OnCategoryChanged"
                               FullWidth="true">
                        <MudSelectItem T="int?" Value="@(null)">All categories</MudSelectItem>
                        @foreach (var c in _categories)
                        {
                            <MudSelectItem T="int?" Value="@((int?)c.Id)">@c.Name</MudSelectItem>
                        }
                    </MudSelect>

                    <div class="two-cols">
                        <MudNumericField T="decimal?"
                                         Variant="Variant.Outlined"
                                         Label="Min price (zł)"
                                         Min="0"
                                         Value="@_minPrice"
                                         ValueChanged="OnMinPriceChanged" />

                        <MudNumericField T="decimal?"
                                         Variant="Variant.Outlined"
                                         Label="Max price (zł)"
                                         Min="0"
                                         Value="@_maxPrice"
                                         ValueChanged="OnMaxPriceChanged" />
                    </div>

                    <MudSelect T="int"
                               Variant="Variant.Outlined"
                               Label="Min rating"
                               Value="@_minRating"
                               ValueChanged="OnMinRatingChanged"
                               FullWidth="true">
                        <MudSelectItem T="int" Value="0">Any</MudSelectItem>
                        <MudSelectItem T="int" Value="1">1+</MudSelectItem>
                        <MudSelectItem T="int" Value="2">2+</MudSelectItem>
                        <MudSelectItem T="int" Value="3">3+</MudSelectItem>
                        <MudSelectItem T="int" Value="4">4+</MudSelectItem>
                        <MudSelectItem T="int" Value="5">5</MudSelectItem>
                    </MudSelect>

                    <div class="switch-shell">
                        <MudSwitch T="bool"
                                   Color="Color.Primary"
                                   Label="Only with reviews"
                                   Checked="@_onlyWithReviews"
                                   CheckedChanged="OnOnlyWithReviewsChanged" />
                    </div>

                    <MudButton Variant="Variant.Filled"
                               Color="Color.Primary"
                               FullWidth="true"
                               Class="btn-strong"
                               OnClick="@LoadAsync">
                        Apply filters
                    </MudButton>
                </div>
            </aside>

            <main class="results">
                @if (_loading)
                {
                    <MudGrid Spacing="3">
                        @for (int i = 0; i < 12; i++)
                        {
                            <MudItem xs="12" sm="6" md="4" lg="3">
                                <div class="service-card skeleton"></div>
                            </MudItem>
                        }
                    </MudGrid>
                }
                else if (_services.Count == 0)
                {
                    <div class="empty-shell">
                        <div class="empty-title">No services found</div>
                        <div class="empty-sub">Try changing your filters or search phrase.</div>
                    </div>
                }
                else
                {
                    <MudGrid Spacing="3">
                        @foreach (var s in _services)
                        {
                            <MudItem xs="12" sm="6" md="4" lg="3">
                                <MudLink Href="@($"/services/{s.Id}")" Class="card-link">
                                    <div class="service-card">
                                        <div class="card-top">
                                            <div class="card-title" title="@s.Title">@s.Title</div>

                                            <div class="pill-row">
                                                <div class="pill" title="@((s.Category?.Name) ?? "Category")">@((s.Category?.Name) ?? "Category")</div>
                                            </div>
                                        </div>

                                        <div class="card-desc">@Trim(s.Description, 120)</div>

                                        <div class="card-bottom">
                                            <div class="rating-row">
                                                <span class="stars">@Stars(s.RatingAvg)</span>
                                                <span class="rating-value">@s.RatingAvg.ToString("0.0")</span>
                                                <span class="reviews-count">(@s.ReviewsCount)</span>
                                            </div>

                                            <div class="price">@s.Price.ToString("0.##") zł</div>
                                        </div>

                                        <div class="card-user">
                                            <img class="avatar" src="@(s.OwnerUser?.AvatarUrl ?? "/images/default-avatar.png")" />
                                            <div class="user-name" title="@DisplayName(s.OwnerUser)">@DisplayName(s.OwnerUser)</div>
                                        </div>
                                    </div>
                                </MudLink>
                            </MudItem>
                        }
                    </MudGrid>
                }
            </main>
        </div>
    </MudContainer>
</MudContainer>

<style>
    .services-shell {
        min-height: calc(100vh - 64px);
        background:
            radial-gradient(circle at top left, rgba(124,58,237,.10), transparent 22%),
            radial-gradient(circle at top right, rgba(99,102,241,.08), transparent 24%),
            linear-gradient(180deg, #fbfaff 0%, #f7f4ff 42%, #ffffff 100%);
    }

    .hero-paper {
        position: relative;
        overflow: hidden;
        border-radius: 32px;
        background: linear-gradient(135deg, #2e1065 0%, #4c1d95 46%, #5b21b6 100%);
        border: 1px solid rgba(255,255,255,.08);
        box-shadow: 0 22px 60px rgba(76,29,149,.18);
    }

    .hero-orb {
        position: absolute;
        border-radius: 999px;
        filter: blur(6px);
        pointer-events: none;
    }

    .hero-orb-left {
        width: 260px;
        height: 260px;
        left: -60px;
        top: -40px;
        background: radial-gradient(circle, rgba(255,255,255,.16), transparent 68%);
    }

    .hero-orb-right {
        width: 320px;
        height: 320px;
        right: -90px;
        top: -90px;
        background: radial-gradient(circle, rgba(255,255,255,.12), transparent 70%);
    }

    .hero-inner {
        position: relative;
        z-index: 1;
    }

    .hero-copy {
        min-width: 0;
    }

    .hero-badge {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        padding: 8px 14px;
        border-radius: 999px;
        background: rgba(255,255,255,.10);
        border: 1px solid rgba(255,255,255,.14);
        color: #fff;
        font-size: 13px;
        font-weight: 700;
    }

    .hero-title {
        font-weight: 900;
        color: #fff;
        font-size: 2.5rem;
        line-height: 1.02;
        letter-spacing: -.03em;
    }

    .hero-sub {
        margin-top: 12px;
        color: rgba(255,255,255,.82);
        max-width: 720px;
        line-height: 1.75;
        font-size: 1rem;
    }

    .hero-controls {
        display: flex;
        gap: 14px;
        align-items: center;
        min-width: 0;
    }

    .search-control {
        flex: 1 1 auto;
        min-width: 0;
    }

    .sort-control {
        width: 300px;
        min-width: 220px;
        flex: 0 0 auto;
    }

    .search-control ::deep .mud-input-control,
    .sort-control ::deep .mud-input-control {
        margin-top: 0;
    }

    .search-control ::deep .mud-input-outlined-border,
    .sort-control ::deep .mud-input-outlined-border {
        border-color: rgba(255,255,255,.90) !important;
    }

    .search-control ::deep input,
    .search-control ::deep .mud-input-adornment,
    .sort-control ::deep input,
    .sort-control ::deep .mud-input-adornment,
    .sort-control ::deep .mud-select-input {
        color: #fff !important;
    }

    .search-control ::deep input::placeholder {
        color: rgba(255,255,255,.65) !important;
    }

    .sort-control ::deep .mud-select-input,
    .sort-control ::deep .mud-input-slot,
    .sort-control ::deep .mud-svg-icon {
        color: #fff !important;
    }

    .hero-chips {
        display: flex;
        flex-wrap: wrap;
        gap: 8px;
        margin-top: 18px;
    }

    .chip {
        display: inline-flex;
        align-items: center;
        min-height: 34px;
        padding: 6px 12px;
        border-radius: 999px;
        border: 1px solid rgba(255,255,255,.18);
        background: rgba(255,255,255,.10);
        color: #fff;
        font-weight: 800;
        font-size: .84rem;
        letter-spacing: .12px;
        backdrop-filter: blur(4px);
    }

    .layout {
        display: grid;
        grid-template-columns: 340px minmax(0,1fr);
        gap: 18px;
        align-items: start;
    }

    .filters-shell,
    .service-card,
    .empty-shell {
        border-radius: 26px;
        background: rgba(255,255,255,.94);
        border: 1px solid rgba(109,40,217,.10);
        box-shadow: 0 14px 38px rgba(88,28,135,.06);
    }

    .filters-shell {
        position: sticky;
        top: 92px;
        overflow: hidden;
    }

    .filters-head {
        padding: 20px 22px 18px 22px;
        border-bottom: 1px solid rgba(109,40,217,.08);
        display: flex;
        justify-content: space-between;
        gap: 12px;
        align-items: flex-start;
    }

    .filters-title {
        font-weight: 900;
        color: #1f1147;
        font-size: 1.08rem;
        letter-spacing: .2px;
    }

    .filters-sub {
        color: #6b5f8d;
        font-size: .94rem;
        margin-top: 4px;
        line-height: 1.4;
    }

    .reset-btn {
        font-weight: 900;
        letter-spacing: .2px;
    }

    .filters-body {
        padding: 18px 20px 20px 20px;
        display: grid;
        gap: 12px;
    }

    .two-cols {
        display: grid;
        grid-template-columns: minmax(0,1fr) minmax(0,1fr);
        gap: 10px;
    }

    .switch-shell {
        border-radius: 16px;
        border: 1px dashed rgba(109,40,217,.18);
        background: rgba(109,40,217,.04);
        padding: 4px 12px;
    }

    .btn-strong {
        border-radius: 14px;
        font-weight: 900;
        letter-spacing: .2px;
        padding: 10px 14px;
    }

    .results {
        min-width: 0;
    }

    .card-link {
        display: block;
        text-decoration: none !important;
        color: inherit !important;
        min-width: 0;
    }

    .card-link:hover,
    .card-link:focus,
    .card-link:active,
    .card-link * {
        text-decoration: none !important;
    }

    .service-card {
        min-height: 290px;
        height: 100%;
        padding: 18px;
        transition: transform .18s ease, box-shadow .18s ease, border-color .18s ease;
        display: flex;
        flex-direction: column;
        gap: 14px;
        min-width: 0;
        overflow: hidden;
    }

    .card-link:hover .service-card {
        transform: translateY(-6px);
        box-shadow: 0 22px 48px rgba(88,28,135,.10);
        border-color: rgba(109,40,217,.20);
    }

    .card-top {
        display: grid;
        gap: 10px;
        min-width: 0;
    }

    .card-title {
        font-weight: 900;
        color: #1f1147;
        font-size: 1.05rem;
        line-height: 1.22;
        min-width: 0;
        overflow: hidden;
        display: -webkit-box;
        -webkit-line-clamp: 2;
        -webkit-box-orient: vertical;
        word-break: break-word;
    }

    .pill-row {
        display: flex;
        min-width: 0;
        max-width: 100%;
    }

    .pill {
        max-width: 100%;
        display: inline-flex;
        align-items: center;
        min-height: 34px;
        padding: 6px 12px;
        border-radius: 999px;
        background: rgba(109,40,217,.08);
        border: 1px solid rgba(109,40,217,.16);
        color: #5b21b6;
        font-weight: 800;
        font-size: .84rem;
        overflow: hidden;
        text-overflow: ellipsis;
        white-space: nowrap;
    }

    .card-desc {
        color: #6b5f8d;
        font-size: .93rem;
        line-height: 1.4;
        flex: 1;
        min-width: 0;
        white-space: pre-wrap;
        overflow: hidden;
        display: -webkit-box;
        -webkit-line-clamp: 4;
        -webkit-box-orient: vertical;
        word-break: break-word;
    }

    .card-bottom {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 12px;
        min-width: 0;
        flex-wrap: wrap;
    }

    .rating-row {
        display: flex;
        align-items: center;
        gap: 6px;
        min-width: 0;
        flex: 1 1 auto;
        overflow: hidden;
    }

    .stars {
        font-weight: 900;
        letter-spacing: .45px;
        color: #1f1147;
        white-space: nowrap;
        flex: 0 0 auto;
    }

    .rating-value,
    .reviews-count {
        color: #6b5f8d;
        font-weight: 800;
        font-size: .9rem;
        white-space: nowrap;
        flex: 0 0 auto;
    }

    .price {
        font-weight: 900;
        color: #1f1147;
        white-space: nowrap;
        flex: 0 0 auto;
        font-size: 1rem;
    }

    .card-user {
        display: flex;
        align-items: center;
        gap: 10px;
        min-width: 0;
        padding-top: 2px;
    }

    .avatar {
        width: 38px;
        height: 38px;
        border-radius: 50%;
        object-fit: cover;
        border: 1px solid rgba(109,40,217,.12);
        flex: 0 0 auto;
        background: #fff;
    }

    .user-name {
        font-weight: 900;
        color: #1f1147;
        font-size: .93rem;
        min-width: 0;
        overflow: hidden;
        text-overflow: ellipsis;
        white-space: nowrap;
    }

    .empty-shell {
        padding: 36px 28px;
        text-align: center;
    }

    .empty-title {
        font-weight: 900;
        color: #1f1147;
        font-size: 1.14rem;
    }

    .empty-sub {
        color: #6b5f8d;
        margin-top: 8px;
        line-height: 1.4;
    }

    .skeleton {
        position: relative;
        overflow: hidden;
        min-height: 290px;
    }

    .skeleton::before {
        content: "";
        position: absolute;
        inset: 0;
        background: linear-gradient(90deg,#f3f4f6,#fafafa,#f3f4f6);
        background-size: 200% 100%;
        animation: shimmer 1.2s infinite linear;
    }

    @@keyframes shimmer {
        0% {
            background-position: 0% 0;
        }

        100% {
            background-position: 200% 0;
        }
    }

    @@media (max-width: 1280px) {
        .sort-control {
            width: 280px;
        }
    }

    @@media (max-width: 1200px) {
        .layout {
            grid-template-columns: 320px minmax(0,1fr);
        }
    }

    @@media (max-width: 992px) {
        .layout {
            grid-template-columns: minmax(0,1fr);
        }

        .filters-shell {
            position: static;
            top: auto;
        }

        .hero-controls {
            flex-direction: column;
            align-items: stretch;
        }

        .sort-control {
            width: 100%;
            min-width: 0;
        }

        .two-cols {
            grid-template-columns: minmax(0,1fr);
        }
    }

    @@media (max-width: 700px) {
        .hero-title {
            font-size: 2rem;
        }

        .hero-paper,
        .filters-shell,
        .service-card,
        .empty-shell {
            border-radius: 22px;
        }
    }

    @@media (max-width: 600px) {
        .hero-inner {
            padding: 0;
        }

        .card-bottom {
            align-items: flex-start;
            flex-direction: column;
        }

        .rating-row {
            width: 100%;
        }

        .pill {
            max-width: 140px;
        }
    }
</style>

@code {
    [SupplyParameterFromQuery]
    public string? Search { get; set; }

    private bool _loading = true;

    private List<Category> _categories = new();
    private List<ServiceCardVm> _services = new();

    private string _search = "";
    private int? _categoryId = null;
    private decimal? _minPrice = null;
    private decimal? _maxPrice = null;
    private int _minRating = 0;
    private bool _onlyWithReviews = false;
    private string _sort = "new";

    protected override async Task OnInitializedAsync()
    {
        _categories = await Db.Categories.AsNoTracking().OrderBy(x => x.Name).ToListAsync();
        _search = Search ?? "";
        await LoadAsync();
    }

    protected override async Task OnParametersSetAsync()
    {
        if ((Search ?? "") != _search)
        {
            _search = Search ?? "";
            await LoadAsync();
        }
    }

    private async Task LoadAsync()
    {
        _loading = true;

        IQueryable<ServiceOffer> qBase = Db.ServiceOffers
            .AsNoTracking()
            .Include(x => x.OwnerUser)
            .Include(x => x.Category);

        if (_categoryId.HasValue)
            qBase = qBase.Where(x => x.CategoryId == _categoryId.Value);

        var s = (_search ?? "").Trim();

        if (!string.IsNullOrWhiteSpace(s))
            qBase = qBase.Where(x =>
                x.Title.Contains(s) ||
                x.Description.Contains(s) ||
                (x.Category != null && x.Category.Name.Contains(s)));

        if (_minPrice.HasValue)
            qBase = qBase.Where(x => x.Price >= _minPrice.Value);

        if (_maxPrice.HasValue)
            qBase = qBase.Where(x => x.Price <= _maxPrice.Value);

        var q = qBase.Select(x => new ServiceCardVm
            {
                Id = x.Id,
                Title = x.Title,
                Description = x.Description,
                Price = x.Price,
                CreatedAt = x.CreatedAt,
                OwnerUser = x.OwnerUser,
                Category = x.Category,
                ReviewsCount = Db.Reviews.Count(r => r.TargetUserId == x.OwnerUserId),
                RatingAvg = Db.Reviews.Where(r => r.TargetUserId == x.OwnerUserId).Select(r => (double?)r.Stars).Average() ?? 0
            });

        if (_onlyWithReviews)
            q = q.Where(x => x.ReviewsCount > 0);

        if (_minRating > 0)
            q = q.Where(x => x.RatingAvg >= _minRating);

        q = _sort switch
        {
            "price_asc" => q.OrderBy(x => x.Price).ThenByDescending(x => x.CreatedAt),
            "price_desc" => q.OrderByDescending(x => x.Price).ThenByDescending(x => x.CreatedAt),
            "rating_desc" => q.OrderByDescending(x => x.RatingAvg).ThenByDescending(x => x.ReviewsCount).ThenByDescending(x => x.CreatedAt),
            "reviews_desc" => q.OrderByDescending(x => x.ReviewsCount).ThenByDescending(x => x.RatingAvg).ThenByDescending(x => x.CreatedAt),
            _ => q.OrderByDescending(x => x.CreatedAt)
        };

        _services = await q.Take(200).ToListAsync();

        _loading = false;
        StateHasChanged();
    }

    private async Task ResetAsync()
    {
        _search = "";
        _categoryId = null;
        _minPrice = null;
        _maxPrice = null;
        _minRating = 0;
        _onlyWithReviews = false;
        _sort = "new";
        await LoadAsync();
    }

    private async Task OnSearchChanged(string v)
    {
        _search = v ?? "";
        await LoadAsync();
    }

    private async Task OnSortChanged(string v)
    {
        _sort = string.IsNullOrWhiteSpace(v) ? "new" : v;
        await LoadAsync();
    }

    private Task OnCategoryChanged(int? v)
    {
        _categoryId = v;
        return Task.CompletedTask;
    }

    private Task OnMinPriceChanged(decimal? v)
    {
        _minPrice = v;
        return Task.CompletedTask;
    }

    private Task OnMaxPriceChanged(decimal? v)
    {
        _maxPrice = v;
        return Task.CompletedTask;
    }

    private Task OnMinRatingChanged(int v)
    {
        _minRating = v;
        return Task.CompletedTask;
    }

    private Task OnOnlyWithReviewsChanged(bool v)
    {
        _onlyWithReviews = v;
        return Task.CompletedTask;
    }

    private static string Trim(string? s, int max)
        => string.IsNullOrWhiteSpace(s) ? "" : (s.Length <= max ? s : s.Substring(0, max) + "...");

    private static string DisplayName(ApplicationUser? u)
        => u is null ? "User"
           : (!string.IsNullOrWhiteSpace(u.DisplayName) ? u.DisplayName : (u.UserName ?? "User"));

    private static string Stars(double rating)
    {
        var full = (int)Math.Round(rating);
        full = Math.Clamp(full, 0, 5);
        return new string('★', full) + new string('☆', 5 - full);
    }

    private sealed class ServiceCardVm
    {
        public int Id { get; set; }
        public string Title { get; set; } = "";
        public string Description { get; set; } = "";
        public decimal Price { get; set; }
        public DateTime CreatedAt { get; set; }
        public ApplicationUser? OwnerUser { get; set; }
        public Category? Category { get; set; }
        public int ReviewsCount { get; set; }
        public double RatingAvg { get; set; }
    }
}