@using System.Text.RegularExpressions
@using MudBlazor
@using SkillGo.Components.Pages.WalletPage

<MudDialog Class="wallet-dialog">
    <DialogContent>
        <div class="dialog-shell">
            <div class="dialog-hero">
                <div class="dialog-badge">
                    <MudIcon Icon="@Icons.Material.Filled.CreditCard" Size="Size.Small" />
                    <span>Secure payment</span>
                </div>

                <MudText Typo="Typo.h5" Class="dialog-title mt-4">Top up balance</MudText>
                <MudText Typo="Typo.body2" Class="dialog-sub mt-2">Pay by card and add funds to your wallet.</MudText>
            </div>

            <MudPaper Class="dialog-card pa-4 mt-4" Elevation="0">
                <MudStack Spacing="2">
                    <MudNumericField T="decimal"
                                     Label="Amount (zł)"
                                     Variant="Variant.Outlined"
                                     Min="1"
                                     Immediate="true"
                                     @bind-Value="_amount" />

                    <MudTextField Label="Card number"
                                  Variant="Variant.Outlined"
                                  Immediate="true"
                                  @bind-Value="_cardNumber"
                                  Placeholder="1234 5678 9012 3456" />

                    <MudGrid Spacing="2">
                        <MudItem xs="6">
                            <MudTextField Label="Expiry (MM/YY)"
                                          Variant="Variant.Outlined"
                                          Immediate="true"
                                          @bind-Value="_expiry"
                                          Placeholder="05/29" />
                        </MudItem>
                        <MudItem xs="6">
                            <MudTextField Label="CVC"
                                          Variant="Variant.Outlined"
                                          Immediate="true"
                                          @bind-Value="_cvc"
                                          Placeholder="123" />
                        </MudItem>
                    </MudGrid>

                    <MudTextField Label="Name on card"
                                  Variant="Variant.Outlined"
                                  Immediate="true"
                                  @bind-Value="_nameOnCard"
                                  Placeholder="JOHN DOE" />

                    @if (!string.IsNullOrWhiteSpace(_error))
                    {
                        <MudAlert Severity="Severity.Error" Variant="Variant.Outlined">@_error</MudAlert>
                    }

                    @if (_busy)
                    {
                        <MudProgressLinear Indeterminate="true" Class="mt-2" />
                        <MudText Typo="Typo.caption" Class="processing-text">Processing payment...</MudText>
                    }
                </MudStack>
            </MudPaper>
        </div>
    </DialogContent>

    <DialogActions>
        <div class="dialog-actions">
            <MudButton Variant="Variant.Text" Disabled="_busy" OnClick="Cancel" Class="dialog-btn">
                Cancel
            </MudButton>

            <MudButton Variant="Variant.Filled" Color="Color.Primary" Disabled="_busy" OnClick="PayAsync" Class="dialog-btn">
                @(_busy ? "Processing..." : "Pay")
            </MudButton>
        </div>
    </DialogActions>
</MudDialog>

<style>
    .dialog-shell {
        padding: 4px;
    }

    .dialog-hero {
        border-radius: 24px;
        background: linear-gradient(135deg, #2e1065 0%, #4c1d95 46%, #5b21b6 100%);
        color: #fff;
        border: 1px solid rgba(255,255,255,.10);
        box-shadow: 0 18px 42px rgba(76,29,149,.18);
        padding: 22px;
    }

    .dialog-badge {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        padding: 8px 14px;
        border-radius: 999px;
        background: rgba(255,255,255,.10);
        border: 1px solid rgba(255,255,255,.14);
        font-size: 13px;
        font-weight: 700;
    }

    .dialog-title {
        font-weight: 900;
        line-height: 1.05;
        letter-spacing: -.02em;
    }

    .dialog-sub {
        color: rgba(255,255,255,.82);
        line-height: 1.6;
    }

    .dialog-card {
        border-radius: 24px;
        background: rgba(255,255,255,.96);
        border: 1px solid rgba(109,40,217,.10);
        box-shadow: 0 14px 38px rgba(88,28,135,.06);
    }

    .dialog-actions {
        padding: 8px 24px 24px 24px;
        display: flex;
        justify-content: flex-end;
        gap: 10px;
        width: 100%;
    }

    .dialog-btn {
        border-radius: 14px;
        font-weight: 900;
        text-transform: none;
        padding: 10px 16px;
    }

    .processing-text {
        color: #6b5f8d;
    }
</style>

@code {
    [CascadingParameter] private IMudDialogInstance MudDialog { get; set; } = default!;

    [Parameter] public decimal? SuggestedAmount { get; set; }

    private decimal _amount = 1;
    private string _cardNumber = "";
    private string _expiry = "";
    private string _cvc = "";
    private string _nameOnCard = "";

    private bool _busy;
    private string? _error;

    protected override void OnInitialized()
    {
        if (SuggestedAmount.HasValue && SuggestedAmount.Value >= 1)
            _amount = SuggestedAmount.Value;
    }

    private void Cancel() => MudDialog.Cancel();

    private async Task PayAsync()
    {
        if (_busy) return;

        _error = null;

        if (_amount < 1)
        {
            _error = "Amount must be at least 1 zł.";
            return;
        }

        var digits = Regex.Replace(_cardNumber ?? "", "[^0-9]", "");
        if (digits.Length < 12 || digits.Length > 19)
        {
            _error = "Invalid card number.";
            return;
        }

        if (!Regex.IsMatch((_expiry ?? "").Trim(), "^(0[1-9]|1[0-2])\\/(\\d{2})$"))
        {
            _error = "Invalid expiry (use MM/YY).";
            return;
        }

        var cvcDigits = Regex.Replace(_cvc ?? "", "[^0-9]", "");
        if (cvcDigits.Length < 3 || cvcDigits.Length > 4)
        {
            _error = "Invalid CVC.";
            return;
        }

        if (string.IsNullOrWhiteSpace(_nameOnCard) || _nameOnCard.Trim().Length < 3)
        {
            _error = "Enter name on card.";
            return;
        }

        _busy = true;

        try
        {
            await Task.Delay(900);

            var last4 = digits.Length >= 4 ? digits[^4..] : "0000";

            MudDialog.Close(DialogResult.Ok(new TopUpDialogResult
            {
                Amount = _amount,
                Last4 = last4
            }));
        }
        finally
        {
            _busy = false;
        }
    }
}