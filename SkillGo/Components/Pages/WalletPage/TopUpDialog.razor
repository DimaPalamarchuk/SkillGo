@using System.Text.RegularExpressions
@using MudBlazor
@using SkillGo.Components.Pages.WalletPage

<MudDialog>
    <DialogContent>
        <MudStack Spacing="2">
            <MudText Typo="Typo.h6" Style="font-weight:900;">Top up balance</MudText>
            <MudText Typo="Typo.body2" Color="Color.Secondary">Pay by card</MudText>

            <MudNumericField T="decimal"
                             Label="Amount (zł)"
                             Variant="Variant.Outlined"
                             Min="1"
                             Immediate="true"
                             @bind-Value="_amount" />

            <MudTextField Label="Card number"
                          Variant="Variant.Outlined"
                          Immediate="true"
                          @bind-Value="_cardNumber"
                          Placeholder="1234 5678 9012 3456" />

            <MudGrid Spacing="2">
                <MudItem xs="6">
                    <MudTextField Label="Expiry (MM/YY)"
                                  Variant="Variant.Outlined"
                                  Immediate="true"
                                  @bind-Value="_expiry"
                                  Placeholder="05/29" />
                </MudItem>
                <MudItem xs="6">
                    <MudTextField Label="CVC"
                                  Variant="Variant.Outlined"
                                  Immediate="true"
                                  @bind-Value="_cvc"
                                  Placeholder="123" />
                </MudItem>
            </MudGrid>

            <MudTextField Label="Name on card"
                          Variant="Variant.Outlined"
                          Immediate="true"
                          @bind-Value="_nameOnCard"
                          Placeholder="JOHN DOE" />

            @if (!string.IsNullOrWhiteSpace(_error))
            {
                <MudText Color="Color.Error">@_error</MudText>
            }

            @if (_busy)
            {
                <MudProgressLinear Indeterminate="true" />
                <MudText Typo="Typo.caption" Color="Color.Secondary">Processing payment...</MudText>
            }
        </MudStack>
    </DialogContent>

    <DialogActions>
        <MudButton Variant="Variant.Text" Disabled="_busy" OnClick="Cancel">Cancel</MudButton>
        <MudButton Variant="Variant.Filled" Color="Color.Primary" Disabled="_busy" OnClick="PayAsync">
            @(_busy ? "Processing..." : "Pay")
        </MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] private IMudDialogInstance MudDialog { get; set; } = default!;

    [Parameter] public decimal? SuggestedAmount { get; set; }

    private decimal _amount = 1;
    private string _cardNumber = "";
    private string _expiry = "";
    private string _cvc = "";
    private string _nameOnCard = "";

    private bool _busy;
    private string? _error;

    protected override void OnInitialized()
    {
        if (SuggestedAmount.HasValue && SuggestedAmount.Value >= 1)
            _amount = SuggestedAmount.Value;
    }

    private void Cancel() => MudDialog.Cancel();

    private async Task PayAsync()
    {
        if (_busy) return;

        _error = null;

        if (_amount < 1)
        {
            _error = "Amount must be at least 1 zł.";
            return;
        }

        var digits = Regex.Replace(_cardNumber ?? "", "[^0-9]", "");
        if (digits.Length < 12 || digits.Length > 19)
        {
            _error = "Invalid card number.";
            return;
        }

        if (!Regex.IsMatch((_expiry ?? "").Trim(), "^(0[1-9]|1[0-2])\\/(\\d{2})$"))
        {
            _error = "Invalid expiry (use MM/YY).";
            return;
        }

        var cvcDigits = Regex.Replace(_cvc ?? "", "[^0-9]", "");
        if (cvcDigits.Length < 3 || cvcDigits.Length > 4)
        {
            _error = "Invalid CVC.";
            return;
        }

        if (string.IsNullOrWhiteSpace(_nameOnCard) || _nameOnCard.Trim().Length < 3)
        {
            _error = "Enter name on card.";
            return;
        }

        _busy = true;

        try
        {
            await Task.Delay(900);

            var last4 = digits.Length >= 4 ? digits[^4..] : "0000";

            MudDialog.Close(DialogResult.Ok(new TopUpDialogResult
                {
                    Amount = _amount,
                    Last4 = last4
                }));
        }
        finally
        {
            _busy = false;
        }
    }
}