@page "/wallet"
@attribute [Microsoft.AspNetCore.Authorization.Authorize]
@using MudBlazor
@using SkillGo.Data
@using SkillGo.Data.Models
@using SkillGo.Repository.IRepository
@using System.Security.Claims
@using Microsoft.EntityFrameworkCore
@using SkillGo.Components.Pages.WalletPage
@inject AuthenticationStateProvider AuthStateProvider
@inject IWalletRepository WalletRepo
@inject SkillGo.Repository.WalletState WalletState
@inject IDialogService DialogService
@inject ISnackbar Snackbar
@inject IDbContextFactory<ApplicationDbContext> DbFactory

<PageTitle>Wallet</PageTitle>

<MudContainer MaxWidth="MaxWidth.Large" Class="py-6">
    <MudGrid Spacing="3">
        <MudItem xs="12">
            <MudStack Direction="Row" AlignItems="AlignItems.Center" JustifyContent="JustifyContent.SpaceBetween">
                <MudStack Spacing="0">
                    <MudText Typo="Typo.h4" Class="fw-bold">Wallet</MudText>
                    <MudText Color="Color.Secondary">Your balance and transactions</MudText>
                </MudStack>

                <MudStack Direction="Row" Spacing="2">
                    <MudButton Variant="Variant.Outlined" Color="Color.Inherit" OnClick="RefreshAsync" Disabled="_loading">
                        Refresh
                    </MudButton>

                    <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="OpenTopUpAsync" Disabled="_loading">
                        Top up
                    </MudButton>
                </MudStack>
            </MudStack>
        </MudItem>

        <MudItem xs="12" md="5" lg="4">
            <MudPaper Elevation="0" Class="p-5 sg-card">
                <MudText Typo="Typo.subtitle2" Class="text-muted">Current balance</MudText>

                @if (!_loadedOnce)
                {
                    <MudText Typo="Typo.h3" Class="fw-bold mt-2">—</MudText>
                }
                else
                {
                    <MudText Typo="Typo.h3" Class="fw-bold mt-2">@($"{_balance:0.##} zł")</MudText>
                }

                <MudDivider Class="my-4" />

                <MudStack Spacing="2">
                    <MudButton Variant="Variant.Outlined" Color="Color.Inherit" OnClick="OpenWithdrawAsync" Disabled="_loading || _balance <= 0">
                        Withdraw to card
                    </MudButton>
                </MudStack>
            </MudPaper>
        </MudItem>

        <MudItem xs="12" md="7" lg="8">
            <MudPaper Elevation="0" Class="p-5 sg-card">
                <MudStack Direction="Row" AlignItems="AlignItems.Center" JustifyContent="JustifyContent.SpaceBetween">
                    <MudStack Spacing="0">
                        <MudText Typo="Typo.h6" Class="fw-bold">Transactions</MudText>
                        <MudText Typo="Typo.body2" Class="text-muted">Only your transactions are shown</MudText>
                    </MudStack>
                </MudStack>

                <MudDivider Class="my-4" />

                @if (_tx.Count == 0)
                {
                    <MudText Class="text-muted">No transactions yet</MudText>
                }
                else
                {
                    <div class="tx-list">
                        @foreach (var tx in _tx)
                        {
                            <div class="tx-item">
                                <div class="tx-item-left">
                                    <div class="tx-item-top">
                                        <MudChip T="string" Size="Size.Small" Variant="Variant.Filled" Color="@GetTypeColor(tx.Type)">
                                            @FormatType(tx.Type)
                                        </MudChip>

                                        <div class="tx-date">@tx.CreatedAt.ToLocalTime().ToString("yyyy-MM-dd HH:mm")</div>
                                    </div>

                                    <div class="tx-note">@tx.Note</div>
                                </div>

                                <div class="tx-amount">@($"{tx.Amount:0.##} zł")</div>
                            </div>
                        }
                    </div>

                    <div class="tx-pagination">
                        <MudPagination Count="@_totalPages"
                                       Selected="@_page"
                                       SelectedChanged="OnPageChanged"
                                       Color="Color.Primary"
                                       Variant="Variant.Outlined" />
                    </div>
                }
            </MudPaper>
        </MudItem>
    </MudGrid>
</MudContainer>

<style>
    .sg-card {
        border: 1px solid rgba(0,0,0,.08);
        border-radius: 18px;
        background: white;
    }

    .tx-list {
        display: flex;
        flex-direction: column;
        gap: 12px;
    }

    .tx-item {
        display: flex;
        align-items: flex-start;
        justify-content: space-between;
        gap: 14px;
        padding: 16px;
        border-radius: 18px;
        border: 1px solid rgba(0,0,0,.06);
        background: #fff;
    }

    .tx-item-left {
        min-width: 0;
        flex: 1 1 auto;
    }

    .tx-item-top {
        display: flex;
        align-items: center;
        gap: 10px;
        flex-wrap: wrap;
    }

    .tx-date {
        color: rgba(17,24,39,.56);
        font-size: .88rem;
        font-weight: 700;
    }

    .tx-note {
        margin-top: 8px;
        color: #111827;
        line-height: 1.4;
        word-break: break-word;
    }

    .tx-amount {
        flex: 0 0 auto;
        font-weight: 900;
        color: #111827;
        white-space: nowrap;
    }

    .tx-pagination {
        margin-top: 20px;
        display: flex;
        justify-content: center;
    }

    @@media (max-width: 760px) {
        .tx-item {
            flex-direction: column;
        }

        .tx-amount {
            width: 100%;
        }
    }
</style>

@code {
    private bool _loading;
    private bool _loadedOnce;
    private decimal _balance;
    private List<WalletTransaction> _tx = new();

    private int _page = 1;
    private int _pageSize = 10;
    private int _totalItems;
    private int _totalPages = 1;

    protected override async Task OnInitializedAsync()
    {
        await RefreshAsync();
    }

    private async Task<string?> GetUserIdAsync()
    {
        var auth = await AuthStateProvider.GetAuthenticationStateAsync();
        return auth.User.FindFirstValue(ClaimTypes.NameIdentifier);
    }

    private async Task RefreshAsync()
    {
        if (_loading) return;
        _loading = true;

        try
        {
            var userId = await GetUserIdAsync();
            if (string.IsNullOrWhiteSpace(userId))
            {
                _balance = 0m;
                _tx = new();
                _loadedOnce = true;
                return;
            }

            _balance = await WalletRepo.GetBalanceAsync(userId);

            await using var db = await DbFactory.CreateDbContextAsync();

            var query = db.WalletTransactions
                .AsNoTracking()
                .Where(x => x.UserId == userId);

            _totalItems = await query.CountAsync();
            _totalPages = Math.Max(1, (int)Math.Ceiling(_totalItems / (double)_pageSize));

            if (_page > _totalPages)
                _page = _totalPages;

            _tx = await query
                .OrderByDescending(x => x.CreatedAt)
                .Skip((_page - 1) * _pageSize)
                .Take(_pageSize)
                .ToListAsync();

            _loadedOnce = true;
        }
        finally
        {
            _loading = false;
        }
    }

    private async Task OnPageChanged(int page)
    {
        _page = page;
        await RefreshAsync();
    }

    private async Task OpenTopUpAsync()
    {
        var options = new DialogOptions { CloseButton = true, MaxWidth = MaxWidth.Small, FullWidth = true };
        var dialog = DialogService.Show<TopUpDialog>("Top up balance", new DialogParameters(), options);
        var result = await dialog.Result;

        if (result.Canceled) return;
        if (result.Data is not TopUpDialogResult data) return;

        var userId = await GetUserIdAsync();
        if (string.IsNullOrWhiteSpace(userId)) return;

        _loading = true;

        try
        {
            var note = $"Top up via card **** {data.Last4}";
            await WalletRepo.TopUpAsync(userId, data.Amount, note);

            _page = 1;

            await WalletState.RefreshAsync();
            await RefreshAsync();

            Snackbar.Add($"Top up successful: {data.Amount:0.##} zł", Severity.Success);
        }
        catch
        {
            Snackbar.Add("Top up failed", Severity.Error);
        }
        finally
        {
            _loading = false;
        }
    }

    private async Task OpenWithdrawAsync()
    {
        var options = new DialogOptions { CloseButton = true, MaxWidth = MaxWidth.Small, FullWidth = true };
        var parameters = new DialogParameters
            {
                ["MaxAmount"] = _balance
            };

        var dialog = DialogService.Show<WithdrawDialog>("Withdraw to card", parameters, options);
        var result = await dialog.Result;

        if (result.Canceled) return;
        if (result.Data is not WithdrawDialogResult data) return;

        var userId = await GetUserIdAsync();
        if (string.IsNullOrWhiteSpace(userId)) return;

        _loading = true;

        try
        {
            var note = $"Withdrawal to card **** {data.Last4}";
            await WalletRepo.WithdrawAsync(userId, data.Amount, note);

            _page = 1;

            await WalletState.RefreshAsync();
            await RefreshAsync();

            Snackbar.Add($"Withdrawal requested: {data.Amount:0.##} zł", Severity.Success);
        }
        catch (Exception ex)
        {
            Snackbar.Add(ex.Message, Severity.Error);
        }
        finally
        {
            _loading = false;
        }
    }

    private static string FormatType(WalletTransactionType type)
    {
        return type switch
        {
            WalletTransactionType.TopUp => "Top up",
            WalletTransactionType.Debit => "Payment",
            WalletTransactionType.Refund => "Refund",
            WalletTransactionType.OrderIncome => "Order income",
            WalletTransactionType.Withdrawal => "Withdrawal",
            _ => type.ToString()
        };
    }

    private static Color GetTypeColor(WalletTransactionType type)
    {
        return type switch
        {
            WalletTransactionType.TopUp => Color.Success,
            WalletTransactionType.Debit => Color.Error,
            WalletTransactionType.Refund => Color.Warning,
            WalletTransactionType.OrderIncome => Color.Info,
            WalletTransactionType.Withdrawal => Color.Secondary,
            _ => Color.Default
        };
    }
}