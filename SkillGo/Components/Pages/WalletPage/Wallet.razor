@page "/wallet"
@attribute [Microsoft.AspNetCore.Authorization.Authorize]
@using MudBlazor
@using SkillGo.Data
@using SkillGo.Data.Models
@using SkillGo.Repository.IRepository
@using System.Security.Claims
@using Microsoft.EntityFrameworkCore
@using SkillGo.Components.Pages.WalletPage
@inject AuthenticationStateProvider AuthStateProvider
@inject IWalletRepository WalletRepo
@inject SkillGo.Repository.WalletState WalletState
@inject IDialogService DialogService
@inject ISnackbar Snackbar
@inject IDbContextFactory<ApplicationDbContext> DbFactory

<PageTitle>Wallet</PageTitle>

<MudContainer MaxWidth="MaxWidth.False" Class="wallet-shell pa-0">
    <MudContainer MaxWidth="MaxWidth.ExtraLarge" Class="pt-6 pb-8">
        <MudPaper Class="wallet-hero pa-6 pa-md-8" Elevation="0">
            <MudGrid Spacing="3" AlignItems="AlignItems.Stretch">
                <MudItem xs="12" md="8">
                    <div class="hero-badge">
                        <MudIcon Icon="@Icons.Material.Filled.AccountBalanceWallet" Size="Size.Small" />
                        <span>Your balance and transactions</span>
                    </div>

                    <MudText Typo="Typo.h3" Class="hero-title mt-4">Wallet</MudText>
                    <MudText Typo="Typo.body1" Class="hero-sub mt-4">
                        Manage balance, add funds and review all wallet activity in one place.
                    </MudText>

                    <MudStack Row="true" Spacing="2" Class="mt-5 hero-actions">
                        <MudButton Variant="Variant.Outlined"
                                   Color="Color.Inherit"
                                   OnClick="RefreshAsync"
                                   Disabled="_loading"
                                   Class="btn-soft">
                            Refresh
                        </MudButton>

                        <MudButton Variant="Variant.Filled"
                                   Color="Color.Primary"
                                   OnClick="OpenTopUpAsync"
                                   Disabled="_loading"
                                   Class="btn-strong">
                            Top up
                        </MudButton>
                    </MudStack>
                </MudItem>

                <MudItem xs="12" md="4">
                    <MudPaper Elevation="0" Class="hero-side pa-5 h-100">
                        <MudText Typo="Typo.subtitle2" Class="balance-label">Current balance</MudText>

                        @if (!_loadedOnce)
                        {
                            <MudText Typo="Typo.h3" Class="balance-value mt-2">—</MudText>
                        }
                        else
                        {
                            <MudText Typo="Typo.h3" Class="balance-value mt-2">@($"{_balance:0.##} zł")</MudText>
                        }

                        <MudDivider Class="my-4" />

                        <MudStack Spacing="2">
                            <MudButton Variant="Variant.Outlined"
                                       Color="Color.Primary"
                                       OnClick="OpenWithdrawAsync"
                                       Disabled="_loading || _balance <= 0"
                                       Class="btn-strong">
                                Withdraw to card
                            </MudButton>
                        </MudStack>
                    </MudPaper>
                </MudItem>
            </MudGrid>
        </MudPaper>

        <MudGrid Spacing="3" Class="mt-4">
            <MudItem xs="12">
                <MudPaper Elevation="0" Class="wallet-card pa-5">
                    <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween" Wrap="Wrap.Wrap">
                        <MudStack Spacing="0">
                            <MudText Typo="Typo.h6" Class="section-title">Transactions</MudText>
                            <MudText Typo="Typo.body2" Class="section-sub">Only your transactions are shown</MudText>
                        </MudStack>
                    </MudStack>

                    <MudDivider Class="my-4" />

                    @if (_tx.Count == 0)
                    {
                        <MudText Class="section-sub">No transactions yet</MudText>
                    }
                    else
                    {
                        <div class="tx-list">
                            @foreach (var tx in _tx)
                            {
                                <div class="tx-item">
                                    <div class="tx-item-left">
                                        <div class="tx-item-top">
                                            <MudChip T="string" Size="Size.Small" Variant="Variant.Filled" Color="@GetTypeColor(tx.Type)">
                                                @FormatType(tx.Type)
                                            </MudChip>

                                            <div class="tx-date">@tx.CreatedAt.ToLocalTime().ToString("yyyy-MM-dd HH:mm")</div>
                                        </div>

                                        <div class="tx-note">@tx.Note</div>
                                    </div>

                                    <div class="tx-amount">@($"{tx.Amount:0.##} zł")</div>
                                </div>
                            }
                        </div>

                        <div class="tx-pagination">
                            <MudPagination Count="@_totalPages"
                                           Selected="@_page"
                                           SelectedChanged="OnPageChanged"
                                           Color="Color.Primary"
                                           Variant="Variant.Outlined" />
                        </div>
                    }
                </MudPaper>
            </MudItem>
        </MudGrid>
    </MudContainer>
</MudContainer>

<style>
    .wallet-shell {
        min-height: calc(100vh - 78px);
        background:
            radial-gradient(circle at top left, rgba(124,58,237,.10), transparent 22%),
            radial-gradient(circle at top right, rgba(99,102,241,.08), transparent 24%),
            linear-gradient(180deg, #fbfaff 0%, #f7f4ff 42%, #ffffff 100%);
    }

    .wallet-hero {
        border-radius: 32px;
        background: linear-gradient(135deg, #2e1065 0%, #4c1d95 46%, #5b21b6 100%);
        color: #fff;
        border: 1px solid rgba(255,255,255,.10);
        box-shadow: 0 22px 60px rgba(76,29,149,.18);
    }

    .hero-badge {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        padding: 8px 14px;
        border-radius: 999px;
        background: rgba(255,255,255,.10);
        border: 1px solid rgba(255,255,255,.14);
        font-size: 13px;
        font-weight: 700;
    }

    .hero-title {
        font-weight: 900;
        line-height: 1.02;
        letter-spacing: -.03em;
    }

    .hero-sub {
        color: rgba(255,255,255,.82);
        line-height: 1.8;
        font-size: 16px;
        max-width: 760px;
    }

    .hero-actions {
        flex-wrap: wrap;
    }

    .hero-side,
    .wallet-card {
        border-radius: 26px;
        background: rgba(255,255,255,.94);
        border: 1px solid rgba(109,40,217,.10);
        box-shadow: 0 14px 38px rgba(88,28,135,.06);
    }

    .balance-label,
    .section-sub,
    .tx-date {
        color: #6b5f8d;
    }

    .balance-value,
    .section-title,
    .tx-amount {
        color: #1f1147;
        font-weight: 900;
    }

    .btn-strong,
    .btn-soft {
        border-radius: 14px;
        font-weight: 900;
        letter-spacing: .2px;
        padding: 10px 14px;
        text-transform: none;
    }

    .btn-soft {
        color: #fff !important;
        border-color: rgba(255,255,255,.24) !important;
        background: rgba(255,255,255,.08) !important;
    }

    .tx-list {
        display: flex;
        flex-direction: column;
        gap: 12px;
    }

    .tx-item {
        display: flex;
        align-items: flex-start;
        justify-content: space-between;
        gap: 14px;
        padding: 16px;
        border-radius: 18px;
        border: 1px solid rgba(109,40,217,.08);
        background: linear-gradient(180deg, #faf7ff 0%, #ffffff 100%);
    }

    .tx-item-left {
        min-width: 0;
        flex: 1 1 auto;
    }

    .tx-item-top {
        display: flex;
        align-items: center;
        gap: 10px;
        flex-wrap: wrap;
    }

    .tx-date {
        font-size: .88rem;
        font-weight: 700;
    }

    .tx-note {
        margin-top: 8px;
        color: #1f1147;
        line-height: 1.45;
        word-break: break-word;
    }

    .tx-amount {
        flex: 0 0 auto;
        white-space: nowrap;
    }

    .tx-pagination {
        margin-top: 20px;
        display: flex;
        justify-content: center;
    }

    @@media (max-width: 760px) {
        .tx-item {
            flex-direction: column;
        }

        .tx-amount {
            width: 100%;
        }
    }

    @@media (max-width: 700px) {
        .wallet-hero,
        .hero-side,
        .wallet-card {
            border-radius: 22px;
        }

        .hero-title {
            font-size: 2rem !important;
        }

        .hero-actions {
            flex-direction: column !important;
            align-items: stretch !important;
        }
    }
</style>

@code {
    private bool _loading;
    private bool _loadedOnce;
    private decimal _balance;
    private List<WalletTransaction> _tx = new();

    private int _page = 1;
    private int _pageSize = 10;
    private int _totalItems;
    private int _totalPages = 1;

    protected override async Task OnInitializedAsync()
    {
        await RefreshAsync();
    }

    private async Task<string?> GetUserIdAsync()
    {
        var auth = await AuthStateProvider.GetAuthenticationStateAsync();
        return auth.User.FindFirstValue(ClaimTypes.NameIdentifier);
    }

    private async Task RefreshAsync()
    {
        if (_loading) return;
        _loading = true;

        try
        {
            var userId = await GetUserIdAsync();
            if (string.IsNullOrWhiteSpace(userId))
            {
                _balance = 0m;
                _tx = new();
                _loadedOnce = true;
                return;
            }

            _balance = await WalletRepo.GetBalanceAsync(userId);

            await using var db = await DbFactory.CreateDbContextAsync();

            var query = db.WalletTransactions
                .AsNoTracking()
                .Where(x => x.UserId == userId);

            _totalItems = await query.CountAsync();
            _totalPages = Math.Max(1, (int)Math.Ceiling(_totalItems / (double)_pageSize));

            if (_page > _totalPages)
                _page = _totalPages;

            _tx = await query
                .OrderByDescending(x => x.CreatedAt)
                .Skip((_page - 1) * _pageSize)
                .Take(_pageSize)
                .ToListAsync();

            _loadedOnce = true;
        }
        finally
        {
            _loading = false;
        }
    }

    private async Task OnPageChanged(int page)
    {
        _page = page;
        await RefreshAsync();
    }

    private async Task OpenTopUpAsync()
    {
        var options = new DialogOptions { CloseButton = true, MaxWidth = MaxWidth.Small, FullWidth = true };
        var dialog = DialogService.Show<TopUpDialog>("Top up balance", new DialogParameters(), options);
        var result = await dialog.Result;

        if (result.Canceled) return;
        if (result.Data is not TopUpDialogResult data) return;

        var userId = await GetUserIdAsync();
        if (string.IsNullOrWhiteSpace(userId)) return;

        _loading = true;

        try
        {
            var note = $"Top up via card **** {data.Last4}";
            await WalletRepo.TopUpAsync(userId, data.Amount, note);

            _page = 1;

            await WalletState.RefreshAsync();
            await RefreshAsync();

            Snackbar.Add($"Top up successful: {data.Amount:0.##} zł", Severity.Success);
        }
        catch
        {
            Snackbar.Add("Top up failed", Severity.Error);
        }
        finally
        {
            _loading = false;
        }
    }

    private async Task OpenWithdrawAsync()
    {
        var options = new DialogOptions { CloseButton = true, MaxWidth = MaxWidth.Small, FullWidth = true };
        var parameters = new DialogParameters
        {
            ["MaxAmount"] = _balance
        };

        var dialog = DialogService.Show<WithdrawDialog>("Withdraw to card", parameters, options);
        var result = await dialog.Result;

        if (result.Canceled) return;
        if (result.Data is not WithdrawDialogResult data) return;

        var userId = await GetUserIdAsync();
        if (string.IsNullOrWhiteSpace(userId)) return;

        _loading = true;

        try
        {
            var note = $"Withdrawal to card **** {data.Last4}";
            await WalletRepo.WithdrawAsync(userId, data.Amount, note);

            _page = 1;

            await WalletState.RefreshAsync();
            await RefreshAsync();

            Snackbar.Add($"Withdrawal requested: {data.Amount:0.##} zł", Severity.Success);
        }
        catch (Exception ex)
        {
            Snackbar.Add(ex.Message, Severity.Error);
        }
        finally
        {
            _loading = false;
        }
    }

    private static string FormatType(WalletTransactionType type)
    {
        return type switch
        {
            WalletTransactionType.TopUp => "Top up",
            WalletTransactionType.Debit => "Payment",
            WalletTransactionType.Refund => "Refund",
            WalletTransactionType.OrderIncome => "Order income",
            WalletTransactionType.Withdrawal => "Withdrawal",
            _ => type.ToString()
        };
    }

    private static Color GetTypeColor(WalletTransactionType type)
    {
        return type switch
        {
            WalletTransactionType.TopUp => Color.Success,
            WalletTransactionType.Debit => Color.Error,
            WalletTransactionType.Refund => Color.Warning,
            WalletTransactionType.OrderIncome => Color.Info,
            WalletTransactionType.Withdrawal => Color.Secondary,
            _ => Color.Default
        };
    }
}