@using MudBlazor
@using SkillGo.Components.Pages.WalletPage

<MudDialog>
    <DialogContent>
        <MudStack Spacing="2">
            <MudText Typo="Typo.h6" Class="fw-bold">Withdraw to card</MudText>
            <MudText Typo="Typo.body2" Color="Color.Secondary">Funds usually arrive within 1–3 business days</MudText>

            <MudNumericField T="decimal"
                             Label="Amount (zł)"
                             Variant="Variant.Outlined"
                             Min="1"
                             Immediate="true"
                             @bind-Value="_amount" />

            <MudTextField @bind-Value="_cardholderName"
                          Label="Cardholder name"
                          Variant="Variant.Outlined"
                          Immediate="true" />

            <MudTextField @bind-Value="_cardNumber"
                          Label="Card number"
                          Variant="Variant.Outlined"
                          Immediate="true" />

            <MudTextField @bind-Value="_expiry"
                          Label="Expiry (MM/YY)"
                          Variant="Variant.Outlined"
                          Immediate="true" />
        </MudStack>
    </DialogContent>

    <DialogActions>
        <MudButton Variant="Variant.Text" Color="Color.Default" OnClick="Cancel">Cancel</MudButton>
        <MudButton Variant="Variant.Filled" Color="Color.Primary" Disabled="@(!CanSubmit)" OnClick="Submit">
            Withdraw
        </MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] public IMudDialogInstance MudDialog { get; set; } = default!;
    [Parameter] public decimal MaxAmount { get; set; }

    decimal _amount;
    string _cardholderName = "";
    string _cardNumber = "";
    string _expiry = "";

    bool CanSubmit =>
        _amount > 0 &&
        _amount <= MaxAmount &&
        !string.IsNullOrWhiteSpace(_cardholderName) &&
        DigitsOnly(_cardNumber).Length >= 12 &&
        !string.IsNullOrWhiteSpace(_expiry);

    void Cancel()
    {
        MudDialog.Cancel();
    }

    void Submit()
    {
        var digits = DigitsOnly(_cardNumber);
        var last4 = digits.Length >= 4 ? digits[^4..] : digits;

        MudDialog.Close(DialogResult.Ok(new WithdrawDialogResult
            {
                Amount = _amount,
                Last4 = last4,
                CardholderName = _cardholderName.Trim()
            }));
    }

    static string DigitsOnly(string? value)
    {
        if (string.IsNullOrWhiteSpace(value))
            return "";

        return new string(value.Where(char.IsDigit).ToArray());
    }
}