@using MudBlazor
@using SkillGo.Components.Pages.WalletPage

<MudDialog Class="wallet-dialog">
    <DialogContent>
        <div class="dialog-shell">
            <div class="dialog-hero">
                <div class="dialog-badge">
                    <MudIcon Icon="@Icons.Material.Filled.Payments" Size="Size.Small" />
                    <span>Withdraw funds</span>
                </div>

                <MudText Typo="Typo.h5" Class="dialog-title mt-4">Withdraw to card</MudText>
                <MudText Typo="Typo.body2" Class="dialog-sub mt-2">Funds usually arrive within 1–3 business days.</MudText>
            </div>

            <MudPaper Class="dialog-card pa-4 mt-4" Elevation="0">
                <MudStack Spacing="2">
                    <MudNumericField T="decimal"
                                     Label="Amount (zł)"
                                     Variant="Variant.Outlined"
                                     Min="1"
                                     Immediate="true"
                                     @bind-Value="_amount" />

                    <MudTextField @bind-Value="_cardholderName"
                                  Label="Cardholder name"
                                  Variant="Variant.Outlined"
                                  Immediate="true" />

                    <MudTextField @bind-Value="_cardNumber"
                                  Label="Card number"
                                  Variant="Variant.Outlined"
                                  Immediate="true" />

                    <MudTextField @bind-Value="_expiry"
                                  Label="Expiry (MM/YY)"
                                  Variant="Variant.Outlined"
                                  Immediate="true" />

                    <MudText Typo="Typo.caption" Class="limit-text">
                        Available for withdrawal: @MaxAmount.ToString("0.##") zł
                    </MudText>
                </MudStack>
            </MudPaper>
        </div>
    </DialogContent>

    <DialogActions>
        <div class="dialog-actions">
            <MudButton Variant="Variant.Text" Color="Color.Default" OnClick="Cancel" Class="dialog-btn">
                Cancel
            </MudButton>

            <MudButton Variant="Variant.Filled" Color="Color.Primary" Disabled="@(!CanSubmit)" OnClick="Submit" Class="dialog-btn">
                Withdraw
            </MudButton>
        </div>
    </DialogActions>
</MudDialog>

<style>
    .dialog-shell {
        padding: 4px;
    }

    .dialog-hero {
        border-radius: 24px;
        background: linear-gradient(135deg, #2e1065 0%, #4c1d95 46%, #5b21b6 100%);
        color: #fff;
        border: 1px solid rgba(255,255,255,.10);
        box-shadow: 0 18px 42px rgba(76,29,149,.18);
        padding: 22px;
    }

    .dialog-badge {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        padding: 8px 14px;
        border-radius: 999px;
        background: rgba(255,255,255,.10);
        border: 1px solid rgba(255,255,255,.14);
        font-size: 13px;
        font-weight: 700;
    }

    .dialog-title {
        font-weight: 900;
        line-height: 1.05;
        letter-spacing: -.02em;
    }

    .dialog-sub {
        color: rgba(255,255,255,.82);
        line-height: 1.6;
    }

    .dialog-card {
        border-radius: 24px;
        background: rgba(255,255,255,.96);
        border: 1px solid rgba(109,40,217,.10);
        box-shadow: 0 14px 38px rgba(88,28,135,.06);
    }

    .dialog-actions {
        padding: 8px 24px 24px 24px;
        display: flex;
        justify-content: flex-end;
        gap: 10px;
        width: 100%;
    }

    .dialog-btn {
        border-radius: 14px;
        font-weight: 900;
        text-transform: none;
        padding: 10px 16px;
    }

    .limit-text {
        color: #6b5f8d;
    }
</style>

@code {
    [CascadingParameter] public IMudDialogInstance MudDialog { get; set; } = default!;
    [Parameter] public decimal MaxAmount { get; set; }

    decimal _amount;
    string _cardholderName = "";
    string _cardNumber = "";
    string _expiry = "";

    bool CanSubmit =>
        _amount > 0 &&
        _amount <= MaxAmount &&
        !string.IsNullOrWhiteSpace(_cardholderName) &&
        DigitsOnly(_cardNumber).Length >= 12 &&
        !string.IsNullOrWhiteSpace(_expiry);

    void Cancel()
    {
        MudDialog.Cancel();
    }

    void Submit()
    {
        var digits = DigitsOnly(_cardNumber);
        var last4 = digits.Length >= 4 ? digits[^4..] : digits;

        MudDialog.Close(DialogResult.Ok(new WithdrawDialogResult
        {
            Amount = _amount,
            Last4 = last4,
            CardholderName = _cardholderName.Trim()
        }));
    }

    static string DigitsOnly(string? value)
    {
        if (string.IsNullOrWhiteSpace(value))
            return "";

        return new string(value.Where(char.IsDigit).ToArray());
    }
}